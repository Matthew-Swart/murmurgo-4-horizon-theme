{{ 'https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;600&display=swap' | stylesheet_tag }}

<section class="plekify-founder" data-section-id="{{ section.id }}">
  <div class="plekify-founder__container">
    <p class="plekify-founder__overline">{{ section.settings.overline | default: 'ABOUT THE FOUNDER' }}</p>
    <h2 class="plekify-founder__heading">{{ section.settings.heading | default: "Built by someone who's done this before." }}</h2>
    <div class="plekify-founder__divider"></div>

    <div class="plekify-founder__content">
      <div class="plekify-founder__photo-wrapper">
        {%- if section.settings.photo != blank -%}
          <img
            class="plekify-founder__photo"
            src="{{ section.settings.photo | image_url: width: 400 }}"
            alt="{{ section.settings.name | default: 'Matthew Swart' }}"
            width="200"
            height="200"
            loading="lazy"
          >
        {%- else -%}
          <div class="plekify-founder__photo plekify-founder__photo--placeholder">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
        <p class="plekify-founder__name">{{ section.settings.name | default: 'Matthew Swart' }}</p>
        <p class="plekify-founder__role">{{ section.settings.role | default: 'Founder, Plekify' }}</p>
      </div>

      <div class="plekify-founder__text">
        <div class="plekify-founder__bio">
          {%- if section.settings.bio != blank -%}
            {{ section.settings.bio }}
          {%- else -%}
            <p>Matthew Swart co-founded SafariNow.com in 1999 — South Africa's pioneering online travel booking platform. Over 18 years as CEO, he grew the business to R320m booking value and 150 employees across Cape Town and Nairobi, winning "South Africa's Favourite eCommerce Website" at the SA eCommerce Awards. He sold a controlling stake to TravelStart in 2017.</p>
            <p>SafariNow was built on a custom tech stack with a team of 10. After 15 years, that stack became a liability — too complex and expensive to evolve.</p>
          {%- endif -%}
        </div>

        <blockquote class="plekify-founder__quote">
          {%- if section.settings.quote != blank -%}
            {{ section.settings.quote }}
          {%- else -%}
            I've spent 25 years building travel technology in South Africa. Plekify is what I'd build if I started SafariNow today — except now, Shopify provides the platform I had to build from scratch. The checkout, the CDN, the app ecosystem, the API infrastructure — it all exists. What was missing was the bridge between travel-industry content systems like Wetu and Shopify's commerce engine. That's Plekify.
          {%- endif -%}
        </blockquote>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .plekify-founder {
    background-color: #F5F2ED;
    padding-block: 96px;
    padding-inline: 24px;
  }

  .plekify-founder__container {
    max-inline-size: 800px;
    margin-inline: auto;
  }

  .plekify-founder__overline {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 12px;
    color: #C9A96E;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    margin-block-end: 16px;
  }

  .plekify-founder__heading {
    font-family: 'DM Serif Display', serif;
    font-size: 44px;
    color: #1A1A1A;
    text-align: center;
    margin-block-end: 0;
    line-height: 1.15;
  }

  .plekify-founder__divider {
    inline-size: 64px;
    block-size: 1px;
    background-color: #D5D0C8;
    margin-inline: auto;
    margin-block-start: 32px;
    margin-block-end: 48px;
  }

  .plekify-founder__content {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    align-items: start;
  }

  .plekify-founder__photo-wrapper {
    text-align: center;
  }

  .plekify-founder__photo {
    inline-size: 200px;
    block-size: 200px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #C9A96E;
    display: block;
    margin-inline: auto;
  }

  .plekify-founder__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #E8E4DD;
    overflow: hidden;
  }

  .plekify-founder__photo--placeholder svg {
    inline-size: 80px;
    block-size: 80px;
    fill: #C9A96E;
  }

  .plekify-founder__name {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    color: #1A1A1A;
    margin-block-start: 16px;
    margin-block-end: 4px;
  }

  .plekify-founder__role {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    color: #8E8E8E;
    margin-block-start: 0;
  }

  .plekify-founder__bio {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #4A4A4A;
    line-height: 1.7;
  }

  .plekify-founder__bio p {
    margin-block-start: 0;
    margin-block-end: 16px;
  }

  .plekify-founder__bio p:last-child {
    margin-block-end: 0;
  }

  .plekify-founder__quote {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    font-style: italic;
    color: #1A1A1A;
    line-height: 1.5;
    border-inline-start: 3px solid #C9A96E;
    padding-inline-start: 24px;
    margin-block-start: 32px;
    margin-inline: 0;
  }

  /* Scroll reveal */
  .plekify-founder__overline,
  .plekify-founder__heading,
  .plekify-founder__divider,
  .plekify-founder__photo-wrapper,
  .plekify-founder__text {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .plekify-founder__heading {
    transition-delay: 0.1s;
  }

  .plekify-founder__divider {
    transition-delay: 0.2s;
  }

  .plekify-founder__photo-wrapper {
    transition-delay: 0.3s;
  }

  .plekify-founder__text {
    transition-delay: 0.4s;
  }

  .plekify-founder.is-visible .plekify-founder__overline,
  .plekify-founder.is-visible .plekify-founder__heading,
  .plekify-founder.is-visible .plekify-founder__divider,
  .plekify-founder.is-visible .plekify-founder__photo-wrapper,
  .plekify-founder.is-visible .plekify-founder__text {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .plekify-founder__overline,
    .plekify-founder__heading,
    .plekify-founder__divider,
    .plekify-founder__photo-wrapper,
    .plekify-founder__text {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media screen and (max-width: 749px) {
    .plekify-founder {
      padding-block: 48px;
    }

    .plekify-founder__heading {
      font-size: 28px;
    }

    .plekify-founder__content {
      grid-template-columns: 1fr;
      gap: 32px;
      justify-items: center;
    }

    .plekify-founder__text {
      text-align: start;
    }

    .plekify-founder__quote {
      font-size: 18px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "Plekify Founder",
  "tag": "section",
  "class": "plekify-founder-section",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "ABOUT THE FOUNDER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built by someone who's done this before."
    },
    {
      "type": "image_picker",
      "id": "photo",
      "label": "Founder photo"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Matthew Swart"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role",
      "default": "Founder, Plekify"
    },
    {
      "type": "richtext",
      "id": "bio",
      "label": "Bio"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote"
    }
  ],
  "presets": [
    {
      "name": "Plekify Founder",
      "category": "Plekify"
    }
  ]
}
{% endschema %}
