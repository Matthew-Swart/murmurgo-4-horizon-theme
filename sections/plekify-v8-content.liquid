.plekify-v8-fw .v8-itin__title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 300;
  color: #111;
  line-height: 1.2;
  margin-bottom: .4rem;
}

.plekify-v8-fw .v8-itin__desc {
  font-size: 11.5px;
  color: #555;
  font-weight: 300;
  line-height: 1.5;
}

.plekify-v8-fw .v8-itin__meta {
  display: flex;
  gap: 1rem;
  margin-top: .7rem;
  padding-top: .7rem;
  border-top: 1px solid #e0e0e0;
  flex-wrap: wrap;
}

.plekify-v8-fw .v8-itin__stat {
  font-size: 10px;
  color: #777;
  letter-spacing: .03em;
}

.plekify-v8-fw .v8-itin__stat strong {
  display: block;
  font-size: 13px;
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  color: #333;
  margin-bottom: 1px;
}

.plekify-v8-fw .v8-itin__badge {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  margin-top: .7rem;
  padding-top: .7rem;
  border-top: 1px solid #e0e0e0;
}

.plekify-v8-fw .v8-itin__dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #3a7d44;
  flex-shrink: 0;
}

.plekify-v8-fw .v8-itin__badge span {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #666;
}

.plekify-v8-fw .v8-itin__body { padding: 1rem 1.25rem; }

.plekify-v8-fw .v8-legs {
  list-style: none;
  padding: 0;
}

.plekify-v8-fw .v8-legs li {
  display: flex;
  align-items: baseline;
  gap: .5rem;
  padding: .3rem 0;
  border-bottom: .5px solid #eee;
  font-size: 11.5px;
  color: #444;
  font-weight: 300;
}

.plekify-v8-fw .v8-legs li:last-child { border-bottom: none; }

.plekify-v8-fw .v8-leg__n {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  color: #888;
  letter-spacing: .06em;
  min-width: 18px;
}

.plekify-v8-fw .v8-leg__nights {
  font-size: 9.5px;
  color: #888;
  margin-left: auto;
  white-space: nowrap;
}

.plekify-v8-fw .v8-itin__links {
  display: flex;
  gap: .6rem;
  padding: 0 1.25rem 1rem;
  flex-wrap: wrap;
}

.plekify-v8-fw .v8-itin__link {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: .04em;
  color: #444;
  border: 1px solid #ccc;
  padding: 4px 10px;
  border-radius: 1px;
  text-decoration: none;
  font-weight: 400;
  white-space: nowrap;
  transition: border-color .2s, color .2s;
}

.plekify-v8-fw .v8-itin__link:hover { border-color: #888; color: #111; }
.plekify-v8-fw .v8-itin__link--ops { color: #666; border-color: #ddd; }
.plekify-v8-fw .v8-itin__link--ops:hover { color: #222; border-color: #999; }

.plekify-v8-fw .v8-itin__note {
  font-size: 13px;
  color: #888;
  padding: 0 1.25rem .7rem;
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
}

/* ── AI PIPELINE ────────────────────────────────────────── */

.plekify-v8-fw .v8-pipeline__header {
  margin-bottom: 1.5rem;
}

.plekify-v8-fw .v8-pipeline__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.5rem;
  align-items: start;
  margin-top: 1.5rem;
}

.plekify-v8-fw .v8-ai-list {
  list-style: none;
  padding: 0;
}

.plekify-v8-fw .v8-ai-list li {
  font-size: 12.5px;
  color: #333;
  font-weight: 300;
  padding: .35rem 0;
  border-bottom: .5px solid #e0e0e0;
  line-height: 1.6;
  padding-left: 1rem;
  position: relative;
}

.plekify-v8-fw .v8-ai-list li:before {
  content: '—';
  position: absolute;
  left: 0;
  color: #aaa;
  font-size: 11px;
}

.plekify-v8-fw .v8-ai-list li:last-child { border-bottom: none; }

/* ── AGENT PILLS ────────────────────────────────────────── */

.plekify-v8-fw .v8-agents {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: .85rem;
}

.plekify-v8-fw .v8-pill {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9.5px;
  color: #444;
  border: 1px solid #d0d0d0;
  padding: 3px 8px;
  border-radius: 1px;
  letter-spacing: .03em;
  font-weight: 400;
  background: #fff;
}

/* ── PIPELINE NOTE ──────────────────────────────────────── */

.plekify-v8-fw .v8-pipeline__note {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-weight: 300;
  font-style: italic;
  color: #555;
  border-top: 1px solid #e0e0e0;
  padding-top: .85rem;
  margin-top: 1rem;
  line-height: 1.65;
}

/* ── PARAMETER CARD ─────────────────────────────────────── */

.plekify-v8-fw .v8-params {
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 1px;
  padding: 1.1rem;
}

.plekify-v8-fw .v8-params__title {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #999;
  font-weight: 400;
  margin-bottom: .85rem;
}

.plekify-v8-fw .v8-params__row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: .4rem 0;
  border-bottom: .5px solid #eee;
}

.plekify-v8-fw .v8-params__row:last-child { border-bottom: none; }

.plekify-v8-fw .v8-params__key {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: #777;
  letter-spacing: .04em;
  font-weight: 400;
  flex-shrink: 0;
  width: 36%;
}

.plekify-v8-fw .v8-params__val {
  font-size: 12px;
  color: #222;
  font-weight: 300;
  text-align: right;
  line-height: 1.45;
}

.plekify-v8-fw .v8-params__val--anchor { color: #111; font-weight: 400; }
.plekify-v8-fw .v8-params__val--never { color: #ccc; text-decoration: line-through; text-decoration-color: #ddd; }

/* ── RESPONSIVE ─────────────────────────────────────────── */

@media (max-width: 720px) {
  .plekify-v8-fw .v8-contain,
  .plekify-v8-fw .v8-contain--wide {
    padding: 0 1.25rem;
  }
  .plekify-v8-fw .v8-band {
    padding: 2rem 0;
  }
  .plekify-v8-fw .v8-modes,
  .plekify-v8-fw .v8-pipeline__grid,
  .plekify-v8-fw .v8-itin-grid {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}

{% endstylesheet %}

