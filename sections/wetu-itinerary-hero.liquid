{% comment %}
  Wetu Itinerary Hero Section
  Full screen hero with video background
{% endcomment %}
{% assign itinerary_data = product.metafields.wetu.itinerary_data.value %}
{% assign banner_image = itinerary_data.theme_banner_image.url %}
{% assign title = product.title %}
{% assign duration = itinerary_data.days | append: ' Days' %}

<div class="wetu-itinerary-hero">
  <div class="hero-content">
    <h1>{{ title }}</h1>
    <p class="duration">{{ duration }}</p>
  </div>
  <div class="hero-media">
    {% if banner_image %}
      <img src="{{ banner_image }}" alt="{{ title }}" />
    {% endif %}
  </div>
</div>

<style>
.wetu-itinerary-hero {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  overflow: hidden;
  color: white;
  text-align: center;
}
.hero-content {
  position: relative;
  z-index: 2;
  padding-bottom: 4rem;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}
.hero-content h1 {
  font-size: 3rem;
  margin-bottom: 0.5rem;
  color: white;
}
.hero-content .duration {
  font-size: 1.5rem;
  font-weight: 300;
}
.hero-media {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.hero-media img, .hero-media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-media::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.3);
}
</style>

{% schema %}
{
  "name": "Itinerary Hero",
  "tag": "section",
  "class": "section-wetu-itinerary-hero",
  "settings": [],
  "presets": [{ "name": "Itinerary Hero" }]
}
{% endschema %}