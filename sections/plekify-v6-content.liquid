.plekify-v6 .itin-ai-badge span { font-size: 9.5px; letter-spacing: .08em; text-transform: uppercase; color: #777; }
.plekify-v6 .itin-body { padding: 1.25rem 1.5rem; }
.plekify-v6 .leg-list { list-style: none; padding: 0; }
.plekify-v6 .leg-item { display: flex; align-items: baseline; gap: .6rem; padding: .35rem 0; border-bottom: .5px solid #eee; font-size: 11.5px; color: #555; font-weight: 300; }
.plekify-v6 .leg-item:last-child { border-bottom: none; }
.plekify-v6 .leg-num { font-size: 10px; color: #aaa; letter-spacing: .06em; min-width: 20px; }
.plekify-v6 .leg-nights { font-size: 10px; color: #999; margin-left: auto; white-space: nowrap; }
.plekify-v6 .itin-links { display: flex; gap: .75rem; padding: 0 1.5rem 1.25rem; flex-wrap: wrap; }
.plekify-v6 .itin-link { font-size: 10.5px; letter-spacing: .06em; color: #555; border: 1px solid #ccc; padding: 5px 12px; border-radius: 1px; text-decoration: none; font-weight: 400; white-space: nowrap; }
.plekify-v6 .itin-link:hover { border-color: #888; color: #111; }
.plekify-v6 .itin-link.ops { color: #777; border-color: #ddd; }
.plekify-v6 .itin-link.ops:hover { color: #333; border-color: #aaa; }
.plekify-v6 .itin-note { font-size: 13px; color: #999; padding: 0 1.5rem .85rem; font-style: italic; font-family: 'Cormorant Garamond', serif; font-weight: 300; }
/* GAP TABLE */
.plekify-v6 .gap-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 1.5rem; }
.plekify-v6 .gap-table th {
  font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase; color: #888; font-weight: 400; padding: .5rem .75rem; text-align: left; border-bottom: 1px solid #e0e0e0;
}
.plekify-v6 .gap-table td {
  padding: .55rem .75rem; color: #555; border-bottom: .5px solid #eee; vertical-align: top; line-height: 1.5; font-weight: 300; font-size: 12px;
}
.plekify-v6 .gap-table td:first-child { color: #333; font-weight: 400; width: 26%; }
.plekify-v6 .gap-table tr:last-child td { border-bottom: none; }
.plekify-v6 .gap-table td.wetu { color: #999; }
.plekify-v6 .gap-table td.plek { color: #333; }

@media (max-width: 640px) {
  .plekify-v6 .two-col,
  .plekify-v6 .modes-grid,
  .plekify-v6 .ai-demo,
  .plekify-v6 .itin-grid {
    grid-template-columns: 1fr;
  }
  .plekify-v6 .ai-section { padding: 1.5rem; }
}
