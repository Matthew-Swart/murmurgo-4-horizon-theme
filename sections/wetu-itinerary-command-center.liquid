      <template data-command-center-inspector-template="guests">
        <article class="itin-command-center__card itin-command-center__inspector-shell itin-command-center__guest-detail">
          <p class="itin-command-center__guest-detail-mode" data-inspector-guests-mode>Guest list</p>
          <h3 class="itin-command-center__guest-detail-title" data-inspector-guests-title>Your Travel Party</h3>
          <p class="itin-command-center__guest-detail-meta" data-inspector-guests-meta hidden></p>
          <p class="itin-command-center__guest-detail-summary" data-inspector-guests-summary hidden></p>
          <div class="itin-command-center__guest-detail-groups" data-inspector-guests-groups></div>
          <p class="itin-command-center__card-copy itin-command-center__guest-detail-empty" data-inspector-guests-empty hidden>Traveller profiles will appear here once details are available.</p>
        </article>
      </template>

      <template data-command-center-inspector-template="pricing">
        <article class="itin-command-center__card itin-command-center__inspector-shell itin-command-center__pricing-detail">
          <p class="itin-command-center__pricing-detail-mode" data-inspector-pricing-mode></p>
          <h3 class="itin-command-center__pricing-detail-title" data-inspector-pricing-title></h3>

          <div class="itin-command-center__pricing-detail-totals" data-inspector-pricing-totals>
            <div class="itin-command-center__pricing-detail-total-row">
              <span class="itin-command-center__pricing-detail-label">PER PERSON</span>
              <span class="itin-command-center__pricing-detail-amount" data-inspector-pricing-per-person>—</span>
            </div>
            <div class="itin-command-center__pricing-detail-total-row">
              <span class="itin-command-center__pricing-detail-label">TOTAL INVESTMENT</span>
              <span class="itin-command-center__pricing-detail-amount itin-command-center__pricing-detail-amount--total" data-inspector-pricing-total>—</span>
            </div>
            <p class="itin-command-center__pricing-detail-party-note" data-inspector-pricing-party-note hidden></p>
          </div>

          <div class="itin-command-center__pricing-detail-summary-metrics" data-inspector-pricing-summary-metrics hidden>
            <p class="itin-command-center__pricing-detail-metric" data-inspector-pricing-metric-adult hidden></p>
            <p class="itin-command-center__pricing-detail-metric" data-inspector-pricing-metric-child hidden></p>
            <p class="itin-command-center__pricing-detail-metric" data-inspector-pricing-metric-logistics hidden></p>
          </div>

          <hr class="itin-command-center__pricing-detail-separator" data-inspector-pricing-phases-separator hidden>

          <div class="itin-command-center__pricing-detail-phases" data-inspector-pricing-phases hidden>
            <p class="itin-command-center__pricing-detail-section-label">PHASES</p>
            <div class="itin-command-center__pricing-detail-phases-list" data-inspector-pricing-phases-list></div>
          </div>

          <hr class="itin-command-center__pricing-detail-separator" data-inspector-pricing-inclusions-separator hidden>

          <div class="itin-command-center__pricing-detail-inclusions" data-inspector-pricing-inclusions-section hidden>
            <p class="itin-command-center__pricing-detail-section-label">INCLUDES</p>
            <ul class="itin-command-center__pricing-detail-bullet-list" data-inspector-pricing-includes-list></ul>
          </div>

          <div class="itin-command-center__pricing-detail-exclusions" data-inspector-pricing-exclusions-section hidden>
            <p class="itin-command-center__pricing-detail-section-label">EXCLUDES</p>
            <ul class="itin-command-center__pricing-detail-bullet-list" data-inspector-pricing-excludes-list></ul>
          </div>

          <hr class="itin-command-center__pricing-detail-separator" data-inspector-pricing-schedule-separator hidden>

          <div class="itin-command-center__pricing-detail-schedule" data-inspector-pricing-schedule hidden>
            <p class="itin-command-center__pricing-detail-section-label">PAYMENT SCHEDULE</p>
            <div class="itin-command-center__pricing-detail-schedule-list" data-inspector-pricing-schedule-list></div>
          </div>
        </article>
      </template>
    </div>
  {% endif %}

  {% if section.settings.show_mobile_picker %}
    <div class="itin-command-center__mobile-picker" data-command-center-mobile-picker>
      <div class="itin-command-center__mobile-picker-track" data-command-center-mobile-track>
        <button type="button" class="itin-command-center__mobile-pill is-active">Overview</button>
        <button type="button" class="itin-command-center__mobile-pill">Day 01</button>
        <button type="button" class="itin-command-center__mobile-pill">Day 02</button>
      </div>
    </div>
  {% endif %}

  {% if section.settings.show_mobile_sheet %}
    <div class="itin-command-center__mobile-sheet" data-command-center-mobile-sheet hidden aria-hidden="true">
      <div class="itin-command-center__mobile-sheet-overlay" data-command-center-mobile-sheet-dismiss></div>
      <div
        class="itin-command-center__mobile-sheet-panel"
        data-command-center-mobile-sheet-panel
        role="dialog"
        aria-modal="true"
        aria-labelledby="command-center-mobile-sheet-title-{{ section.id }}"
      >
        <div class="itin-command-center__mobile-sheet-handle" aria-hidden="true"></div>
        <div class="itin-command-center__pane-header itin-command-center__mobile-sheet-header">
          <div>
            <p class="itin-command-center__pane-eyebrow">Mobile details</p>
            <p class="itin-command-center__pane-title" id="command-center-mobile-sheet-title-{{ section.id }}">Inspector summary</p>
          </div>
          <button
            type="button"
            class="itin-command-center__mobile-sheet-close"
            data-command-center-mobile-sheet-close
            aria-label="Close detail sheet"
          >
            Close
          </button>
        </div>
        <div class="itin-command-center__pane-body itin-command-center__mobile-sheet-body" data-command-center-mobile-sheet-body>
          <article class="itin-command-center__card itin-command-center__card--feature">
            <p class="itin-command-center__ui-label">Inspector</p>
            <h3 class="itin-command-center__day-title">Select a card to inspect</h3>
            <p class="itin-command-center__card-copy">Tap any selectable card to open linked product details or transfer metadata.</p>
          </article>
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% render 'wetu-itinerary-command-center-styles', section: section %}
{% render 'wetu-itinerary-inspector-renderer', section: section %}
{% render 'wetu-itinerary-command-center-script', section: section %}
{% render 'wetu-itinerary-command-center-mapbox', section: section %}

{% schema %}
{
  "name": "WETU command center",
  "tag": "section",
  "class": "section-itin-command-center",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "label": "Show sidebar pane",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_inspector",
      "label": "Show inspector pane",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mobile_picker",
      "label": "Show mobile picker",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mobile_sheet",
      "label": "Show mobile bottom sheet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tour_overview",
      "label": "Show tour overview bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_pin_map",
      "label": "Expose pin map data",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_link_manifest",
      "label": "Expose link manifest data",
      "default": true
    },
    {
      "type": "text",
      "id": "mapbox_public_token",
      "label": "Mapbox public token (pk.*)",
      "default": "pk.your_mapbox_public_token"
    },
    {
      "type": "text",
      "id": "mapbox_style",
      "label": "Mapbox style URL",
      "default": "mapbox://styles/mapbox/satellite-streets-v12"
    },
    {
      "type": "text",
      "id": "mapbox_geocode_hint",
      "label": "Map geocode country/region hint",
      "default": "South Africa"
    }
  ],
  "presets": [
    {
      "name": "WETU command center"
    }
  ]
}
{% endschema %}
