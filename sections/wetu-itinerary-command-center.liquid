{%- liquid
  assign itinerary_json_raw = product.metafields.wetu.itinerary_json.value | default: product.metafields.wetu.itinerary_json
  assign itinerary_source_json_raw = product.metafields.wetu.itinerary_source_json.value | default: product.metafields.wetu.itinerary_source_json
  assign itinerary_identifier_raw = product.metafields.wetu.itinerary_identifier.value | default: product.metafields.wetu.itinerary_identifier
  assign hero_video_raw = product.metafields.wetu.hero_video.value | default: product.metafields.wetu.hero_video

  assign canonical_json_url = product.metafields.wetu.itinerary_source_json_cdn_url.value | default: product.metafields.wetu.itinerary_source_json_cdn_url
  if canonical_json_url == blank and itinerary_source_json_raw != blank and itinerary_source_json_raw.storage == 'shopify_file'
    assign canonical_json_url = itinerary_source_json_raw.cdn_url
  endif

  assign fallback_json_url = product.metafields.wetu.itinerary_json_cdn_url.value | default: product.metafields.wetu.itinerary_json_cdn_url
  if fallback_json_url == blank and itinerary_json_raw != blank and itinerary_json_raw.storage == 'shopify_file'
    assign fallback_json_url = itinerary_json_raw.cdn_url
  endif

  assign component_products = product.metafields.wetu_itinerary.component_products.value
  assign pin_ids_list = ''
  assign handles_list = ''

  capture component_product_candidates_json
    echo '['
    assign component_candidate_emitted = false
    if component_products.size > 0
      for comp_product in component_products
        if comp_product.handle
          assign prod_obj = comp_product
        else
          assign prod_obj = all_products[comp_product]
        endif

        assign prod_handle = prod_obj.handle
        assign prod_primary_pin = prod_obj.metafields.wetu.pin_id.value | default: prod_obj.metafields.wetu.pin_id | default: prod_obj.metafields.wetu.content_entity_id.value | default: prod_obj.metafields.wetu.content_entity_id
        assign prod_content_pin = prod_obj.metafields.wetu.content_entity_id.value | default: prod_obj.metafields.wetu.content_entity_id
        assign prod_linked_activity_pin = prod_obj.metafields.wetu_linked_activity.parent_pin_id.value | default: prod_obj.metafields.wetu_linked_activity.parent_pin_id
        assign prod_linked_restaurant_pin = prod_obj.metafields.wetu_linked_restaurant.parent_pin_id.value | default: prod_obj.metafields.wetu_linked_restaurant.parent_pin_id
        assign prod_linked_spa_pin = prod_obj.metafields.wetu_linked_spa.parent_pin_id.value | default: prod_obj.metafields.wetu_linked_spa.parent_pin_id
        assign prod_linked_collection_pin = prod_obj.metafields.wetu_collection.parent_pin_id.value | default: prod_obj.metafields.wetu_collection.parent_pin_id
        assign prod_wetu_type = prod_obj.metafields.wetu.type.value | default: prod_obj.metafields.wetu.type
        assign prod_wetu_category = prod_obj.metafields.wetu.category.value | default: prod_obj.metafields.wetu.category
        assign prod_wetu_subcategory = prod_obj.metafields.wetu.subcategory.value | default: prod_obj.metafields.wetu.subcategory
        assign prod_position = prod_obj.metafields.wetu.position.value | default: prod_obj.metafields.wetu.position
        assign prod_latitude = prod_position.latitude
        assign prod_longitude = prod_position.longitude
        assign prod_driving_latitude = prod_position.driving_latitude | default: prod_latitude
        assign prod_driving_longitude = prod_position.driving_longitude | default: prod_longitude
        assign prod_tagline = prod_obj.metafields.wetu.tagline.value | default: prod_obj.metafields.wetu.tagline
        assign prod_featured_image_thumb = prod_obj.featured_image | image_url: width: 80
        assign prod_featured_image_large = prod_obj.featured_image | image_url: width: 1600
        assign emitted_pin_tokens = ''

        if prod_handle != blank
          if prod_primary_pin != blank
            assign candidate_pin = prod_primary_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
            unless component_candidate_emitted == false
              echo ','
            endunless
            echo '{'
            echo '"pin":'
            echo candidate_pin | json
            echo ',"handle":'
            echo prod_handle | json
            echo ',"url":'
            echo prod_obj.url | json
            echo ',"featured_image":'
            echo prod_featured_image_thumb | json
            echo ',"featured_image_large":'
            echo prod_featured_image_large | json
            echo ',"title":'
            echo prod_obj.title | json
            echo ',"tagline":'
            echo prod_tagline | json
            echo ',"template_suffix":'
            echo prod_obj.template_suffix | json
            echo ',"product_type":'
            echo prod_obj.type | json
            echo ',"tags":'
            echo prod_obj.tags | json
            echo ',"wetu_type":'
            echo prod_wetu_type | json
            echo ',"wetu_category":'
            echo prod_wetu_category | json
            echo ',"wetu_subcategory":'
            echo prod_wetu_subcategory | json
            echo ',"content_entity_id":'
            echo prod_content_pin | json
            echo ',"primary_pin":'
            echo prod_primary_pin | json
            echo ',"latitude":'
            echo prod_latitude | json
            echo ',"longitude":'
            echo prod_longitude | json
            echo ',"driving_latitude":'
            echo prod_driving_latitude | json
            echo ',"driving_longitude":'
            echo prod_driving_longitude | json
            echo ',"source":'
            echo 'component_products' | json
            echo ',"pin_field":'
            echo 'wetu.pin_id' | json
            echo ',"component_index":'
            echo forloop.index0 | json
            echo '}'
            assign component_candidate_emitted = true
          endif

          if prod_content_pin != blank
            assign candidate_pin = prod_content_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            unless emitted_pin_tokens contains candidate_pin_token
              assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
              unless component_candidate_emitted == false
                echo ','
              endunless
              echo '{'
              echo '"pin":'
              echo candidate_pin | json
              echo ',"handle":'
              echo prod_handle | json
              echo ',"url":'
              echo prod_obj.url | json
              echo ',"featured_image":'
              echo prod_featured_image_thumb | json
              echo ',"featured_image_large":'
              echo prod_featured_image_large | json
              echo ',"title":'
              echo prod_obj.title | json
              echo ',"tagline":'
              echo prod_tagline | json
              echo ',"template_suffix":'
              echo prod_obj.template_suffix | json
              echo ',"product_type":'
              echo prod_obj.type | json
              echo ',"tags":'
              echo prod_obj.tags | json
              echo ',"wetu_type":'
              echo prod_wetu_type | json
              echo ',"wetu_category":'
              echo prod_wetu_category | json
              echo ',"wetu_subcategory":'
              echo prod_wetu_subcategory | json
              echo ',"content_entity_id":'
              echo prod_content_pin | json
              echo ',"primary_pin":'
              echo prod_primary_pin | json
              echo ',"latitude":'
              echo prod_latitude | json
              echo ',"longitude":'
              echo prod_longitude | json
              echo ',"driving_latitude":'
              echo prod_driving_latitude | json
              echo ',"driving_longitude":'
              echo prod_driving_longitude | json
              echo ',"source":'
              echo 'component_products' | json
              echo ',"pin_field":'
              echo 'wetu.content_entity_id' | json
              echo ',"component_index":'
              echo forloop.index0 | json
              echo '}'
              assign component_candidate_emitted = true
            endunless
          endif

          if prod_linked_activity_pin != blank
            assign candidate_pin = prod_linked_activity_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            unless emitted_pin_tokens contains candidate_pin_token
              assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
              unless component_candidate_emitted == false
                echo ','
              endunless
              echo '{'
              echo '"pin":'
              echo candidate_pin | json
              echo ',"handle":'
              echo prod_handle | json
              echo ',"url":'
              echo prod_obj.url | json
              echo ',"featured_image":'
              echo prod_featured_image_thumb | json
              echo ',"featured_image_large":'
              echo prod_featured_image_large | json
              echo ',"title":'
              echo prod_obj.title | json
              echo ',"tagline":'
              echo prod_tagline | json
              echo ',"template_suffix":'
              echo prod_obj.template_suffix | json
              echo ',"product_type":'
              echo prod_obj.type | json
              echo ',"tags":'
              echo prod_obj.tags | json
              echo ',"wetu_type":'
              echo prod_wetu_type | json
              echo ',"wetu_category":'
              echo prod_wetu_category | json
              echo ',"wetu_subcategory":'
              echo prod_wetu_subcategory | json
              echo ',"content_entity_id":'
              echo prod_content_pin | json
              echo ',"primary_pin":'
              echo prod_primary_pin | json
              echo ',"latitude":'
              echo prod_latitude | json
              echo ',"longitude":'
              echo prod_longitude | json
              echo ',"driving_latitude":'
              echo prod_driving_latitude | json
              echo ',"driving_longitude":'
              echo prod_driving_longitude | json
              echo ',"source":'
              echo 'component_products' | json
              echo ',"pin_field":'
              echo 'wetu_linked_activity.parent_pin_id' | json
              echo ',"component_index":'
              echo forloop.index0 | json
              echo '}'
              assign component_candidate_emitted = true
            endunless
          endif

          if prod_linked_restaurant_pin != blank
            assign candidate_pin = prod_linked_restaurant_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            unless emitted_pin_tokens contains candidate_pin_token
              assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
              unless component_candidate_emitted == false
                echo ','
              endunless
              echo '{'
              echo '"pin":'
              echo candidate_pin | json
              echo ',"handle":'
              echo prod_handle | json
              echo ',"url":'
              echo prod_obj.url | json
              echo ',"featured_image":'
              echo prod_featured_image_thumb | json
              echo ',"featured_image_large":'
              echo prod_featured_image_large | json
              echo ',"title":'
              echo prod_obj.title | json
              echo ',"tagline":'
              echo prod_tagline | json
              echo ',"template_suffix":'
              echo prod_obj.template_suffix | json
              echo ',"product_type":'
              echo prod_obj.type | json
              echo ',"tags":'
              echo prod_obj.tags | json
              echo ',"wetu_type":'
              echo prod_wetu_type | json
              echo ',"wetu_category":'
              echo prod_wetu_category | json
              echo ',"wetu_subcategory":'
              echo prod_wetu_subcategory | json
              echo ',"content_entity_id":'
              echo prod_content_pin | json
              echo ',"primary_pin":'
              echo prod_primary_pin | json
              echo ',"latitude":'
              echo prod_latitude | json
              echo ',"longitude":'
              echo prod_longitude | json
              echo ',"driving_latitude":'
              echo prod_driving_latitude | json
              echo ',"driving_longitude":'
              echo prod_driving_longitude | json
              echo ',"source":'
              echo 'component_products' | json
              echo ',"pin_field":'
              echo 'wetu_linked_restaurant.parent_pin_id' | json
              echo ',"component_index":'
              echo forloop.index0 | json
              echo '}'
              assign component_candidate_emitted = true
            endunless
          endif

          if prod_linked_spa_pin != blank
            assign candidate_pin = prod_linked_spa_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            unless emitted_pin_tokens contains candidate_pin_token
              assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
              unless component_candidate_emitted == false
                echo ','
              endunless
              echo '{'
              echo '"pin":'
              echo candidate_pin | json
              echo ',"handle":'
              echo prod_handle | json
              echo ',"url":'
              echo prod_obj.url | json
              echo ',"featured_image":'
              echo prod_featured_image_thumb | json
              echo ',"featured_image_large":'
              echo prod_featured_image_large | json
              echo ',"title":'
              echo prod_obj.title | json
              echo ',"tagline":'
              echo prod_tagline | json
              echo ',"template_suffix":'
              echo prod_obj.template_suffix | json
              echo ',"product_type":'
              echo prod_obj.type | json
              echo ',"tags":'
              echo prod_obj.tags | json
              echo ',"wetu_type":'
              echo prod_wetu_type | json
              echo ',"wetu_category":'
              echo prod_wetu_category | json
              echo ',"wetu_subcategory":'
              echo prod_wetu_subcategory | json
              echo ',"content_entity_id":'
              echo prod_content_pin | json
              echo ',"primary_pin":'
              echo prod_primary_pin | json
              echo ',"latitude":'
              echo prod_latitude | json
              echo ',"longitude":'
              echo prod_longitude | json
              echo ',"driving_latitude":'
              echo prod_driving_latitude | json
              echo ',"driving_longitude":'
              echo prod_driving_longitude | json
              echo ',"source":'
              echo 'component_products' | json
              echo ',"pin_field":'
              echo 'wetu_linked_spa.parent_pin_id' | json
              echo ',"component_index":'
              echo forloop.index0 | json
              echo '}'
              assign component_candidate_emitted = true
            endunless
          endif

          if prod_linked_collection_pin != blank
            assign candidate_pin = prod_linked_collection_pin
            assign candidate_pin_token = '|' | append: candidate_pin | append: '|'
            unless emitted_pin_tokens contains candidate_pin_token
              assign emitted_pin_tokens = emitted_pin_tokens | append: candidate_pin_token
              unless component_candidate_emitted == false
                echo ','
              endunless
              echo '{'
              echo '"pin":'
              echo candidate_pin | json
              echo ',"handle":'
              echo prod_handle | json
              echo ',"url":'
              echo prod_obj.url | json
              echo ',"featured_image":'
              echo prod_featured_image_thumb | json
              echo ',"featured_image_large":'
              echo prod_featured_image_large | json
              echo ',"title":'
              echo prod_obj.title | json
              echo ',"tagline":'
              echo prod_tagline | json
              echo ',"template_suffix":'
              echo prod_obj.template_suffix | json
              echo ',"product_type":'
              echo prod_obj.type | json
              echo ',"tags":'
              echo prod_obj.tags | json
              echo ',"wetu_type":'
              echo prod_wetu_type | json
              echo ',"wetu_category":'
              echo prod_wetu_category | json
              echo ',"wetu_subcategory":'
              echo prod_wetu_subcategory | json
              echo ',"content_entity_id":'
              echo prod_content_pin | json
              echo ',"primary_pin":'
              echo prod_primary_pin | json
              echo ',"latitude":'
              echo prod_latitude | json
              echo ',"longitude":'
              echo prod_longitude | json
              echo ',"driving_latitude":'
              echo prod_driving_latitude | json
              echo ',"driving_longitude":'
              echo prod_driving_longitude | json
              echo ',"source":'
              echo 'component_products' | json
              echo ',"pin_field":'
              echo 'wetu_collection.parent_pin_id' | json
              echo ',"component_index":'
              echo forloop.index0 | json
              echo '}'
              assign component_candidate_emitted = true
            endunless
          endif
        endif
      endfor
    endif
    echo ']'
  endcapture

  if component_products.size > 0
    for comp_product in component_products
      if comp_product.handle
        assign prod_obj = comp_product
      else
        assign prod_obj = all_products[comp_product]
      endif

      assign prod_pin = prod_obj.metafields.wetu.pin_id.value | default: prod_obj.metafields.wetu.content_entity_id.value
      assign prod_handle = prod_obj.handle

      if prod_pin != blank and prod_handle != blank
        if pin_ids_list == ''
          assign pin_ids_list = prod_pin
          assign handles_list = prod_handle
        else
          assign pin_ids_list = pin_ids_list | append: ',' | append: prod_pin
          assign handles_list = handles_list | append: ',' | append: prod_handle
        endif
      endif
    endfor
  endif

  assign pin_ids_array = pin_ids_list | split: ','
  assign handles_array = handles_list | split: ','

  capture pin_map_json
    echo '{'
    for pin_id in pin_ids_array
      if pin_id != blank
        unless forloop.first
          echo ','
        endunless
        echo '"'
        echo pin_id
        echo '":"'
        echo handles_array[forloop.index0] | default: ''
        echo '"'
      endif
    endfor
    echo '}'
  endcapture

  assign link_manifest_raw = product.metafields.wetu_itinerary.link_manifest.value | default: product.metafields.wetu_itinerary.link_manifest | default: '{}'

  assign has_data = false
  if canonical_json_url != blank or fallback_json_url != blank
    assign has_data = true
  endif

  assign workspace_layout = 'layout-center-only'
  if section.settings.show_sidebar and section.settings.show_inspector
    assign workspace_layout = 'layout-three'
  elsif section.settings.show_sidebar
    assign workspace_layout = 'layout-left-center'
  elsif section.settings.show_inspector
    assign workspace_layout = 'layout-center-right'
  endif
-%}

<section
  class="itin-command-center color-{{ section.settings.color_scheme }} is-initial-inspector-hydrating"
  id="itinerary-command-center"
  data-section-id="{{ section.id }}"
  data-canonical-json-url="{{ canonical_json_url | escape }}"
  data-fallback-json-url="{{ fallback_json_url | escape }}"
  data-itinerary-identifier="{{ itinerary_identifier_raw | escape }}"
  data-pin-map="{% if section.settings.enable_pin_map %}{{ pin_map_json | strip | escape }}{% else %}{}{% endif %}"
  data-component-product-candidates="{{ component_product_candidates_json | strip | escape }}"
  data-link-manifest="{% if section.settings.enable_link_manifest %}{{ link_manifest_raw | escape }}{% else %}{}{% endif %}"
  data-product-handle="{{ product.handle | escape }}"
  data-product-id="{{ product.id }}"
  data-product-selected-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-locale-code="{{ request.locale.iso_code | default: shop.locale | escape }}"
  data-currency-code="{{ localization.country.currency.iso_code | default: cart.currency.iso_code | default: shop.currency | escape }}"
  data-mapbox-token="{{ section.settings.mapbox_public_token | strip | escape }}"
  data-mapbox-style="{{ section.settings.mapbox_style | strip | escape }}"
  data-mapbox-geocode-hint="{{ section.settings.mapbox_geocode_hint | strip | escape }}"
>
  <div class="itin-command-center__mode-flash" data-command-center-mode-flash aria-hidden="true"></div>
  <div class="itin-command-center__desktop-scroll-wrapper" data-command-center-scroll-wrapper>
    {% if section.settings.show_hero %}
      <header class="itin-command-center__hero" data-command-center-hero>
        <div class="itin-command-center__hero-media" aria-hidden="true">
          {% if hero_video_raw != blank %}
            {% if hero_video_raw.sources != blank %}
              {{
                hero_video_raw
                | video_tag:
                  class: 'itin-command-center__hero-video',
                  image_size: '2400x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  playsinline: true
              }}
            {% else %}
              <video
                class="itin-command-center__hero-video"
                muted
                loop
                playsinline
                preload="metadata"
                {% if product.featured_image != blank %}
                  poster="{{ product.featured_image | image_url: width: 2400 }}"
                {% endif %}
              >
                <source src="{{ hero_video_raw | file_url }}" type="video/mp4">
              </video>
            {% endif %}
          {% elsif product.featured_image != blank %}
            {{
              product.featured_image
              | image_url: width: 2400
              | image_tag:
                class: 'itin-command-center__hero-image',
                loading: 'eager',
                widths: '900, 1400, 1800, 2200, 2400',
                sizes: '100vw',
                alt: product.featured_image.alt | default: product.title
            }}
          {% endif %}
        </div>
        <div class="itin-command-center__hero-inner">
          <h1 class="itin-command-center__hero-title">{{ product.title }}</h1>
          <p class="itin-command-center__hero-locations" data-command-center-hero-locations>Locations loading...</p>
          <p class="itin-command-center__hero-days" data-command-center-hero-days>-- days</p>
          <button
            type="button"
            class="itin-command-center__theme-toggle"
            data-command-center-theme-toggle
            aria-label="Switch to dark mode"
            title="Switch to dark mode"
          >
            <span class="itin-command-center__theme-toggle-icon itin-command-center__theme-toggle-icon--sun" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <circle cx="12" cy="12" r="3.75"></circle>
                <path d="M12 1.5v2.5"></path>
                <path d="M12 20v2.5"></path>
                <path d="M4.58 4.58l1.77 1.77"></path>
                <path d="M17.65 17.65l1.77 1.77"></path>
                <path d="M1.5 12h2.5"></path>
                <path d="M20 12h2.5"></path>
                <path d="M4.58 19.42l1.77-1.77"></path>
                <path d="M17.65 6.35l1.77-1.77"></path>
              </svg>
            </span>
            <span class="itin-command-center__theme-toggle-icon itin-command-center__theme-toggle-icon--moon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M20.13 15.48A9 9 0 1 1 8.52 3.87a7 7 0 1 0 11.61 11.61Z"></path>
              </svg>
            </span>
            <span class="itin-command-center__visually-hidden" data-command-center-theme-toggle-label>Switch to dark mode</span>
          </button>
        </div>
      </header>
    {% endif %}

    {% if section.settings.show_tour_overview %}
      <section class="itin-command-center__tour-summary" data-command-center-tour-summary>
        <div class="itin-command-center__tour-summary-shell itin-command-center__tour-summary-shell--{{ workspace_layout }}">
          <div class="itin-command-center__tour-summary-rail">
            <p class="itin-command-center__tour-summary-rail-label">Tour metrics</p>
            <dl class="itin-command-center__tour-summary-facts">
              <div class="itin-command-center__tour-summary-fact">
                <dt>Days</dt>
                <dd data-command-center-tour-summary-fact="days">--</dd>
              </div>
              <div class="itin-command-center__tour-summary-fact">
                <dt>Legs</dt>
                <dd data-command-center-tour-summary-fact="legs">--</dd>
              </div>
              <div class="itin-command-center__tour-summary-fact">
                <dt>Routes</dt>
                <dd data-command-center-tour-summary-fact="routes">--</dd>
              </div>
              <div class="itin-command-center__tour-summary-fact">
                <dt>Stops</dt>
                <dd data-command-center-tour-summary-fact="stops">--</dd>
              </div>
            </dl>
          </div>

          <div class="itin-command-center__tour-summary-main">
            <p class="itin-command-center__tour-summary-overview-line" data-command-center-tour-summary-stats>Loading itinerary metrics...</p>
            <div class="itin-command-center__tour-summary-prose" data-command-center-tour-summary-copy>
              <p>Loading itinerary summary...</p>
            </div>
            <div class="itin-command-center__tour-summary-leg-rail" data-command-center-tour-summary-leg-rail></div>
          </div>

          <div class="itin-command-center__tour-summary-side">
            <section class="itin-command-center__booking itin-command-center__tour-summary-booking" data-inspector-booking data-command-center-tour-summary-booking>
              <p class="itin-command-center__ui-label">Booking console</p>
              <p class="itin-command-center__booking-itinerary" data-inspector-booking-itinerary-title>Itinerary</p>
              <div class="itin-command-center__booking-price-panel" aria-live="polite" aria-atomic="true">
                <p class="itin-command-center__booking-price-row">
                  <strong data-inspector-booking-base-price>—</strong>
                  <span>per person</span>
                </p>
                <p class="itin-command-center__booking-total-line" data-inspector-booking-total-price-line>—</p>
              </div>
