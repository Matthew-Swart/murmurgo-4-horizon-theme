      "default": "Your Wetu content is ready. Shopify's infrastructure is ready. Let's connect the two."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "matt@plekify.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+27 60 937 4204"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Made in Cape Town."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    }
  ],
  "presets": [
    {
      "name": "Plekify CTA Footer",
      "category": "Plekify"
    }
  ]
}
{% endschema %}
