{{ 'https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;600&display=swap' | stylesheet_tag }}

<section class="plekify-cta-footer" data-section-id="{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="plekify-cta-footer__bg-image">
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        loading="lazy"
      >
    </div>
  {%- endif -%}
  <div class="plekify-cta-footer__overlay"></div>

  <div class="plekify-cta-footer__container">
    <h2 class="plekify-cta-footer__heading">
      {{ section.settings.heading | default: 'Ready to turn your itineraries into transactions?' }}
    </h2>
    <p class="plekify-cta-footer__subline">
      {{ section.settings.subline | default: "Your Wetu content is ready. Shopify's infrastructure is ready. Let's connect the two." }}
    </p>

    {%- assign cta_url = section.settings.cta_url | default: '#' -%}
    <a class="plekify-cta-footer__cta" href="{{ cta_url }}">
      {{ section.settings.cta_text | default: 'Book a Demo' }}
    </a>

    <p class="plekify-cta-footer__contact">
      {{ section.settings.email | default: 'matt@plekify.com' }} · {{ section.settings.phone | default: '+27 60 937 4204' }}
    </p>

    <p class="plekify-cta-footer__tagline">
      {{ section.settings.tagline | default: 'Made in Cape Town.' }}
    </p>
  </div>
</section>

{% stylesheet %}
  .plekify-cta-footer {
    position: relative;
    background-color: #121212;
    padding-block: 96px;
    padding-inline: 24px;
    overflow: hidden;
  }

  .plekify-cta-footer__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .plekify-cta-footer__bg-image img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    opacity: 0.25;
  }

  .plekify-cta-footer__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18, 18, 18, 0.85) 0%, rgba(18, 18, 18, 0.95) 100%);
    z-index: 1;
  }

  .plekify-cta-footer__container {
    position: relative;
    z-index: 2;
    max-inline-size: 800px;
    margin-inline: auto;
    text-align: center;
  }

  .plekify-cta-footer__heading {
    font-family: 'DM Serif Display', serif;
    font-size: 44px;
    color: #FFFFFF;
    line-height: 1.15;
    margin-block-start: 0;
    margin-block-end: 24px;
  }

  .plekify-cta-footer__subline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 18px;
    color: #8E8E8E;
    line-height: 1.6;
    max-inline-size: 680px;
    margin-inline: auto;
    margin-block-start: 0;
    margin-block-end: 40px;
  }

  .plekify-cta-footer__cta {
    display: inline-block;
    background-color: #C9A96E;
    color: #121212;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding-block: 16px;
    padding-inline: 40px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .plekify-cta-footer__cta:hover {
    background-color: #D4B87A;
  }

  .plekify-cta-footer__contact {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #8E8E8E;
    margin-block-start: 32px;
    margin-block-end: 0;
  }

  .plekify-cta-footer__tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    color: #8E8E8E;
    margin-block-start: 48px;
    margin-block-end: 0;
  }

  /* Scroll reveal */
  .plekify-cta-footer__heading,
  .plekify-cta-footer__subline,
  .plekify-cta-footer__cta,
  .plekify-cta-footer__contact,
  .plekify-cta-footer__tagline {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .plekify-cta-footer__subline {
    transition-delay: 0.1s;
  }

  .plekify-cta-footer__cta {
    transition-delay: 0.2s;
  }

  .plekify-cta-footer__contact {
    transition-delay: 0.3s;
  }

  .plekify-cta-footer__tagline {
    transition-delay: 0.4s;
  }

  .plekify-cta-footer.is-visible .plekify-cta-footer__heading,
  .plekify-cta-footer.is-visible .plekify-cta-footer__subline,
  .plekify-cta-footer.is-visible .plekify-cta-footer__cta,
  .plekify-cta-footer.is-visible .plekify-cta-footer__contact,
  .plekify-cta-footer.is-visible .plekify-cta-footer__tagline {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .plekify-cta-footer__heading,
    .plekify-cta-footer__subline,
    .plekify-cta-footer__cta,
    .plekify-cta-footer__contact,
    .plekify-cta-footer__tagline {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media screen and (max-width: 749px) {
    .plekify-cta-footer {
      padding-block: 48px;
    }

    .plekify-cta-footer__heading {
      font-size: 28px;
    }

    .plekify-cta-footer__subline {
      font-size: 16px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "Plekify CTA Footer",
  "tag": "section",
  "class": "plekify-cta-footer-section",
  "settings": [
    {
