{% comment %}
  ============================================================================
  WETU DAY-BY-DAY SECTION
  ============================================================================
  
  Comprehensive daily itinerary display with timeline layout.
  Shows each leg/stay with accommodation details, check-in/out times,
  room basis, and daily activities categorized by type.
  
  TEMPLATE: product.wetu-itinerary3.json
  
  ============================================================================
  DATA ACCESS ARCHITECTURE
  ============================================================================
  
  METAOBJECT HIERARCHY:
  
  product.metafields.wetu.itinerary_metaobject.value (wetu_itinerary)
  └── legs.value (list of wetu_itinerary_leg)
      ├── leg_id, sequence, accommodation_name, content_entity_id
      ├── nights, type (Standard/Mobile/Departure)
      ├── check_in_time, check_out_time
      ├── rooms (JSON: room configurations)
      └── periods.value (list of wetu_itinerary_period)
          ├── day_label, room_basis, notes
          └── activities.value (list of wetu_itinerary_activity)
              ├── name, description, type (Included/Recommended/Optional)
              ├── is_highlight, time_slot
              ├── start_time, end_time, duration
              └── content_entity_id (links to activity product)
  
  ACCESS EXAMPLE:
  {% assign itinerary = product.metafields.wetu.itinerary_metaobject.value %}
  {% assign legs = itinerary.legs.value %}
  {% for leg in legs %}
    {% assign periods = leg.periods.value %}
    {% for period in periods %}
      {% assign activities = period.activities.value %}
      {% for activity in activities %}
        {{ activity.name.value }} - {{ activity.type.value }}
      {% endfor %}
    {% endfor %}
  {% endfor %}
  
  ============================================================================
  LINKING TO PIN ID PRODUCTS
  ============================================================================
  
  Handle Format: wetu-{content_entity_id}
  
  ACCOMMODATION LINKING:
  {% assign acc_id = leg.content_entity_id.value %}
  {% assign acc_handle = 'wetu-' | append: acc_id %}
  {% assign property = all_products[acc_handle] %}
  
  ACTIVITY LINKING:
  {% assign activity_id = activity.content_entity_id.value %}
  {% assign activity_handle = 'wetu-' | append: activity_id %}
  {% assign activity_product = all_products[activity_handle] %}
  
  LINKED PRODUCT TYPES:
  - wetu-property        : Accommodation with images, position, features
  - wetu-linked-activity : Activity with description, images
  
  PROPERTY METAFIELDS (after linking):
  - linked_product.metafields.wetu.position.value (JSON: latitude, longitude)
  - linked_product.metafields.wetu.features.value (metaobject_reference)
  - linked_product.metafields.wetu.videos.value (list.metaobject_reference)
  - linked_product.images (product images)
  
  ============================================================================
{% endcomment %}

{% assign itinerary_metaobject = product.metafields.wetu.itinerary_metaobject.value %}
{% assign legs_array = itinerary_metaobject.legs.value %}
{% assign routes_array = itinerary_metaobject.routes.value %}
{% assign start_date = itinerary_metaobject.start_date.value %}

{% comment %} --------------------------------------------------------
    BUILD ACTIVITY MAP
    Map Wetu Item IDs to Shopify Product Handles for smart linking
-------------------------------------------------------- {% endcomment %}
{%- liquid
  assign activity_map_ids = ''
  assign activity_map_handles = ''
  
  assign itinerary_activities = product.metafields.wetu_itinerary.activities.value
  
  if itinerary_activities != blank
    for activity_ref in itinerary_activities
      # Check if this product has the linking metafield
      assign act_id = activity_ref.metafields.wetu_linked_activity.wetu_item_id.value | default: activity_ref.metafields.wetu_linked_activity.wetu_item_id
      
      if act_id != blank
        assign activity_map_ids = activity_map_ids | append: act_id | append: ','
        assign activity_map_handles = activity_map_handles | append: activity_ref.handle | append: ','
      endif
    endfor
  endif
  
  assign activity_map_ids_array = activity_map_ids | split: ','
  assign activity_map_handles_array = activity_map_handles | split: ','
-%}

<section 
  class="wetu-day-by-day color-{{ section.settings.color_scheme }}"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="day-by-day__header">
      <span class="day-by-day__label">Your Itinerary</span>
      <h2 class="day-by-day__title h2">Day by Day</h2>
    </div>

    <div class="day-by-day__timeline {% if section.settings.layout_style == 'cards' %}day-by-day__timeline--cards{% endif %}">
      {% assign current_day = 1 %}
      
      {% for leg in legs_array %}
        {% assign leg_type = leg.type.value | default: "Standard" %}
        {% assign leg_nights = leg.nights.value | default: 0 %}
        
        {% comment %} Skip departure legs {% endcomment %}
        {% if leg_type == "Departure" %}
          {% continue %}
        {% endif %}
        
        {% comment %} Get accommodation product {% endcomment %}
        {% assign acc_id = leg.content_entity_id.value %}
        {% assign acc_handle = 'wetu-' | append: acc_id %}
        {% assign linked_product = all_products[acc_handle] %}
        
        {% assign accommodation_name = leg.accommodation_name.value | default: linked_product.title | default: "Accommodation" %}
        {% assign accommodation_image = linked_product.featured_image %}
        {% assign periods_array = leg.periods.value %}
        
        <div class="timeline-day" data-day="{{ current_day }}">
          <div class="timeline-marker">
            <div class="timeline-line"></div>
            <div class="timeline-dot">
              <span class="timeline-dot__number">{{ forloop.index }}</span>
            </div>
          </div>
          
          <div class="timeline-content">
            <div class="day-card">
              {% comment %} Day Header {% endcomment %}
              <div class="day-card__header">
                <div class="day-card__date">
                  {% if leg_nights > 1 %}
                    <span class="day-badge">Days {{ current_day }} - {{ current_day | plus: leg_nights | minus: 1 }}</span>
                  {% else %}
                    <span class="day-badge">Day {{ current_day }}</span>
                  {% endif %}
                  {% if start_date != blank %}
                    {% assign day_offset = current_day | minus: 1 %}
                    {% assign day_date = start_date | date: "%s" | plus: day_offset | times: 86400 %}
                    <span class="day-date">{{ day_date | date: "%B %d, %Y" }}</span>
                  {% endif %}
                </div>
                <div class="day-card__stay">
                  <span class="stay-nights">{{ leg_nights }} {{ leg_nights | pluralize: 'Night', 'Nights' }}</span>
                </div>
              </div>

              {% comment %} Accommodation Info {% endcomment %}
              <div class="day-card__accommodation">
                {% if accommodation_image != blank %}
                  <div class="accommodation-image">
                    <img 
                      src="{{ accommodation_image | image_url: width: 600 }}" 
                      alt="{{ accommodation_name }}"
                      loading="lazy"
                      width="300"
                      height="200"
                    >
                  </div>
                {% endif %}
                <div class="accommodation-info">
                  <h3 class="accommodation-name h4">
                    {% if section.settings.show_accommodation_link and linked_product != blank %}
                      <a href="{{ linked_product.url }}">{{ accommodation_name }}</a>
                    {% else %}
                      {{ accommodation_name }}
                    {% endif %}
                  </h3>
                  
                  {% comment %} Check-in/Check-out {% endcomment %}
                  <div class="accommodation-times">
                    {% assign check_in = leg.check_in_time.value %}
                    {% assign check_out = leg.check_out_time.value %}
                    {% if check_in != blank %}
                      <span class="time-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                          <polyline points="10 17 15 12 10 7"/>
                          <line x1="15" y1="12" x2="3" y2="12"/>
                        </svg>
                        Check-in: {{ check_in }}
                      </span>
                    {% endif %}
                    {% if check_out != blank %}
                      <span class="time-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                          <polyline points="16 17 21 12 16 7"/>
                          <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Check-out: {{ check_out }}
                      </span>
                    {% endif %}
                  </div>

                  {% comment %} Room Basis {% endcomment %}
                  {% if periods_array.first.room_basis.value != blank %}
                    <div class="accommodation-basis">
                      <span class="basis-badge">{{ periods_array.first.room_basis.value }}</span>
                    </div>
                  {% endif %}
                </div>
              </div>

              {% comment %} Daily Periods {% endcomment %}
              {% for period in periods_array %}
                {% assign period_day = current_day | plus: forloop.index0 %}
                {% assign period_notes = period.notes.value %}
                {% assign activities_array = period.activities.value %}
                
                {% if period_notes != blank or activities_array.size > 0 %}
                  <div class="day-card__period">
                    {% if leg_nights > 1 %}
                      <div class="period-header">
                        <span class="period-label">Day {{ period_day }}</span>
                        {% assign day_label = period.day_label.value %}
                        {% if day_label != blank %}
                          <span class="period-title">{{ day_label }}</span>
                        {% endif %}
                      </div>
                    {% endif %}
                    
                    {% comment %} Period Notes {% endcomment %}
                    {% if period_notes != blank %}
                      <div class="period-notes rte">
                        {{ period_notes }}
                      </div>
                    {% endif %}
                    
                    {% comment %} Activities {% endcomment %}
                    {% if section.settings.show_activities and activities_array.size > 0 %}
                      <div class="period-activities">
                        <h4 class="activities-title">Activities & Experiences</h4>
                        <div class="activities-list">
                          {% for activity in activities_array %}
                            {% assign activity_name = activity.name.value %}
                            {% assign activity_type = activity.type.value | default: "Included" %}
                            {% assign activity_time = activity.time_slot.value %}
                            {% assign activity_desc = activity.description.value %}
                            {% assign is_highlight = activity.is_highlight.value %}
                            {% assign activity_entity_id = activity.content_entity_id.value %}
                            
                            {% comment %} Try to link to activity product {% endcomment %}
                            {% assign activity_handle = 'wetu-' | append: activity_entity_id %}
                            {% assign activity_product = all_products[activity_handle] %}
                            
                            <div class="activity-item{% if is_highlight %} activity-item--highlight{% endif %}">
                              <div class="activity-icon">
                                {% case activity_type %}
                                  {% when "Recommended" %}
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                      <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
                                    </svg>
                                  {% when "Optional" %}
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                      <circle cx="12" cy="12" r="10"/>
                                      <path d="M12 8v4l3 3"/>
                                    </svg>
                                  {% else %}
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                      <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                {% endcase %}
                              </div>
                              <div class="activity-content">
                                <div class="activity-header">
                                  <span class="activity-name">
                                    {% if activity_product != blank %}
                                      <a href="{{ activity_product.url }}">{{ activity_name }}</a>
                                    {% else %}
                                      {{ activity_name }}
                                    {% endif %}
                                  </span>
                                  {% if activity_time != blank and activity_time != "None" %}
                                    <span class="activity-time">{{ activity_time }}</span>
                                  {% endif %}
                                </div>
                                {% if activity_desc != blank %}
                                  <p class="activity-description">{{ activity_desc | strip_html | truncatewords: 25 }}</p>
                                {% endif %}
                                <span class="activity-type-badge activity-type--{{ activity_type | handleize }}">{{ activity_type }}</span>
                              </div>
                              {% if is_highlight %}
                                <span class="highlight-star" title="Trip Highlight">★</span>
                              {% endif %}
                            </div>
                          {% endfor %}
                        </div>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        
        {% assign current_day = current_day | plus: leg_nights %}
      {% endfor %}
      
      {% comment %} Final Departure {% endcomment %}
      <div class="timeline-day timeline-day--departure">
        <div class="timeline-marker">
          <div class="timeline-dot timeline-dot--end">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
            </svg>
          </div>
        </div>
        <div class="timeline-content">
          <div class="departure-card">
            <span class="day-badge">Day {{ current_day }}</span>
            <h3 class="departure-title">Departure</h3>
            <p class="departure-text">End of your journey</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Build lookup map from Liquid variables
    const wetuActivityMap = {
      {% for id in activity_map_ids_array %}
        {% if id != blank %}
          "{{ id | strip }}": "{{ activity_map_handles_array[forloop.index0] | strip }}",
        {% endif %}
      {% endfor %}
    };

  // Parse custom PIN links in notes
  // These are injected by the uploader to survive Wetu sanitization
  // Note: Using string concatenation to avoid Liquid syntax conflict
  const notesElements = document.querySelectorAll('.period-notes, .day-notes, .itinerary-notes');
  
  notesElements.forEach(el => {
    // Look for pattern
    if (el.innerHTML.includes('{' + '{PIN:')) {
      // Replace with Shopify product link
      // Uses map if available, otherwise falls back to wetu-{id} convention
      // Using RegExp constructor to avoid Liquid processing of curly braces
      const pinRegex = new RegExp('{' + '{PIN:(\\d+)\\|([^}]+)}' + '}', 'g');
      
      el.innerHTML = el.innerHTML.replace(pinRegex, (match, id, text) => {
        const handle = wetuActivityMap[id] || `wetu-${id}`;
        return `<a href="/products/${handle}" class="text-link wetu-product-link">${text}</a>`;
      });
    }
  });
});
</script>

{% stylesheet %}
  .wetu-day-by-day {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background: var(--color-background);
  }

  .day-by-day__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .day-by-day__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .day-by-day__title {
    margin: 0;
    color: var(--color-foreground);
  }

  /* Timeline Layout */
  .day-by-day__timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-day {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media screen and (max-width: 749px) {
    .timeline-day {
      grid-template-columns: 40px 1fr;
      gap: 16px;
    }
  }

  .timeline-marker {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .timeline-line {
    position: absolute;
    top: 48px;
    bottom: -32px;
    width: 2px;
    background: var(--color-border);
  }

  .timeline-day:last-child .timeline-line {
    display: none;
  }

  .timeline-dot {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-background);
    font-weight: 700;
    font-size: 1rem;
    z-index: 1;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  @media screen and (max-width: 749px) {
    .timeline-dot {
      width: 36px;
      height: 36px;
      font-size: 0.85rem;
    }
  }

  .timeline-dot--end {
    background: color-mix(in srgb, var(--color-foreground) 20%, transparent);
    color: var(--color-foreground);
  }

  /* Day Card */
  .day-card {
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .day-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    border-bottom: 1px solid var(--color-border);
  }

  .day-card__date {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .day-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
  }

  .day-date {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  }

  .day-card__stay {
    text-align: right;
  }

  .stay-nights {
    display: inline-block;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    color: var(--color-primary);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Accommodation */
  .day-card__accommodation {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  @media screen and (min-width: 750px) {
    .day-card__accommodation {
      grid-template-columns: 200px 1fr;
    }
  }

  .accommodation-image {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/2;
  }

  .accommodation-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .accommodation-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .accommodation-name {
    margin: 0;
    font-size: 1.25rem;
    color: var(--color-foreground);
  }

  .accommodation-name a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .accommodation-name a:hover {
    color: var(--color-primary);
  }

  .accommodation-times {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .time-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
  }

  .accommodation-basis {
    margin-top: auto;
  }

  .basis-badge {
    display: inline-block;
    padding: 4px 10px;
    background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
    border-radius: 6px;
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
  }

  /* Period */
  .day-card__period {
    padding: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .day-card__period:last-child {
    border-bottom: none;
  }

  .period-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .period-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-primary);
    padding: 4px 8px;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border-radius: 4px;
  }

  .period-title {
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
  }

  .period-notes {
    font-size: 0.95rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    margin-bottom: 20px;
  }

  /* Activities */
  .period-activities {
    margin-top: 20px;
  }

  .activities-title {
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    margin: 0 0 16px;
  }

  .activities-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .activity-item {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: color-mix(in srgb, var(--color-foreground) 2%, transparent);
    border-radius: 10px;
    position: relative;
    transition: background 0.2s ease;
  }

  .activity-item:hover {
    background: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }

  .activity-item--highlight {
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .activity-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    color: var(--color-primary);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .activity-content {
    flex: 1;
    min-width: 0;
  }

  .activity-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 4px;
  }

  .activity-name {
    font-weight: 500;
    color: var(--color-foreground);
  }

  .activity-name a {
    color: inherit;
    text-decoration: none;
  }

  .activity-name a:hover {
    color: var(--color-primary);
  }

  .activity-time {
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
    white-space: nowrap;
  }

  .activity-description {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    margin: 4px 0 8px;
    line-height: 1.5;
  }

  .activity-type-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .activity-type--included {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #16a34a;
  }

  .activity-type--recommended {
    background: color-mix(in srgb, #3b82f6 15%, transparent);
    color: #2563eb;
  }

  .activity-type--optional {
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    color: #d97706;
  }

  .highlight-star {
    position: absolute;
    top: 12px;
    right: 12px;
    color: #f59e0b;
    font-size: 1rem;
  }

  /* Departure */
  .departure-card {
    padding: 24px;
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-align: center;
  }

  .departure-title {
    margin: 8px 0 4px;
    font-size: 1.25rem;
    color: var(--color-foreground);
  }

  .departure-text {
    margin: 0;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  }

  /* Cards Layout Variant */
  .day-by-day__timeline--cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: none;
  }

  @media screen and (min-width: 990px) {
    .day-by-day__timeline--cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .day-by-day__timeline--cards .timeline-day {
    display: block;
    margin-bottom: 0;
  }

  .day-by-day__timeline--cards .timeline-marker {
    display: none;
  }
{% endstylesheet %}

