{%- liquid
  assign video_id = section.settings.video_1.id
  assign video_alt = section.settings.video_1.alt | default: section.settings.heading
  assign poster = section.settings.video_1.preview_image
  assign media_count = 0
  if section.settings.video_1 != blank
    assign media_count = 1
  elsif section.settings.image_1 != blank
    assign media_count = 1
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .africa-map-video-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background-color: rgba(var(--color-background), 1);
  }
  
  /* Hero-like content positioning */
  .africa-map-content-wrapper {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    display: flex;
    padding: 2rem;
  }
  
  .africa-map-content-wrapper > * {
    pointer-events: auto;
  }

  .africa-map-video-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .africa-map-video-bg video,
  .africa-map-video-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Map Overlay - Positioned to the right */
  .africa-map-overlay-container {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 65%;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  @media screen and (max-width: 990px) {
    .africa-map-overlay-container {
      width: 90%;
      right: -10%;
    }
  }

  .africa-svg-map-overlay {
    width: 100%;
    height: 110%;
    display: block;
    filter: drop-shadow(0 0 10px rgba(0,0,0,0.3));
    pointer-events: auto;
    transform-origin: bottom right;
  }

  /* Map Styling - Dark mode compatible */
  .africa-svg-map-overlay .africa-outline {
    fill: none;
    stroke: rgba(var(--color-foreground), 0.3);
    stroke-width: 1;
  }

  .africa-svg-map-overlay .country-background {
    fill: rgba(var(--color-foreground), 0.08);
    stroke: rgba(var(--color-foreground), 0.15);
    stroke-width: 0.5;
  }

  .africa-svg-map-overlay path.country-selectable {
    fill: rgba(var(--color-foreground), 0.2);
    stroke: rgba(var(--color-foreground), 0.5);
    stroke-width: 1;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .africa-svg-map-overlay path.country-selectable:hover {
    fill: rgba(var(--color-foreground), 0.4);
    stroke: rgba(var(--color-foreground), 0.9);
    stroke-width: 1.5;
  }

  .africa-svg-map-overlay .country-label {
    fill: rgba(var(--color-foreground), 1);
    font-size: 14px;
    font-weight: 700;
    pointer-events: none;
  }

  /* Islands - Dark mode compatible */
  .island-inset-box {
    position: absolute;
    background: rgba(var(--color-foreground), 0.08);
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 8px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    backdrop-filter: blur(4px);
    pointer-events: auto;
    z-index: 10;
  }

  .island-inset-box:hover {
    background: rgba(var(--color-foreground), 0.15);
    border-color: rgba(var(--color-foreground), 0.4);
    transform: scale(1.05);
  }

  .island-inset-box svg {
    width: 60px;
    height: 50px;
    overflow: visible;
  }

  .island-shape {
    fill: rgba(var(--color-foreground), 0.25);
    stroke: rgba(var(--color-foreground), 0.5);
    stroke-width: 1;
    transition: all 0.3s ease;
  }
  
  .island-inset-box:hover .island-shape {
    fill: rgba(var(--color-foreground), 0.45);
    stroke: rgba(var(--color-foreground), 0.8);
  }

  .island-label {
    color: rgba(var(--color-foreground), 1);
    font-size: 12px;
    font-weight: 600;
  }

  /* Island disclaimer note */
  .island-disclaimer {
    position: absolute;
    bottom: 12px;
    left: 12px;
    color: rgba(var(--color-foreground), 0.6);
    font-size: 11px;
    font-style: italic;
    pointer-events: none;
    z-index: 5;
  }

  @media screen and (max-width: 749px) {
    .island-disclaimer {
      bottom: 8px;
      left: 8px;
      font-size: 10px;
    }
  }

  {% if section.settings.show_info_text and section.settings.info_text != blank %}
  .africa-map-info-text {
    position: absolute;
    bottom: 40px;
    left: 12px;
    color: rgba(var(--color-foreground), 0.8);
    font-size: 13px;
    max-width: 300px;
    pointer-events: none;
    z-index: 5;
  }
  {% endif %}
{%- endstyle -%}

{% comment %} Reuse Hero Styles {% endcomment %}
{% stylesheet %}
  .hero__content-wrapper .text-block,
  .hero__content-wrapper h1,
  .hero__content-wrapper h2,
  .hero__content-wrapper h3,
  .hero__content-wrapper h4,
  .hero__content-wrapper h5,
  .hero__content-wrapper h6,
  .hero__content-wrapper p,
  .hero__content-wrapper a,
  .hero__content-wrapper span,
  .hero__content-wrapper button {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), 0 1px 2px rgba(0, 0, 0, 0.4);
  }
{% endstylesheet %}

