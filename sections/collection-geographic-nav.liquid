{% schema %}
{
  "name": "Geographic Navigation",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "filter_label",
      "label": "Filter Label",
      "default": "Region",
      "info": "The exact name of the filter in Search & Discovery app (e.g., 'Region', 'Area')."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore by Region"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image_map",
      "name": "Filter Image",
      "settings": [
        {
          "type": "text",
          "id": "filter_value",
          "label": "Filter Value",
          "info": "Exact text of the filter value (e.g. 'Western Cape')."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Geographic Navigation"
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .geo-nav-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .geo-nav-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2rem;
    }
  }

  .geo-nav-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: #f4f4f4;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease;
    height: 100%;
    min-height: 200px;
  }

  .geo-nav-card:hover {
    transform: translateY(-5px);
  }

  .geo-nav-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .geo-nav-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    z-index: 2;
  }

  .geo-nav-content {
    position: relative;
    z-index: 3;
    margin-top: auto;
    padding: 1.5rem;
    color: white;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .geo-nav-label {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .geo-nav-count {
    display: block;
    font-size: 0.9rem;
    opacity: 0.9;
  }
  
  .geo-nav-placeholder {
    width: 100%;
    height: 100%;
    background: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }
{%- endstyle -%}

<div class="page-width section-{{ section.id }}-padding">
  {% if section.settings.heading != blank %}
    <h2 class="title inline-richtext h2 scroll-trigger animate--slide-in">{{ section.settings.heading }}</h2>
  {% endif %}

  {% assign target_filter = nil %}
  {% for filter in collection.filters %}
    {% if filter.label == section.settings.filter_label %}
      {% assign target_filter = filter %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if target_filter %}
    <ul class="geo-nav-grid">
      {% for value in target_filter.values %}
        {% if value.count > 0 %}
          <li class="scroll-trigger animate--slide-in">
            <a href="{{ value.url_to_add }}" class="geo-nav-card">
              {% assign block_image = nil %}
              {% for block in section.blocks %}
                {% if block.settings.filter_value == value.label %}
                  {% assign block_image = block.settings.image %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if block_image %}
                {{ block_image | image_url: width: 600 | image_tag: class: 'geo-nav-image', loading: 'lazy' }}
              {% else %}
                 <div class="geo-nav-placeholder">
                    <span>{{ value.label }}</span>
                 </div>
              {% endif %}

              <div class="geo-nav-overlay"></div>
              
              <div class="geo-nav-content">
                <span class="geo-nav-label">{{ value.label }}</span>
                <span class="geo-nav-count">{{ value.count }} properties</span>
              </div>
            </a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  {% else %}
    <div class="page-width">
      <p>Filter with label "{{ section.settings.filter_label }}" not found. Please ensure it is added in the Search & Discovery app.</p>
    </div>
  {% endif %}
</div>
