{% stylesheet %}

/* ═══════════════════════════════════════════════════════════
   V8 PLATFORM — Sections 9–13
   ═══════════════════════════════════════════════════════════ */

.plekify-v8-fw {
  font-family: 'Inter', sans-serif;
  font-weight: 300;
  color: #1a1a1a;
  background: #fff;
}

/* ── CONTAINMENT ───────────────────────────────────────── */

.plekify-v8-fw .v8-contain {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 2rem;
}

.plekify-v8-fw .v8-contain--wide {
  max-width: 1120px;
  margin: 0 auto;
  padding: 0 2rem;
}

.plekify-v8-fw .v8-prose {
  max-width: 640px;
}

/* ── SHARED TYPOGRAPHY ──────────────────────────────────── */

.plekify-v8-fw h2.v8-sh {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-size: clamp(24px, 3.2vw, 36px);
  line-height: 1.12;
  color: #111;
  margin-bottom: .4rem;
}
.plekify-v8-fw h2.v8-sh em { font-style: italic; color: #555; }

.plekify-v8-fw .v8-body { font-size: 13.5px; line-height: 1.8; color: #444; font-weight: 300; }
.plekify-v8-fw .v8-sm { font-size: 12px; line-height: 1.7; color: #666; }
.plekify-v8-fw .v8-annot {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: #888;
  font-weight: 400;
  margin-bottom: .5rem;
  display: block;
}

/* ── BANDS (full-width sections) ───────────────────────── */

.plekify-v8-fw .v8-band {
  padding: 3rem 0;
  border-bottom: 1px solid #eee;
}

.plekify-v8-fw .v8-band--alt {
  background: #f9f9f9;
  border-bottom: none;
}

.plekify-v8-fw .v8-band--cta {
  padding: 3rem 0;
  border-top: 1px solid #e0e0e0;
  border-bottom: 1px solid #e0e0e0;
}

/* ── TWO COLUMNS ────────────────────────────────────────── */

.plekify-v8-fw .v8-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

/* ── HIGHLIGHT BOX ──────────────────────────────────────── */

.plekify-v8-fw .v8-hl {
  background: #f7f7f7;
  border-left: 2px solid #ccc;
  padding: .9rem 1.2rem;
  margin-top: .85rem;
}

.plekify-v8-fw .v8-hl__label {
  font-weight: 400;
  color: #222;
}

/* ── COMPARISON TABLE ───────────────────────────────────── */

.plekify-v8-fw .v8-comp {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
}

.plekify-v8-fw .v8-comp th {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #777;
  font-weight: 400;
  padding: .55rem .85rem;
  text-align: left;
  border-bottom: 1px solid #ddd;
}

.plekify-v8-fw .v8-comp td {
  padding: .6rem .85rem;
  color: #444;
  border-bottom: .5px solid #eee;
  vertical-align: top;
  line-height: 1.5;
  font-weight: 300;
  font-size: 12px;
}

.plekify-v8-fw .v8-comp td:first-child { color: #222; font-weight: 400; width: 22%; }
.plekify-v8-fw .v8-comp tr:last-child td { border-bottom: none; }
.plekify-v8-fw .v8-comp--g { color: #222 !important; }
.plekify-v8-fw .v8-comp--d { color: #888 !important; }

/* B2B row highlight */
.plekify-v8-fw .v8-comp__row--highlight td {
  background: #f7f7f7;
  border-bottom-color: #ddd;
}
.plekify-v8-fw .v8-comp__row--highlight td:first-child {
  font-weight: 500;
  color: #111;
}

/* ── ACCORDION ROWS ─────────────────────────────────────── */

.plekify-v8-fw .v8-acc {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: .65rem 0;
  border-bottom: .5px solid #e0e0e0;
}

.plekify-v8-fw .v8-acc:first-of-type { padding-top: 0; }
.plekify-v8-fw .v8-acc:last-of-type { border-bottom: none; }
.plekify-v8-fw .v8-acc__text { font-size: 13px; color: #222; font-weight: 300; letter-spacing: .01em; line-height: 1.5; }
.plekify-v8-fw .v8-acc__plus { font-size: 14px; color: #bbb; font-weight: 300; flex-shrink: 0; margin-left: .5rem; }

/* ── INTEGRATIONS ───────────────────────────────────────── */

.plekify-v8-fw .v8-int-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 1.25rem;
}

.plekify-v8-fw .v8-int {
  border: 1px solid #ddd;
  border-radius: 1px;
  padding: 1.1rem;
}

.plekify-v8-fw .v8-int__status {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 8.5px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 400;
  margin-bottom: .5rem;
  padding: 2px 7px;
  border-radius: 1px;
  display: inline-block;
}

.plekify-v8-fw .v8-int__status--live { color: #2d6b36; background: #e8f2ea; border: 1px solid #b6d4bb; }
.plekify-v8-fw .v8-int__status--soon { color: #555; background: #f0f0f0; border: 1px solid #d4d4d4; }

.plekify-v8-fw .v8-int__name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 19px;
  font-weight: 300;
  color: #111;
  margin-bottom: .3rem;
}

/* ── BUILDER ────────────────────────────────────────────── */

.plekify-v8-fw .v8-builder {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 3rem;
  align-items: start;
  margin-top: 1rem;
}

.plekify-v8-fw .v8-builder__profile {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.plekify-v8-fw .v8-builder__avatar {
  width: 88px;
  height: 88px;
  border-radius: 1px;
  object-fit: cover;
  object-position: center top;
  border: 1px solid #d8d8d8;
  flex-shrink: 0;
  filter: grayscale(20%);
}

.plekify-v8-fw .v8-builder__name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 300;
  color: #111;
  line-height: 1.2;
}

.plekify-v8-fw .v8-builder__role {
  font-size: 10px;
  color: #777;
  letter-spacing: .06em;
  margin-top: 2px;
}

.plekify-v8-fw .v8-stat {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14.5px;
  font-weight: 300;
  color: #555;
  padding: .5rem 0;
  border-bottom: .5px solid #e0e0e0;
  line-height: 1.5;
}

.plekify-v8-fw .v8-stat:last-child { border-bottom: none; }
.plekify-v8-fw .v8-stat strong { font-weight: 400; color: #222; }

.plekify-v8-fw .v8-text-link {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: .04em;
  color: #444;
  border-bottom: 1px solid #ccc;
  padding-bottom: 1px;
  text-decoration: none;
  font-weight: 400;
  transition: color .18s, border-color .18s;
}

.plekify-v8-fw .v8-text-link:hover { color: #111; border-color: #888; }

/* inline text links within body copy */
.plekify-v8-fw .v8-body .v8-text-link {
  font-family: inherit;
  font-size: inherit;
  letter-spacing: inherit;
}

.plekify-v8-fw .v8-stat .v8-text-link {
  font-family: inherit;
  font-size: inherit;
  letter-spacing: inherit;
}

/* ── PRICING ────────────────────────────────────────────── */

.plekify-v8-fw .v8-price-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin-top: 1.25rem;
}

.plekify-v8-fw .v8-price {
  border: 1px solid #ddd;
  border-radius: 1px;
  padding: 1.5rem;
}

.plekify-v8-fw .v8-price--feat { border-color: #999; }

.plekify-v8-fw .v8-price__type {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #777;
  margin-bottom: .6rem;
}

.plekify-v8-fw .v8-price__name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 21px;
  font-weight: 300;
  color: #111;
  margin-bottom: .4rem;
}

/* ── Commission model highlight items ──────────────────── */

.plekify-v8-fw .v8-price__highlights {
  margin: .85rem 0 .5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.plekify-v8-fw .v8-price__highlight-item {
  font-size: 13px;
  font-weight: 400;
  color: #111;
  padding: .55rem .85rem;
  background: #f7f7f7;
  border-left: 2px solid #999;
  line-height: 1.5;
}

.plekify-v8-fw .v8-price__highlight-item + .v8-price__highlight-item {
  border-top: 1px solid #e8e8e8;
}

.plekify-v8-fw .v8-price__list {
  list-style: none;
  padding: 0;
  margin: .75rem 0 0;
}

.plekify-v8-fw .v8-price__list li {
  font-size: 12.5px;
  color: #333;
  font-weight: 300;
  padding: .3rem 0 .3rem 1rem;
  position: relative;
  line-height: 1.55;
}

.plekify-v8-fw .v8-price__list li:before {
  content: '—';
  position: absolute;
  left: 0;
  color: #bbb;
  font-size: 11px;
}

.plekify-v8-fw .v8-price__note {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-style: italic;
  color: #777;
  margin-top: .75rem;
  padding-top: .65rem;
  border-top: .5px solid #e8e8e8;
}

/* ── CTA ────────────────────────────────────────────────── */

.plekify-v8-fw .v8-cta__btn {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #fff;
  background: #111;
  padding: 11px 26px;
  cursor: pointer;
  border-radius: 1px;
  border: none;
  font-weight: 400;
  margin-top: 1.25rem;
  text-decoration: none;
  display: inline-block;
  transition: background .2s;
}

.plekify-v8-fw .v8-cta__btn:hover { background: #333; }

/* ── FOOTER ─────────────────────────────────────────────── */

.plekify-v8-fw .v8-footer {
  border-top: 1px solid #e0e0e0;
}

.plekify-v8-fw .v8-footer__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.75rem;
  padding-bottom: 1.75rem;
}

.plekify-v8-fw .v8-footer__logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-weight: 300;
  color: #888;
  letter-spacing: .06em;
}

.plekify-v8-fw .v8-footer__note {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: #888;
  letter-spacing: .04em;
}

/* ── RESPONSIVE ─────────────────────────────────────────── */

@media (max-width: 720px) {
  .plekify-v8-fw .v8-contain,
  .plekify-v8-fw .v8-contain--wide {
    padding: 0 1.25rem;
  }
  .plekify-v8-fw .v8-band {
    padding: 2rem 0;
  }
  .plekify-v8-fw .v8-2col,
  .plekify-v8-fw .v8-int-grid,
  .plekify-v8-fw .v8-price-grid,
  .plekify-v8-fw .v8-builder {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .plekify-v8-fw .v8-footer__inner { flex-direction: column; gap: .75rem; text-align: center; }
}

