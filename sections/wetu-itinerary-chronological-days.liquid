{%- liquid
  assign itinerary_json_raw = product.metafields.wetu.itinerary_json.value | default: product.metafields.wetu.itinerary_json
  assign itinerary_source_json_raw = product.metafields.wetu.itinerary_source_json.value | default: product.metafields.wetu.itinerary_source_json

  assign itinerary_json = itinerary_json_raw
  assign itinerary_source_json = itinerary_source_json_raw

  assign itinerary_json_cdn_url = product.metafields.wetu.itinerary_json_cdn_url.value | default: product.metafields.wetu.itinerary_json_cdn_url
  if itinerary_json_cdn_url == blank and itinerary_json and itinerary_json.storage == 'shopify_file'
    assign itinerary_json_cdn_url = itinerary_json.cdn_url
  endif

  assign itinerary_source_json_cdn_url = product.metafields.wetu.itinerary_source_json_cdn_url.value | default: product.metafields.wetu.itinerary_source_json_cdn_url
  if itinerary_source_json_cdn_url == blank and itinerary_source_json and itinerary_source_json.storage == 'shopify_file'
    assign itinerary_source_json_cdn_url = itinerary_source_json.cdn_url
  endif

  assign wetu_itinerary = blank
  assign chronology_source = 'missing'
  if itinerary_source_json != blank and itinerary_source_json.storage != 'shopify_file'
    assign wetu_itinerary = itinerary_source_json
    assign chronology_source = 'itinerary_source_json_inline'
  elsif itinerary_source_json_cdn_url != blank
    assign chronology_source = 'itinerary_source_json_cdn'
  endif

  assign wetu_total_days = wetu_itinerary.days.value | default: wetu_itinerary.days | default: 0
  assign start_date = wetu_itinerary.start_date.value | default: wetu_itinerary.start_date

  assign wetu_legs = wetu_itinerary.legs.value | default: wetu_itinerary.legs
  assign wetu_routes = wetu_itinerary.routes.value | default: wetu_itinerary.routes
  if chronology_source == 'itinerary_source_json_inline'
    assign wetu_legs = wetu_legs | sort: 'sequence'
    assign wetu_routes = wetu_routes | sort: 'sequence'
  else
    assign wetu_legs = ''
    assign wetu_routes = ''
  endif

  assign wetu_total_nights = 0
  for leg in wetu_legs
    assign leg_nights = leg.nights.value | default: leg.nights | default: 0
    assign wetu_total_nights = wetu_total_nights | plus: leg_nights
  endfor

  assign total_days = wetu_total_days | plus: 0
  if total_days < 1
    assign total_days = wetu_total_nights | plus: 1
  endif
  unless chronology_source == 'itinerary_source_json_inline'
    assign total_days = 0
  endunless

  assign itinerary_type = product.metafields.wetu.itinerary_type.value | default: wetu_itinerary.type.value | default: wetu_itinerary.type | default: ''
  assign itinerary_type_normalized = itinerary_type | downcase
  assign is_day_tour_timeline = false
  if itinerary_type_normalized contains 'daytour' or itinerary_type_normalized contains 'day tour'
    assign is_day_tour_timeline = true
  endif
  if is_day_tour_timeline and total_days > 1
    assign total_days = 1
  endif

  assign component_products = product.metafields.wetu_itinerary.component_products.value
  assign pin_ids_list = ''
  assign handles_list = ''
  if component_products.size > 0
    for comp_product in component_products
      if comp_product.handle
        assign prod_obj = comp_product
      else
        assign prod_obj = all_products[comp_product]
      endif
      assign prod_pin = prod_obj.metafields.wetu.pin_id.value | default: prod_obj.metafields.wetu.content_entity_id.value
      assign prod_handle = prod_obj.handle
      if prod_pin != blank and prod_handle != blank
        if pin_ids_list == ''
          assign pin_ids_list = prod_pin
          assign handles_list = prod_handle
        else
          assign pin_ids_list = pin_ids_list | append: ',' | append: prod_pin
          assign handles_list = handles_list | append: ',' | append: prod_handle
        endif
      endif
    endfor
  endif

  assign wetu_pin_ids_array = pin_ids_list | split: ','
  assign wetu_handles_array = handles_list | split: ','

  capture wetu_pin_to_product_map
    echo '{'
    for pin_id in wetu_pin_ids_array
      if pin_id != blank
        unless forloop.first
          echo ','
        endunless
        echo '"'
        echo pin_id
        echo '":"'
        echo wetu_handles_array[forloop.index0] | default: ''
        echo '"'
      endif
    endfor
    echo '}'
  endcapture

  assign link_manifest_raw = product.metafields.wetu_itinerary.link_manifest.value | default: product.metafields.wetu_itinerary.link_manifest | default: '{}'

  assign seen_destinations = '|'
  assign seen_accommodations = '|'

  assign hero_video = product.metafields.wetu.hero_video.value | default: product.metafields.wetu.hero_video

  assign inspector_variant = product.selected_or_first_available_variant
  assign inspector_variant_id = inspector_variant.id
  assign inspector_price = inspector_variant.price | default: 0
  assign inspector_default_guests = 2
  assign inspector_min_guests = 1
  assign inspector_max_guests = 12
  assign inspector_total_price = inspector_price | times: inspector_default_guests

  capture inspector_guests_template
    echo 'wetu.accommodation.guests_count' | t: count: '__COUNT__' | default: '__COUNT__ guests'
  endcapture
  assign inspector_guests_template = inspector_guests_template | strip | escape

  assign inspector_confirm_base_url = '#'
  if inspector_variant_id != blank
    assign inspector_confirm_base_url = '/cart/add?id=' | append: inspector_variant_id
  endif
  assign inspector_confirm_url = inspector_confirm_base_url
  if inspector_variant_id != blank
    assign inspector_confirm_url = inspector_confirm_url | append: '&quantity=' | append: inspector_default_guests
  endif

  assign inspector_itinerary = wetu_itinerary
  if inspector_itinerary == blank
    assign inspector_itinerary = product.metafields.wetu.itinerary_metaobject.value
  endif

  assign inspector_legs = wetu_legs
  if inspector_legs == blank and inspector_itinerary != blank
    assign inspector_legs = inspector_itinerary.legs.value | default: inspector_itinerary.legs
    assign inspector_legs = inspector_legs | sort: 'sequence.value'
  endif

  assign itinerary_reference = product.metafields.wetu.reference.value | default: product.metafields.wetu.reference
  if itinerary_reference == blank
    assign itinerary_reference = inspector_itinerary.reference.value | default: inspector_itinerary.reference
  endif
  if itinerary_reference == blank
    assign itinerary_reference = inspector_itinerary.reference_number.value | default: inspector_itinerary.reference_number
  endif
  if itinerary_reference == blank
    assign itinerary_reference = product.metafields.wetu.itinerary_identifier.value | default: product.metafields.wetu.itinerary_identifier
  endif

  assign inspector_start_date = start_date
  if inspector_start_date == blank
    assign inspector_start_date = inspector_itinerary.start_date.value | default: inspector_itinerary.start_date
  endif

  assign inspector_start_year = inspector_start_date | date: '%Y'
  if inspector_start_date == blank
    assign inspector_start_year = 'now' | date: '%Y'
  endif

  assign travellers_adult = inspector_itinerary.travellers_adult.value | default: inspector_itinerary.travellers_adult | default: 0 | plus: 0
  assign travellers_children = inspector_itinerary.travellers_children.value | default: inspector_itinerary.travellers_children | default: 0 | plus: 0
  capture inspector_guest_subtitle
    assign has_guest_details = false
    if travellers_adult > 0
      echo travellers_adult
      echo ' '
      echo 'wetu.itinerary.adults' | t | default: 'adults'
      assign has_guest_details = true
    endif
    if travellers_children > 0
      if has_guest_details
        echo ' · '
      endif
      echo travellers_children
      echo ' '
      echo 'wetu.itinerary.children' | t | default: 'children'
      assign has_guest_details = true
    endif
  endcapture
  assign inspector_guest_subtitle = inspector_guest_subtitle | strip
  if inspector_guest_subtitle == blank
    assign inspector_guest_subtitle = 'wetu.accommodation.guests_count' | t: count: inspector_default_guests | default: '2 guests'
  endif

  assign inspector_contacts = inspector_itinerary.contacts.value | default: inspector_itinerary.contacts
  assign inspector_primary_contact = blank
  if inspector_contacts != blank and inspector_contacts.size > 0
    assign inspector_primary_contact = inspector_contacts | first
  endif

  assign inspector_operator_name = inspector_primary_contact.company.value | default: inspector_primary_contact.company | default: inspector_primary_contact.company_name.value | default: inspector_primary_contact.company_name | default: product.vendor
  assign inspector_consultant_name = inspector_primary_contact.contact_person.value | default: inspector_primary_contact.contact_person | default: inspector_primary_contact.name.value | default: inspector_primary_contact.name | default: inspector_operator_name
  assign inspector_consultant_role = inspector_primary_contact.role.value | default: inspector_primary_contact.role
  if inspector_consultant_role == blank
    assign inspector_consultant_role = 'wetu.itinerary.primary_contact' | t | default: 'Travel consultant'
  endif
  assign inspector_contact_phone = inspector_primary_contact.telephone.value | default: inspector_primary_contact.telephone | default: inspector_primary_contact.phone.value | default: inspector_primary_contact.phone | default: inspector_primary_contact.alternative_telephone.value | default: inspector_primary_contact.alternative_telephone
  assign inspector_contact_email = inspector_primary_contact.email.value | default: inspector_primary_contact.email

  capture inspector_contact_role_line
    if inspector_consultant_role != blank
      echo inspector_consultant_role
    endif
    if inspector_operator_name != blank
      if inspector_consultant_role != blank
        echo ' · '
      endif
      echo inspector_operator_name
    endif
  endcapture
  assign inspector_contact_role_line = inspector_contact_role_line | strip
  if inspector_contact_role_line == blank
    assign inspector_contact_role_line = 'wetu.itinerary.contact_us' | t | default: 'Contact'
  endif

  assign inspector_contact_initials = ''
  assign inspector_contact_name_parts = inspector_consultant_name | split: ' '
  for name_part in inspector_contact_name_parts
    if name_part == blank
      continue
    endif
    assign name_initial = name_part | slice: 0
    assign inspector_contact_initials = inspector_contact_initials | append: name_initial
    if inspector_contact_initials.size >= 2
      break
    endif
  endfor
  if inspector_contact_initials == '' and inspector_operator_name != blank
    assign inspector_contact_initials = inspector_operator_name | slice: 0, 2
  endif
  assign inspector_contact_initials = inspector_contact_initials | upcase

  assign inspector_inclusion_limit = 12
  assign inspector_inclusion_count = 0
  assign inspector_inclusion_rows = ''
  assign inspector_inclusion_seen = '|'

  for leg in inspector_legs
    if inspector_inclusion_count >= inspector_inclusion_limit
      break
    endif

    assign inspector_leg_type = leg.type.value | default: leg.type | default: ''
    assign inspector_leg_name = leg.accommodation_name.value | default: leg.accommodation_name | default: leg.destination_name.value | default: leg.destination_name | default: ''
    if inspector_leg_name == blank
      assign inspector_leg_name = leg.name.value | default: leg.name | default: leg.label.value | default: leg.label | default: ''
    endif
    if inspector_leg_name == blank
      assign inspector_leg_pin = leg.content_entity_id.value | default: leg.content_entity_id
      if inspector_leg_pin != blank
        assign inspector_pin_search = inspector_leg_pin | append: ''
        for check_pin in wetu_pin_ids_array
          assign inspector_current_pin = check_pin | append: ''
          if inspector_current_pin == inspector_pin_search
            assign inspector_leg_handle = wetu_handles_array[forloop.index0]
            assign inspector_leg_product = all_products[inspector_leg_handle]
            assign inspector_leg_name = inspector_leg_product.title | default: ''
            break
          endif
        endfor
      endif
    endif
    assign inspector_leg_name_normalized = inspector_leg_name | strip | downcase
    if inspector_leg_name_normalized == 'unknown' or inspector_leg_name_normalized == 'unknown location' or inspector_leg_name_normalized == 'not provided'
      assign inspector_leg_name = ''
    endif
    assign inspector_leg_nights = leg.nights.value | default: leg.nights | default: 0 | plus: 0
    if inspector_leg_name == blank or inspector_leg_type == 'Departure'
      continue
    endif

    capture inspector_leg_label
      echo inspector_leg_name
      if inspector_leg_nights > 0
        echo ' ('

        capture inspector_leg_nights_text
          if inspector_leg_nights == 1
            echo 'sections.itinerary_chronological.nights' | t: count: inspector_leg_nights, suffix: ''
          else
            echo 'sections.itinerary_chronological.nights' | t: count: inspector_leg_nights, suffix: 's'
          endif
        endcapture
        assign inspector_leg_nights_text = inspector_leg_nights_text | strip

        if inspector_leg_nights_text == blank or inspector_leg_nights_text contains 'Translation missing:'
          if inspector_leg_nights == 1
            echo '1 night'
          else
            echo inspector_leg_nights
            echo ' nights'
          endif
        else
          echo inspector_leg_nights_text
        endif

        echo ')'
      endif
    endcapture
    assign inspector_leg_label = inspector_leg_label | strip

    assign inspector_leg_key = inspector_leg_label | handleize
    if inspector_leg_key == blank
      assign inspector_leg_key = 'stay-' | append: forloop.index0
    endif
    assign inspector_leg_token = '|' | append: inspector_leg_key | append: '|'
    if inspector_inclusion_seen contains inspector_leg_token
      continue
    endif

    if inspector_inclusion_rows == ''
      assign inspector_inclusion_rows = inspector_leg_label
    else
      assign inspector_inclusion_rows = inspector_inclusion_rows | append: '||WETU_INCLUSION||' | append: inspector_leg_label
    endif
    assign inspector_inclusion_seen = inspector_inclusion_seen | append: inspector_leg_key | append: '|'
    assign inspector_inclusion_count = inspector_inclusion_count | plus: 1
  endfor

  for leg in inspector_legs
    if inspector_inclusion_count >= inspector_inclusion_limit
      break
    endif

    assign inspector_periods = leg.periods.value | default: leg.periods
    if inspector_periods == blank or inspector_periods.size == 0
      continue
    endif

    for period in inspector_periods
      if inspector_inclusion_count >= inspector_inclusion_limit
        break
      endif

      assign inspector_period_activities = period.activities.value | default: period.activities
      if inspector_period_activities == blank or inspector_period_activities.size == 0
        continue
      endif

      for activity in inspector_period_activities
        if inspector_inclusion_count >= inspector_inclusion_limit
          break
        endif

        assign activity_name = activity.name.value | default: activity.name | default: ''
        if activity_name == blank
          continue
        endif

        assign inspector_activity_key = activity_name | handleize
        if inspector_activity_key == blank
          assign inspector_activity_key = 'activity-' | append: forloop.index0
        endif
        assign inspector_activity_token = '|' | append: inspector_activity_key | append: '|'
        if inspector_inclusion_seen contains inspector_activity_token
          continue
        endif

        if inspector_inclusion_rows == ''
          assign inspector_inclusion_rows = activity_name
        else
          assign inspector_inclusion_rows = inspector_inclusion_rows | append: '||WETU_INCLUSION||' | append: activity_name
        endif
        assign inspector_inclusion_seen = inspector_inclusion_seen | append: inspector_activity_key | append: '|'
        assign inspector_inclusion_count = inspector_inclusion_count | plus: 1
      endfor
    endfor
  endfor

  assign inspector_inclusion_items = inspector_inclusion_rows | split: '||WETU_INCLUSION||'
-%}

<div
  class="itin-chrono color-{{ section.settings.color_scheme }}"
  id="itinerary-days"
  data-pin-map="{{ wetu_pin_to_product_map | escape }}"
  data-link-manifest="{{ link_manifest_raw | escape }}"
  data-itinerary-json-cdn-url="{{ itinerary_json_cdn_url | escape }}"
  data-itinerary-source-json-cdn-url="{{ itinerary_source_json_cdn_url | escape }}"
  data-chronology-source="{{ chronology_source }}"
>
  <div class="itin-chrono__hero">
    {% if hero_video != blank %}
      {%- liquid
        assign is_youtube = false
        assign is_vimeo = false
        if hero_video contains 'youtube.com' or hero_video contains 'youtu.be'
          assign is_youtube = true
        elsif hero_video contains 'vimeo.com'
          assign is_vimeo = true
        endif
      -%}
      {% if is_youtube %}
        {%- liquid
          assign yt_id = ''
          if hero_video contains 'youtu.be/'
            assign yt_parts = hero_video | split: 'youtu.be/'
            assign yt_id = yt_parts[1] | split: '?' | first | split: '&' | first
          elsif hero_video contains 'v='
            assign yt_parts = hero_video | split: 'v='
            assign yt_id = yt_parts[1] | split: '&' | first
          elsif hero_video contains '/embed/'
            assign yt_parts = hero_video | split: '/embed/'
            assign yt_id = yt_parts[1] | split: '?' | first | split: '&' | first
          endif
        -%}
        {% if yt_id != blank %}
          <iframe
            src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_id }}&controls=0&showinfo=0&rel=0&iv_load_policy=3&modestbranding=1&playsinline=1"
            allow="autoplay; encrypted-media"
            allowfullscreen
            loading="lazy"
            title="{{ product.title | escape }}"
          ></iframe>
        {% endif %}
      {% elsif is_vimeo %}
        {%- liquid
          assign vimeo_parts = hero_video | split: 'vimeo.com/'
          assign vimeo_id = vimeo_parts[1] | split: '?' | first | split: '/' | first
        -%}
        {% if vimeo_id != blank %}
          <iframe
            src="https://player.vimeo.com/video/{{ vimeo_id }}?background=1&autoplay=1&loop=1&muted=1"
            allow="autoplay"
            allowfullscreen
            loading="lazy"
            title="{{ product.title | escape }}"
          ></iframe>
        {% endif %}
      {% else %}
        <video autoplay muted loop playsinline>
          <source src="{{ hero_video }}" type="video/mp4">
        </video>
      {% endif %}
    {% elsif product.featured_image %}
      {{ product.featured_image | image_url: width: 2400 | image_tag:
        loading: 'eager',
        alt: product.title,
        sizes: '100vw',
        widths: '1200,1800,2400',
        class: 'itin-chrono__hero-img'
      }}
    {% endif %}
    <div class="itin-chrono__hero-overlay"></div>
    <div class="itin-chrono__hero-text">
      <div class="itin-chrono__hero-eyebrow">
        {{ product.vendor | default: 'Private Journey' }}
        {%- if start_date != blank %} · {{ start_date | date: '%Y' }}{% endif -%}
      </div>
      <h1 class="itin-chrono__hero-title">{{ product.title }}</h1>
      <div class="itin-chrono__hero-subtitle">{{ total_days }} {{ 'sections.itinerary_chronological.day_label_plural' | t | default: 'Days' }} · {{ wetu_total_nights }} {{ 'sections.itinerary_chronological.nights_label_plural' | t | default: 'Nights' }}</div>
    </div>
  </div>

  <div class="itin-chrono__layout">
    <aside class="itin-chrono__rail" aria-label="Itinerary timeline">
      <div class="itin-chrono__rail-inner">
        <div class="itin-chrono__rail-label">Itinerary</div>
        <nav class="itin-chrono__rail-nav" role="navigation" aria-label="Day navigation">
          {%- liquid
            assign rail_running_day = 1
            assign prev_leg_index = -1
          -%}
          {% for day_num in (1..total_days) %}
            {%- liquid
              assign day_offset = day_num | minus: 1
              if start_date != blank
                assign day_seconds = day_offset | times: 86400
                assign start_seconds = start_date | date: '%s'
                assign day_date = start_seconds | plus: day_seconds
                assign day_weekday = day_date | date: '%a'
                assign day_short = day_date | date: '%b %d'
              else
                assign day_weekday = ''
                assign day_short = ''
              endif

              assign rail_current_leg = nil
              assign rail_leg_index = -1
              assign rail_dest_name = ''
              assign test_running = 1
              for leg in wetu_legs
                assign leg_nights = leg.nights.value | default: leg.nights | default: 0 | plus: 0
                assign leg_start = test_running
                if leg_nights > 0
                  assign leg_end = test_running | plus: leg_nights | minus: 1
                else
                  assign leg_end = test_running
                endif
                if day_num >= leg_start and day_num <= leg_end
                  assign rail_current_leg = leg
                  assign rail_leg_index = forloop.index0
                  assign rail_dest_name = leg.destination_name.value | default: leg.destination_name | default: leg.accommodation_name.value | default: leg.accommodation_name | default: ''
                  break
                endif
                assign test_running = test_running | plus: leg_nights
              endfor
            -%}

            {% if rail_leg_index != prev_leg_index and rail_current_leg %}
              {% if prev_leg_index >= 0 %}
                  </div>
                </div>
              {% endif %}
              <div class="itin-chrono__leg-group">
                <button class="itin-chrono__leg-header" type="button" aria-expanded="true" data-leg-toggle="leg-{{ rail_leg_index }}">
                  <span class="itin-chrono__leg-title">{{ rail_dest_name }}</span>
                  <span class="itin-chrono__leg-line" aria-hidden="true"></span>
                </button>
                <div class="itin-chrono__leg-days" id="leg-{{ rail_leg_index }}">
              {%- assign prev_leg_index = rail_leg_index -%}
            {% endif %}

            <a href="#day-{{ day_num }}" class="itin-chrono__rail-link" data-rail-day="{{ day_num }}">
              <span class="itin-chrono__rail-day">{{ 'sections.itinerary_chronological.day_label' | t: day: day_num }}{% if day_weekday != blank %} · {{ day_weekday }} {{ day_short }}{% endif %}</span>
              <span class="itin-chrono__rail-dest">{{ rail_dest_name }}</span>
            </a>
          {% endfor %}

          {% if prev_leg_index >= 0 %}
              </div>
            </div>
          {% endif %}
        </nav>
      </div>
    </aside>

    <div class="itin-chrono__content">
      {% for day_num in (1..total_days) %}
        {%- liquid
          assign current_leg = nil
          assign leg_total_nights = 0
          assign day_within_leg = 0
          assign running_day = 1

          for leg in wetu_legs
            assign leg_type = leg.type.value | default: leg.type | default: 'Standard'
            assign leg_nights = leg.nights.value | default: leg.nights | default: 0 | plus: 0

            assign this_leg_start = running_day
            if leg_nights > 0
              assign this_leg_end = running_day | plus: leg_nights | minus: 1
            else
              assign this_leg_end = running_day
            endif

            if day_num >= this_leg_start and day_num <= this_leg_end
              assign current_leg = leg
              assign leg_total_nights = leg_nights
              assign day_within_leg = day_num | minus: this_leg_start | plus: 1
              break
            endif

            assign running_day = running_day | plus: leg_nights
          endfor
        -%}

        {% unless current_leg %}{% continue %}{% endunless %}

        {%- liquid
          assign leg_type = current_leg.type.value | default: current_leg.type | default: 'Standard'
          assign acc_pin_id = current_leg.content_entity_id.value | default: current_leg.content_entity_id
          assign acc_name = current_leg.accommodation_name.value | default: current_leg.accommodation_name
          assign dest_pin_id = current_leg.destination_content_entity_id.value | default: current_leg.destination_content_entity_id

          assign is_arrival_day = false
          assign is_departure_day = false
          if day_within_leg == 1
            assign is_arrival_day = true
          endif
          if leg_type == 'Departure' or day_num == total_days
            assign is_departure_day = true
          endif

          assign day_offset = day_num | minus: 1
          if start_date != blank
            assign day_seconds = day_offset | times: 86400
            assign start_seconds = start_date | date: '%s'
            assign day_date = start_seconds | plus: day_seconds
            assign day_date_display = day_date | date: '%A, %B %e, %Y'
          else
            assign day_date_display = ''
          endif

          assign acc_product = nil
          if acc_pin_id != blank
            assign search_pin = acc_pin_id | append: ''
            for check_pin in wetu_pin_ids_array
              assign current_pin = check_pin | append: ''
              if current_pin == search_pin
                assign acc_handle = wetu_handles_array[forloop.index0]
                assign acc_product = all_products[acc_handle]
                break
              endif
            endfor
          endif

          assign dest_product = nil
          assign dest_name = ''
          if dest_pin_id != blank
            assign search_dest = dest_pin_id | append: ''
            for check_pin in wetu_pin_ids_array
              assign current_pin = check_pin | append: ''
              if current_pin == search_dest
                assign dest_handle = wetu_handles_array[forloop.index0]
                assign dest_product = all_products[dest_handle]
                assign dest_name = dest_product.title
                break
              endif
            endfor
          endif

          if dest_name == ''
            assign leg_destination_name = current_leg.destination_name.value | default: current_leg.destination_name | default: ''
            if leg_destination_name != ''
              assign dest_name = leg_destination_name
            elsif acc_product
              assign acc_position = acc_product.metafields.wetu.position.value
              if acc_position
                assign dest_name = acc_position.area | default: acc_position.destination | default: acc_position.region | default: acc_position.country | default: ''
              endif
            endif
          endif

          if dest_pin_id != blank
            assign dest_check = '|' | append: dest_pin_id | append: '|'
            unless seen_destinations contains dest_check
              assign seen_destinations = seen_destinations | append: dest_pin_id | append: '|'
            endunless
          endif

          if acc_pin_id != blank
            assign acc_check = '|' | append: acc_pin_id | append: '|'
            unless seen_accommodations contains acc_check
              assign seen_accommodations = seen_accommodations | append: acc_pin_id | append: '|'
            endunless
          endif

          assign day_routes = ''
          for route in wetu_routes
            assign include_route = true
            if is_day_tour_timeline
              assign route_type = route.type.value | default: route.type | default: ''
              assign route_type_normalized = route_type | downcase
              if route_type_normalized != '' and route_type_normalized != 'daytour' and route_type_normalized != 'day tour'
                assign include_route = false
              endif
            endif
            assign route_start = route.start_day.value | default: route.start_day | default: 0 | plus: 0
            assign route_end = route.end_day.value | default: route.end_day | default: route_start | plus: 0
            if include_route and route_start == day_num or include_route and route_end == day_num
              assign day_routes = day_routes | append: forloop.index0 | append: '|'
            endif
          endfor
          assign routes_array = day_routes | split: '|'
          assign route_count = 0
          for route_index in routes_array
            if route_index != blank
              assign route_count = route_count | plus: 1
            endif
          endfor

          assign day_period = nil
          assign periods = current_leg.periods.value | default: current_leg.periods
          if periods and periods.size > 0
            assign period_index = day_within_leg | minus: 1
            if period_index < periods.size
              assign day_period = periods[period_index]
            elsif periods.size == 1
              assign day_period = periods[0]
            endif
          endif

          assign day_narrative = ''
          assign day_notes = ''
          assign day_consultant = ''
          assign has_plekify_blocks = false
          assign has_plekify_markers = false
          assign check_in_time = current_leg.check_in_time.value | default: current_leg.check_in_time | default: ''
          assign check_out_time = current_leg.check_out_time.value | default: current_leg.check_out_time | default: ''
          assign day_activities = nil
          assign day_commentary_items = nil
          assign day_included = ''
          if day_period
            assign day_narrative = day_period.day_narrative.value | default: day_period.day_narrative | default: ''
            if day_narrative == ''
              assign day_narrative = day_period.consultant_notes.value | default: day_period.consultant_notes | default: ''
            endif
            assign day_notes = day_period.notes.value | default: day_period.notes | default: ''
            assign day_consultant = day_period.consultant_notes.value | default: day_period.consultant_notes | default: ''
            assign day_activities_raw = day_period.activities.value | default: day_period.activities
            assign day_activities = day_activities_raw
            assign day_commentary_items_raw = day_period.commentary_items.value | default: day_period.commentary_items
            assign day_commentary_items = day_commentary_items_raw
            assign day_included = day_period.included.value | default: day_period.included | default: ''
          endif

          if day_consultant contains 'data-plekify-block="narrative"' or day_consultant contains 'data-plekify-block="timeline"' or day_consultant contains 'data-plekify-list="timeline"'
            assign has_plekify_blocks = true
          endif

          if day_consultant contains '[[BLOCK:' or day_consultant contains '[[COMMENTARY]]' or day_consultant contains '[[/BLOCK]]'
            assign has_plekify_markers = true
          endif

          if day_narrative == '' and day_consultant != '' and has_plekify_blocks == false and has_plekify_markers == false
            assign day_narrative = day_consultant
            assign day_consultant = ''
          endif

          assign insert_blocks = nil
          if day_period and day_period.insert_blocks
            assign insert_blocks_raw = day_period.insert_blocks.value | default: day_period.insert_blocks
            if insert_blocks_raw != blank
              assign insert_blocks = insert_blocks_raw
            endif
          endif

          assign timeline_rows = ''
          assign timeline_delimiter = '||WETU_EVT||'
          assign timeline_entry_count = 0
          assign activity_order_rows = ''
          assign activity_order_delimiter = '||WETU_ACTIVITY||'
          assign commentary_rows = ''
          assign commentary_delimiter = '||WETU_COMMENTARY||'

          if has_plekify_blocks == false and has_plekify_markers == false
            if is_arrival_day and check_in_time != blank and check_in_time != 'None' and check_in_time != 'NotProvided'
              assign check_in_parts = check_in_time | split: ':'
              assign check_in_hour = check_in_parts[0] | plus: 0
              assign check_in_minute = check_in_parts[1] | plus: 0
              assign check_in_minutes = check_in_hour | times: 60 | plus: check_in_minute
              capture check_in_sort_key
                if check_in_minutes < 10
                  echo '000'
                elsif check_in_minutes < 100
                  echo '00'
                elsif check_in_minutes < 1000
                  echo '0'
                endif
                echo check_in_minutes
              endcapture
              capture check_in_row
                echo check_in_sort_key | strip
                echo '-10'
                echo '~~check_in~~'
                echo check_in_time
              endcapture
              if timeline_rows == ''
                assign timeline_rows = check_in_row
              else
                assign timeline_rows = timeline_rows | append: timeline_delimiter | append: check_in_row
              endif
              assign timeline_entry_count = timeline_entry_count | plus: 1
            endif

            for route_index in routes_array
              if route_index != blank
                assign route = wetu_routes[route_index]
                assign route_time = route.start_time.value | default: route.start_time | default: ''
                assign route_sort_key = '9999'
                if route_time != blank and route_time != 'None' and route_time != 'NotProvided' and route_time contains ':'
                  assign route_time_parts = route_time | split: ':'
                  assign route_hour = route_time_parts[0] | plus: 0
                  assign route_minute = route_time_parts[1] | plus: 0
                  assign route_minutes = route_hour | times: 60 | plus: route_minute
                  capture route_sort_key
                    if route_minutes < 10
                      echo '000'
                    elsif route_minutes < 100
                      echo '00'
                    elsif route_minutes < 1000
                      echo '0'
                    endif
                    echo route_minutes
                  endcapture
                endif
                capture route_row
                  echo route_sort_key | strip
                  echo '-20'
                  echo '~~route~~'
                  echo route_index
                endcapture
                if timeline_rows == ''
                  assign timeline_rows = route_row
                else
                  assign timeline_rows = timeline_rows | append: timeline_delimiter | append: route_row
                endif
                assign timeline_entry_count = timeline_entry_count | plus: 1
              endif
            endfor

            if day_activities and day_activities.size > 0
              for activity in day_activities
                assign activity_time = activity.start_time.value | default: activity.start_time | default: ''
                if activity_time == blank or activity_time == 'None' or activity_time == 'NotProvided'
                  assign activity_time = activity.end_time.value | default: activity.end_time | default: ''
                endif
                assign activity_sort_key = '9999'
                if activity_time != blank and activity_time != 'None' and activity_time != 'NotProvided' and activity_time contains ':'
                  assign activity_time_parts = activity_time | split: ':'
                  assign activity_hour = activity_time_parts[0] | plus: 0
                  assign activity_minute = activity_time_parts[1] | plus: 0
                  assign activity_minutes = activity_hour | times: 60 | plus: activity_minute
                  capture activity_sort_key
                    if activity_minutes < 10
                      echo '000'
                    elsif activity_minutes < 100
                      echo '00'
                    elsif activity_minutes < 1000
                      echo '0'
                    endif
                    echo activity_minutes
                  endcapture
                endif
                capture activity_row
                  echo activity_sort_key | strip
                  echo '-30'
                  echo '~~activity~~'
                  echo forloop.index0
                endcapture
                if timeline_rows == ''
                  assign timeline_rows = activity_row
                else
                  assign timeline_rows = timeline_rows | append: timeline_delimiter | append: activity_row
                endif

                capture activity_order_row
                  echo activity_sort_key | strip
                  echo '~~'
                  echo forloop.index0
                endcapture
                if activity_order_rows == ''
                  assign activity_order_rows = activity_order_row
                else
                  assign activity_order_rows = activity_order_rows | append: activity_order_delimiter | append: activity_order_row
                endif

                assign timeline_entry_count = timeline_entry_count | plus: 1
              endfor
            endif

            if day_commentary_items and day_commentary_items.size > 0
              for commentary_item in day_commentary_items
                assign commentary_time = commentary_item.time.value | default: commentary_item.time | default: ''
                assign commentary_sort_key = '9999'
                if commentary_time != blank and commentary_time != 'None' and commentary_time != 'NotProvided' and commentary_time contains ':'
                  assign commentary_time_parts = commentary_time | split: ':'
                  assign commentary_hour = commentary_time_parts[0] | plus: 0
                  assign commentary_minute = commentary_time_parts[1] | plus: 0
                  assign commentary_minutes = commentary_hour | times: 60 | plus: commentary_minute
                  capture commentary_sort_key
                    if commentary_minutes < 10
                      echo '000'
                    elsif commentary_minutes < 100
                      echo '00'
                    elsif commentary_minutes < 1000
                      echo '0'
                    endif
                    echo commentary_minutes
                  endcapture
                endif
                capture commentary_row
                  echo commentary_sort_key | strip
                  echo '~~'
                  echo forloop.index0
                endcapture
                if commentary_rows == ''
                  assign commentary_rows = commentary_row
                else
                  assign commentary_rows = commentary_rows | append: commentary_delimiter | append: commentary_row
                endif
              endfor
            endif

            if is_departure_day and check_out_time != blank and check_out_time != 'None' and check_out_time != 'NotProvided'
              assign check_out_parts = check_out_time | split: ':'
              assign check_out_hour = check_out_parts[0] | plus: 0
              assign check_out_minute = check_out_parts[1] | plus: 0
              assign check_out_minutes = check_out_hour | times: 60 | plus: check_out_minute
              capture check_out_sort_key
                if check_out_minutes < 10
                  echo '000'
                elsif check_out_minutes < 100
                  echo '00'
                elsif check_out_minutes < 1000
                  echo '0'
                endif
                echo check_out_minutes
              endcapture
              capture check_out_row
                echo check_out_sort_key | strip
                echo '-40'
                echo '~~check_out~~'
                echo check_out_time
              endcapture
              if timeline_rows == ''
                assign timeline_rows = check_out_row
              else
                assign timeline_rows = timeline_rows | append: timeline_delimiter | append: check_out_row
              endif
              assign timeline_entry_count = timeline_entry_count | plus: 1
            endif
          endif

          assign timeline_rows_array = timeline_rows | split: timeline_delimiter | sort
          assign activity_order_array = activity_order_rows | split: activity_order_delimiter | sort
          assign commentary_rows_array = commentary_rows | split: commentary_delimiter | sort

          assign day_summary = ''
          if current_leg.day_summary
            assign day_summary = current_leg.day_summary.value | default: current_leg.day_summary | default: ''
          endif

          assign night_suffix = ''
          if leg_total_nights != 1
            assign night_suffix = 's'
          endif
        -%}

        <article class="itin-chrono__day" id="day-{{ day_num }}" data-day-section="{{ day_num }}">
          <header class="itin-chrono__day-header">
            <div class="itin-chrono__day-ghost" aria-hidden="true">{{ day_num }}</div>
            {% if day_date_display != blank %}
              <span class="itin-chrono__day-meta">{{ 'sections.itinerary_chronological.day_label' | t: day: day_num }} · {{ day_date_display }}</span>
            {% endif %}
            <h2 class="itin-chrono__day-title">
              {% if dest_name != blank %}{{ dest_name }}{% else %}{{ 'sections.itinerary_chronological.day_label' | t: day: day_num }}{% endif %}
            </h2>
            {% if acc_name != blank and acc_name != dest_name %}
              <div class="itin-chrono__day-subtitle">{{ acc_name }}{% if leg_total_nights > 0 %} · {{ leg_total_nights }} night{{ night_suffix }}{% endif %}</div>
            {% endif %}
            <div class="itin-chrono__day-rule" aria-hidden="true"></div>
          </header>

          {% if day_summary != blank and is_arrival_day %}
            <div class="itin-chrono__summary" data-pin-links>
              {% render 'wetu-pin-link', content: day_summary, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
            </div>
          {% endif %}

          {% if has_plekify_blocks == false and has_plekify_markers == false %}
              {% if timeline_entry_count > 0 %}
                <section class="itin-chrono__timeline" data-pin-links>
                  {% if route_count > 0 %}
                      <p class="itin-chrono__transition-note">Inter-leg transition · {{ route_count }} segment{% if route_count != 1 %}s{% endif %}</p>
                    {% endif %}
                    <ul class="itin-chrono__timeline-list" role="list">
                    {% for timeline_row in timeline_rows_array %}
                      {% if timeline_row == blank %}{% continue %}{% endif %}
                      {%- liquid
                        assign row_parts = timeline_row | split: '~~'
                        assign row_type = row_parts[1]
                        assign row_value = row_parts[2]
                      -%}
                      {% if row_type == 'check_in' %}
                        <li class="itin-chrono__timeline-item itin-chrono__timeline-item--context">
                          <span class="itin-chrono__timeline-time">{{ row_value }}</span>
                          <span class="itin-chrono__timeline-text">Check-in{% if acc_name != blank %}: {{ acc_name }}{% endif %}</span>
                        </li>
                      {% elsif row_type == 'check_out' %}
                        <li class="itin-chrono__timeline-item itin-chrono__timeline-item--context">
                          <span class="itin-chrono__timeline-time">{{ row_value }}</span>
                          <span class="itin-chrono__timeline-text">Check-out{% if acc_name != blank %}: {{ acc_name }}{% endif %}</span>
                        </li>
                      {% elsif row_type == 'route' %}
                        {%- liquid
                          assign route_index = row_value | plus: 0
                          assign route = wetu_routes[route_index]
                          assign route_start_pin = route.start_content_entity_id.value | default: route.start_content_entity_id
                          assign route_end_pin = route.end_content_entity_id.value | default: route.end_content_entity_id
                          assign route_start_name = route.start_location.value | default: route.start_location
                          assign route_end_name = route.end_location.value | default: route.end_location
                          assign route_start_link = ''
                          assign route_end_link = ''
                          assign route_start_handle = ''
                            assign route_end_handle = ''
                            if route_start_pin != blank
                              assign route_start_pin_key = route_start_pin | append: ''
                              for check_pin in wetu_pin_ids_array
                                assign check_pin_key = check_pin | append: ''
                                if check_pin_key == route_start_pin_key
                                  assign route_start_handle = wetu_handles_array[forloop.index0]
                                  assign route_start_product = all_products[route_start_handle]
                                  assign route_start_name = route_start_product.title | default: route_start_name
                                  break
                            endif
                            endfor
                              if route_start_name == ''
                                assign route_start_name = 'Location PIN ' | append: route_start_pin
                            endif
                              if route_start_handle != ''
                                assign route_start_link = '{{PIN:' | append: route_start_pin | append: '|' | append: route_start_name | append: '}}'
                              endif
                            endif
                            if route_end_pin != blank
                              assign route_end_pin_key = route_end_pin | append: ''
                            for check_pin in wetu_pin_ids_array
                                assign check_pin_key = check_pin | append: ''
                              if check_pin_key == route_end_pin_key
                                  assign route_end_handle = wetu_handles_array[forloop.index0]
                                  assign route_end_product = all_products[route_end_handle]
                                  assign route_end_name = route_end_product.title | default: route_end_name
                                  break
                                endif
                              endfor
                              if route_end_name == ''
                                assign route_end_name = 'Location PIN ' | append: route_end_pin
                            endif
                              if route_end_handle != ''
                                assign route_end_link = '{{PIN:' | append: route_end_pin | append: '|' | append: route_end_name | append: '}}'
                            endif
                            endif
                            assign route_time = route.start_time.value | default: route.start_time | default: ''
                            assign route_mode = route.mode.value | default: route.mode | default: 'Transfer'
                          assign route_type_label = route.label.value | default: route.label | default: ''
                            assign route_mode_display = route_mode
                            case route_mode
                              when 'ScheduledFlight'
                                assign route_mode_display = 'Scheduled flight'
                              when 'CharterFlight'
                                assign route_mode_display = 'Charter flight'
                              when 'Transfer'
                                if route_type_label == 'Private'
                                  assign route_mode_display = 'Private transfer'
                                else
                                  assign route_mode_display = 'Transfer'
                                endif
                              when 'Rail', 'Train'
                                assign route_mode_display = 'Rail transfer'
                              when 'Selfdrive'
                                assign route_mode_display = 'Self-drive'
                              when 'Boat'
                                assign route_mode_display = 'Boat transfer'
                            endcase
                          -%}
                          <li class="itin-chrono__timeline-item">
                            {% if route_time != blank and route_time != 'None' and route_time != 'NotProvided' %}
                              <span class="itin-chrono__timeline-time">{{ route_time }}</span>
                            {% endif %}
                            <span class="itin-chrono__timeline-text">
                              <span class="itin-chrono__timeline-chip">{{ route_mode_display }}</span>
                              <span class="itin-chrono__timeline-route">
                                {% if route_start_link != blank %}
                                  {% render 'wetu-pin-link', content: route_start_link, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
                                {% elsif route_start_name != blank %}
                                  {{ route_start_name }}
                                {% else %}
                                  Origin pending
                                {% endif %}
                                {% if route_start_name != blank or route_start_link != blank or route_end_name != blank or route_end_link != blank %} → {% endif %}
                                {% if route_end_link != blank %}
                                  {% render 'wetu-pin-link', content: route_end_link, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
                                {% elsif route_end_name != blank %}
                                  {{ route_end_name }}
                                {% else %}
                                  Destination pending
                                {% endif %}
                              </span>
                            </span>
                          </li>
                      {% elsif row_type == 'activity' %}
                        {%- liquid
                          assign activity_index = row_value | plus: 0
                          assign activity = day_activities[activity_index]
                          assign activity_pin = activity.content_entity_id.value | default: activity.content_entity_id
                          assign activity_name = activity.name.value | default: activity.name
                          assign activity_link = activity_name
                          if activity_pin != blank
                            if activity_name == blank
                              assign activity_name = 'Location PIN ' | append: activity_pin
                            endif
                            assign activity_link = '{{PIN:' | append: activity_pin | append: '|' | append: activity_name | append: '}}'
                          endif
                        -%}
                        <li class="itin-chrono__timeline-item">
                          {% assign activity_time = activity.start_time.value | default: activity.start_time %}
                          {% if activity_time != blank and activity_time != 'None' and activity_time != 'NotProvided' %}
                            <span class="itin-chrono__timeline-time">{{ activity_time }}</span>
                          {% endif %}
                          <span class="itin-chrono__timeline-text">{% render 'wetu-pin-link', content: activity_link, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}</span>
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                </section>
              {% endif %}
          {% endif %}

          {% if day_commentary_items and day_commentary_items.size > 0 and has_plekify_blocks == false and has_plekify_markers == false %}
            <section class="itin-chrono__commentary-stream" data-pin-links>
              <h3 class="itin-chrono__section-title">Snoop live wire</h3>
              <ul class="itin-chrono__commentary-list" role="list">
                {% for commentary_row in commentary_rows_array %}
                  {% if commentary_row == blank %}{% continue %}{% endif %}
                  {%- liquid
                    assign commentary_parts = commentary_row | split: '~~'
                    assign commentary_index = commentary_parts[1] | plus: 0
                    assign commentary_item = day_commentary_items[commentary_index]
                    assign commentary_time = commentary_item.time.value | default: commentary_item.time | default: ''
                    assign commentary_content = commentary_item.content.value | default: commentary_item.content | default: ''
                  -%}
                  {% if commentary_content == blank %}{% continue %}{% endif %}
                  <li class="itin-chrono__commentary-item">
                    {% if commentary_time != blank and commentary_time != 'None' and commentary_time != 'NotProvided' %}
                      <span class="itin-chrono__commentary-time">{{ commentary_time }}</span>
                    {% endif %}
                    <div class="itin-chrono__commentary-body">
                      {% render 'wetu-pin-link', content: commentary_content, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
                    </div>
                  </li>
                {% endfor %}
              </ul>
            </section>
          {% endif %}

          {% if has_plekify_markers == true %}
            {%- liquid
              assign block_tokens = day_consultant | split: '[[BLOCK:'
              assign rendered_blocks = ''
              if block_tokens.size > 1
                for block_part in block_tokens
                  if forloop.first
                    continue
                  endif
                  assign block_segments = block_part | split: ']]'
                  assign block_label = block_segments[0] | strip
                  assign block_body = block_part | split: ']]' | last | split: '[[/BLOCK]]' | first
                  assign block_type = block_label | split: ':' | first | downcase
                  assign block_day = ''
                  if block_label contains ':DAY:'
                    assign block_day = block_label | split: ':DAY:' | last
                  endif
                  assign block_body = block_body | replace: '[[COMMENTARY]]', '<div class="itin-chrono__commentary">' | append: '</div>'
                  if block_type == 'narrative'
                    assign rendered_blocks = rendered_blocks | append: '<div class="itin-chrono__narrative" data-day="' | append: block_day | append: '">' | append: block_body | append: '</div>'
                  elsif block_type == 'timeline'
                    assign rendered_blocks = rendered_blocks | append: '<div class="itin-chrono__timeline" data-day="' | append: block_day | append: '">' | append: block_body | append: '</div>'
                  elsif block_type == 'consultant'
                    assign rendered_blocks = rendered_blocks | append: '<div class="itin-chrono__consultant" data-day="' | append: block_day | append: '">' | append: block_body | append: '</div>'
                  else
                    assign rendered_blocks = rendered_blocks | append: '<div class="itin-chrono__block" data-day="' | append: block_day | append: '">' | append: block_body | append: '</div>'
                  endif
                endfor
              endif
            -%}
            <section class="itin-chrono__rich" data-pin-links>
              {{ rendered_blocks }}
            </section>
          {% endif %}

          {% if day_notes != blank and has_plekify_blocks == false and has_plekify_markers == false %}
            <div class="itin-chrono__morning-verse" data-pin-links>
              <div class="itin-chrono__morning-verse-label">Setting the Tone</div>
              <div class="itin-chrono__morning-verse-text">
                {% render 'wetu-pin-link', content: day_notes, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
              </div>
            </div>
          {% endif %}

          {% if day_narrative != blank and has_plekify_blocks == false %}
            <div class="itin-chrono__narrative" data-pin-links>
              {% render 'wetu-pin-link', content: day_narrative, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
            </div>
          {% endif %}

          {% if has_plekify_blocks and day_consultant != blank %}
            <div class="itin-chrono__embedded" data-pin-links>
              {% render 'wetu-pin-link', content: day_consultant, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
            </div>
          {% endif %}

          {% if insert_blocks and insert_blocks.size > 0 %}
            <div class="itin-chrono__inserts">
              {% for block in insert_blocks %}
                {%- liquid
                  assign block_type = block.type.value | default: block.type | downcase
                  assign block_title = block.title.value | default: block.title
                  assign block_content = block.content.value | default: block.content
                  assign block_links = nil
                  if block.links
                    assign block_links = block.links.value
                  endif
                -%}
                {% if block_type == 'narrative' %}
                  <section class="itin-chrono__insert">
                    {% if block_title != blank %}
                      <h3 class="itin-chrono__insert-title">{{ block_title }}</h3>
                    {% endif %}
                    <div class="itin-chrono__insert-content" data-pin-links>
                      {% render 'wetu-pin-link', content: block_content, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
                    </div>
                  </section>
                {% elsif block_type == 'link_list' and block_links and block_links.size > 0 %}
                  <details class="itin-chrono__insert itin-chrono__insert--links">
                    <summary class="itin-chrono__insert-title">{{ block_title | default: 'Related links' }}</summary>
                      <ul class="itin-chrono__link-list" role="list">
                        {% assign seen_link_keys = '|' %}
                        {% for link_item in block_links %}
                          {%- liquid
                            assign link_label = link_item.label.value | default: link_item.label
                          assign link_pin = link_item.pin_id.value | default: link_item.pin_id
                          assign link_pin_key = link_pin | append: ''
                          assign link_key = link_pin_key
                          if link_key == ''
                            assign link_key = link_label | strip | downcase
                            endif
                            assign link_token = '|' | append: link_key | append: '|'
                            if seen_link_keys contains link_token
                              continue
                            endif
                          assign seen_link_keys = seen_link_keys | append: link_key | append: '|'

                          assign link_handle = ''
                            if link_pin != blank
                              for check_pin in wetu_pin_ids_array
                                assign check_pin_key = check_pin | append: ''
                                if check_pin_key == link_pin_key
                                  assign link_handle = wetu_handles_array[forloop.index0]
                                break
                              endif
                            endfor
                          endif

                            if link_label == blank and link_handle != ''
                            assign link_label = all_products[link_handle].title
                            endif

                            assign link_url = ''
                            if link_handle != ''
                            assign link_url = all_products[link_handle].url
                          elsif link_pin != blank
                              assign link_url = '/pages/wetu-property-' | append: link_pin
                            endif
                          -%}
                          {% if link_label != blank and link_url != blank %}
                          <li class="itin-chrono__link-item">
                              <a href="{{ link_url }}">{{ link_label }}</a>
                            </li>
                          {% endif %}
                        {% endfor %}
                      </ul>
                    </details>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}

            {% if route_count > 0 and is_arrival_day %}
              {% for route_index in routes_array %}
                {% if route_index == blank %}{% continue %}{% endif %}
                {%- liquid
                  assign route = wetu_routes[route_index]
                  assign route_start_pin = route.start_content_entity_id.value | default: route.start_content_entity_id
                  assign route_end_pin = route.end_content_entity_id.value | default: route.end_content_entity_id
                  assign route_preview_handle = ''

                  if route_end_pin != blank
                    assign route_end_pin_key = route_end_pin | append: ''
                    for check_pin in wetu_pin_ids_array
                      assign check_pin_key = check_pin | append: ''
                      if check_pin_key == route_end_pin_key
                        assign route_preview_handle = wetu_handles_array[forloop.index0]
                        break
                      endif
                    endfor
                  endif

                  if route_preview_handle == '' and route_start_pin != blank
                    assign route_start_pin_key = route_start_pin | append: ''
                    for check_pin in wetu_pin_ids_array
                      assign check_pin_key = check_pin | append: ''
                      if check_pin_key == route_start_pin_key
                        assign route_preview_handle = wetu_handles_array[forloop.index0]
                        break
                      endif
                    endfor
                  endif

                  assign route_preview_url = ''
                  if route_preview_handle != ''
                    assign route_preview_url = '/products/' | append: route_preview_handle
                  endif
                -%}
                {% render 'wetu-chronological-transfer-card', route: route, wetu_pin_ids_array: wetu_pin_ids_array, wetu_handles_array: wetu_handles_array, preview_url: route_preview_url %}
              {% endfor %}
          {% endif %}

          {% if acc_product != nil %}
            <section class="itin-chrono__accom">
              {%- liquid
                assign acc_title = acc_name | default: acc_product.title
                assign acc_body = acc_product.description | strip_html | strip | truncate: 200
              -%}
              <div class="itin-chrono__card" data-preview-url="/products/{{ acc_product.handle }}">
                <div class="itin-chrono__card-time">Your Stay · {{ leg_total_nights }} night{{ night_suffix }}</div>
                <div class="itin-chrono__card-title">{{ acc_title }}</div>
                {% if acc_body != blank %}
                  <div class="itin-chrono__card-body">{{ acc_body }}</div>
                {% endif %}
                <div class="itin-chrono__card-footer">
                  <span class="itin-chrono__card-tag">{{ leg_total_nights }} nights</span>
                  {% if dest_name != blank %}<span class="itin-chrono__card-tag">{{ dest_name }}</span>{% endif %}
                </div>
                <div class="itin-chrono__card-hint"><span>→</span> View property details</div>
              </div>
            </section>
          {% endif %}

          {% comment %} day_notes rendered as morning verse above {% endcomment %}

          {% if day_consultant != blank and has_plekify_blocks == false %}
            <details class="itin-chrono__notes" data-pin-links open>
              <summary>{{ 'sections.itinerary_chronological.consultant_notes' | t }}</summary>
              <div class="itin-chrono__notes-body">
                {% render 'wetu-pin-link', content: day_consultant, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
              </div>
            </details>
          {% endif %}

          {% if day_activities and day_activities.size > 0 %}
            <section class="itin-chrono__activities">
              <h3 class="itin-chrono__section-title">{{ 'sections.itinerary_chronological.todays_experiences' | t }}</h3>
              {%- liquid
                assign activity_indices = ''
              -%}
              {% if activity_order_rows != '' %}
                {% for activity_row in activity_order_array %}
                  {% if activity_row == blank %}{% continue %}{% endif %}
                  {%- liquid
                    assign activity_row_parts = activity_row | split: '~~'
                    assign ordered_activity_index = activity_row_parts[1] | default: ''
                  -%}
                  {% if ordered_activity_index == blank %}{% continue %}{% endif %}
                  {% if activity_indices == '' %}
                    {% assign activity_indices = ordered_activity_index %}
                  {% else %}
                    {% assign activity_indices = activity_indices | append: '|' | append: ordered_activity_index %}
                  {% endif %}
                {% endfor %}
              {% else %}
                {% for activity in day_activities %}
                  {% if activity_indices == '' %}
                    {% assign activity_indices = forloop.index0 %}
                  {% else %}
                    {% assign activity_indices = activity_indices | append: '|' | append: forloop.index0 %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              {% assign activity_indices_array = activity_indices | split: '|' %}
              <ul class="itin-chrono__activity-list" role="list">
                {% for activity_index in activity_indices_array %}
                  {% if activity_index == blank %}{% continue %}{% endif %}
                  {%- liquid
                    assign activity_index_number = activity_index | plus: 0
                    assign activity = day_activities[activity_index_number]

                    assign activity_time = activity.start_time.value | default: activity.start_time | default: ''
                    if activity_time == blank or activity_time == 'None' or activity_time == 'NotProvided'
                      assign activity_time = activity.end_time.value | default: activity.end_time | default: ''
                    endif

                    assign activity_name = activity.name.value | default: activity.name | default: ''
                    assign activity_type = activity.type.value | default: activity.type | default: 'Experience'
                    assign activity_description_raw = activity.description.value | default: activity.description | default: ''

                    assign activity_pin = activity.content_entity_id.value | default: activity.content_entity_id
                    assign activity_pin_key = activity_pin | append: ''
                    assign activity_handle = ''
                    if activity_pin != blank
                      for check_pin in wetu_pin_ids_array
                        assign check_pin_key = check_pin | append: ''
                        if check_pin_key == activity_pin_key
                          assign activity_handle = wetu_handles_array[forloop.index0]
                          break
                        endif
                      endfor
                    endif

                    assign activity_product = nil
                    if activity_handle != ''
                      assign activity_product = all_products[activity_handle]
                    endif

                    if activity_name == '' and activity_product
                      assign activity_name = activity_product.title
                    endif

                    if activity_name == ''
                      assign activity_name = activity_type
                    endif

                    if activity_description_raw == '' and activity_product
                      assign activity_description_raw = activity_product.description
                    endif

                    assign activity_description_text = activity_description_raw | strip_html | strip | truncate: 220

                    assign activity_time_label = activity_type
                    if activity_time != blank and activity_time != 'None' and activity_time != 'NotProvided'
                      assign activity_time_label = activity_time | append: ' · ' | append: activity_type
                    endif
                  -%}
                  {% if activity_handle != '' %}
                    <li>
                      <div class="itin-chrono__card" data-preview-url="/products/{{ activity_handle }}">
                        <div class="itin-chrono__card-time">{{ activity_time_label }}</div>
                        <div class="itin-chrono__card-title">{{ activity_name }}</div>
                        {% if activity_description_text != blank %}
                          <div class="itin-chrono__card-body">{{ activity_description_text }}</div>
                        {% endif %}
                        <div class="itin-chrono__card-footer">
                          <span class="itin-chrono__card-tag">{{ activity_type }}</span>
                          {% if dest_name != blank %}<span class="itin-chrono__card-tag">{{ dest_name }}</span>{% endif %}
                        </div>
                        <div class="itin-chrono__card-hint"><span>→</span> View activity details</div>
                      </div>
                    </li>
                  {% else %}
                    <li class="itin-chrono__activity">
                      <div class="itin-chrono__activity-main">
                        {% if activity_time != blank and activity_time != 'None' and activity_time != 'NotProvided' %}
                          <span class="itin-chrono__activity-time">{{ activity_time }}</span>
                        {% endif %}
                        <span class="itin-chrono__activity-name">{{ activity_name }}</span>
                      </div>
                      {% if activity_description_raw != blank %}
                        <div class="itin-chrono__activity-desc" data-pin-links>
                          {% render 'wetu-pin-link', content: activity_description_raw, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
                        </div>
                      {% endif %}
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </section>
          {% endif %}

          {% if day_included != blank %}
            <details class="itin-chrono__notes" data-pin-links>
              <summary>{{ 'sections.itinerary_chronological.included_today' | t }}</summary>
              <div class="itin-chrono__notes-body">
                {% render 'wetu-pin-link', content: day_included, pin_ids: wetu_pin_ids_array, handles: wetu_handles_array %}
              </div>
            </details>
          {% endif %}

          {% if route_count > 0 and is_departure_day and is_arrival_day == false %}
            {% for route_index in routes_array %}
              {% if route_index == blank %}{% continue %}{% endif %}
              {%- liquid
                assign route = wetu_routes[route_index]
                assign route_start_pin = route.start_content_entity_id.value | default: route.start_content_entity_id
                assign route_end_pin = route.end_content_entity_id.value | default: route.end_content_entity_id
                assign route_preview_handle = ''

                if route_end_pin != blank
                  assign route_end_pin_key = route_end_pin | append: ''
                  for check_pin in wetu_pin_ids_array
                    assign check_pin_key = check_pin | append: ''
                    if check_pin_key == route_end_pin_key
                      assign route_preview_handle = wetu_handles_array[forloop.index0]
                      break
                    endif
                  endfor
                endif

                if route_preview_handle == '' and route_start_pin != blank
                  assign route_start_pin_key = route_start_pin | append: ''
                  for check_pin in wetu_pin_ids_array
                    assign check_pin_key = check_pin | append: ''
                    if check_pin_key == route_start_pin_key
                      assign route_preview_handle = wetu_handles_array[forloop.index0]
                      break
                    endif
                  endfor
                endif

                assign route_preview_url = ''
                if route_preview_handle != ''
                  assign route_preview_url = '/products/' | append: route_preview_handle
                endif
              -%}
              {% render 'wetu-chronological-transfer-card', route: route, wetu_pin_ids_array: wetu_pin_ids_array, wetu_handles_array: wetu_handles_array, preview_url: route_preview_url %}
            {% endfor %}
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <aside class="itin-chrono__preview" data-chrono-preview aria-label="Linked page preview">
      <div class="itin-chrono__preview-inner">
        <section class="itin-chrono__preview-panel" data-preview-state="empty" data-preview-open="false">
          <div class="itin-chrono__preview-body" data-preview-body>
            <h3 class="itin-chrono__preview-hidden" data-preview-title>No page selected</h3>
            <p class="itin-chrono__preview-hidden" data-preview-url>Select an itinerary link to open it here.</p>
            <a
              class="itin-chrono__preview-hidden"
              data-preview-open
              href="#"
              target="_blank"
              rel="noopener"
              aria-label="Open linked page in a new tab"
              aria-disabled="true"
              tabindex="-1"
            >
              Open full page
            </a>
            <button
              type="button"
              class="itin-chrono__preview-hidden"
              data-preview-clear
              aria-label="Clear linked page preview"
              disabled
            >
              Clear preview
            </button>
            <div class="itin-chrono__preview-empty" data-preview-view="empty">
              <div
                class="itin-chrono__transact"
                data-inspector-default
                data-inspector-price-cents="{{ inspector_price | plus: 0 }}"
                data-inspector-min-guests="{{ inspector_min_guests }}"
                data-inspector-max-guests="{{ inspector_max_guests }}"
                data-inspector-guests-template="{{ inspector_guests_template }}"
              >
                <div class="itin-chrono__transact-price-block">
                  <p class="itin-chrono__transact-ref-line">
                    {{ product.vendor | default: 'Private journey' }} · {{ inspector_start_year }} · REF {{ itinerary_reference | default: product.id }}
                  </p>
                  <p class="itin-chrono__transact-price-label">
                    {{ 'wetu.rates.per_person_sharing' | t | default: 'Per person sharing' }}
                  </p>
                  <div class="itin-chrono__transact-price-row">
                    <span class="itin-chrono__transact-price-value">{{ inspector_price | money }}</span>
                    <span class="itin-chrono__transact-price-unit">per person</span>
                  </div>
                  <p class="itin-chrono__transact-price-total" data-inspector-price-total>
                    <span data-inspector-price-total-amount>{{ inspector_total_price | money }}</span>
                    total for
                    <span data-inspector-price-total-guests>{{ 'wetu.accommodation.guests_count' | t: count: inspector_default_guests | default: '2 guests' }}</span>
                  </p>

                  <div class="itin-chrono__transact-guest-row" data-inspector-guest-counter>
                    <div>
                      <p class="itin-chrono__transact-guest-label">
                        {{ 'travel_search.guests' | t | default: 'Guests' }}
                      </p>
                      <p class="itin-chrono__transact-guest-sub">{{ inspector_guest_subtitle }}</p>
                    </div>
                    <div class="itin-chrono__transact-guest-counter">
                      <button
                        type="button"
                        class="itin-chrono__transact-guest-btn"
                        aria-label="Decrease guests"
                        data-inspector-guest-decrease
                      >
                        -
                      </button>
                      <span class="itin-chrono__transact-guest-count" data-inspector-guest-count aria-live="polite" aria-atomic="true">{{ inspector_default_guests }}</span>
                      <button
                        type="button"
                        class="itin-chrono__transact-guest-btn"
                        aria-label="Increase guests"
                        data-inspector-guest-increase
                      >
                        +
                      </button>
                    </div>
                  </div>

                  <div class="itin-chrono__transact-cta-wrap">
                    <a
                      class="itin-chrono__transact-cta itin-chrono__transact-cta--primary{% unless inspector_variant.available %} is-disabled{% endunless %}"
                      href="{% if inspector_variant.available %}{{ inspector_confirm_url }}{% else %}#{% endif %}"
                      data-inspector-confirm-link
                      data-inspector-confirm-base-url="{{ inspector_confirm_base_url }}"
                      {% unless inspector_variant.available %}aria-disabled="true" tabindex="-1"{% endunless %}
                    >
                      Confirm journey
                    </a>
                    <a class="itin-chrono__transact-cta itin-chrono__transact-cta--secondary" href="#itinerary-enquiry-form" data-inspector-customisation-link>
                      Request customisation
                    </a>
                  </div>
                </div>

                <div class="itin-chrono__transact-inclusions">
                  <p class="itin-chrono__transact-inclusions-label">
                    {{ 'wetu.itinerary.price_includes' | t | default: "What's included" }}
                  </p>
                  <ul class="itin-chrono__transact-inclusions-grid" role="list">
                    {% if inspector_inclusion_count > 0 %}
                      {% for inclusion_item in inspector_inclusion_items limit: inspector_inclusion_limit %}
                        {% if inclusion_item == blank %}{% continue %}{% endif %}
                        <li class="itin-chrono__transact-inclusion-item">
                          <span class="itin-chrono__transact-inclusion-dot" aria-hidden="true"></span>
                          <span>{{ inclusion_item }}</span>
                        </li>
                      {% endfor %}
                    {% else %}
                      <li class="itin-chrono__transact-inclusion-item itin-chrono__transact-inclusion-item--full">
                        <span class="itin-chrono__transact-inclusion-dot" aria-hidden="true"></span>
                        <span>{{ 'sections.itinerary_chronological.included_today' | t | default: 'Inclusions available in your itinerary details' }}</span>
                      </li>
                    {% endif %}
                  </ul>
                </div>

                <div class="itin-chrono__transact-contact">
                  <div class="itin-chrono__transact-contact-avatar" aria-hidden="true">{{ inspector_contact_initials }}</div>
                  <div class="itin-chrono__transact-contact-main">
                    <p class="itin-chrono__transact-contact-name">{{ inspector_consultant_name }}</p>
                    <p class="itin-chrono__transact-contact-role">{{ inspector_contact_role_line }}</p>
                    <div class="itin-chrono__transact-contact-links">
                      {% if inspector_contact_phone != blank %}
                        <a class="itin-chrono__transact-contact-link" href="tel:{{ inspector_contact_phone | remove: ' ' }}">{{ inspector_contact_phone }}</a>
                      {% endif %}
                      {% if inspector_contact_email != blank %}
                        <a class="itin-chrono__transact-contact-link" href="mailto:{{ inspector_contact_email }}">{{ inspector_contact_email }}</a>
                      {% endif %}
                      {% if inspector_contact_phone == blank and inspector_contact_email == blank %}
                        <span class="itin-chrono__transact-contact-link itin-chrono__transact-contact-link--muted">
                          {{ 'wetu.itinerary.contact_us' | t | default: 'Contact available on request' }}
                        </span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="itin-chrono__preview-loading" data-preview-view="loading" hidden>
              <div class="itin-chrono__preview-skeleton" aria-hidden="true"></div>
              <div class="itin-chrono__preview-skeleton itin-chrono__preview-skeleton--line" aria-hidden="true"></div>
              <div class="itin-chrono__preview-skeleton itin-chrono__preview-skeleton--line" aria-hidden="true"></div>
            </div>
            <div class="itin-chrono__preview-product" data-preview-view="product" hidden>
              <div class="itin-chrono__preview-product-card" data-preview-product-card></div>
            </div>
            <div class="itin-chrono__preview-error" data-preview-view="error" hidden>
              <a
                class="itin-chrono__preview-error-open itin-chrono__preview-hidden"
                data-preview-error-open
                href="#"
                target="_blank"
                rel="noopener"
                aria-label="Open linked page in a new tab instead"
              >
                Open full page
              </a>
            </div>
          </div>
        </section>
      </div>
    </aside>
  </div>

  <div class="itin-chrono__mobile-picker" id="itin-mobile-picker" aria-label="Day navigation"></div>

  <div class="itin-chrono__bottom-sheet-overlay" data-bottom-sheet-overlay>
    <div class="itin-chrono__bottom-sheet" data-bottom-sheet>
      <span class="itin-chrono__bottom-sheet-handle" aria-hidden="true"></span>
      <div class="itin-chrono__bottom-sheet-content" data-bottom-sheet-content></div>
    </div>
  </div>
</div>

{% stylesheet %}
.itin-chrono {
  background: var(--color-background);
  color: var(--color-foreground);
  --itin-chrono-highlight: rgba(255, 255, 255, 0.96);
  --itin-chrono-bg-deep: #2e2e2e;
  --itin-chrono-bg-mid: #363636;
  --itin-chrono-bg-card: #3d3d3d;
  --itin-chrono-bg-card-lift: #444444;
  --itin-chrono-bg-divider: #505050;
  --itin-chrono-surface: rgba(var(--color-foreground-rgb), 0.03);
  --itin-chrono-surface-strong: rgba(var(--color-foreground-rgb), 0.07);
  --itin-chrono-sticky-offset: calc(var(--header-height, 60px) + 24px);
  --itin-chrono-workspace-gap-top: 2px;
  --itin-chrono-inspector-width: 500px;
  --itin-chrono-sidebar-width: 185px;
  scroll-margin-top: calc(var(--itin-chrono-sticky-offset) + 12px);
}

.itin-chrono__hero {
  position: relative;
  width: 100%;
  aspect-ratio: 2.40 / 1;
  overflow: hidden;
  background: #111;
}

.itin-chrono__hero--fullwidth {
  position: relative;
  width: 100%;
  aspect-ratio: 2.40 / 1;
  overflow: hidden;
  background: var(--itin-chrono-bg-deep, #2e2e2e);
  flex-shrink: 0;
}

.itin-chrono__hero--fullwidth iframe {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 250%;
  transform: translate(-50%, -50%);
  border: none;
  pointer-events: none;
}

.itin-chrono__hero--fullwidth .itin-chrono__hero-overlay {
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.08) 0%,
    rgba(0, 0, 0, 0.02) 40%,
    rgba(0, 0, 0, 0.5) 78%,
    var(--itin-chrono-bg-deep, #2e2e2e) 100%
  );
}

.itin-chrono__hero iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 250%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: none;
  pointer-events: none;
}

.itin-chrono__hero video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.itin-chrono__hero-img,
.itin-chrono__hero > img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.itin-chrono__hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.08) 0%,
    rgba(0, 0, 0, 0.02) 40%,
    rgba(0, 0, 0, 0.5) 78%,
    rgba(var(--color-background-rgb, 46, 46, 46), 1) 100%
  );
}

.itin-chrono__hero-text {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: clamp(24px, 4vw, 48px);
}

.itin-chrono__hero-eyebrow {
  font-size: 0.62rem;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 0.26em;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.itin-chrono__hero-title {
  font-size: clamp(2rem, 5vw, 3.8rem);
  font-weight: 300;
  color: #fff;
  line-height: 1.0;
  letter-spacing: 0.01em;
  margin: 0 0 10px;
}

.itin-chrono__hero-subtitle {
  font-size: 0.68rem;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.itin-chrono__layout {
  display: grid;
  grid-template-columns: var(--itin-chrono-sidebar-width) minmax(0, 1fr);
  width: min(100%, max(var(--page-width, 1400px), 1640px));
  margin: 0 auto;
  padding: var(--itin-chrono-workspace-gap-top) clamp(20px, 4vw, 56px) 120px;
}

.itin-chrono__rail {
  position: relative;
  background: var(--itin-chrono-bg-deep, #2e2e2e);
  border-inline-end: 1px solid rgba(var(--color-foreground-rgb), 0.14);
}

.itin-chrono__rail-inner {
  position: sticky;
  top: var(--itin-chrono-sticky-offset);
  max-height: calc(100vh - var(--itin-chrono-sticky-offset) - 24px);
  overflow-y: auto;
  padding: 24px 0 40px;
  scrollbar-width: none;
}

.itin-chrono__rail-inner::-webkit-scrollbar {
  display: none;
}

.itin-chrono__rail-label {
  font-size: 0.6rem;
  font-weight: 400;
  color: rgba(var(--color-foreground-rgb), 0.42);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 0 16px 14px;
}

.itin-chrono__leg-group {
  display: flex;
  flex-direction: column;
}

.itin-chrono__leg-header {
  appearance: none;
  background: none;
  border: none;
  padding: 8px 16px 5px;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  user-select: none;
  color: inherit;
  text-align: start;
}

.itin-chrono__leg-title {
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(var(--color-foreground-rgb), 0.42);
  white-space: nowrap;
}

.itin-chrono__leg-line {
  flex: 1;
  height: 1px;
  background: rgba(var(--color-foreground-rgb), 0.14);
}

.itin-chrono__leg-days {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  max-height: 600px;
}

.itin-chrono__leg-days.is-collapsed {
  max-height: 0;
}

.itin-chrono__rail-link {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1px;
  padding: 6px 16px 6px 22px;
  text-decoration: none;
  color: rgba(var(--color-foreground-rgb), 0.72);
  cursor: pointer;
  transition: color 0.22s, background 0.22s;
}

.itin-chrono__rail-link::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 2px;
  height: 0;
  background: var(--color-foreground);
  transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s;
  opacity: 0;
  border-radius: 0 1px 1px 0;
}

.itin-chrono__rail-link.is-active::before {
  height: 22px;
  opacity: 1;
}

.itin-chrono__rail-link.is-active {
  background: rgba(var(--color-foreground-rgb), 0.06);
}

.itin-chrono__rail-link:hover:not(.is-active) .itin-chrono__rail-dest {
  color: rgba(var(--color-foreground-rgb), 0.55);
}

.itin-chrono__rail-link:focus-visible {
  outline: 2px solid rgba(var(--color-foreground-rgb), 0.85);
  outline-offset: 3px;
}

.itin-chrono__rail-link.is-active,
.itin-chrono__rail-link[aria-current="true"] {
  color: var(--itin-chrono-highlight);
}

.itin-chrono__rail-day {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(var(--color-foreground-rgb), 0.42);
}

.itin-chrono__rail-link.is-active .itin-chrono__rail-day {
  color: rgba(var(--color-foreground-rgb), 0.65);
}

.itin-chrono__rail-dest {
  font-size: 0.92rem;
  font-weight: 400;
  color: rgba(var(--color-foreground-rgb), 0.72);
  line-height: 1.2;
}

.itin-chrono__rail-link.is-active .itin-chrono__rail-dest {
  color: var(--itin-chrono-highlight);
}

.itin-chrono__content {
  display: grid;
  gap: 94px;
  min-width: 0;
  padding-top: 0;
  background: var(--itin-chrono-bg-mid, #363636);
  scrollbar-width: thin;
  scrollbar-color: var(--itin-chrono-bg-divider, #505050) transparent;
}

.itin-chrono__content::-webkit-scrollbar {
  width: 4px;
}

.itin-chrono__content::-webkit-scrollbar-track {
  background: transparent;
}

.itin-chrono__content::-webkit-scrollbar-thumb {
  background: var(--itin-chrono-bg-divider, #505050);
  border-radius: 2px;
}

.itin-chrono__preview {
  display: none;
  min-width: 0;
}

.itin-chrono__preview-inner {
  position: sticky;
  top: 2px;
  height: calc(100vh - 2px);
}

.itin-chrono__preview-panel {
  display: flex;
  flex-direction: column;
  height: 100%;
  border: 1px solid rgba(var(--color-foreground-rgb), 0.12);
  border-radius: 16px;
  overflow: hidden;
  background: var(--itin-chrono-bg-deep, #2e2e2e);
  box-shadow: 0 24px 48px rgba(0, 0, 0, 0.24);
}

.itin-chrono__preview-hidden {
  display: none !important;
}

.itin-chrono__preview-header {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.12);
  padding: 14px 16px;
  background: rgba(var(--color-foreground-rgb), 0.04);
}

.itin-chrono__preview-meta {
  min-width: 0;
  display: grid;
  gap: 4px;
}

.itin-chrono__preview-label {
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  color: rgba(var(--color-foreground-rgb), 0.62);
}

.itin-chrono__preview-title {
  margin: 0;
  font-size: 1rem;
  line-height: 1.3;
  color: rgba(var(--color-foreground-rgb), 0.95);
}

.itin-chrono__preview-url {
  margin: 0;
  font-size: 0.75rem;
  line-height: 1.45;
  color: rgba(var(--color-foreground-rgb), 0.65);
  overflow-wrap: anywhere;
}

.itin-chrono__preview-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.itin-chrono__preview-open,
.itin-chrono__preview-clear,
.itin-chrono__preview-error-open {
  appearance: none;
  border-radius: 10px;
  border: 1px solid rgba(var(--color-foreground-rgb), 0.2);
  background: rgba(var(--color-foreground-rgb), 0.06);
  color: inherit;
  text-decoration: none;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  padding: 8px 10px;
  line-height: 1.2;
  cursor: pointer;
  transition: border-color 0.2s ease, background-color 0.2s ease;
}

.itin-chrono__preview-open:hover,
.itin-chrono__preview-clear:hover,
.itin-chrono__preview-error-open:hover {
  border-color: rgba(var(--color-foreground-rgb), 0.45);
  background: rgba(var(--color-foreground-rgb), 0.13);
}

.itin-chrono__preview-open[aria-disabled="true"],
.itin-chrono__preview-clear[disabled] {
  cursor: not-allowed;
  opacity: 0.45;
}

.itin-chrono__preview-open:focus-visible,
.itin-chrono__preview-clear:focus-visible,
.itin-chrono__preview-error-open:focus-visible {
  outline: 2px solid rgba(var(--color-foreground-rgb), 0.78);
  outline-offset: 2px;
}

.itin-chrono__preview-body {
  position: relative;
  flex: 1;
  min-height: 0;
  background: var(--itin-chrono-bg-deep, #2e2e2e);
}

.itin-chrono__preview-body > [hidden] {
  display: none !important;
}

.itin-chrono__preview-loading,
.itin-chrono__preview-error {
  display: grid;
  align-content: center;
  justify-items: start;
  gap: 12px;
  height: 100%;
  padding: 20px;
  color: rgba(var(--color-foreground-rgb), 0.7);
}

.itin-chrono__preview-empty {
  display: block;
  height: 100%;
  padding: 0;
  overflow-y: auto;
}

.itin-chrono__preview-loading {
  width: 100%;
}

.itin-chrono__preview-skeleton {
  width: 100%;
  height: 52%;
  border-radius: 14px;
  background: linear-gradient(
    90deg,
    rgba(var(--color-foreground-rgb), 0.05),
    rgba(var(--color-foreground-rgb), 0.15),
    rgba(var(--color-foreground-rgb), 0.05)
  );
  background-size: 200% 100%;
  animation: itin-chrono-preview-loading 1.4s linear infinite;
}

.itin-chrono__preview-skeleton--line {
