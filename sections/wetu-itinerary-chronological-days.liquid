{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.querySelector('.itin-chrono');
    if (!root) return;

    let pinMap = {};
    let linkManifest = {};
    try {
      pinMap = JSON.parse(root.dataset.pinMap || '{}');
    } catch (e) {
      pinMap = {};
    }
    try {
      linkManifest = JSON.parse(root.dataset.linkManifest || '{}');
    } catch (e) {
      linkManifest = {};
    }

    const pinRegex = new RegExp('{' + '{PIN:(\\d+)\\|([^}]+)}' + '}', 'g');
    const escapeHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const replacePinTokens = (content) => String(content || '').replace(pinRegex, (match, id, text) => {
      const status = linkManifest[id];
      if (status && status !== 'found') {
        return escapeHtml(text);
      }
      const handle = pinMap[id];
      if (!handle) {
        return escapeHtml(text);
      }
      return `<a href="/products/${handle}">${escapeHtml(text)}</a>`;
    });

    const applyPinLinks = (scope = document) => {
      const elements = scope.querySelectorAll('[data-pin-links]');
      elements.forEach((el) => {
        if (!el.innerHTML.includes('{' + '{PIN:')) return;
        el.innerHTML = replacePinTokens(el.innerHTML);
      });
    };

    const humanizeRouteMode = (modeRaw, labelRaw) => {
      const mode = String(modeRaw || 'Transfer');
      const label = String(labelRaw || '');
      switch (mode) {
        case 'ScheduledFlight':
          return 'Scheduled flight';
        case 'CharterFlight':
          return 'Charter flight';
        case 'Transfer':
          return label === 'Private' ? 'Private transfer' : 'Transfer';
        case 'Rail':
        case 'Train':
          return 'Rail transfer';
        case 'Selfdrive':
          return 'Self-drive';
        case 'Boat':
          return 'Boat transfer';
        default:
          return mode;
      }
    };

    const humanizeHandle = (handle) => String(handle || '')
      .split('-')
      .filter(Boolean)
      .map((word) => {
        const upperTokenList = new Set(['cpt', 'dur', 'jnb', 'or']);
        if (upperTokenList.has(word.toLowerCase())) return word.toUpperCase();
        return word.charAt(0).toUpperCase() + word.slice(1);
      })
      .join(' ');

    const normalizeRouteLocationLabels = (scope = document) => {
      const anchors = scope.querySelectorAll('.itin-chrono__timeline-route a');
      anchors.forEach((anchor) => {
        const currentText = anchor.textContent.replace(/\s+/g, ' ').trim();
        if (!/^Location PIN \d+$/i.test(currentText)) return;

        const href = anchor.getAttribute('href') || '';
        const match = href.match(/\/products\/([^/?#]+)/i);
        if (!match) return;

        const pretty = humanizeHandle(match[1]);
        if (pretty) {
          anchor.textContent = pretty;
        }
      });
    };

    const formatSnoopNarrative = (scope = document) => {
      const blocks = scope.querySelectorAll('.itin-chrono__narrative');
      blocks.forEach((block) => {
        if (block.dataset.snoopEnhanced === 'true') return;

        const paragraphs = [...block.querySelectorAll(':scope > p')];
        paragraphs.forEach((paragraph) => {
          const heading = paragraph.querySelector(':scope > strong');
          if (!heading) return;

          const headingText = heading.textContent.replace(/\s+/g, ' ').trim();
          if (!headingText) return;

          if (/^Day\s+\d+\s*--/i.test(headingText)) {
            paragraph.classList.add('itin-chrono__snoop-title');
            return;
          }

          if (/^Pulse\b/i.test(headingText)) {
            paragraph.classList.add('itin-chrono__snoop-card', 'itin-chrono__snoop-card--pulse');
            heading.textContent = 'Pulse';
            return;
          }

          if (/^Street Intel\b/i.test(headingText)) {
            paragraph.classList.add('itin-chrono__snoop-card', 'itin-chrono__snoop-card--intel');
            heading.textContent = 'Street Intel';
            return;
          }

          if (/^Closeout\b/i.test(headingText)) {
            paragraph.classList.add('itin-chrono__snoop-card', 'itin-chrono__snoop-card--closeout');
            heading.textContent = 'Closeout';
            return;
          }

          if (/^Run Sheet\b/i.test(headingText)) {
            const maybeList = paragraph.nextElementSibling;
            if (maybeList && maybeList.tagName === 'UL') {
              const details = document.createElement('details');
              details.className = 'itin-chrono__snoop-runsheet';

              const summary = document.createElement('summary');
              summary.textContent = 'Run Sheet';
              details.appendChild(summary);
              details.appendChild(maybeList);

              paragraph.replaceWith(details);
            }
          }
        });

        block.dataset.snoopEnhanced = 'true';
      });
    };

    const injectNarrativeCues = (scope = document) => {
      const dayCards = scope.querySelectorAll('.itin-chrono__day');
      dayCards.forEach((dayCard) => {
        if (dayCard.dataset.snoopCuesInjected === 'true') return;
        if (dayCard.querySelector('.itin-chrono__commentary-stream')) {
          dayCard.dataset.snoopCuesInjected = 'true';
          return;
        }

        const runsheetItems = Array.from(dayCard.querySelectorAll('.itin-chrono__narrative .itin-chrono__snoop-runsheet ul li'));
        if (runsheetItems.length === 0) return;

        const cueRows = runsheetItems.map((item) => {
          const clone = item.cloneNode(true);
          const firstStrong = clone.querySelector('strong');
          let time = '';
          if (firstStrong) {
            const timeMatch = (firstStrong.textContent || '').match(/\d{1,2}:\d{2}/);
            if (timeMatch) {
              time = timeMatch[0];
            }
            firstStrong.remove();
          }

          const bodyHtml = clone.innerHTML.replace(/^\s*[—-]\s*/, '').trim();
          if (!bodyHtml) return null;
          return {
            time,
            minutes: toMinutes(time),
            bodyHtml,
          };
        }).filter(Boolean).sort((a, b) => a.minutes - b.minutes);

        if (cueRows.length === 0) return;

        const commentarySection = document.createElement('section');
        commentarySection.className = 'itin-chrono__commentary-stream';
        commentarySection.setAttribute('data-pin-links', '');
        commentarySection.innerHTML = `
          <h3 class="itin-chrono__section-title">Snoop live wire</h3>
          <ul class="itin-chrono__commentary-list" role="list">
            ${cueRows.map((row) => `
              <li class="itin-chrono__commentary-item">
                ${row.time ? `<span class="itin-chrono__commentary-time">${escapeHtml(row.time)}</span>` : '<span class="itin-chrono__commentary-time"></span>'}
                <div class="itin-chrono__commentary-body">${row.bodyHtml}</div>
              </li>
            `).join('')}
          </ul>
        `;

        const timelineSection = dayCard.querySelector('.itin-chrono__timeline');
        if (timelineSection && timelineSection.parentNode) {
          timelineSection.insertAdjacentElement('afterend', commentarySection);
        } else {
          const narrativeSection = dayCard.querySelector('.itin-chrono__narrative');
          if (narrativeSection && narrativeSection.parentNode) {
            narrativeSection.insertAdjacentElement('beforebegin', commentarySection);
          }
        }

        dayCard.dataset.snoopCuesInjected = 'true';
      });
    };

    const suppressRunSheetWhenLiveWirePresent = (scope = document) => {
      const dayCards = scope.querySelectorAll('.itin-chrono__day');
      dayCards.forEach((dayCard) => {
        if (!dayCard.querySelector('.itin-chrono__commentary-stream')) return;
        dayCard.querySelectorAll('.itin-chrono__narrative .itin-chrono__snoop-runsheet').forEach((runsheet) => {
          runsheet.remove();
        });
      });
    };

    const decodeEntities = (() => {
      const textarea = document.createElement('textarea');
      return (value) => {
        textarea.innerHTML = String(value || '');
        return textarea.value;
      };
    })();

    const containsHtml = (value) => /<\/?[a-z][\s\S]*>/i.test(String(value || ''));

    const fieldValue = (obj, key) => {
      if (!obj || typeof obj !== 'object') return null;
      const value = obj[key];
      if (value && typeof value === 'object' && Object.prototype.hasOwnProperty.call(value, 'value')) {
        return value.value;
      }
      return value ?? null;
    };

    const extractRichText = (input) => {
      if (!input) return '';
      if (typeof input === 'object') {
        if (Array.isArray(input.children)) {
          return input.children.map((child) => extractRichText(child)).join(' ');
        }
        if (typeof input.value === 'string') {
          return input.value;
        }
        return '';
      }

      const raw = String(input).trim();
      if (!raw) return '';
      if (raw.startsWith('{') || raw.startsWith('[')) {
        try {
          const parsed = JSON.parse(raw);
          return extractRichText(parsed);
        } catch (error) {
          return raw;
        }
      }
      return raw;
    };

    const prettyText = (value) => {
      const text = extractRichText(value).trim();
      if (!text) return '';
      const decoded = decodeEntities(text).trim();
      if (!decoded) return '';

      if (containsHtml(decoded)) {
        return replacePinTokens(decoded);
      }

      const paragraphHtml = escapeHtml(decoded)
        .replace(/\n\n+/g, '</p><p>')
        .replace(/\n/g, '<br>');
      return `<p>${replacePinTokens(paragraphHtml)}</p>`;
    };

    const normalizeList = (raw) => {
      if (Array.isArray(raw)) return raw;
      if (typeof raw === 'string') {
        try {
          const parsed = JSON.parse(raw);
          return Array.isArray(parsed) ? parsed : [];
        } catch (error) {
          return [];
        }
      }
      return [];
    };

    const normalizeActivities = (period) => normalizeList(fieldValue(period, 'activities') || []);
    const normalizeCommentaryItems = (period) => normalizeList(fieldValue(period, 'commentary_items') || []);
    const normalizeInsertBlocks = (period) => normalizeList(fieldValue(period, 'insert_blocks') || []);
    const previewDesktopMediaQuery = window.matchMedia('(min-width: 900px)');
    const previewQueryParam = 'chronoPreview';
    const previewEligiblePathPrefixes = ['/products/', '/pages/', '/collections/'];

    const toMinutes = (value) => {
      if (!value || typeof value !== 'string' || !value.includes(':')) return 9_999;
      const [hours, minutes] = value.split(':');
      const parsedHours = Number.parseInt(hours, 10);
      const parsedMinutes = Number.parseInt(minutes, 10);
      if (Number.isNaN(parsedHours) || Number.isNaN(parsedMinutes)) return 9_999;
      return parsedHours * 60 + parsedMinutes;
    };

    const isPreviewEligiblePath = (pathname) => {
      const normalizedPathname = String(pathname || '').toLowerCase();
      return previewEligiblePathPrefixes.some((prefix) => normalizedPathname.startsWith(prefix));
    };

    const normalizePreviewUrl = (value) => {
      if (!value) return null;

      try {
        const candidateUrl = new URL(value, window.location.origin);
        if (candidateUrl.origin !== window.location.origin) return null;
        if (!isPreviewEligiblePath(candidateUrl.pathname)) return null;

        candidateUrl.hash = '';
        return candidateUrl.toString();
      } catch (error) {
        return null;
      }
    };

    const formatPreviewUrl = (value) => {
      const normalized = normalizePreviewUrl(value);
      if (!normalized) return '';

      const parsed = new URL(normalized);
      return `${parsed.pathname}${parsed.search}`;
    };

    const previewUrlFromAnchor = (anchor) => {
      if (!anchor) return null;

      const rawHref = String(anchor.getAttribute('href') || '').trim();
      if (!rawHref) return null;

      const lowerHref = rawHref.toLowerCase();
      if (
        rawHref.startsWith('#')
        || lowerHref.startsWith('mailto:')
        || lowerHref.startsWith('tel:')
        || lowerHref.startsWith('javascript:')
      ) {
        return null;
      }

      return normalizePreviewUrl(rawHref);
    };

    const resolveLegForDay = (legs, day) => {
      let runningDay = 1;
      for (const leg of legs) {
        const nights = Number(fieldValue(leg, 'nights') || 0);
        const start = runningDay;
        const end = nights > 0 ? runningDay + nights - 1 : runningDay;
        if (day >= start && day <= end) {
          return { leg, dayWithinLeg: day - start + 1 };
        }
        runningDay += nights;
      }
      return null;
    };

    const buildDayDate = (startDateRaw, day) => {
      if (!startDateRaw) return '';
      const date = new Date(startDateRaw);
      if (Number.isNaN(date.getTime())) return '';
      date.setDate(date.getDate() + (day - 1));
      return date.toLocaleDateString(undefined, {
        weekday: 'long',
        month: 'long',
        day: 'numeric',
        year: 'numeric',
      });
    };

    const pinLink = (pin, label) => {
      const safeLabel = escapeHtml(label || `Location PIN ${pin}`);
      if (!pin) return safeLabel;
      const normalizedPin = String(pin);
      const status = linkManifest[normalizedPin];
      const handle = pinMap[normalizedPin];
      if (!handle || (status && status !== 'found')) {
        return safeLabel;
      }
      return `<a href="/products/${handle}">${safeLabel}</a>`;
    };

    const renderInsertBlocks = (blocks) => {
      if (!Array.isArray(blocks) || blocks.length === 0) return '';

      const blockHtml = blocks.map((block) => {
        const type = String(fieldValue(block, 'type') || '').toLowerCase();
        const title = fieldValue(block, 'title') || '';
        const content = prettyText(fieldValue(block, 'content'));

        if (type === 'link_list') {
          const links = normalizeList(fieldValue(block, 'links') || []);
          const seen = new Set();
            const linkRows = links.map((linkItem) => {
            const label = fieldValue(linkItem, 'label') || '';
            const pin = fieldValue(linkItem, 'pin_id');
            const dedupeKey = String(pin || label || '').trim().toLowerCase();
              if (!dedupeKey || seen.has(dedupeKey)) return '';
              seen.add(dedupeKey);
              if (!label) return '';
              return `<li class="itin-chrono__link-item">${pin ? pinLink(pin, label) : escapeHtml(label)}</li>`;
            }).filter(Boolean).join('');

            if (!linkRows) return '';
            return `<details class="itin-chrono__insert itin-chrono__insert--links"><summary class="itin-chrono__insert-title">${escapeHtml(title || 'Related links')}</summary><ul class="itin-chrono__link-list" role="list">${linkRows}</ul></details>`;
          }

        if (!content) return '';
        return `<section class="itin-chrono__insert">${title ? `<h3 class="itin-chrono__insert-title">${escapeHtml(title)}</h3>` : ''}<div class="itin-chrono__insert-content" data-pin-links>${content}</div></section>`;
      }).filter(Boolean).join('');

      if (!blockHtml) return '';
      return `<div class="itin-chrono__inserts">${blockHtml}</div>`;
    };

    const renderCommentaryStream = (items) => {
      if (!Array.isArray(items) || items.length === 0) return '';

      const commentaryRows = items.map((item) => {
        const time = String(fieldValue(item, 'time') || '');
        const contentHtml = prettyText(fieldValue(item, 'content'));
        if (!contentHtml) return null;
        return {
          time,
          minutes: toMinutes(time),
          html: contentHtml,
        };
      }).filter(Boolean).sort((a, b) => a.minutes - b.minutes);

      if (commentaryRows.length === 0) return '';

      const rowHtml = commentaryRows.map((row) => `
        <li class="itin-chrono__commentary-item">
          ${row.time && row.time !== 'None' && row.time !== 'NotProvided' ? `<span class="itin-chrono__commentary-time">${escapeHtml(row.time)}</span>` : '<span class="itin-chrono__commentary-time"></span>'}
          <div class="itin-chrono__commentary-body" data-pin-links>${row.html}</div>
        </li>
      `).join('');

      return `<section class="itin-chrono__commentary-stream" data-pin-links><h3 class="itin-chrono__section-title">Snoop live wire</h3><ul class="itin-chrono__commentary-list" role="list">${rowHtml}</ul></section>`;
    };

    const railList = root.querySelector('.itin-chrono__rail-nav') || root.querySelector('.itin-chrono__rail-list');
    const contentRoot = root.querySelector('.itin-chrono__content');
    const previewRoot = root.querySelector('[data-chrono-preview]');
    const previewPanel = previewRoot ? previewRoot.querySelector('.itin-chrono__preview-panel') : null;
    const previewProductCard = previewRoot ? previewRoot.querySelector('[data-preview-product-card]') : null;
    const previewTitle = previewRoot ? previewRoot.querySelector('[data-preview-title]') : null;
    const previewUrlText = previewRoot ? previewRoot.querySelector('[data-preview-url]') : null;
    const previewOpen = previewRoot ? previewRoot.querySelector('[data-preview-open]') : null;
    const previewErrorOpen = previewRoot ? previewRoot.querySelector('[data-preview-error-open]') : null;
    const previewClear = previewRoot ? previewRoot.querySelector('[data-preview-clear]') : null;
    const previewViews = previewRoot ? {
      empty: previewRoot.querySelector('[data-preview-view="empty"]'),
      loading: previewRoot.querySelector('[data-preview-view="loading"]'),
      product: previewRoot.querySelector('[data-preview-view="product"]'),
      error: previewRoot.querySelector('[data-preview-view="error"]'),
    } : null;

    let activeDayObserver = null;
    let activeDayId = null;
    let activePreviewUrl = '';
    let pendingPreviewUrl = '';
    let previewLoadTimeout = null;
    let previewRequestToken = 0;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const smoothBehavior = prefersReducedMotion ? 'auto' : 'smooth';
    const themeCurrency = window.Shopify && window.Shopify.currency ? window.Shopify.currency.active : '';

    const clampValue = (value, min, max) => Math.min(Math.max(value, min), max);

    const formatMoney = (cents) => {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(Math.round(cents));
      }

      const amount = Number(cents) / 100;
      try {
        return new Intl.NumberFormat(document.documentElement.lang || undefined, {
          style: 'currency',
          currency: themeCurrency || 'USD',
        }).format(amount);
      } catch (error) {
        return amount.toFixed(2);
      }
    };

    const getStickyOffset = () => {
      const offset = Number.parseFloat(getComputedStyle(root).getPropertyValue('--itin-chrono-sticky-offset'));
      if (Number.isFinite(offset) && offset > 0) {
        return offset;
      }
      return 84;
    };

    const syncStickyOffset = () => {
      const rootStyles = getComputedStyle(document.documentElement);
      const cssHeaderHeight = Number.parseFloat(rootStyles.getPropertyValue('--header-height'));
      let measuredHeaderHeight = Number.isFinite(cssHeaderHeight) && cssHeaderHeight > 0 ? cssHeaderHeight : 0;

      const headerElement = document.querySelector('sticky-header, #shopify-section-header, .shopify-section-group-header-group');
      if (headerElement) {
        measuredHeaderHeight = Math.max(measuredHeaderHeight, headerElement.getBoundingClientRect().height || 0);
      }

      root.style.setProperty('--itin-chrono-sticky-offset', `${Math.round(measuredHeaderHeight + 24)}px`);
    };

    const scrollViewportTo = (top, behavior = smoothBehavior) => {
      window.scrollTo({
        top: Math.max(0, top),
        left: 0,
        behavior,
      });
    };

    const focusWorkspace = (behavior = smoothBehavior) => {
      const workspaceTop = window.scrollY + root.getBoundingClientRect().top - getStickyOffset() - 6;
      scrollViewportTo(workspaceTop, behavior);
    };

    const initInspectorGuestCounters = () => {
      const guestCounterRows = root.querySelectorAll('[data-inspector-guest-counter]');
      if (guestCounterRows.length === 0) return;

      for (const counterRow of guestCounterRows) {
        const panel = counterRow.closest('[data-inspector-default]');
        if (!panel) continue;

        const decreaseButton = counterRow.querySelector('[data-inspector-guest-decrease]');
        const increaseButton = counterRow.querySelector('[data-inspector-guest-increase]');
        const countEl = counterRow.querySelector('[data-inspector-guest-count]');
        const totalAmountEl = panel.querySelector('[data-inspector-price-total-amount]');
        const totalGuestsEl = panel.querySelector('[data-inspector-price-total-guests]');
        const confirmLink = panel.querySelector('[data-inspector-confirm-link]');
        if (!decreaseButton || !increaseButton || !countEl || !totalAmountEl || !totalGuestsEl) continue;

        const parsedPerGuestCents = Number.parseInt(panel.dataset.inspectorPriceCents || '0', 10);
        const perGuestCents = Number.isNaN(parsedPerGuestCents) ? 0 : parsedPerGuestCents;
        const parsedMinGuests = Number.parseInt(panel.dataset.inspectorMinGuests || '1', 10);
        const parsedMaxGuests = Number.parseInt(panel.dataset.inspectorMaxGuests || '12', 10);
        const minGuests = Number.isNaN(parsedMinGuests) ? 1 : parsedMinGuests;
        const maxGuests = Number.isNaN(parsedMaxGuests) || parsedMaxGuests < minGuests
          ? minGuests
          : parsedMaxGuests;
        const guestsTemplate = decodeEntities(panel.dataset.inspectorGuestsTemplate || '__COUNT__ guests');

        const currentCount = Number.parseInt(countEl.textContent.replace(/\D+/g, ''), 10);
        let guests = clampValue(Number.isNaN(currentCount) ? minGuests : currentCount, minGuests, maxGuests);

        const updateConfirmUrl = () => {
          if (!confirmLink) return;
          if (confirmLink.getAttribute('aria-disabled') === 'true') return;

          const baseUrl = confirmLink.dataset.inspectorConfirmBaseUrl || '';
          if (!baseUrl || baseUrl === '#') return;

          try {
            const parsedUrl = new URL(baseUrl, window.location.origin);
            parsedUrl.searchParams.set('quantity', String(guests));
            confirmLink.href = `${parsedUrl.pathname}${parsedUrl.search}`;
          } catch (error) {
            // Keep fallback href when URL parsing fails.
          }
        };

        const updateGuestText = () => {
          const template = guestsTemplate.includes('__COUNT__')
            ? guestsTemplate
            : '{{ count }} guests';
          return template
            .replace('__COUNT__', String(guests))
            .replace(/\{\{\s*count\s*\}\}/gi, String(guests));
        };

        const renderCounter = () => {
          countEl.textContent = String(guests);
          totalAmountEl.textContent = formatMoney(perGuestCents * guests);
          totalGuestsEl.textContent = updateGuestText();

          decreaseButton.disabled = guests <= minGuests;
          increaseButton.disabled = guests >= maxGuests;
          updateConfirmUrl();
        };

        decreaseButton.addEventListener('click', () => {
          guests = clampValue(guests - 1, minGuests, maxGuests);
          renderCounter();
        });

        increaseButton.addEventListener('click', () => {
          guests = clampValue(guests + 1, minGuests, maxGuests);
          renderCounter();
        });

        renderCounter();
      }
    };

    const initInspectorCustomisationLinks = () => {
      const customisationLinks = root.querySelectorAll('[data-inspector-customisation-link]');
      if (customisationLinks.length === 0) return;

      for (const link of customisationLinks) {
        link.addEventListener('click', (event) => {
          const href = String(link.getAttribute('href') || '').trim();
          if (!href.startsWith('#')) return;

          const target = document.querySelector(href);
          if (!target) return;

          event.preventDefault();
          const scrollTarget = window.scrollY + target.getBoundingClientRect().top - getStickyOffset() - 12;
          scrollViewportTo(scrollTarget, smoothBehavior);

          const hadTabindex = target.hasAttribute('tabindex');
          if (!hadTabindex) {
            target.setAttribute('tabindex', '-1');
          }
          target.focus({ preventScroll: true });
          if (!hadTabindex) {
            target.addEventListener('blur', () => {
              target.removeAttribute('tabindex');
            }, { once: true });
          }
        });
      }
    };

    const clearPreviewLoadTimeout = () => {
      if (!previewLoadTimeout) return;
      window.clearTimeout(previewLoadTimeout);
      previewLoadTimeout = null;
    };

    const previewEnabled = () => Boolean(previewRoot && previewDesktopMediaQuery.matches);

    const setPreviewPanelOpen = (isOpen) => {
      if (!previewPanel) return;
      previewPanel.dataset.previewOpen = isOpen ? 'true' : 'false';
    };

    const previewTitleFromUrl = (url, titleHint = '') => {
      if (titleHint) return titleHint;
      const normalizedUrl = normalizePreviewUrl(url);
      if (!normalizedUrl) return 'Linked page';
      const parsedUrl = new URL(normalizedUrl);
      const pathSegments = parsedUrl.pathname.split('/').filter(Boolean);
      const handle = pathSegments[pathSegments.length - 1] || '';
      if (!handle) return 'Linked page';
      return humanizeHandle(handle);
    };

    const clearProductCard = () => {
      if (!previewProductCard) return;
      previewProductCard.innerHTML = '';
    };

    const renderPageContent = (html) => {
      if (!previewProductCard) return '';
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var mainEl = doc.querySelector('#MainContent') || doc.querySelector('main') || doc.querySelector('[role="main"]');
      if (mainEl) {
        previewProductCard.innerHTML = mainEl.innerHTML;
      }
      var titleEl = doc.querySelector('title');
      var pageTitle = titleEl ? titleEl.textContent.split('\u2013')[0].split('|')[0].trim() : '';
      return pageTitle;
    };

    const updatePreviewActions = (url) => {
      const normalizedUrl = normalizePreviewUrl(url);

      [previewOpen, previewErrorOpen].forEach((linkEl) => {
        if (!linkEl) return;

        if (!normalizedUrl) {
          linkEl.removeAttribute('href');
          linkEl.setAttribute('aria-disabled', 'true');
          if (linkEl === previewOpen) {
            linkEl.tabIndex = -1;
          }
          return;
        }

        linkEl.href = normalizedUrl;
        linkEl.removeAttribute('aria-disabled');
        if (linkEl === previewOpen) {
          linkEl.removeAttribute('tabindex');
        }
      });

      if (previewClear) {
        previewClear.disabled = !normalizedUrl;
      }
    };

    const updatePreviewHeading = (titleText, urlText) => {
      if (previewTitle) {
        previewTitle.textContent = titleText || 'No page selected';
      }
      if (previewUrlText) {
        previewUrlText.textContent = urlText || 'Select an itinerary link to open it here.';
      }
    };

    const setPreviewView = (state) => {
      if (!previewPanel || !previewViews) return;

      previewPanel.dataset.previewState = state;
      Object.entries(previewViews).forEach(([viewState, viewElement]) => {
        if (!viewElement) return;
        viewElement.hidden = viewState !== state;
      });
    };

    const storePreviewSelection = (url) => {
      const currentUrl = new URL(window.location.href);
      if (url) {
        currentUrl.searchParams.set(previewQueryParam, formatPreviewUrl(url));
      } else {
        currentUrl.searchParams.delete(previewQueryParam);
      }

      const nextUrl = `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`;
      window.history.replaceState(window.history.state, '', nextUrl);
    };

    const readPreviewSelection = () => {
      const currentUrl = new URL(window.location.href);
      const previewValue = currentUrl.searchParams.get(previewQueryParam);
      if (!previewValue) return null;
      return normalizePreviewUrl(previewValue);
    };

    const syncActivePreviewLinks = () => {
      if (!contentRoot) return;

      const anchors = contentRoot.querySelectorAll('a');
      anchors.forEach((anchor) => {
        const isActive = previewEnabled()
          && activePreviewUrl
          && previewUrlFromAnchor(anchor) === activePreviewUrl;
        anchor.classList.toggle('is-preview-active', Boolean(isActive));
      });
    };

    const showPreviewErrorState = () => {
      clearPreviewLoadTimeout();
      pendingPreviewUrl = '';
      setPreviewPanelOpen(true);
      setPreviewView('error');
      clearProductCard();
      updatePreviewHeading('Preview unavailable', formatPreviewUrl(activePreviewUrl));
      updatePreviewActions(activePreviewUrl);
      syncActivePreviewLinks();
    };

    const loadPreviewUrl = (url, options = {}) => {
      if (!previewEnabled()) return false;

      const normalizedUrl = normalizePreviewUrl(url);
      if (!normalizedUrl) return false;

      const {
        titleHint = '',
        skipHistory = false,
      } = options;
      const requestToken = previewRequestToken + 1;
      previewRequestToken = requestToken;

      activePreviewUrl = normalizedUrl;
      pendingPreviewUrl = normalizedUrl;
      setPreviewPanelOpen(true);
      clearProductCard();
      setPreviewView('loading');
      updatePreviewHeading(previewTitleFromUrl(normalizedUrl, titleHint), formatPreviewUrl(normalizedUrl));
      updatePreviewActions(normalizedUrl);
      syncActivePreviewLinks();

      clearPreviewLoadTimeout();
      previewLoadTimeout = window.setTimeout(() => {
        if (pendingPreviewUrl === normalizedUrl && previewRequestToken === requestToken) {
          showPreviewErrorState();
        }
      }, 12000);

      if (!skipHistory) {
        storePreviewSelection(normalizedUrl);
      }

      fetch(normalizedUrl)
        .then(function (res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.text();
        })
        .then(function (html) {
          if (previewRequestToken !== requestToken) return;
          clearPreviewLoadTimeout();
          pendingPreviewUrl = '';
          var pageTitle = renderPageContent(html);
          if (previewProductCard && previewProductCard.innerHTML) {
            setPreviewView('product');
            updatePreviewHeading(pageTitle || previewTitleFromUrl(normalizedUrl), formatPreviewUrl(normalizedUrl));
            updatePreviewActions(normalizedUrl);
            syncActivePreviewLinks();
          } else {
            showPreviewErrorState();
          }
        })
        .catch(function () {
          if (previewRequestToken !== requestToken) return;
          showPreviewErrorState();
        });

      return true;
    };

    const clearPreview = (options = {}) => {
      const { skipHistory = false } = options;

      activePreviewUrl = '';
      pendingPreviewUrl = '';
      previewRequestToken += 1;
      clearPreviewLoadTimeout();
      setPreviewPanelOpen(previewEnabled());
      clearProductCard();

      setPreviewView('empty');
      updatePreviewHeading('', '');
      updatePreviewActions('');
      syncActivePreviewLinks();

      if (!skipHistory) {
        storePreviewSelection('');
      }
    };

    const restorePreviewSelection = () => {
      if (!previewEnabled()) {
        setPreviewPanelOpen(false);
        clearPreviewLoadTimeout();
        clearProductCard();
        syncActivePreviewLinks();
        return;
      }

      setPreviewPanelOpen(true);
      const persistedUrl = readPreviewSelection();
      if (!persistedUrl) {
        if (!activePreviewUrl) {
          clearPreview({ skipHistory: true });
          return;
        }

        syncActivePreviewLinks();
        return;
      }

      if (persistedUrl === activePreviewUrl && previewPanel && previewPanel.dataset.previewState === 'product') {
        syncActivePreviewLinks();
        return;
      }

      loadPreviewUrl(persistedUrl, { skipHistory: true });
    };

    const scrollToDay = (dayId, options = {}) => {
      const {
        behavior = smoothBehavior,
        updateHash = true,
        scrollRail = true,
      } = options;

      const dayCard = root.querySelector(`#day-${dayId}`);
      if (!dayCard) return;

      setActiveDay(dayId, { scrollRail });
      const dayRect = dayCard.getBoundingClientRect();
      const contentTop = contentRoot ? contentRoot.getBoundingClientRect().top : 0;
      const stickyTop = getStickyOffset() + 2;
      const alignmentTop = contentTop > stickyTop ? contentTop : stickyTop;
      const dayTop = window.scrollY + dayRect.top - alignmentTop;
      scrollViewportTo(dayTop, behavior);

      if (updateHash) {
        const nextUrl = new URL(window.location.href);
        nextUrl.hash = `day-${dayId}`;
        window.history.replaceState(window.history.state, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
      }
    };

    const setActiveDay = (dayId, options = {}) => {
      if (!dayId || dayId === activeDayId) return;

      const { scrollRail = true } = options;
      const dayCards = root.querySelectorAll('.itin-chrono__day[data-day-section]');
      const railLinks = root.querySelectorAll('.itin-chrono__rail-link');

      dayCards.forEach((card) => {
        const isActive = card.dataset.daySection === dayId;
        card.classList.toggle('is-active', isActive);
      });

      let activeLink = null;
      railLinks.forEach((link) => {
        const railDay = link.dataset.railDay || '';
        const href = link.getAttribute('href') || '';
        const isActive = railDay === dayId || href === `#day-${dayId}`;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
          activeLink = link;
        } else {
          link.removeAttribute('aria-current');
        }
      });

      if (activeLink && scrollRail) {
        activeLink.scrollIntoView({
          block: 'nearest',
          inline: 'nearest',
          behavior: smoothBehavior,
        });
      }

      const mobileTabs = root.querySelectorAll('.itin-chrono__mobile-tab');
      mobileTabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.target === dayId);
      });

      activeDayId = dayId;
    };

    const initializeRailSync = () => {
      if (!railList || !contentRoot) return;

      if (activeDayObserver) {
        activeDayObserver.disconnect();
      }

      const dayCards = Array.from(root.querySelectorAll('.itin-chrono__day[data-day-section]'));
      if (!dayCards.length) return;

      const visibilityByDay = new Map();
      activeDayObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const dayId = entry.target.dataset.daySection;
          if (!dayId) return;

          if (entry.isIntersecting) {
            visibilityByDay.set(dayId, entry.intersectionRatio);
          } else {
            visibilityByDay.delete(dayId);
          }
        });

        if (visibilityByDay.size === 0) return;

        let strongestDay = null;
        let strongestRatio = 0;
        visibilityByDay.forEach((ratio, dayId) => {
          if (ratio > strongestRatio) {
            strongestRatio = ratio;
            strongestDay = dayId;
          }
        });

        if (strongestDay) {
          setActiveDay(strongestDay);
        }
      }, {
        threshold: [0.15, 0.3, 0.45, 0.6, 0.75],
        rootMargin: `${-(getStickyOffset() + 20)}px 0px -55% 0px`,
      });

      dayCards.forEach((dayCard) => activeDayObserver.observe(dayCard));

      const hashMatch = window.location.hash.match(/#day-(\d+)/);
      if (hashMatch) {
        setActiveDay(hashMatch[1], { scrollRail: false });
      } else {
        const firstDay = dayCards[0].dataset.daySection;
        if (firstDay) {
          setActiveDay(firstDay, { scrollRail: false });
        }
      }
    };

    if (previewOpen) {
      previewOpen.addEventListener('click', (event) => {
        if (previewOpen.getAttribute('aria-disabled') === 'true') {
          event.preventDefault();
        }
      });
    }

    if (previewClear) {
      previewClear.addEventListener('click', () => {
        clearPreview();
      });
    }

    root.addEventListener('click', (event) => {
      const railLink = event.target.closest('.itin-chrono__rail-link');
      if (!railLink) return;

      if (
        event.defaultPrevented
        || event.button !== 0
        || event.metaKey
        || event.ctrlKey
        || event.shiftKey
        || event.altKey
      ) {
        return;
      }

      const dayMatch = (railLink.getAttribute('href') || '').match(/#day-(\d+)/);
      if (!dayMatch) return;

      event.preventDefault();
      scrollToDay(dayMatch[1], {
        behavior: smoothBehavior,
        updateHash: true,
        scrollRail: false,
      });
    });

    if (contentRoot) {
      contentRoot.addEventListener('click', (event) => {
        const targetLink = event.target.closest('a');
        if (!targetLink || !contentRoot.contains(targetLink)) return;
        if (!previewEnabled()) return;

        if (
          event.defaultPrevented
          || event.button !== 0
          || event.metaKey
          || event.ctrlKey
          || event.shiftKey
          || event.altKey
          || targetLink.hasAttribute('download')
        ) {
          return;
        }

        const targetAttr = String(targetLink.getAttribute('target') || '').toLowerCase();
        if (targetAttr && targetAttr !== '_blank' && targetAttr !== '_self') {
          return;
        }

        const previewUrl = previewUrlFromAnchor(targetLink);
        if (!previewUrl) return;

        event.preventDefault();
        focusWorkspace();
        const linkTitle = targetLink.textContent.replace(/\s+/g, ' ').trim();
        loadPreviewUrl(previewUrl, { titleHint: linkTitle });
      });
    }

    window.addEventListener('hashchange', () => {
      const hashMatch = window.location.hash.match(/#day-(\d+)/);
      if (!hashMatch) return;

      window.requestAnimationFrame(() => {
        scrollToDay(hashMatch[1], {
          behavior: 'auto',
          updateHash: false,
          scrollRail: true,
        });
      });
    });

    const handlePreviewViewportChange = () => {
      if (!previewEnabled()) {
        setPreviewPanelOpen(false);
        syncActivePreviewLinks();
        return;
      }

      restorePreviewSelection();
    };

    if (typeof previewDesktopMediaQuery.addEventListener === 'function') {
      previewDesktopMediaQuery.addEventListener('change', handlePreviewViewportChange);
    } else if (typeof previewDesktopMediaQuery.addListener === 'function') {
      previewDesktopMediaQuery.addListener(handlePreviewViewportChange);
    }

    window.addEventListener('resize', () => {
      syncStickyOffset();
      initializeRailSync();
    });

    const initLegToggles = () => {
      root.querySelectorAll('.itin-chrono__leg-header[data-leg-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const legId = btn.dataset.legToggle;
          const container = root.querySelector(`#${legId}`);
          if (!container) return;
          const isCollapsed = container.classList.toggle('is-collapsed');
          btn.setAttribute('aria-expanded', String(!isCollapsed));
        });
      });
    };

    const initMobilePicker = () => {
      const picker = root.querySelector('.itin-chrono__mobile-picker');
      if (!picker) return;

      const dayCards = root.querySelectorAll('.itin-chrono__day[data-day-section]');
      dayCards.forEach((dayCard) => {
        const dayId = dayCard.dataset.daySection;
        const titleEl = dayCard.querySelector('.itin-chrono__day-title');
        const label = titleEl ? titleEl.textContent.trim() : `Day ${dayId}`;
        const tab = document.createElement('div');
        tab.className = 'itin-chrono__mobile-tab';
        tab.dataset.target = dayId;
        tab.textContent = label;
        tab.addEventListener('click', () => {
          scrollToDay(dayId, { behavior: smoothBehavior, updateHash: true, scrollRail: false });
          picker.querySelectorAll('.itin-chrono__mobile-tab').forEach((t) => t.classList.remove('is-active'));
          tab.classList.add('is-active');
        });
        picker.appendChild(tab);
      });
    };

    const initBottomSheet = () => {
      const overlay = root.querySelector('[data-bottom-sheet-overlay]');
      if (!overlay) return;

      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) {
          overlay.classList.remove('is-open');
        }
      });
    };

    syncStickyOffset();
    applyPinLinks();
    normalizeRouteLocationLabels(root);
    formatSnoopNarrative(root);
    injectNarrativeCues(root);
    suppressRunSheetWhenLiveWirePresent(root);
    applyPinLinks(root);
    initLegToggles();
    initMobilePicker();
    initBottomSheet();
    initInspectorGuestCounters();
    initInspectorCustomisationLinks();
    initializeRailSync();
    restorePreviewSelection();

    const initialHashMatch = window.location.hash.match(/#day-(\d+)/);
    if (initialHashMatch) {
      window.requestAnimationFrame(() => {
        scrollToDay(initialHashMatch[1], {
          behavior: 'auto',
          updateHash: false,
          scrollRail: false,
        });
      });
    }

    const chronologySource = root.dataset.chronologySource || '';
    const existingDayCount = root.querySelectorAll('.itin-chrono__day').length;
    const canonicalPayloadUrl = root.dataset.itinerarySourceJsonCdnUrl || '';

    if (chronologySource === 'itinerary_source_json_inline' && existingDayCount > 0) {
      return;
    }

    if (!railList || !contentRoot || !canonicalPayloadUrl) {
      return;
    }

    const renderFromPayload = (payload) => {
      const legs = [...(payload.legs || [])].sort((a, b) => Number(fieldValue(a, 'sequence') || 0) - Number(fieldValue(b, 'sequence') || 0));
      const routes = [...(payload.routes || [])].sort((a, b) => Number(fieldValue(a, 'sequence') || 0) - Number(fieldValue(b, 'sequence') || 0));
      const totalDays = Number(payload.days || 0);
      if (!totalDays || legs.length === 0) {
        return false;
      }

      const startDate = fieldValue(payload, 'start_date');
      railList.innerHTML = '';
      contentRoot.innerHTML = '';

      for (let day = 1; day <= totalDays; day += 1) {
        const legInfo = resolveLegForDay(legs, day);
        if (!legInfo) continue;

        const { leg, dayWithinLeg } = legInfo;
        const periods = fieldValue(leg, 'periods') || [];
        const period = periods[dayWithinLeg - 1] || (periods.length === 1 ? periods[0] : null);
        const activities = period ? normalizeActivities(period) : [];
        const commentaryItems = period ? normalizeCommentaryItems(period) : [];
        const insertBlocks = period ? normalizeInsertBlocks(period) : [];
        const checkIn = String(fieldValue(leg, 'check_in_time') || '');
        const checkOut = String(fieldValue(leg, 'check_out_time') || '');
        const accName = fieldValue(leg, 'accommodation_name') || '';
        const destName = fieldValue(leg, 'destination_name') || '';

        const dayRoutes = routes.filter((route) => {
          const startDay = Number(fieldValue(route, 'start_day') || 0);
          const endDay = Number(fieldValue(route, 'end_day') || startDay);
          return startDay === day || endDay === day;
        });

        const timelineRows = [];
        if (checkIn && checkIn !== 'None' && checkIn !== 'NotProvided' && dayWithinLeg === 1) {
          timelineRows.push({
            type: 'context',
            time: checkIn,
            minutes: toMinutes(checkIn),
            rank: 10,
            body: `Check-in${accName ? `: ${escapeHtml(accName)}` : ''}`,
          });
        }

        dayRoutes.forEach((route) => {
          const startPin = fieldValue(route, 'start_content_entity_id');
          const endPin = fieldValue(route, 'end_content_entity_id');
          const startName = fieldValue(route, 'start_location') || `Location PIN ${startPin}`;
          const endName = fieldValue(route, 'end_location') || `Location PIN ${endPin}`;
          const time = String(fieldValue(route, 'start_time') || '');
          const mode = fieldValue(route, 'mode') || 'Transfer';
          const modeLabel = fieldValue(route, 'label') || '';
          timelineRows.push({
            type: 'route',
            time,
            minutes: toMinutes(time),
            rank: 20,
            body: `<span class="itin-chrono__timeline-chip">${escapeHtml(humanizeRouteMode(mode, modeLabel))}</span><span class="itin-chrono__timeline-route">${pinLink(startPin, startName)} &rarr; ${pinLink(endPin, endName)}</span>`,
          });
        });

        activities.forEach((activity) => {
          const pin = fieldValue(activity, 'content_entity_id');
          const name = fieldValue(activity, 'name') || (pin ? `PIN ${pin}` : 'Activity');
          const time = String(fieldValue(activity, 'start_time') || fieldValue(activity, 'end_time') || '');
          timelineRows.push({
            type: 'activity',
            time,
            minutes: toMinutes(time),
            rank: 30,
            body: pin ? pinLink(pin, name) : escapeHtml(name),
          });
        });

        const legType = String(fieldValue(leg, 'type') || '').toLowerCase();
        if (checkOut && checkOut !== 'None' && checkOut !== 'NotProvided' && (legType === 'departure' || day === totalDays)) {
          timelineRows.push({
            type: 'context',
            time: checkOut,
            minutes: toMinutes(checkOut),
            rank: 40,
            body: `Check-out${accName ? `: ${escapeHtml(accName)}` : ''}`,
          });
        }

        timelineRows.sort((a, b) => {
          const minuteDiff = a.minutes - b.minutes;
          if (minuteDiff !== 0) return minuteDiff;
          return (a.rank || 99) - (b.rank || 99);
        });

        const railDate = buildDayDate(startDate, day);
        const railItem = document.createElement('li');
        railItem.className = 'itin-chrono__rail-item';
        railItem.innerHTML = `<a href="#day-${day}" class="itin-chrono__rail-link"><span class="itin-chrono__rail-day">Day ${day}</span>${railDate ? `<span class="itin-chrono__rail-date">${escapeHtml(railDate)}</span>` : ''}</a>`;
        railList.appendChild(railItem);

        const narrativeRaw = period ? fieldValue(period, 'day_narrative') || fieldValue(period, 'consultant_notes') : '';
        const consultantRaw = period ? fieldValue(period, 'consultant_notes') : '';
        const includedRaw = period ? fieldValue(period, 'included') : '';
        const notesRaw = period ? fieldValue(period, 'notes') : '';
        const narrativeHtml = prettyText(narrativeRaw);
        const consultantHtml = prettyText(consultantRaw);
        const includedHtml = prettyText(includedRaw);
        const notesHtml = prettyText(notesRaw);
        const insertBlocksHtml = renderInsertBlocks(insertBlocks);
        const commentaryStreamHtml = renderCommentaryStream(commentaryItems);
        const dayDateDisplay = buildDayDate(startDate, day);

        const article = document.createElement('article');
        article.className = 'itin-chrono__day';
        article.id = `day-${day}`;
        article.setAttribute('data-day-section', String(day));
        const transitionNote = dayRoutes.length > 0
          ? `<p class="itin-chrono__transition-note">Inter-leg transition · ${dayRoutes.length} segment${dayRoutes.length === 1 ? '' : 's'}</p>`
          : '';
        article.innerHTML = `
          <header class="itin-chrono__day-header">
            <div class="itin-chrono__day-meta">
              <span class="itin-chrono__day-number">Day ${day}</span>
              ${dayDateDisplay ? `<span class="itin-chrono__day-date">${escapeHtml(dayDateDisplay)}</span>` : ''}
            </div>
            ${destName ? `<div class="itin-chrono__day-destination">${escapeHtml(destName)}</div>` : ''}
          </header>
          ${timelineRows.length > 0 ? `<section class="itin-chrono__timeline">${transitionNote}<ul class="itin-chrono__timeline-list" role="list">${timelineRows.map((row) => `<li class="itin-chrono__timeline-item${row.type === 'context' ? ' itin-chrono__timeline-item--context' : ''}">${row.time && row.time !== 'None' && row.time !== 'NotProvided' ? `<span class="itin-chrono__timeline-time">${escapeHtml(row.time)}</span>` : '<span></span>'}<span class="itin-chrono__timeline-text">${row.body}</span></li>`).join('')}</ul></section>` : ''}
          ${commentaryStreamHtml}
          ${narrativeHtml ? `<div class="itin-chrono__narrative" data-pin-links>${narrativeHtml}</div>` : ''}
          ${insertBlocksHtml}
          ${notesHtml ? `<details class="itin-chrono__notes" data-pin-links open><summary>Day notes</summary><div class="itin-chrono__notes-body">${notesHtml}</div></details>` : ''}
          ${includedHtml ? `<details class="itin-chrono__notes" data-pin-links><summary>Included today</summary><div class="itin-chrono__notes-body">${includedHtml}</div></details>` : ''}
          ${consultantHtml ? `<details class="itin-chrono__notes" data-pin-links open><summary>Consultant notes</summary><div class="itin-chrono__notes-body">${consultantHtml}</div></details>` : ''}
        `;
        contentRoot.appendChild(article);
      }

      applyPinLinks(contentRoot);
      normalizeRouteLocationLabels(contentRoot);
      formatSnoopNarrative(contentRoot);
      injectNarrativeCues(contentRoot);
      suppressRunSheetWhenLiveWirePresent(contentRoot);
      applyPinLinks(contentRoot);
      initializeRailSync();
      restorePreviewSelection();
      return contentRoot.querySelector('.itin-chrono__day') !== null;
    };

    const fetchAndRenderCanonicalPayload = async () => {
      try {
        const response = await fetch(canonicalPayloadUrl, { credentials: 'omit' });
        if (!response.ok) return;

        const payload = await response.json();
        renderFromPayload(payload);
      } catch (error) {
        // Canonical payload fetch failed; leave chronology empty.
      }
    };

    fetchAndRenderCanonicalPayload();
  });
