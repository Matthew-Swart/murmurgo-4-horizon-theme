    .travel-brief__container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
    
    .travel-brief__map-column {
      aspect-ratio: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }
    
    .travel-brief__content-column {
      min-height: 100%;
    }
    
    .travel-brief__content-inner {
      padding: var(--tb-content-padding);
