  .travel-brief__tabs::-webkit-scrollbar {
    display: none;
  }
  
  .travel-brief__tab {
    position: relative;
    padding: 12px 16px;
    background: none;
    border: none;
    font-size: 14px;
    font-weight: 500;
    color: var(--wetu-text-secondary, rgba(0,0,0,0.6));
    cursor: pointer;
    white-space: nowrap;
