{% comment %} Mapbox CSS {% endcomment %}
<link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css">

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const mapContainerId = 'travel-brief-map-' + sectionId;
  const mapStyle = '{{ section.settings.mapbox_style | default: "mapbox://styles/mapbox/outdoors-v12" }}';
  
  const markersData = {{ markers_json | strip_newlines }};
  const routesData = {{ routes_json | strip_newlines }};
  
  {% comment %} Tab switching functionality {% endcomment %}
  function initTabs() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    
    const tabs = section.querySelectorAll('.travel-brief__tab');
    const panels = section.querySelectorAll('.travel-brief__panel');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetPanel = tab.dataset.tab;
        
        tabs.forEach(t => {
          t.classList.remove('is-active');
          t.setAttribute('aria-selected', 'false');
        });
        
        panels.forEach(p => {
          p.classList.remove('is-active');
          p.hidden = true;
        });
        
        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        
        const activePanel = section.querySelector(`[data-panel="${targetPanel}"]`);
        if (activePanel) {
          activePanel.classList.add('is-active');
          activePanel.hidden = false;
        }
      });
      
      tab.addEventListener('keydown', (e) => {
        const tabsArray = Array.from(tabs);
        const currentIndex = tabsArray.indexOf(tab);
        
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          let nextIndex;
          
          if (e.key === 'ArrowRight') {
            nextIndex = currentIndex < tabsArray.length - 1 ? currentIndex + 1 : 0;
          } else {
            nextIndex = currentIndex > 0 ? currentIndex - 1 : tabsArray.length - 1;
          }
          
          tabsArray[nextIndex].click();
          tabsArray[nextIndex].focus();
        }
      });
    });
  }
  
  {% comment %} Initialize map {% endcomment %}
  function initMap() {
    if (typeof mapboxgl === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }
    
    const mapContainer = document.getElementById(mapContainerId);
    if (!mapContainer) return;
    
    const loadingEl = mapContainer.parentElement.querySelector('.travel-brief__map-loading');
    
    mapboxgl.accessToken = '{{ settings.mapbox_access_token | default: "{{ MAPBOX_ACCESS_TOKEN }}" }}';
    
    if (markersData.length === 0) {
      if (loadingEl) loadingEl.classList.add('is-hidden');
      return;
    }
    
    const bounds = new mapboxgl.LngLatBounds();
    markersData.forEach(m => bounds.extend([m.lng, m.lat]));
    
    const map = new mapboxgl.Map({
      container: mapContainerId,
      style: mapStyle,
      bounds: bounds,
      fitBoundsOptions: { padding: 60 },
      interactive: true,
      attributionControl: false
    });
    
    map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'bottom-right');
    
    map.on('load', () => {
      if (loadingEl) loadingEl.classList.add('is-hidden');
      
      if (routesData.length > 0) {
        routesData.forEach((route, index) => {
          const coordinates = [
            [route.startLng, route.startLat],
            [route.endLng, route.endLat]
          ];
          
          map.addSource('route-' + index, {
            type: 'geojson',
            data: {
              type: 'Feature',
              geometry: {
                type: 'LineString',
                coordinates: coordinates
              }
            }
          });
          
          map.addLayer({
            id: 'route-line-' + index,
            type: 'line',
            source: 'route-' + index,
            layout: {
              'line-join': 'round',
              'line-cap': 'round'
            },
            paint: {
              'line-color': route.isFlight ? '#8b5cf6' : '#10b981',
              'line-width': 2.5,
              'line-opacity': 0.8,
              'line-dasharray': route.isFlight ? [2, 2] : [1, 0]
            }
          });
        });
      }
      
      markersData.forEach((marker, index) => {
        const el = document.createElement('div');
        el.className = 'travel-brief-marker';
        el.innerHTML = `<span>${marker.sequence}</span>`;
        el.style.cssText = `
          width: 28px;
          height: 28px;
          background: #2563eb;
          border: 2px solid #fff;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          color: #fff;
          font-size: 12px;
          font-weight: 600;
          cursor: pointer;
          box-shadow: 0 2px 8px rgba(0,0,0,0.3);
          transition: transform 0.15s ease;
        `;
        
        el.addEventListener('mouseenter', () => {
          el.style.transform = 'scale(1.15)';
        });
        el.addEventListener('mouseleave', () => {
          el.style.transform = 'scale(1)';
        });
        
        const popup = new mapboxgl.Popup({
          offset: 20,
          closeButton: false,
          closeOnClick: false
        }).setHTML(`
          <div style="padding: 8px 12px; font-size: 13px;">
            <strong>${marker.name}</strong>
            <div style="color: #666; font-size: 12px; margin-top: 2px;">
              ${marker.nights} ${marker.nights === 1 ? 'night' : 'nights'}
            </div>
          </div>
        `);
        
        const markerInstance = new mapboxgl.Marker(el)
          .setLngLat([marker.lng, marker.lat])
          .setPopup(popup)
          .addTo(map);
        
        el.addEventListener('mouseenter', () => popup.addTo(map));
        el.addEventListener('mouseleave', () => popup.remove());
      });
    });
  }
  
  {% comment %} Load Mapbox and initialize {% endcomment %}
  function loadMapbox() {
    if (typeof mapboxgl !== 'undefined') {
      initMap();
      return;
    }
    
    const script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js';
    script.onload = initMap;
    document.head.appendChild(script);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initTabs();
      loadMapbox();
    });
  } else {
    initTabs();
    loadMapbox();
  }
})();
</script>

