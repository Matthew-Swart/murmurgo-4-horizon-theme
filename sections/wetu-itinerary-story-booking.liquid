{% comment %}
  ============================================================================
  WETU ITINERARY STORY BOOKING SECTION
  ============================================================================

  Final booking section at bottom of itinerary with:
  - Seasonal pricing table from WETU
  - Full booking widget
  - What's included/excluded
  - Operator contact details
  - Trust badges

  ============================================================================
{% endcomment %}

{% comment %} Load itinerary data {% endcomment %}
{% include 'wetu-itinerary-data' %}

{% assign itinerary_metaobject = product.metafields.wetu.itinerary_metaobject.value %}
{% assign wetu_price = itinerary_metaobject.price.value | default: '' %}
{% assign price_includes = itinerary_metaobject.price_includes.value | default: '' %}
{% assign price_excludes = itinerary_metaobject.price_excludes.value | default: '' %}
{% assign wetu_contacts = itinerary_metaobject.contacts.value | default: '' %}

{% comment %} Parse includes - handle newlines, multiple spaces, and sentences {% endcomment %}
{% capture includes_parsed %}
  {% if price_includes != blank %}
    {% assign includes_text = price_includes | newline_to_br | split: '<br />' %}
    {% for line in includes_text %}
      {% assign cleaned_line = line | strip %}
      {% if cleaned_line != blank %}
        {% comment %} Check if line has multiple items separated by multiple spaces {% endcomment %}
        {% assign space_test = cleaned_line | split: '   ' %}
        {% if space_test.size > 1 %}
          {% for subitem in space_test %}
            {% assign cleaned_subitem = subitem | strip %}
            {% if cleaned_subitem != blank and cleaned_subitem.size > 3 %}
              {{ cleaned_subitem }}|||
            {% endif %}
          {% endfor %}
        {% else %}
          {{ cleaned_line }}|||
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endcapture %}
{% assign includes_array = includes_parsed | strip | split: '|||' %}

{% comment %} Parse excludes - same logic {% endcomment %}
{% capture excludes_parsed %}
  {% if price_excludes != blank %}
    {% assign excludes_text = price_excludes | newline_to_br | split: '<br />' %}
    {% for line in excludes_text %}
      {% assign cleaned_line = line | strip %}
      {% if cleaned_line != blank %}
        {% assign space_test = cleaned_line | split: '   ' %}
        {% if space_test.size > 1 %}
          {% for subitem in space_test %}
            {% assign cleaned_subitem = subitem | strip %}
            {% if cleaned_subitem != blank and cleaned_subitem.size > 3 %}
              {{ cleaned_subitem }}|||
            {% endif %}
          {% endfor %}
        {% else %}
          {{ cleaned_line }}|||
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endcapture %}
{% assign excludes_array = excludes_parsed | strip | split: '|||' %}

<section
  class="itinerary-booking-section color-{{ section.settings.color_scheme }}"
  id="booking"
  aria-labelledby="booking-heading"
>
  <div class="page-width">

    {% comment %} Section Header {% endcomment %}
    <header class="itinerary-booking-section__header">
      <h2 class="itinerary-booking-section__heading" id="booking-heading">
        {{ section.settings.heading | default: 'Pricing & Booking' }}
      </h2>
      {% if section.settings.subheading != blank %}
        <p class="itinerary-booking-section__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </header>

    {% comment %} ============================================
         PRICING TABLE SECTION
         ============================================ {% endcomment %}
    {% if wetu_price != blank %}
      <div class="itinerary-pricing-table">
        <div class="itinerary-pricing-table__header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
          <h3>Seasonal Pricing</h3>
        </div>
        <div class="itinerary-pricing-table__content">
          {{ wetu_price }}
        </div>
      </div>
    {% endif %}

    <div class="itinerary-booking-section__grid">

      {% comment %} Left: Includes/Excludes {% endcomment %}
      <div class="itinerary-booking-section__details">

        {% comment %} What's Included {% endcomment %}
        {% if includes_array.size > 0 or section.settings.default_includes != blank %}
          <div class="itinerary-booking-section__includes">
            <h3 class="itinerary-booking-section__list-heading">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              What's Included
            </h3>
            <ul class="itinerary-booking-section__list itinerary-booking-section__list--included">
              {% if includes_array.size > 0 %}
                {% for item in includes_array %}
                  {% assign cleaned_item = item | strip %}
                  {% if cleaned_item != blank %}
                    <li>
                      <svg class="itinerary-booking-section__list-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span>{{ cleaned_item }}</span>
                    </li>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% assign default_includes = section.settings.default_includes | split: '|' %}
                {% for item in default_includes %}
                  <li>
                    <svg class="itinerary-booking-section__list-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span>{{ item | strip }}</span>
                  </li>
                {% endfor %}
              {% endif %}
            </ul>
          </div>
        {% endif %}

        {% comment %} What's Excluded {% endcomment %}
        {% if excludes_array.size > 0 or section.settings.default_excludes != blank %}
          <div class="itinerary-booking-section__excludes">
            <h3 class="itinerary-booking-section__list-heading">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
              </svg>
              Not Included
            </h3>
            <ul class="itinerary-booking-section__list itinerary-booking-section__list--excluded">
              {% if excludes_array.size > 0 %}
                {% for item in excludes_array %}
                  {% assign cleaned_item = item | strip %}
                  {% if cleaned_item != blank %}
                    <li>
                      <svg class="itinerary-booking-section__list-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                      </svg>
                      <span>{{ cleaned_item }}</span>
                    </li>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% assign default_excludes = section.settings.default_excludes | split: '|' %}
                {% for item in default_excludes %}
                  <li>
                    <svg class="itinerary-booking-section__list-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    <span>{{ item | strip }}</span>
                  </li>
                {% endfor %}
              {% endif %}
            </ul>
          </div>
        {% endif %}

        {% comment %} ============================================
             OPERATOR CONTACT SECTION
             ============================================ {% endcomment %}
        {% if wetu_contacts != blank %}
          {% assign contacts = wetu_contacts %}
          {% if contacts.size > 0 %}
            <div class="itinerary-booking-section__operator">
              <h3 class="itinerary-booking-section__list-heading">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                Tour Operator
              </h3>
              {% for contact in contacts %}
                <div class="itinerary-operator-card">
                  {% if contact.company %}
                    <h4 class="itinerary-operator-card__company">{{ contact.company }}</h4>
                  {% endif %}

                  <div class="itinerary-operator-card__details">
                    {% if contact.contact_person %}
                      <div class="itinerary-operator-card__row">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                          <circle cx="12" cy="7" r="4"/>
                        </svg>
                        <span>{{ contact.contact_person }}</span>
                      </div>
                    {% endif %}

                    {% if contact.email %}
                      <div class="itinerary-operator-card__row">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                          <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
                      </div>
                    {% endif %}

                    {% if contact.telephone %}
                      <div class="itinerary-operator-card__row">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        <a href="tel:{{ contact.telephone | remove: ' ' }}">{{ contact.telephone }}</a>
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}

        {% comment %} Trust Badges {% endcomment %}
        <div class="itinerary-booking-section__trust">
          <div class="itinerary-booking-section__trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <span>Secure Payment</span>
          </div>
          <div class="itinerary-booking-section__trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Instant Confirmation</span>
          </div>
          <div class="itinerary-booking-section__trust-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <span>24/7 Support</span>
          </div>
        </div>
      </div>

      {% comment %} Right: Booking Widget {% endcomment %}
      <div class="itinerary-booking-section__widget">
        {% render 'wetu-itinerary-booking-widget',
          product: product,
          variant: 'full',
          show_guests: true,
          show_customize: true
        %}

        {% comment %} Alternative Contact {% endcomment %}
        <div class="itinerary-booking-section__contact">
          <p>Have questions or need a custom itinerary?</p>
          <a href="{{ section.settings.contact_page | default: '/pages/contact' }}" class="itinerary-booking-section__contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Contact Our Travel Experts
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* ====================================
   Itinerary Booking Section
   ==================================== */

.itinerary-booking-section {
  padding: 80px 0;
  background: var(--color-background);
}

.itinerary-booking-section__header {
  text-align: center;
  margin-bottom: 48px;
}

.itinerary-booking-section__heading {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 12px;
}

.itinerary-booking-section__subheading {
  font-size: 1rem;
  color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  margin: 0;
  max-width: 500px;
  margin-left: auto;
  margin-right: auto;
}

/* ====================================
   Pricing Table
   ==================================== */

.itinerary-pricing-table {
  max-width: 900px;
  margin: 0 auto 48px;
  background: color-mix(in srgb, var(--color-foreground) 2%, transparent);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  overflow: hidden;
}

.itinerary-pricing-table__header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 20px 24px;
  background: var(--color-primary);
  color: var(--color-background);
}

.itinerary-pricing-table__header h3 {
  margin: 0;
  font-size: 1.125rem;
  font-weight: 600;
}

.itinerary-pricing-table__header svg {
  flex-shrink: 0;
}

.itinerary-pricing-table__content {
  padding: 24px;
  font-size: 0.9375rem;
  line-height: 1.8;
  color: var(--color-foreground);
}

/* Style the WETU price HTML content */
.itinerary-pricing-table__content p {
  margin: 0 0 8px;
}

.itinerary-pricing-table__content strong,
.itinerary-pricing-table__content b {
  color: var(--color-foreground);
  font-weight: 600;
}

/* Parse seasonal headers (usually bold/strong text with dates) */
.itinerary-pricing-table__content br {
  display: block;
  content: '';
  margin-bottom: 4px;
}

/* Style for season blocks - targeting text that looks like headers */
.itinerary-pricing-table__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* Grid Layout */
.itinerary-booking-section__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: start;
}

@media (min-width: 1024px) {
  .itinerary-booking-section__grid {
    grid-template-columns: 1fr 500px;
    gap: 64px;
  }
}

/* Details Column */
.itinerary-booking-section__details {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

.itinerary-booking-section__list-heading {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-foreground);
  margin: 0 0 16px;
}

.itinerary-booking-section__list-heading svg {
  flex-shrink: 0;
}

.itinerary-booking-section__list {
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 12px;
}

.itinerary-booking-section__list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.9375rem;
  line-height: 1.5;
  color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
}

.itinerary-booking-section__list-icon {
  flex-shrink: 0;
  margin-top: 2px;
}

.itinerary-booking-section__list--included .itinerary-booking-section__list-icon {
  color: #22c55e;
}

.itinerary-booking-section__list--excluded .itinerary-booking-section__list-icon {
  color: color-mix(in srgb, var(--color-foreground) 40%, transparent);
}

.itinerary-booking-section__list li span {
  flex: 1;
}

/* ====================================
   Operator Contact Card
   ==================================== */

.itinerary-booking-section__operator {
  padding: 24px;
  background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  border-radius: 12px;
}

.itinerary-operator-card {
  margin-top: 16px;
}

.itinerary-operator-card__company {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-foreground);
  margin: 0 0 16px;
}

.itinerary-operator-card__details {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.itinerary-operator-card__row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9375rem;
  color: var(--color-foreground);
}

.itinerary-operator-card__row svg {
  flex-shrink: 0;
  color: var(--color-primary);
}

.itinerary-operator-card__row a {
  color: var(--color-primary);
  text-decoration: none;
  word-break: break-all;
}

.itinerary-operator-card__row a:hover {
  text-decoration: underline;
}

/* Trust Badges */
.itinerary-booking-section__trust {
  display: flex;
  flex-wrap: wrap;
  gap: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--color-border);
}

.itinerary-booking-section__trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.875rem;
  color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
}

.itinerary-booking-section__trust-item svg {
  flex-shrink: 0;
  color: var(--color-primary);
}

/* Widget Column */
.itinerary-booking-section__widget {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

@media (min-width: 1024px) {
  .itinerary-booking-section__widget {
    position: sticky;
    top: 100px;
  }
}

/* Contact */
.itinerary-booking-section__contact {
  text-align: center;
  padding: 20px;
  background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
  border-radius: 12px;
}

.itinerary-booking-section__contact p {
  font-size: 0.9375rem;
  color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  margin: 0 0 12px;
}

.itinerary-booking-section__contact-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-primary);
  text-decoration: none;
}

.itinerary-booking-section__contact-link:hover {
  text-decoration: underline;
}

/* ====================================
   Responsive
   ==================================== */

@media (max-width: 640px) {
  .itinerary-booking-section {
    padding: 48px 0 120px; /* Extra padding for sticky bar */
  }

  .itinerary-booking-section__grid {
    gap: 32px;
  }

  .itinerary-pricing-table {
    margin-bottom: 32px;
    border-radius: 12px;
  }

  .itinerary-pricing-table__header {
    padding: 16px 20px;
  }

  .itinerary-pricing-table__content {
    padding: 20px;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .itinerary-booking-section__trust {
    flex-direction: column;
    gap: 16px;
  }

  .itinerary-booking-section__operator {
    padding: 20px;
  }

  .itinerary-operator-card__row {
    font-size: 0.875rem;
  }
}
</style>

{% schema %}
{
  "name": "Itinerary Booking Section",
  "tag": "section",
  "class": "section-itinerary-booking",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pricing & Booking"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Review what's included and secure your adventure today."
    },
    {
      "type": "header",
      "content": "Default inclusions"
    },
    {
      "type": "textarea",
      "id": "default_includes",
      "label": "Default included items (separated by |)",
      "info": "Used as fallback when WETU data is not available",
      "default": "Accommodation as indicated|Meals as specified|Park entry fees|Local transfers|24/7 support"
    },
    {
      "type": "textarea",
      "id": "default_excludes",
      "label": "Default excluded items (separated by |)",
      "info": "Used as fallback when WETU data is not available",
      "default": "International flights|Travel insurance|Personal expenses|Gratuities|Visa fees"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "url",
      "id": "contact_page",
      "label": "Contact page URL"
    }
  ],
  "presets": [
    {
      "name": "Itinerary Booking Section"
    }
  ]
}
{% endschema %}
