================================================================ {% endcomment %}

<script>
(function() {
  'use strict';

  // Lightbox functionality
  window.openLightbox = function(src, alt) {
    if (!src) return;
    
    var modal = document.createElement('div');
    modal.className = 'itinerary-lightbox';
    modal.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.95);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transition:opacity 0.3s ease;';
    modal.innerHTML = '<img src="' + src + '" alt="' + (alt || '') + '" style="max-width:90%;max-height:90vh;object-fit:contain;transform:scale(0.95);transition:transform 0.3s ease;"><button style="position:absolute;top:20px;right:20px;background:rgba(255,255,255,0.1);border:none;color:#fff;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:24px;backdrop-filter:blur(8px);">×</button>';
    
    var close = function() {
      modal.style.opacity = '0';
      setTimeout(function() { 
        if (modal.parentNode) modal.parentNode.removeChild(modal); 
      }, 300);
    };
    
    modal.onclick = close;
    modal.onkeydown = function(e) { if (e.key === 'Escape') close(); };
    
    document.body.appendChild(modal);
    modal.focus();
    
    requestAnimationFrame(function() {
      modal.style.opacity = '1';
      modal.querySelector('img').style.transform = 'scale(1)';
    });
  };

  // Scroll Animation for Editorial Layout
  function initScrollAnimations() {
    var editorialLegs = document.querySelectorAll('.editorial-leg');
    if (!editorialLegs.length) return;
    
    // Respect reduced motion preference
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      editorialLegs.forEach(function(leg) { leg.classList.add('is-visible'); });
      return;
    }
    
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, {
      root: null,
      rootMargin: '0px 0px -10% 0px',
      threshold: 0.1
    });
    
    editorialLegs.forEach(function(leg) {
      observer.observe(leg);
    });
  }

  // Day Navigator Integration
  function initDayNavigator() {
    var daysContainer = document.getElementById('itinerary-days-container');
    if (!daysContainer) return;
    
    var daySections = daysContainer.querySelectorAll('.itinerary-day');
    
    // Update active day indicator on scroll
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var dayNum = entry.target.dataset.day;
          // Dispatch custom event for navigator to update
          window.dispatchEvent(new CustomEvent('itinerary:day-visible', {
            detail: { day: dayNum }
          }));
        }
      });
    }, {
      root: null,
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0
    });
    
    daySections.forEach(function(section) {
      observer.observe(section);
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initScrollAnimations();
      initDayNavigator();
    });
  } else {
    initScrollAnimations();
    initDayNavigator();
  }
})();

document.addEventListener('DOMContentLoaded', () => {
  // Build lookup map from Liquid variables
  const wetuActivityMap = {
    {% for id in activity_map_ids_array %}
      {% if id != blank %}
        "{{ id | strip }}": "{{ activity_map_handles_array[forloop.index0] | strip }}",
      {% endif %}
    {% endfor %}
  };

  // Parse custom PIN links in notes (Pattern: PIN:ID|Text wrapped in double curly braces)
  // These are injected by the uploader to survive Wetu sanitization
  // Note: Using string concatenation to avoid Liquid syntax conflict
  const notesElements = document.querySelectorAll('.itinerary-day__notes-content, .period-notes, .day-notes');
  
  notesElements.forEach(el => {
    // Look for pattern
    if (el.innerHTML.includes('{' + '{PIN:')) {
      // Replace with Shopify product link
      // Uses map if available, otherwise falls back to wetu-{id} convention
      // Using RegExp constructor to avoid Liquid processing of curly braces
      const pinRegex = new RegExp('{' + '{PIN:(\\d+)\\|([^}]+)}' + '}', 'g');
      
      el.innerHTML = el.innerHTML.replace(pinRegex, (match, id, text) => {
        const handle = wetuActivityMap[id] || `wetu-${id}`;
        return `<a href="/products/${handle}" class="text-link wetu-product-link" style="color: var(--color-primary); text-decoration: underline;">${text}</a>`;
      });
    }
  });
});
</script>

