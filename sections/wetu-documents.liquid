{% liquid
  # Section settings
  assign heading = section.settings.heading
  assign show_categories = section.settings.show_categories
  assign layout = section.settings.layout
  assign color_scheme = section.settings.color_scheme
  
  # Get documents from product
  assign documents = product.metafields.wetu.documents.value
  
  # Check if we have documents (MetaobjectListDrop doesn't support .size)
  assign show_section = false
  if documents
    for doc in documents limit: 1
      assign show_section = true
    endfor
  endif
%}

{% if show_section %}
  <div 
    class="section-wetu-documents color-{{ color_scheme }} gradient section-{{ section.id }}-padding"
    style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  >
    <div class="page-width">
      {% render 'wetu-documents-display',
        product: product,
        heading: heading,
        show_categories: show_categories,
        layout: layout
      %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Wetu Documents",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Documents & Resources",
      "info": "Leave blank to use default translation"
    },
    {
      "type": "checkbox",
      "id": "show_categories",
      "label": "Group by category",
      "default": true,
      "info": "Group documents by type (Fact Sheets, Rates, Maps, etc.)"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "list",
          "label": "List"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "list"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "scheme-1",
          "label": "Scheme 1"
        },
        {
          "value": "scheme-2",
          "label": "Scheme 2"
        },
        {
          "value": "scheme-3",
          "label": "Scheme 3"
        },
        {
          "value": "scheme-4",
          "label": "Scheme 4"
        },
        {
          "value": "scheme-5",
          "label": "Scheme 5"
        }
      ],
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Wetu Documents"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}

{% stylesheet %}
  .section-wetu-documents {
    margin-top: 0 !important;
    margin-left: 0;
    margin-right: 0;
    background-color: #f8f8f8;
    width: 100vw;
    max-width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }
  
  .section-wetu-documents .page-width {
    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: var(--page-width-margin, 1.5rem);
    padding-right: var(--page-width-margin, 1.5rem);
  }
  
  @media screen and (min-width: 750px) {
    .section-wetu-documents .page-width {
      padding-left: var(--page-width-margin, 3rem);
      padding-right: var(--page-width-margin, 3rem);
    }
  }
{% endstylesheet %}
