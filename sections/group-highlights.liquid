{% liquid
  assign section_id = section.settings.custom_id | default: section.id
  assign section_class = 'group-highlights'
  assign properties_collection = collections[section.settings.collection] | default: collections.properties
  
  # Initialize aggregation variables
  assign total_accommodations = 0
  assign total_activities = 0
  assign total_restaurants = 0
  assign total_spas = 0
  assign countries_array = ''
  assign regions_array = ''
  assign unique_experiences = ''
  
  # Aggregate data from all properties
  for product in properties_collection.products
    assign accommodations_ref = product.metafields.wetu.accommodation_collection.value
    assign activities_ref = product.metafields.wetu.activities_collection.value
    assign restaurants_ref = product.metafields.wetu.restaurants_collection.value
    assign spa_ref = product.metafields.wetu.spa_collection.value
    
    if accommodations_ref
      assign total_accommodations = total_accommodations | plus: accommodations_ref.products_count
    endif
    if activities_ref
      assign total_activities = total_activities | plus: activities_ref.products_count
    endif
    if restaurants_ref
      assign total_restaurants = total_restaurants | plus: restaurants_ref.products_count
    endif
    if spa_ref
      assign total_spas = total_spas | plus: spa_ref.products_count
    endif
    
    assign product_country = product.metafields.wetu.country.value
    assign product_region = product.metafields.wetu.region.value
    
    unless countries_array contains product_country
      if countries_array != blank
        assign countries_array = countries_array | append: '|'
      endif
      assign countries_array = countries_array | append: product_country
    endunless
    
    unless regions_array contains product_region
      if regions_array != blank
        assign regions_array = regions_array | append: '|'
      endif
      assign regions_array = regions_array | append: product_region
    endunless
  endfor
  
  assign countries = countries_array | split: '|'
  assign regions = regions_array | split: '|'
%}

<section
  id="{{ section_id }}"
  class="{{ section_class }} section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="group-highlights__container page-width">
    
    {% comment %} Main heading {% endcomment %}
    {% if section.settings.heading != blank %}
      <h2 class="group-highlights__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% comment %} Key statistics - at a glance {% endcomment %}
    <div class="group-highlights__stats">
      <div class="stats__primary">
        <p class="stats__stat">
          <strong>{{ properties_collection.products.size }}</strong> 
          {{ 'sections.group_highlights.unique_properties' | t }}{% if total_accommodations > 0 %},{% endif %}
          {% if total_accommodations > 0 %}
            <strong>{{ total_accommodations }}</strong> {{ 'sections.group_highlights.luxury_spaces' | t }}
          {% endif %}
        </p>
      </div>
      
      {% if regions.size > 0 or countries.size > 0 %}
        <div class="stats__geography">
          {% if regions.size > 0 %}
            <p class="stats__stat">
              <strong>{{ regions.size }}</strong> 
              {{ 'sections.group_highlights.iconic_destinations' | t }}: 
              <span class="geography__list">{{ regions | join: ', ' }}</span>
            </p>
          {% endif %}
          {% if countries.size > 0 %}
            <p class="stats__country">{{ countries | join: ' · ' | upcase }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
    
    {% comment %} Signature experiences section {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="group-highlights__experiences">
        <h3 class="experiences__heading">
          {{ section.settings.experiences_heading | default: 'Signature Experiences' }}
        </h3>
        
        <div class="experiences__grid">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'experience' %}
                <div class="experience__item" {{ block.shopify_attributes }}>
                  {% if block.settings.experience_title != blank %}
                    <h4 class="experience__title">{{ block.settings.experience_title }}</h4>
                  {% endif %}
                  {% if block.settings.experience_description != blank %}
                    <p class="experience__description">{{ block.settings.experience_description }}</p>
                  {% endif %}
                  {% if block.settings.link_to_product != blank %}
                    <a href="{{ block.settings.link_to_product.url }}" class="experience__link">
                      {{ 'sections.group_highlights.explore' | t }} →
                    </a>
                  {% elsif block.settings.link_to_collection != blank %}
                    <a href="{{ block.settings.link_to_collection.url }}" class="experience__link">
                      {{ 'sections.group_highlights.view_collection' | t }} →
                    </a>
                  {% endif %}
                </div>
              
              {% when 'highlight_stat' %}
                <div class="experience__stat" {{ block.shopify_attributes }}>
                  {% if block.settings.stat_number != blank %}
                    <p class="stat__number">{{ block.settings.stat_number }}</p>
                  {% endif %}
                  {% if block.settings.stat_label != blank %}
                    <p class="stat__label">{{ block.settings.stat_label }}</p>
                  {% endif %}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
    
    {% comment %} Call to action {% endcomment %}
    {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
      <div class="group-highlights__cta">
        <a href="{{ section.settings.cta_link }}" class="btn btn--primary">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}
    
  </div>
</section>

{% stylesheet %}
  .group-highlights {
    --gh-heading-size: clamp(3.2rem, 5vw, 5.2rem);
    --gh-stat-size: clamp(2.4rem, 3.5vw, 3.6rem);
    --gh-body-size: clamp(1.5rem, 1.8vw, 1.8rem);
    --gh-exp-title-size: clamp(1.8rem, 2.2vw, 2.2rem);
    --gh-spacing: clamp(4rem, 8vw, 10rem);
  }
  
  .group-highlights__container {
    max-width: 90rem;
    margin: 0 auto;
  }
  
  .group-highlights__heading {
    font-size: var(--gh-heading-size);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 3rem;
    text-align: center;
  }
  
  /* Statistics section */
  .group-highlights__stats {
    margin-bottom: var(--gh-spacing);
    text-align: center;
  }
  
  .stats__primary {
    margin-bottom: 2rem;
  }
  
  .stats__stat {
    font-size: var(--gh-body-size);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  
  .stats__stat strong {
    font-size: var(--gh-stat-size);
    font-weight: 400;
    display: inline-block;
    margin: 0 0.3em;
  }
  
  .geography__list {
    font-style: italic;
    opacity: 0.9;
  }
  
  .stats__country {
    font-size: 1.2rem;
    letter-spacing: 0.3em;
    font-weight: 500;
    opacity: 0.6;
    margin-top: 1.5rem;
  }
  
  /* Experiences section */
  .group-highlights__experiences {
    margin-bottom: var(--gh-spacing);
  }
  
  .experiences__heading {
    font-size: var(--gh-exp-title-size);
    font-weight: 400;
    margin-bottom: 4rem;
    text-align: center;
    letter-spacing: -0.01em;
  }
  
  .experiences__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  @media screen and (min-width: 750px) {
    .experiences__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4rem 6rem;
    }
  }
  
  @media screen and (min-width: 990px) {
    .experiences__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .experience__item {
    text-align: left;
  }
  
  .experience__title {
    font-size: 1.9rem;
    font-weight: 400;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  
  .experience__description {
    font-size: 1.5rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    opacity: 0.85;
    font-weight: 300;
  }
  
  .experience__link {
    font-size: 1.4rem;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease;
    font-weight: 400;
  }
  
  .experience__link:hover {
    transform: translateX(0.5rem);
  }
  
  .experience__stat {
    text-align: left;
    border-left: 2px solid currentColor;
    padding-left: 2rem;
  }
  
  .stat__number {
    font-size: 3rem;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  
  .stat__label {
    font-size: 1.4rem;
    opacity: 0.7;
    font-weight: 300;
    line-height: 1.4;
  }
  
  /* CTA */
  .group-highlights__cta {
    text-align: center;
    margin-top: var(--gh-spacing);
  }
  
  /* Minimalist enhancements */
  @media screen and (min-width: 750px) {
    .group-highlights__stats {
      padding: 0 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Group Highlights",
  "tag": "section",
  "class": "group-highlights-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Properties collection",
      "info": "Select the collection containing your properties"
    },
    {
      "type": "header",
      "content": "Signature Experiences"
    },
    {
      "type": "text",
      "id": "experiences_heading",
      "label": "Experiences heading",
      "default": "Signature Experiences"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "experience",
      "name": "Experience",
      "settings": [
        {
          "type": "text",
          "id": "experience_title",
          "label": "Title",
          "default": "Hot Air Balloon Safaris"
        },
        {
          "type": "textarea",
          "id": "experience_description",
          "label": "Description",
          "default": "Soar above the Mara at sunrise, witnessing breathtaking views and unparalleled wildlife spotting opportunities."
        },
        {
          "type": "product",
          "id": "link_to_product",
          "label": "Link to product (optional)"
        },
        {
          "type": "collection",
          "id": "link_to_collection",
          "label": "Link to collection (optional)",
          "info": "Used if no product is selected"
        }
      ]
    },
    {
      "type": "highlight_stat",
      "name": "Highlight Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Number/Stat",
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "stat_label",
          "label": "Label",
          "default": "Eco-Tourism Kenya Awards"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Group Highlights",
      "blocks": [
        {
          "type": "experience",
          "settings": {
            "experience_title": "Hot Air Balloon Safaris",
            "experience_description": "Soar above the Mara at sunrise, witnessing breathtaking views and unparalleled wildlife spotting opportunities."
          }
        },
        {
          "type": "experience",
          "settings": {
            "experience_title": "Legendary Game Drives",
            "experience_description": "Explore iconic landscapes with expert guides on twice-daily game drives, seeking out the Big 5 and more."
          }
        },
        {
          "type": "experience",
          "settings": {
            "experience_title": "Conservation Experiences",
            "experience_description": "Participate in vital conservation work, including lion tracking and learning about cheetah conservation projects."
          }
        },
        {
          "type": "highlight_stat",
          "settings": {
            "stat_number": "50+",
            "stat_label": "years of safari excellence"
          }
        }
      ]
    }
  ]
}
{% endschema %}
