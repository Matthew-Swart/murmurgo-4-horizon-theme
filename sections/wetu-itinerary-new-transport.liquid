{% schema %}
{
  "name": "New Transport Summary",
  "tag": "section",
  "class": "section-itin-new-transport",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Transport Summary"
    },
    {
      "type": "header",
      "content": "Flights"
    },
    {
      "type": "checkbox",
      "id": "show_flights",
      "label": "Show flights table",
      "default": true
    },
    {
      "type": "text",
      "id": "flights_heading",
      "label": "Flights heading",
      "default": "Flights"
    },
    {
      "type": "header",
      "content": "Road Routes"
    },
    {
      "type": "checkbox",
      "id": "show_road_routes",
      "label": "Show road routes table",
      "default": true
    },
    {
      "type": "text",
      "id": "road_routes_heading",
      "label": "Road routes heading",
      "default": "Road Routes"
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    {
      "type": "checkbox",
      "id": "show_duration",
      "label": "Show drive duration",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_distance",
      "label": "Show distance",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_directions",
      "label": "Show driving directions",
      "default": true,
      "info": "Expandable turn-by-turn directions"
    },
    {
      "type": "checkbox",
      "id": "show_maps_link",
      "label": "Show Google Maps link",
      "default": true,
      "info": "Direct navigation link using driving coordinates"
    }
  ],
  "presets": [
    {
      "name": "New Transport Summary",
      "settings": {
        "color_scheme": "scheme-5",
        "heading": "Transport Summary",
        "show_flights": true,
        "flights_heading": "Flights",
        "show_road_routes": true,
        "road_routes_heading": "Road Routes"
      }
    }
  ]
}
{% endschema %}
