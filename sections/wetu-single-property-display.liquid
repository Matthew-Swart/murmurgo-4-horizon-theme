{% comment %}
  WETU Single Property Display Section
  
  Displays detailed information for a single property on the homepage.
  Fetches the single property from the 'properties' collection and displays
  it using the same layout as the product page, but optimized for homepage use.
{% endcomment %}

{% liquid
  assign properties_collection = collections['properties']
  assign property_count = properties_collection.products_count
  assign single_property = properties_collection.products.first
  
  comment Only render if there's exactly one property
  endcomment
  assign should_render = false
  if property_count == 1 and single_property
    assign should_render = true
  endif
%}

{% if should_render %}
  {% comment %} Hero Section - matches product page hero {% endcomment %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div 
    class="wetu-single-property spacing-style section color-{{ section.settings.color_scheme }}"
    style="
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-block-start: var(--section-padding-top);
      padding-block-end: var(--section-padding-bottom);
    "
  >
    {% comment %} Hero Image Section {% endcomment %}
    {% if single_property.featured_image %}
      <div class="wetu-single-property__hero section--full-width">
        <div class="wetu-single-property__hero-image-wrapper">
          {{
            single_property.featured_image
            | image_url: width: 3840
            | image_tag:
              width: single_property.featured_image.width,
              widths: '832, 1200, 1600, 1920, 2560, 3840',
              height: single_property.featured_image.height,
              alt: single_property.featured_image.alt,
              class: 'wetu-single-property__hero-image',
              sizes: '100vw',
              fetchpriority: 'high'
          }}
          <div class="wetu-single-property__hero-overlay"></div>
          {% comment %} Title on bottom-left, pricing on bottom-right {% endcomment %}
          {% render 'wetu-pricing-overlay', product: single_property, position: 'bottom-left', size: 'large', show_title: true, show_pricing: false %}
          {% render 'wetu-pricing-overlay', product: single_property, position: 'bottom-right', size: 'medium', show_title: false, show_pricing: true %}
        </div>
      </div>
    {% endif %}

    {% comment %} Product Details Section {% endcomment %}
    <div class="wetu-single-property__details page-width">
      <div class="wetu-single-property__grid">
        {% comment %} Media Gallery {% endcomment %}
        {% if single_property.media.size > 0 %}
          <div class="wetu-single-property__media">
            <div class="wetu-single-property__media-grid">
              {% for media in single_property.media limit: 6 %}
                {% if media.media_type == 'image' %}
                  <div class="wetu-single-property__media-item">
                    {{
                      media
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800, 1000',
                        class: 'wetu-single-property__image'
                    }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% comment %} Product Information {% endcomment %}
        <div class="wetu-single-property__info">
          {% comment %} Accommodation Headline for accommodation products {% endcomment %}
          {% if single_property.type == 'wetu-accommodation' %}
            {% render 'wetu-accommodation-headline', product: single_property %}
          {% endif %}

          {% comment %} Product Description {% endcomment %}
          {% if single_property.description != blank %}
            <div class="wetu-single-property__description">
              {{ single_property.description }}
            </div>
          {% endif %}

          {% comment %} Accommodation Key Details for accommodation products {% endcomment %}
          {% if single_property.type == 'wetu-accommodation' %}
            {% render 'wetu-accommodation-key-details', product: single_property %}
          {% endif %}
        </div>
      </div>
    </div>

    {% comment %} Rates Section - Inline minimal version {% endcomment %}
    {% liquid
      assign has_rates = false
      assign min_rate = nil
      assign max_rate = nil
      assign currency = nil
      
      if single_property.type == 'wetu-accommodation'
        assign seasonal_rates_json = single_property.metafields.wetu_room.seasonal_rates.value
        assign base_rate = single_property.metafields.wetu_room.base_rate.value
        assign currency = single_property.metafields.wetu_room.currency.value
        if seasonal_rates_json != blank or base_rate and base_rate > 0
          assign has_rates = true
        endif
      elsif single_property.type == 'wetu-property'
        assign min_rate = single_property.metafields.wetu_property.min_base_rate.value
        assign max_rate = single_property.metafields.wetu_property.max_base_rate.value
        assign currency = single_property.metafields.wetu_property.min_base_rate_currency.value
        if min_rate and min_rate > 0
          assign has_rates = true
        endif
      endif
    %}
    
    {% if has_rates %}
      <div class="wetu-single-property__rates page-width">
        <div class="wetu-single-property__rates-header">
          <h2 class="wetu-single-property__rates-title">{{ 'wetu.rates.title' | t | default: 'Rates & Pricing' }}</h2>
          {% if min_rate and min_rate > 0 %}
            <div class="wetu-single-property__price-range">
              <span class="wetu-single-property__price-label">{{ 'wetu.rates.from' | t | default: 'from' | downcase }}</span>
              <span class="wetu-single-property__price-amount">{{ currency | default: shop.currency }} {{ min_rate | round: 0 }}</span>
              {% if max_rate and max_rate != min_rate %}
                <span class="wetu-single-property__price-separator">-</span>
                <span class="wetu-single-property__price-amount">{{ currency | default: shop.currency }} {{ max_rate | round: 0 }}</span>
              {% endif %}
            </div>
          {% endif %}
        </div>
        <div class="wetu-single-property__rates-cta">
          <p>{{ 'wetu.rates.view_details' | t | default: 'View detailed rates and availability' }}</p>
          <a href="{{ single_property.url }}" class="wetu-single-property__rates-button">
            {{ 'wetu.rates.view_full_details' | t | default: 'View Full Details' }}
          </a>
        </div>
      </div>
    {% endif %}

    {% comment %} Videos Section - Inline rendering {% endcomment %}
    {% liquid
      assign videos = single_property.metafields.wetu.videos.value
      assign has_videos = false
      if videos != blank
        assign has_videos = true
      endif
    %}
    
    {% if has_videos %}
      <div class="wetu-single-property__videos">
        <div class="wetu-single-property__videos-grid">
          {% for video_metaobject in videos limit: 3 %}
            {% liquid
              assign video_embed_url = video_metaobject.embed_url.value
              assign video_title = video_metaobject.title.value | default: video_metaobject.label.value
              
              comment Add HD 1080p quality parameters
              endcomment
              if video_embed_url contains 'youtube.com' or video_embed_url contains 'youtu.be'
                if video_embed_url contains '?'
                  assign video_embed_url = video_embed_url | append: '&vq=hd1080&hd=1'
                else
                  assign video_embed_url = video_embed_url | append: '?vq=hd1080&hd=1'
                endif
              elsif video_embed_url contains 'vimeo.com'
                if video_embed_url contains '?'
                  assign video_embed_url = video_embed_url | append: '&quality=1080p'
                else
                  assign video_embed_url = video_embed_url | append: '?quality=1080p'
                endif
              endif
            %}
            
            {% if video_embed_url != blank %}
              <div class="wetu-single-property__video-item">
                <div class="wetu-single-property__video-container">
                  <iframe
                    src="{{ video_embed_url }}"
                    title="{{ video_title | escape }}"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                    class="wetu-single-property__video-iframe"
                  ></iframe>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .wetu-single-property {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* Hero Section */
  .wetu-single-property__hero {
    position: relative;
    width: 100%;
    margin-inline-start: calc(var(--page-width-margin) * -1);
    margin-inline-end: calc(var(--page-width-margin) * -1);
  }

  .wetu-single-property__hero-image-wrapper {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
  }

  .wetu-single-property__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .wetu-single-property__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.4), transparent);
    pointer-events: none;
  }
  
  /* Adjust overlay positioning for hero section - positioned within page-width */
  .wetu-single-property__hero .wetu-pricing-overlay--bottom-left {
    left: var(--page-width-margin);
    bottom: 2.5rem;
  }
  
  .wetu-single-property__hero .wetu-pricing-overlay--bottom-right {
    right: var(--page-width-margin);
    bottom: 2.5rem;
  }
  
  @media screen and (max-width: 749px) {
    .wetu-single-property__hero .wetu-pricing-overlay--bottom-left,
    .wetu-single-property__hero .wetu-pricing-overlay--bottom-right {
      bottom: 1.5rem;
    }
  }

  /* Details Section */
  .wetu-single-property__details {
    padding-block: 24px;
  }

  .wetu-single-property__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media screen and (min-width: 750px) {
    .wetu-single-property__grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  .wetu-single-property__media-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .wetu-single-property__media-item {
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border-radius: 4px;
  }

  .wetu-single-property__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .wetu-single-property__info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .wetu-single-property__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-foreground, #000);
  }

  .wetu-single-property__description p {
    margin-block-end: 1em;
  }

  .wetu-single-property__description p:last-child {
    margin-block-end: 0;
  }

  /* Rates Section */
  .wetu-single-property__rates {
    width: 100%;
    padding: 48px 0;
  }

  .wetu-single-property__rates-header {
    text-align: center;
    margin-block-end: 32px;
  }

  .wetu-single-property__rates-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    margin-block-end: 16px;
    color: var(--color-foreground, #000);
  }

  .wetu-single-property__price-range {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
    font-size: 1.5rem;
    color: var(--color-foreground, #000);
  }

  .wetu-single-property__price-label {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-foreground-secondary, #666);
  }

  .wetu-single-property__price-amount {
    font-weight: 600;
  }

  .wetu-single-property__price-separator {
    color: var(--color-foreground-secondary, #666);
  }

  .wetu-single-property__rates-cta {
    text-align: center;
    padding: 32px 24px;
    background: var(--color-background-secondary, #f7f7f7);
    border-radius: 8px;
  }

  .wetu-single-property__rates-cta p {
    margin-block-end: 16px;
    color: var(--color-foreground-secondary, #666);
  }

  .wetu-single-property__rates-button {
    display: inline-block;
    padding: 12px 32px;
    background: var(--color-button, #000);
    color: var(--color-button-text, #fff);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .wetu-single-property__rates-button:hover {
    opacity: 0.85;
  }

  /* Videos Section */
  .wetu-single-property__videos {
    width: 100%;
    margin-inline-start: calc(var(--page-width-margin) * -1);
    margin-inline-end: calc(var(--page-width-margin) * -1);
    background: #000000;
    padding: 0;
  }

  .wetu-single-property__videos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    background: #000000;
  }

  .wetu-single-property__video-item {
    width: 100%;
    background: #000000;
  }

  .wetu-single-property__video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    background: #000000;
  }

  .wetu-single-property__video-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .wetu-single-property {
      gap: 48px;
    }

    .wetu-single-property__hero-image-wrapper {
      height: 60vh;
      min-height: 400px;
    }

    .wetu-single-property__hero-content {
      bottom: 24px;
    }

    .wetu-single-property__hero-text {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .wetu-single-property__title {
      font-size: 2rem;
    }

    .wetu-single-property__media-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Single Property Display",
  "tag": "section",
  "class": "wetu-single-property-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "paragraph",
      "content": "Displays the single property from the properties collection with full details, rates, and videos."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Single Property Display"
    }
  ]
}
{% endschema %}
