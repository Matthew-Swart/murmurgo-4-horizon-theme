{% comment %}
  Minimal related-products section for Wetu compatibility
  This section displays related/recommended products
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<div class="page-width section-{{ section.id }}-padding">
  {% if section.settings.heading != blank %}
    <h2 class="related-products__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="grid grid--2-col-tablet grid--4-col-desktop">
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% for product in recommendations.products limit: section.settings.products_to_show %}
        <div class="grid__item">
          {% render 'card-product', card_product: product %}
        </div>
      {% endfor %}
    {% else %}
      {% for product in collections.all.products limit: section.settings.products_to_show %}
        {% unless product.id == product.id %}
          <div class="grid__item">
            {% render 'card-product', card_product: product %}
          </div>
        {% endunless %}
      {% endfor %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ]
}
{% endschema %}