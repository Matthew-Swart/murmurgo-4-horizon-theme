{% comment %}
  ============================================================================
  WETU DAY-BY-DAY SPLIT SECTION (50/50 Layout)
  ============================================================================
  
  Safari Portal-style day-by-day itinerary display:
  - Desktop: 50/50 split with sticky media left, scrolling content right
  - Images change as user scrolls through days
  - Mobile: Stacked layout with images above content
  
  TEMPLATE: product.wetu-itinerary3.json
  
  DESIGN REFERENCE: https://itineraries.safariportal.app
  
  ============================================================================
  DATA ACCESS
  ============================================================================
  
  Uses wetu-itinerary-data snippet for centralized data loading.
  Accesses legs and routes from itinerary metaobject.
  Links to property products via wetu-{content_entity_id} handles.
  
  ============================================================================
{% endcomment %}

{% comment %} 
  Load data directly (render snippet variables don't persist to parent scope)
{% endcomment %}
{% assign itinerary = product.metafields.wetu.itinerary_metaobject.value %}
{% assign legs_array = itinerary.legs.value %}
{% assign routes_array = itinerary.routes.value %}

{% comment %} Build PIN ID to handle mapping arrays for product lookups {% endcomment %}
{% assign component_handles = product.metafields.wetu_itinerary.component_products.value %}
{% assign component_pin_ids = product.metafields.wetu_itinerary.component_pin_ids.value %}

{% assign pin_ids_list = '' %}
{% if component_pin_ids.size > 0 %}
  {% for pin_id in component_pin_ids %}
    {% if forloop.first %}
      {% assign pin_ids_list = pin_id %}
    {% else %}
      {% assign pin_ids_list = pin_ids_list | append: ',' | append: pin_id %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign wetu_pin_ids_array = pin_ids_list | split: ',' %}

{% assign handles_list = '' %}
{% if component_handles.size > 0 %}
  {% for handle in component_handles %}
    {% if forloop.first %}
      {% assign handles_list = handle %}
    {% else %}
      {% assign handles_list = handles_list | append: ',' | append: handle %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign wetu_handles_array = handles_list | split: ',' %}

{% comment %} 
  Note: We filter departure legs inline using {% continue %} 
  since Liquid doesn't have a native 'push' array method
{% endcomment %}

<section 
  id="day-by-day"
  class="wetu-days color-{{ section.settings.color_scheme }} wetu-days--media-{{ section.settings.desktop_layout }}"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  data-section-type="day-by-day-split"
>
  {% comment %} Section Header (Mobile & Optional Desktop) {% endcomment %}
  {% if section.settings.show_header %}
    <div class="wetu-days__header page-width">
      <span class="wetu-days__label">Your Journey</span>
      <h2 class="wetu-days__title h2">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="wetu-days__container">
    {% comment %} Sticky Media Container (50% width on desktop) {% endcomment %}
    <div class="wetu-days__media" aria-hidden="true">
      {% assign current_day = 1 %}
      {% for leg in legs_array %}
        {% assign leg_type = leg.type.value | default: 'Standard' %}
        {% if leg_type == 'Departure' %}{% continue %}{% endif %}
        
        {% assign content_id = leg.content_entity_id.value %}
        {% assign property_handle = 'wetu-' | append: content_id %}
        {% assign property = all_products[property_handle] %}
        {% assign leg_nights = leg.nights.value | default: 1 %}
        {% assign accommodation_name = leg.accommodation_name.value | default: property.title | default: 'Destination' %}
        
        <div 
          class="wetu-days__media-item{% if forloop.first %} is-active{% endif %}" 
          data-day="{{ current_day }}"
          data-leg-index="{{ forloop.index0 }}"
          {% unless forloop.first %}hidden{% endunless %}
        >
          {% if property != blank and property.images.size > 0 %}
            {% render 'wetu-image-carousel', 
              images: property.images, 
              property_name: accommodation_name,
              show_counter: true,
              show_arrows: true,
              lazy_load: true
            %}
          {% else %}
            {% comment %} Placeholder when no images {% endcomment %}
            <div class="wetu-days__media-placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span>{{ accommodation_name }}</span>
            </div>
          {% endif %}
          
          {% comment %} Media Overlay Info {% endcomment %}
          <div class="wetu-days__media-overlay">
            <span class="media-overlay__day">Day {{ current_day }}{% if leg_nights > 1 %} - {{ current_day | plus: leg_nights | minus: 1 }}{% endif %}</span>
            <h3 class="media-overlay__title">{{ accommodation_name }}</h3>
            {% if property != blank %}
              {% assign position = property.metafields.wetu.position.value %}
              {% if position.destination != blank %}
                <span class="media-overlay__location">{{ position.destination }}{% if position.country != blank %}, {{ position.country }}{% endif %}</span>
              {% endif %}
            {% endif %}
          </div>
        </div>
        
        {% assign current_day = current_day | plus: leg_nights %}
      {% endfor %}
      
      {% comment %} Day Progress Indicator {% endcomment %}
      <div class="wetu-days__progress">
        {% assign current_day = 1 %}
        {% for leg in legs_array %}
          {% assign leg_type = leg.type.value | default: 'Standard' %}
          {% if leg_type == 'Departure' %}{% continue %}{% endif %}
          {% assign leg_nights = leg.nights.value | default: 1 %}
          <button 
            type="button" 
            class="progress-dot{% if forloop.first %} is-active{% endif %}" 
            data-scroll-to-day="{{ current_day }}"
            aria-label="Go to Day {{ current_day }}"
          ></button>
          {% assign current_day = current_day | plus: leg_nights %}
        {% endfor %}
      </div>
    </div>

    {% comment %} Scrolling Content Container (50% width on desktop) {% endcomment %}
    <div class="wetu-days__content">
      {% assign current_day = 1 %}
      {% for leg in legs_array %}
        {% assign leg_type = leg.type.value | default: 'Standard' %}
        {% if leg_type == 'Departure' %}{% continue %}{% endif %}
        {% assign leg_nights = leg.nights.value | default: 1 %}
        
        {% render 'wetu-day-content', 
          leg: leg, 
          day_number: current_day, 
          day_end: current_day | plus: leg_nights | minus: 1,
          routes: routes_array,
          show_property_link: section.settings.show_property_link,
          collapsible_details: section.settings.collapsible_details,
          is_first: forloop.first,
          is_last: forloop.last,
          pin_ids_array: wetu_pin_ids_array,
          handles_array: wetu_handles_array
        %}
        
        {% assign current_day = current_day | plus: leg_nights %}
      {% endfor %}
      
      {% comment %} Journey End Card {% endcomment %}
      <div class="wetu-day wetu-day--end" data-day="end">
        <div class="wetu-day__end-card">
          <div class="end-card__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <span class="end-card__label">End of Journey</span>
          <h3 class="end-card__title">Day {{ current_day }}</h3>
          <p class="end-card__text">Thank you for traveling with us. We hope this journey creates lasting memories.</p>
          
          {% if section.settings.show_book_cta %}
            <a href="#booking" class="end-card__cta button">Book This Journey</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% comment %} Load scroll behavior JavaScript {% endcomment %}
<script src="{{ 'wetu-day-scroll.js' | asset_url }}" defer></script>

{% stylesheet %}
  /* ============================================
     BASE STYLES (Mobile First)
     ============================================ */
  
  .wetu-days {
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .wetu-days__header {
    text-align: center;
    padding: var(--section-padding-top) 16px 40px;
  }

  .wetu-days__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .wetu-days__title {
    margin: 0;
    color: var(--color-foreground);
  }

  .wetu-days__container {
    display: flex;
    flex-direction: column;
  }

  /* ============================================
     MEDIA CONTAINER (Mobile)
     ============================================ */
  
  .wetu-days__media {
    width: 100%;
    aspect-ratio: 16/10;
    position: relative;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-foreground) 5%, transparent);
  }

  .wetu-days__media-item {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .wetu-days__media-item.is-active {
    opacity: 1;
    visibility: visible;
  }

  .wetu-days__media-item[hidden] {
    display: block; /* Override hidden for transition */
  }

  .wetu-days__media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: color-mix(in srgb, var(--color-foreground) 40%, transparent);
    background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .wetu-days__media-placeholder span {
    font-size: 1rem;
    font-weight: 500;
  }

  /* Media Overlay */
  .wetu-days__media-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 60px 24px 24px;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
    color: white;
    pointer-events: none;
  }

  .media-overlay__day {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--color-primary);
    padding: 4px 12px;
    border-radius: 12px;
    margin-bottom: 8px;
  }

  .media-overlay__title {
    margin: 0 0 4px;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .media-overlay__location {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  /* Progress Dots */
  .wetu-days__progress {
    position: absolute;
    bottom: 24px;
    right: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 10;
  }

  .progress-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .progress-dot:hover,
  .progress-dot.is-active {
    background: white;
    transform: scale(1.2);
  }

  /* ============================================
     CONTENT CONTAINER (Mobile)
     ============================================ */
  
  .wetu-days__content {
    width: 100%;
    padding: 0 16px var(--section-padding-bottom);
  }

  /* ============================================
     DESKTOP LAYOUT (50/50 Split)
     ============================================ */
  
  @media screen and (min-width: 1024px) {
    .wetu-days__header {
      padding: var(--section-padding-top) 0 40px;
    }

    .wetu-days__container {
      flex-direction: row;
      min-height: 100vh;
    }

    /* Media Left (Default) */
    .wetu-days__media {
      width: 50%;
      height: 100vh;
      aspect-ratio: auto;
      position: sticky;
      top: 0;
    }

    /* Media Right Option */
    .wetu-days--media-right .wetu-days__container {
      flex-direction: row-reverse;
    }

    .wetu-days__content {
      width: 50%;
      padding: 80px 60px var(--section-padding-bottom);
    }

    .wetu-days__media-overlay {
      padding: 80px 40px 40px;
    }

    .media-overlay__title {
      font-size: 2rem;
    }

    .wetu-days__progress {
      bottom: 40px;
      right: 40px;
      gap: 10px;
    }

    .progress-dot {
      width: 14px;
      height: 14px;
    }
  }

  @media screen and (min-width: 1200px) {
    .wetu-days__content {
      padding: 100px 80px var(--section-padding-bottom);
    }
  }

  /* ============================================
     JOURNEY END CARD
     ============================================ */
  
  .wetu-day--end {
    padding: 60px 0;
  }

  .wetu-day__end-card {
    text-align: center;
    padding: 60px 40px;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    border-radius: 24px;
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .end-card__icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    color: var(--color-primary);
    border-radius: 50%;
    margin: 0 auto 24px;
  }

  .end-card__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .end-card__title {
    margin: 0 0 12px;
    font-size: 1.75rem;
    color: var(--color-foreground);
  }

  .end-card__text {
    margin: 0 0 24px;
    font-size: 1rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .end-card__cta {
    display: inline-flex;
    padding: 14px 32px;
    text-decoration: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Day by Day (Split)",
  "tag": "section",
  "class": "section-wetu-day-by-day-split",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Day by Day"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop media position",
      "options": [
        { "value": "left", "label": "Media Left" },
        { "value": "right", "label": "Media Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_property_link",
      "label": "Show link to property page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "collapsible_details",
      "label": "Collapsible property details",
      "default": true,
      "info": "Collapse amenities, room types, etc."
    },
    {
      "type": "checkbox",
      "id": "show_book_cta",
      "label": "Show booking CTA at end",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Day by Day (Split)"
    }
  ]
}
{% endschema %}

