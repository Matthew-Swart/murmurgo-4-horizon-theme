{% style %}
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&family=IBM+Plex+Mono:wght@300;400&display=swap');
{% endstyle %}

<div class="plekify-v8-fw">
  <section class="v8-demo-frame">
    <div class="v8-contain">
      <span class="v8-annot"></span>
      <h2 class="v8-sh"></h2>
      <p class="v8-body v8-prose" style="margin-top:.5rem"></p>
    </div>
  </section>
</div>

{% stylesheet %}

.plekify-v8-fw {
  font-family: 'Inter', sans-serif;
  font-weight: 300;
  color: #1a1a1a;
  background: #fff;
}

.plekify-v8-fw .v8-contain {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 2rem;
}

.plekify-v8-fw h2.v8-sh {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 300;
  font-size: clamp(24px, 3.2vw, 36px);
  line-height: 1.12;
  color: #111;
  margin-bottom: .4rem;
}
.plekify-v8-fw h2.v8-sh em { font-style: italic; color: #555; }

.plekify-v8-fw .v8-body { font-size: 13.5px; line-height: 1.8; color: #444; font-weight: 300; }

.plekify-v8-fw .v8-prose { max-width: 640px; }

.plekify-v8-fw .v8-annot {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: #888;
  font-weight: 400;
  margin-bottom: .5rem;
  display: block;
}

.v8-demo-frame {
  padding: 3rem 0 1rem;
  border-top: 1px solid #e0e0e0;
}

@media (max-width: 720px) {
  .plekify-v8-fw .v8-contain {
    padding: 0 1.25rem;
  }
  .v8-demo-frame {
    padding: 2rem 0 .75rem;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Plekify V8 Demo Frame",
  "tag": "section",
  "class": "plekify-v8-demo-frame-section",
  "limit": 1,
  "settings": [],
  "presets": [
    {
      "name": "Plekify V8 Demo Frame",
      "category": "Plekify"
    }
  ]
}
{% endschema %}
