</style>

<script>
(function() {
  'use strict';
  
  function initBookingCalc() {
    var section = document.querySelector('.itin-new-booking');
    if (!section) return;
    
    var calc = section.querySelector('[data-booking-calc]');
    if (!calc) return;

    var priceType = (calc.dataset.priceType || 'per_person_sharing').toLowerCase();
    var isPerGroup = priceType === 'per_group';
    var defaultGuests = parseInt(calc.dataset.defaultGuests, 10) || (isPerGroup ? 1 : 2);

    if (!isPerGroup && window.wetuItineraryBooking && typeof window.wetuItineraryBooking.initWidget === 'function') {
      window.wetuItineraryBooking.initWidget({
        root: section,
        widgetSelector: '[data-itinerary-booking-widget]',
        guestInputSelector: '[data-calc-input]',
        decreaseSelector: '[data-calc-decrease]',
        increaseSelector: '[data-calc-increase]',
        priceValueSelector: '.itin-new-booking__price-value',
        totalValueSelector: '[data-calc-total]',
        guestCountSelector: '[data-calc-guest-count]',
        priceTotalSelector: '.itin-new-booking__price-total',
        bookButtonSelector: '[data-add-to-cart]'
      });
      return;
    }

    var basePrice = parseInt(calc.dataset.basePrice, 10) || 0;
    var input = calc.querySelector('[data-calc-input]');
    var totalEl = calc.querySelector('[data-calc-total]');
    var countEl = calc.querySelector('[data-calc-guest-count]');
    var decrease = calc.querySelector('[data-calc-decrease]');
    var increase = calc.querySelector('[data-calc-increase]');
    var bookButton = calc.querySelector('[data-add-to-cart]');

    if (!bookButton) return;

    var selectedVariantId = parseInt(calc.dataset.selectedVariantId, 10);
    var currency = calc.dataset.currency || 'USD';
    var locale = calc.dataset.locale || 'en-US';

    function formatCurrency(cents) {
      return new Intl.NumberFormat(locale, {
        style: 'currency',
        currency: currency,
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format((Number(cents) || 0) / 100);
    }

    function updateTotal() {
      var guests = isPerGroup ? 1 : (parseInt(input && input.value, 10) || defaultGuests);
      guests = Math.max(1, Math.min(20, guests));
      if (input) {
        input.value = guests;
      }

      if (totalEl) {
        totalEl.textContent = formatCurrency(isPerGroup ? basePrice : basePrice * guests);
      }

      if (countEl) {
        countEl.textContent = guests;
      }
    }

    if (!isPerGroup && input && decrease) {
      decrease.addEventListener('click', function() {
        input.value = (parseInt(input.value, 10) || defaultGuests) - 1;
        updateTotal();
      });
    }

    if (!isPerGroup && input && increase) {
      increase.addEventListener('click', function() {
        input.value = (parseInt(input.value, 10) || defaultGuests) + 1;
        updateTotal();
      });
    }

    if (!isPerGroup && input) {
      input.addEventListener('change', updateTotal);
    }

    bookButton.addEventListener('click', async function() {
      if (!selectedVariantId) return;

      var quantity = isPerGroup ? 1 : Math.max(1, parseInt(input && input.value, 10) || 1);
      var label = bookButton.querySelector('span');
      var originalLabel = label ? label.textContent : 'Book Now';

      bookButton.disabled = true;
      if (label) {
        label.textContent = 'Processing...';
      }

      try {
        var response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json'
          },
          body: JSON.stringify({
            items: [
              {
                id: selectedVariantId,
                quantity: quantity
              }
            ]
          })
        });

        if (!response.ok) {
          throw new Error('Add to cart failed with status ' + response.status);
        }

        window.location.href = '/checkout';
      } catch (error) {
        console.error('Book now fallback checkout failed:', error);
        bookButton.disabled = false;
        if (label) {
          label.textContent = originalLabel;
        }
        alert('Unable to start checkout right now. Please try again.');
      }
    });

    updateTotal();
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBookingCalc);
  } else {
    initBookingCalc();
  }
})();
</script>

{% schema %}
{
  "name": "Itinerary New Booking",
