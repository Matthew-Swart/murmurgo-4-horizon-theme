      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Book Your Journey"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ready to start your adventure? Reserve your spot today."
    },
    {
      "type": "checkbox",
      "id": "use_scheduled_departure_pricing",
      "label": "Use scheduled departure pricing metadata",
      "default": true
    },
    {
      "type": "select",
