        {
          "value": "auto",
          "label": "Auto (Per Person Sharing)"
        },
        {
          "value": "per_person_sharing",
          "label": "Per Person Sharing"
        },
        {
          "value": "per_group",
          "label": "Per Group"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_includes",
      "label": "Show What's Included",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excludes",
      "label": "Show Not Included",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_operator",
      "label": "Show tour operator",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "url",
      "id": "contact_page",
      "label": "Contact page URL"
    }
  ],
  "presets": [
    {
      "name": "Itinerary New Booking"
    }
  ]
}
{% endschema %}
