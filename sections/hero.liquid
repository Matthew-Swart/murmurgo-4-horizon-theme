
<!-- DEBUG: page_type={{ request.page_type }}, product={{ product.title }}, product_type={{ product.type }}, hero_video_raw={{ product.metafields.wetu.hero_video }}, hero_video_value={{ product.metafields.wetu.hero_video.value }} -->
{% liquid
  assign media_count = 0
  assign media_count_mobile = 0
  assign fallback_to_desktop = false
  assign media_1 = 'none'
  assign media_2 = 'none'
  assign media_1_mobile = 'none'
  assign media_2_mobile = 'none'
  assign has_only_video = false
  assign has_only_video_mobile = false

  # Wetu hero video/image fallback logic for product templates
  # Priority: 1. wetu.hero_video metafield (if exists), 2. featured image
  # Only applies to specific wetu product types that have hero sections
  assign wetu_hero_video = nil
  assign wetu_hero_image = nil
  assign use_wetu_video = false
  assign use_wetu_image = false
  assign is_wetu_hero_product = false
  assign is_wetu_linked_product_template = false
  assign force_auto_height = false
  assign suppress_hero_overlay = false
  assign is_auto_height = false

  if template.name == 'product' and template.suffix == 'wetu-linked-product'
    assign is_wetu_linked_product_template = true
  endif

  # Check if this is a wetu product type that should use hero fallback
  if request.page_type == 'product' and product != blank
    assign product_type_lower = product.type | downcase
    if product_type_lower contains 'wetu-property' or product_type_lower contains 'wetu-accommodation' or product_type_lower contains 'wetu-linked-activity' or product_type_lower contains 'wetu-linked-restaurant' or product_type_lower contains 'wetu-linked-spa'
      assign is_wetu_hero_product = true
    endif
  endif

  # Keep home and wetu product heroes at auto height with text-only readability treatment.
  if template.name == 'index' or is_wetu_hero_product
    assign force_auto_height = true
    assign suppress_hero_overlay = true
  endif

  if section.settings.section_height == 'auto' or force_auto_height
    assign is_auto_height = true
  endif

  if is_wetu_hero_product
    # Check for wetu.hero_video metafield - this takes PRIORITY over section settings
    if product.metafields.wetu.hero_video != blank and product.metafields.wetu.hero_video.value != blank
      assign wetu_hero_video = product.metafields.wetu.hero_video.value
      assign use_wetu_video = true
    endif

    # Set featured image as fallback
    if product.featured_image != blank
      assign wetu_hero_image = product.featured_image
      assign use_wetu_image = true
    endif
  endif

  # Desktop media checks
  # For each media slot, check if the media is not blank and the media type matches the slot
  # Need to check both (1) media picker is not blank AND (2) section.setting.media_type because user can toggle between different media types to display, but choosing "Image" doesn't clear a saved "Video" in the theme editor.
  # The alternate setting (section.settings.image_1 when "Video" is selected) is only visually hidden in theme editor.
  
  # Wetu product template override: prioritize wetu.hero_video metafield over section settings
  # If wetu.hero_video metafield exists, use video regardless of media_type_1 setting
  # Only fall back to section settings image if no video exists
  assign effective_video_1 = section.settings.video_1
  assign effective_image_1 = section.settings.image_1
  assign effective_media_type_1 = section.settings.media_type_1
  assign wetu_video_fallback_to_image = false

  # For wetu products: if hero_video metafield exists, ALWAYS use video (override media_type setting)
  if use_wetu_video
    assign effective_video_1 = wetu_hero_video
    assign effective_media_type_1 = 'video'
  endif

  # Fallback: if section.settings.image_1 is blank but featured image exists, use featured image
  if effective_image_1 == blank and use_wetu_image
    assign effective_image_1 = wetu_hero_image
  endif

  # If media_type is set to video but no video exists, fallback to image
  if effective_media_type_1 == 'video' and effective_video_1 == blank
    assign wetu_video_fallback_to_image = true
    if use_wetu_image
      assign effective_image_1 = wetu_hero_image
    endif
    assign effective_media_type_1 = 'image'
  endif

  # Check for image media
  if effective_image_1 != blank and effective_media_type_1 == 'image'
    assign media_1 = 'image'
    assign media_count = media_count | plus: 1
  endif
  
  # Check for video media
  if effective_video_1 != blank and effective_media_type_1 == 'video'
    assign media_1 = 'video'
    assign media_count = media_count | plus: 1
  endif

  # Handle fallback: if video was requested but not available, use image
  if wetu_video_fallback_to_image and effective_image_1 != blank
    assign media_1 = 'image'
    if media_count == 0
      assign media_count = media_count | plus: 1
    endif
  endif
%}
<!-- DEBUG2: is_wetu_hero_product={{ is_wetu_hero_product }}, use_wetu_video={{ use_wetu_video }}, use_wetu_image={{ use_wetu_image }}, effective_media_type_1={{ effective_media_type_1 }}, effective_video_1={{ effective_video_1 }}, media_1={{ media_1 }}, media_count={{ media_count }} -->
{% liquid
  if section.settings.image_2 != blank and section.settings.media_type_2 == 'image'
    assign media_2 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_2 != blank and section.settings.media_type_2 == 'video'
    assign media_2 = 'video'
    assign media_count = media_count | plus: 1
  endif

  if section.settings.custom_mobile_media
    # Mobile media checks
    # For each media slot, check if the media is not blank and the media type matches the slot
    if section.settings.image_1_mobile != blank and section.settings.media_type_1_mobile == 'image'
      assign media_1_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_1_mobile != blank and section.settings.media_type_1_mobile == 'video'
      assign media_1_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.image_2_mobile != blank and section.settings.media_type_2_mobile == 'image'
      assign media_2_mobile = 'image'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
    if section.settings.video_2_mobile != blank and section.settings.media_type_2_mobile == 'video'
      assign media_2_mobile = 'video'
      assign media_count_mobile = media_count_mobile | plus: 1
    endif
  endif
  if media_count > 0 and media_1 != 'image' and media_2 != 'image'
    assign has_only_video = true
  endif
  if media_count > 0 and media_count_mobile > 0 and media_1_mobile != 'image' and media_2_mobile != 'image'
    assign has_only_video_mobile = true
  endif

  assign media_image_desktop_class = 'hero__image hero__image--desktop'
  assign media_video_desktop_class = 'hero__video hero__video--desktop'
  assign media_video_poster_desktop_class = 'hero__video-poster--desktop'
  assign video_wrapper_desktop_class = 'hero__video-wrapper--desktop'
  if section.settings.custom_mobile_media == false or section.settings.custom_mobile_media == true and media_count_mobile == 0
    assign media_image_desktop_class = media_image_desktop_class | append: ' hero__image--mobile'
    assign media_video_desktop_class = media_video_desktop_class | append: ' hero__video--mobile'
    assign media_video_poster_desktop_class = media_video_poster_desktop_class | append: ' hero__video-poster--mobile'
    assign video_wrapper_desktop_class = video_wrapper_desktop_class | append: ' hero__video-wrapper--mobile'
  endif

  # Should we show the blurred reflection on mobile?
  assign show_mobile_blurred_reflection = false
  if section.settings.blurred_reflection
    if section.settings.custom_mobile_media == true and media_count_mobile > 0 and has_only_video_mobile == false
      # Custom mobile media is active and a mobile image is present
      assign show_mobile_blurred_reflection = true
    elsif section.settings.custom_mobile_media == true and media_count_mobile == 0 and media_count > 0 and has_only_video == false
      # Custom mobile media is active, no mobile media is present, but a desktop image is present
      assign show_mobile_blurred_reflection = true
    elsif section.settings.custom_mobile_media == false and media_count > 0 and has_only_video == false
      # Custom mobile media is inactive, but a desktop image is present
      assign show_mobile_blurred_reflection = true
    endif
  endif

  if media_1 == 'image' and media_2 == 'image'
    assign media_width_desktop = '50vw'
  else
    assign media_width_desktop = '100vw'
  endif

  # If custom mobile media is disabled or no mobile media is present, we need to fallback to desktop media.
  if section.settings.custom_mobile_media == false or media_count_mobile == 0 or media_count == 0
    assign media_count_mobile = media_count
    assign fallback_to_desktop = true
  endif

  if fallback_to_desktop
    assign media_width_mobile = media_width_desktop
  elsif section.settings.stack_media_on_mobile or media_1_mobile != 'image' or media_2_mobile != 'image'
    assign media_width_mobile = '100vw'
  else
    assign media_width_mobile = '50vw'
  endif

  assign sizes = '(min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '832, 1200, 1600, 1920, 2560, 3840'
  assign sizes_mobile = media_width_mobile
  assign mobile_widths = '416, 600, 800, 1200, 1600'

  assign fetch_priority = 'auto'

  if section.index == 1
    assign fetch_priority = 'high'
  endif
%}

{% capture media %}
  {%- if media_1 == 'image' -%}
    {{
      effective_image_1
      | image_url: width: 3840
      | image_tag:
        width: effective_image_1.width,
        widths: widths,
        height: effective_image_1.height,
        alt: effective_image_1.alt,
        class: media_image_desktop_class,
        sizes: sizes,
        fetchpriority: fetch_priority,
        data-testid: 'hero-desktop-image-1'
    }}
  {%- endif -%}

  {%- if media_1 == 'video' -%}
    <div class="{{ video_wrapper_desktop_class }}">
      {%- assign show_video_controls = false -%}
      {%- if shop.permanent_domain == 'city-lodge-hotels.myshopify.com' -%}
        {%- assign show_video_controls = true -%}
      {%- endif -%}
      {{
        effective_video_1
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: show_video_controls,
          muted: true,
          class: media_video_desktop_class,
          data-testid: 'hero-desktop-video-1'
      }}
      <button class="hero__audio-toggle" data-muted="true" aria-label="Toggle audio">
        <svg class="hero__audio-icon hero__audio-icon--muted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
        <svg class="hero__audio-icon hero__audio-icon--unmuted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
      </button>
    </div>
  {%- endif -%}

  {%- if media_2 == 'image' -%}
    {{
      section.settings.image_2
      | image_url: width: 3840
      | image_tag:
        width: section.settings.image_2.width,
        widths: widths,
        height: section.settings.image_2.height,
        alt: section.settings.image_2.alt,
        class: media_image_desktop_class,
        sizes: sizes,
        fetchpriority: fetch_priority,
        data-testid: 'hero-desktop-image-2'
    }}
  {%- endif -%}

  {%- if media_2 == 'video' -%}
    <div class="{{ video_wrapper_desktop_class }}">
      {%- assign show_video_controls = false -%}
      {%- if shop.permanent_domain == 'city-lodge-hotels.myshopify.com' -%}
        {%- assign show_video_controls = true -%}
      {%- endif -%}
      {{
        section.settings.video_2
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: show_video_controls,
          muted: true,
          class: media_video_desktop_class,
          data-testid: 'hero-desktop-video-2'
      }}
      <button class="hero__audio-toggle" data-muted="true" aria-label="Toggle audio">
        <svg class="hero__audio-icon hero__audio-icon--muted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
        <svg class="hero__audio-icon hero__audio-icon--unmuted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
      </button>
    </div>
  {%- endif -%}

  {% if media_count == 0 %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__image' }}
  {%- endif -%}

  {%- comment -%} Mobile Media {%- endcomment -%}
  {%- if media_count > 0 and media_count_mobile > 0 %}
    {% if media_1_mobile == 'image' %}
      {{
        section.settings.image_1_mobile
        | image_url: width: 1600
        | image_tag:
          width: section.settings.image_1_mobile.width,
          widths: mobile_widths,
          height: section.settings.image_1_mobile.height,
          alt: section.settings.image_1_mobile.alt,
          class: 'hero__image hero__image--mobile',
          sizes: sizes_mobile,
          fetchpriority: fetch_priority,
          data-testid: 'hero-mobile-image-1'
      }}
    {%- endif -%}

    {% if media_1_mobile == 'video' %}
      <div class="hero__video-wrapper hero__video-wrapper--mobile">
        {%- assign show_video_controls = false -%}
        {%- if shop.permanent_domain == 'city-lodge-hotels.myshopify.com' -%}
          {%- assign show_video_controls = true -%}
        {%- endif -%}
        {{
          section.settings.video_1_mobile
          | video_tag:
            poster: nil,
            autoplay: true,
            loop: true,
            controls: show_video_controls,
            muted: true,
            class: 'hero__video hero__video--mobile',
            data-testid: 'hero-mobile-video-1'
        }}
        <button class="hero__audio-toggle" data-muted="true" aria-label="Toggle audio">
          <svg class="hero__audio-icon hero__audio-icon--muted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
          <svg class="hero__audio-icon hero__audio-icon--unmuted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        </button>
      </div>
    {%- endif -%}

    {% if media_2_mobile == 'image' %}
      {{
        section.settings.image_2_mobile
        | image_url: width: 1600
        | image_tag:
          width: section.settings.image_2_mobile.width,
          widths: mobile_widths,
          height: section.settings.image_2_mobile.height,
          alt: section.settings.image_2_mobile.alt,
          class: 'hero__image hero__image--mobile',
          sizes: sizes_mobile,
          fetchpriority: fetch_priority,
          data-testid: 'hero-mobile-image-2'
      }}
    {%- endif -%}

    {% if media_2_mobile == 'video' %}
      <div class="hero__video-wrapper hero__video-wrapper--mobile">
        {%- assign show_video_controls = false -%}
        {%- if shop.permanent_domain == 'city-lodge-hotels.myshopify.com' -%}
          {%- assign show_video_controls = true -%}
        {%- endif -%}
        {{
          section.settings.video_2_mobile
          | video_tag:
            poster: nil,
            autoplay: true,
            loop: true,
            controls: show_video_controls,
            muted: true,
            class: 'hero__video hero__video--mobile',
            data-testid: 'hero-mobile-video-2'
        }}
        <button class="hero__audio-toggle" data-muted="true" aria-label="Toggle audio">
          <svg class="hero__audio-icon hero__audio-icon--muted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
          <svg class="hero__audio-icon hero__audio-icon--unmuted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        </button>
      </div>
    {%- endif -%}
  {% endif %}
{% endcapture %}

{% capture media_blurred %}
  {% if media_1 == 'image' %}
    {{
      effective_image_1
      | image_url: width: 3840
      | image_tag:
        width: effective_image_1.width,
        widths: widths,
        height: effective_image_1.height,
        alt: '',
        class: media_image_desktop_class,
        sizes: sizes
    }}
  {% endif %}
  {% if media_2 == 'image' %}
    {{
      section.settings.image_2
      | image_url: width: 3840
      | image_tag:
        width: section.settings.image_2.width,
        widths: widths,
        height: section.settings.image_2.height,
        alt: '',
        class: media_image_desktop_class,
        sizes: sizes
    }}
  {% endif %}
  {% if media_count == 0 %}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__image' }}
  {% endif %}
{% endcapture %}

{% capture mobile_media_blurred %}
  {%- comment -%}
    On mobile we need to check:
    1. If the media should be stacked. If it is,we check for the second (bottom) image first, then for the first (top) image.
    2. If custom mobile setting is active and has media (show desktop media otherwise).
  {%- endcomment -%}
  {% if section.settings.stack_media_on_mobile == false %}
    {% if section.settings.custom_mobile_media == true and fallback_to_desktop == false %}
      {% if media_1_mobile == 'image' %}
        {{ section.settings.image_1_mobile
          | image_url: width: 1600
          | image_tag: width: section.settings.image_1_mobile.width,
            widths: mobile_widths,
            height: section.settings.image_1_mobile.height,
            alt: '',
            class: 'hero__image hero__image--mobile',
            sizes: sizes_mobile
          }}
      {% endif %}
      {% if media_2_mobile == 'image' %}
        {{ section.settings.image_2_mobile
          | image_url: width: 1600
          | image_tag: width: section.settings.image_2_mobile.width,
            widths: mobile_widths,
            height: section.settings.image_2_mobile.height,
            alt: '',
            class: 'hero__image hero__image--mobile',
            sizes: sizes_mobile
          }}
      {% endif %}
    {% elsif fallback_to_desktop %}
      {{ media_blurred }}
    {% endif %}
  {% elsif section.settings.stack_media_on_mobile == true %}
    {% if section.settings.custom_mobile_media == true and fallback_to_desktop == false %}
      {% if media_2_mobile == 'image' %}
        {{ section.settings.image_2_mobile
          | image_url: width: 1600
          | image_tag: width: section.settings.image_2_mobile.width,
            widths: mobile_widths,
            height: section.settings.image_2_mobile.height,
            alt: '',
            class: 'hero__image hero__image--mobile',
            sizes: sizes_mobile
        }}
      {% elsif media_1_mobile == 'image' %}
        {{ section.settings.image_1_mobile
          | image_url: width: 1600
          | image_tag: width: section.settings.image_1_mobile.width,
            widths: mobile_widths,
            height: section.settings.image_1_mobile.height,
            alt: '',
            class: 'hero__image hero__image--mobile',
            sizes: sizes_mobile
          }}
      {% endif %}
    {% elsif fallback_to_desktop %}
      {% if media_count > 0 %}
        {% if media_2 == 'image' %}
          {{ section.settings.image_2
            | image_url: width: 1600
            | image_tag: width: section.settings.image_2.width,
              widths: widths,
              height: section.settings.image_2.height,
              alt: '',
              class: media_image_desktop_class,
              sizes: sizes
            }}
        {% elsif media_1 == 'image' %}
          {{ section.settings.image_1
            | image_url: width: 1600
            | image_tag: width: section.settings.image_1.width,
              widths: widths,
              height: section.settings.image_1.height,
              alt: '',
              class: media_image_desktop_class,
              sizes: sizes
            }}
        {% endif %}
        {% if media_count == 0 %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__image hero__image--mobile' }}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endcapture %}

<div
  id="Hero-{{ section.id }}"
  class="hero color-{{ section.settings.color_scheme }}{% if section.blocks.size == 0 and is_auto_height %} hero--no-blocks-auto-height{% endif %}{% if section.settings.stack_media_on_mobile %} hero--stack-mobile{% endif %}{% if media_1 == 'video' and is_auto_height %} hero--video-auto{% endif %}{% if media_1 == 'image' and is_auto_height %} hero--image-auto{% endif %}{% if is_wetu_linked_product_template %} hero--wetu-linked-product{% endif %}{% if shop.permanent_domain == 'city-lodge-hotels.myshopify.com' %} hero--city-lodge-controls{% endif %}"
  style="
    --hero-border-style: {{ section.settings.border }};
    --hero-border-width: {{ section.settings.border_width }}px;
    --hero-border-opacity: {{ section.settings.border_opacity }}%;
    --blur-opacity: {{ section.settings.reflection_opacity | divided_by: 100.0 }};
    {% if is_auto_height %}
      --hero-min-height: auto;
    {% elsif section.settings.section_height == 'custom' %}
      --hero-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == "full-screen" %}
       --hero-min-height: 100svh;
    {% else %}
      --hero-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
  {% if section.settings.blurred_reflection and has_only_video == false or has_only_video_mobile == false %}
    data-blur-shadow="true"
  {% endif %}
>
  {% if section.settings.blurred_reflection %}
    {% unless has_only_video %}
      <div
        class="hero__blurred-image hero__blurred-image--desktop"
        data-testid="hero-blurred-image-desktop"
      >
        {{ media_blurred }}
      </div>
    {% endunless %}
    {% if show_mobile_blurred_reflection %}
      <div
        class="hero__blurred-image hero__blurred-image--mobile"
        data-testid="hero-blurred-image-mobile"
      >
        {{ mobile_media_blurred }}
      </div>
    {% endif %}
  {% endif %}

  {% comment %}
    Hardcoded to section--full-width bc the media has to be full width in all cases.
    hero__content-wrapper applies section_width.
  {% endcomment %}

  <div
    class="hero__container spacing-style section section--full-width"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {%- comment -%} Home page logo overlay - only show on index template {%- endcomment -%}
    {%- if settings.logo_inverse != blank -%}
      {%- if template.name == 'index' -%}
        <div class="hero__logo-overlay" aria-label="{{ shop.name }}">
      {%- elsif is_wetu_hero_product -%}
        <a href="/" class="hero__logo-overlay hero__logo-overlay--link" aria-label="{{ shop.name }}">
      {%- endif -%}
      {%- if template.name == 'index' or is_wetu_hero_product -%}
        {{
          settings.logo_inverse
          | image_url: width: 400
          | image_tag:
            width: settings.logo_inverse.width,
            widths: '120, 160, 200, 240, 320, 400',
            height: settings.logo_inverse.height,
            alt: shop.name,
            class: 'hero__logo-image',
            loading: 'eager'
        }}
        {%- if template.name == 'index' -%}
          </div>
        {%- elsif is_wetu_hero_product -%}
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.link != blank -%}
      <a
        href="{{ section.settings.link }}"
        class="hero__link"
        {% if section.settings.open_in_new_tab %}
          target="_blank" rel="noopener"
        {% endif %}
      ></a>
    {%- endif -%}
    <div
      class="hero__media-wrapper{% if media_1 == 'video' and is_auto_height %} hero__media-wrapper--video-auto{% endif %}"
      style="--hero-media-count: {{ media_count }};--hero-media-count-mobile: {{ media_count_mobile }};{%- if effective_image_1 != blank -%} --hero-media-aspect-ratio: {{ effective_image_1.aspect_ratio }};{% endif %}{%- if effective_video_1 != blank -%} --hero-video-aspect-ratio: {{ effective_video_1.aspect_ratio | default: '16/9' }};{% endif %}"
      data-testid="hero-media-wrapper"
    >
      {% liquid
        if section.settings.toggle_overlay and suppress_hero_overlay == false
          render 'overlay', settings: section.settings
        endif
      %}
      {{ media }}
    </div>
    <div
      class="
        hero__content-wrapper
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        {% if section.settings.vertical_on_mobile %}mobile-column{% endif %}
        section-content-wrapper
        {{section.settings.section_width}}
        {% if request.design_mode %}hero__content-wrapper--design-mode{% endif %}
      "
      style="{% render 'layout-panel-style', settings: section.settings %}"
    >
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-wrapper {
    --hero-height-offset: 0px;
  }

  /* Being extra specific in the selector for performance reasons */
  body:has(> #header-group > .header-section > #header-component) .hero-wrapper:first-child {
    --hero-height-offset: var(--header-group-height, 0);
  }

  .hero {
    position: relative;
    min-height: calc(var(--hero-min-height) - var(--hero-height-offset));
  }

  .hero[data-shopify-visual-preview] {
    --hero-min-height: 600px;

    min-height: 600px;
  }

  .hero__container {
    position: relative;
    overflow: hidden;
    border: var(--hero-border-width) var(--hero-border-style) rgb(var(--color-border-rgb) / var(--hero-border-opacity));
    min-height: inherit;
    align-items: var(--vertical-alignment-mobile);
    justify-content: var(--horizontal-alignment);
    z-index: var(--layer-base);

    @media screen and (min-width: 750px) {
      align-items: var(--vertical-alignment);
    }
  }

  .hero__content-wrapper.page-width {
    grid-column: 2 / 3;
  }

  .hero__content-wrapper {
    position: relative;
    inset: 0;
    z-index: var(--layer-flat);
  }

  .hero__content-wrapper .group-block-content {
    position: relative;
  }

  /* Ensure hero bottom-aligned content aligns with page-width content margins */
  .hero__content-wrapper.full-width > .group-block-content {
    /* Use util-page-margin-offset to align with page-width sections */
    padding-inline: var(--util-page-margin-offset, var(--page-margin)) !important;
    padding-block-end: var(--page-margin) !important;
  }

  /* Ensure hero bottom-aligned content has proper padding for page-width layout */
  .hero__content-wrapper.page-width > .group-block > .group-block-content {
    padding-block-end: var(--page-margin, 24px);
    padding-inline-start: var(--page-margin, 24px);
    padding-inline-end: var(--page-margin, 24px);
  }

  /* Match linked-product hero text overlay spacing with accommodation/activity templates. */
  .hero--wetu-linked-product .hero__content-wrapper {
    justify-content: flex-end !important;
    align-items: flex-start !important;
  }

  .hero--wetu-linked-product .hero__content-wrapper > .group-block > .group-block-content,
  .hero--wetu-linked-product .hero__content-wrapper > .group-block-content {
    padding-inline: clamp(24px, 3vw, 42px) !important;
    padding-block-end: clamp(24px, 3vw, 42px) !important;
  }

  .hero__media-wrapper {
    position: absolute;
    inset: 0;
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(var(--hero-media-count, 1), 1fr);
  }

  .hero--auto .hero__image,
  .hero--auto .hero__video {
    aspect-ratio: var(--hero-media-aspect-ratio);
  }

  .hero--no-blocks-auto-height {
    :is(.hero__image, .hero__video) {
      width: 100%;
      aspect-ratio: auto;
    }

    .hero__media-wrapper {
      /* When there are no blocks and the height is auto, allow the image to appear. */
      position: relative;
    }
  }

  /* Video auto height - show at natural aspect ratio full width */
  .hero--video-auto {
    min-height: auto !important;
  }

  .hero--video-auto .hero__container {
    min-height: auto !important;
    display: flex;
    flex-direction: column;
  }

  .hero--video-auto .hero__media-wrapper,
  .hero__media-wrapper--video-auto {
    position: relative !important;
    width: 100%;
    height: auto !important;
  }

  .hero--video-auto .hero__video-wrapper--desktop,
  .hero--video-auto .hero__video-wrapper--mobile,
  .hero__media-wrapper--video-auto .hero__video-wrapper--desktop,
  .hero__media-wrapper--video-auto .hero__video-wrapper--mobile {
    position: relative;
    width: 100%;
    height: auto !important;
  }

  .hero--video-auto .hero__video,
  .hero__media-wrapper--video-auto .hero__video {
    width: 100%;
    height: auto !important;
    aspect-ratio: var(--hero-video-aspect-ratio, 16/9);
    object-fit: cover !important;
    object-position: center;
  }

  /* Content overlay positioning for video auto height */
  .hero--video-auto .hero__content-wrapper {
    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);
  }

  /* Image fallback in auto mode - also use natural aspect ratio */
  .hero--video-auto .hero__image {
    width: 100%;
    height: auto !important;
    object-fit: cover !important;
    aspect-ratio: var(--hero-media-aspect-ratio, auto);
  }

  /* Image auto height - show at natural aspect ratio full width */
  .hero--image-auto {
    min-height: auto !important;
  }

  .hero--image-auto .hero__container {
    min-height: auto !important;
    display: flex;
    flex-direction: column;
  }

  .hero--image-auto .hero__media-wrapper {
    position: relative !important;
    width: 100%;
    height: auto !important;
  }

  .hero--image-auto .hero__image {
    width: 100%;
    height: auto !important;
    object-fit: cover !important;
    aspect-ratio: var(--hero-media-aspect-ratio, auto);
  }

  /* Content overlay positioning for image auto height */
  .hero--image-auto .hero__content-wrapper {
    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);
  }

  /* Transparent header support for auto-height hero sections */
  /* When header is transparent, pull hero up behind it */
  /* Target the first shopify-section in main that contains a hero-wrapper */
  body:has(.header[transparent]) main > .shopify-section:first-child .hero--image-auto,
  body:has(.header[transparent]) main > .shopify-section:first-child .hero--video-auto {
    margin-top: calc(var(--header-height, 0px) * -1);
  }

  /* Add padding to ensure content isn't hidden behind the transparent header */
  body:has(.header[transparent]) main > .shopify-section:first-child .hero--image-auto .hero__content-wrapper,
  body:has(.header[transparent]) main > .shopify-section:first-child .hero--video-auto .hero__content-wrapper {
    padding-top: var(--header-height, 0px);
  }

  .hero__container {
    background: #000;
  }

  .hero__image,
  .hero__video,
  .hero__video-poster {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center center;
    overflow: hidden;
    position: relative;
    z-index: var(--layer-base);
  }

  /* Video controls - hide by default, only show for specific stores */
  .hero__video {
    pointer-events: none;
  }
  
  /* Hide all video controls by default */
  .hero__video::-webkit-media-controls {
    display: none !important;
  }
  
  .hero__video::-webkit-media-controls-enclosure {
    display: none !important;
  }
  
  .hero__video::-webkit-media-controls-panel {
    display: none !important;
  }

  /* Only show controls for city-lodge store */
  .hero.hero--city-lodge-controls .hero__video {
    pointer-events: auto;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls-enclosure {
    display: block !important;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    top: auto;
    padding: 0;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls-panel {
    opacity: 1 !important;
    display: flex !important;
    width: 100%;
    padding: 16px 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 50%, transparent 100%) !important;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls {
    opacity: 1 !important;
    display: flex !important;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls-mute-button {
    opacity: 1 !important;
    display: block !important;
    margin-left: auto;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls-volume-slider-container {
    opacity: 1 !important;
    display: block !important;
  }

  .hero.hero--city-lodge-controls .hero__video--desktop::-webkit-media-controls-volume-slider {
    opacity: 1 !important;
    display: block !important;
  }

  /* Mobile/Desktop media visibility */

  .hero__image--mobile,
  .hero__video--mobile,
  .hero__video-wrapper--mobile {
    display: none;
  }

  .hero__image--desktop,
  .hero__video--desktop,
  .hero__video-wrapper--desktop {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .hero__image--desktop,
    .hero__video--desktop,
    .hero__video-wrapper--desktop {
      display: none;
    }

    .hero__image--mobile,
    .hero__video--mobile,
    .hero__video-wrapper--mobile {
      display: block;
    }

    .hero__media-wrapper {
      grid-template-columns: repeat(var(--hero-media-count-mobile, 1), 1fr);
    }

    /* Mobile stacking */
    .hero--stack-mobile .hero__media-wrapper {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(var(--hero-media-count-mobile, 1), calc(100% / var(--hero-media-count-mobile, 1)));
    }

    /* Mobile video - no controls by default */
    .hero__video--mobile {
      object-fit: cover;
      position: relative;
    }

    /* Only show mobile controls for city-lodge store */
    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls-enclosure {
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      top: auto !important;
      height: auto !important;
      padding: 0 !important;
      z-index: 5 !important;
    }

    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls-panel {
      position: relative !important;
      bottom: 0 !important;
      display: flex !important;
      width: 100% !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 12px !important;
      padding: 16px 12px !important;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.6) 60%, transparent 100%) !important;
    }

    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls {
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      top: auto !important;
      opacity: 1 !important;
    }

    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls-mute-button {
      opacity: 1 !important;
      width: 48px !important;
      height: 48px !important;
      min-width: 48px !important;
      display: block !important;
    }

    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls-play-button {
      width: 48px !important;
      height: 48px !important;
      min-width: 48px !important;
    }

    .hero.hero--city-lodge-controls .hero__video--mobile::-webkit-media-controls-timeline {
      flex: 1 !important;
    }
  }

  .hero__video-wrapper--desktop {
    position: relative;
  }

  .hero__video-poster--desktop {
    position: absolute;
  }

  .hero__link {
    position: absolute;
    inset: 0;
    grid-column: 1 / -1;
  }

  .hero__media-wrapper,
  .hero__content-wrapper {
    pointer-events: none;

    :is(a, button, input, textarea, select, video) {
      pointer-events: auto;
    }
  }

  /* Remove color scheme background when hero has video/image media */
  .hero:has(.hero__video),
  .hero:has(.hero__image) {
    background-color: transparent !important;
  }

  .hero__content-wrapper--design-mode * {
    pointer-events: auto;
  }

  /* Text shadows for better readability on images - subtle but effective */
  .hero__content-wrapper .text-block,
  .hero__content-wrapper h1,
  .hero__content-wrapper h2,
  .hero__content-wrapper h3,
  .hero__content-wrapper h4,
  .hero__content-wrapper h5,
  .hero__content-wrapper h6,
  .hero__content-wrapper p,
  .hero__content-wrapper a,
  .hero__content-wrapper span,
  .hero__content-wrapper button {
    text-shadow: 0 0 0.45em rgba(0, 0, 0, 0.75), 0 1px 2px rgba(0, 0, 0, 0.85);
  }

  /* Apply same shadow to logo/icons in hero */
  .hero__content-wrapper img,
  .hero__content-wrapper svg,
  .hero__content-wrapper .logo,
  .hero__content-wrapper .shopify-policy__container svg,
  .hero__content-wrapper .icon,
  .hero__content-wrapper [class*="icon-"] {
    filter: drop-shadow(0 0 6px rgba(0, 0, 0, 0.7)) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.85));
  }

  .hero[data-blur-shadow='true'] {
    --blurred-reflection-filter-saturate: saturate(1.5);
    --blurred-reflection-mask-image: linear-gradient(to bottom, #000 0%, #000 60%, transparent 100%);
    --blurred-reflection-box-shadow: rgb(0 0 0 / 5%) 0 0 1rem;
    --blurred-reflection-filter-blur: blur(20px);
    --blurred-reflection-scale: scale(2, 1.25);
    --blurred-reflection-padding-block-end: 60px;
  }

  .hero[data-blur-shadow='true'] .hero__container::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: var(--blurred-reflection-box-shadow);
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: -1;
  }

  .hero__blurred-image {
    position: absolute;
    inset: 0;
    z-index: -1;
    mask-image: var(--blurred-reflection-mask-image);
    filter: var(--blurred-reflection-filter-saturate);
    pointer-events: none;
    transform: translateY(50%);
    overflow: hidden;
  }

  .hero__blurred-image--desktop {
    display: none;

    @media screen and (min-width: 750px) {
      display: block;
    }
  }

  .hero__blurred-image--mobile {
    display: block;

    @media screen and (min-width: 750px) {
      display: none;
    }
  }

  .hero__blurred-image img,
  .hero__blurred-image svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: var(--blurred-reflection-filter-blur);
    opacity: var(--blur-opacity);
    transform: var(--blurred-reflection-scale);
    padding-block-end: var(--blurred-reflection-padding-block-end);

    &:not(:only-child) {
      width: 50%;

      &:last-child {
        right: 0;
        left: auto;
      }
    }
  }

  /* ============================================= */
  /* AUTO HEIGHT HERO - FINAL OVERRIDES           */
  /* These must be at the end to override defaults */
  /* ============================================= */
  
  .hero--video-auto,
  .hero--image-auto {
    min-height: auto !important;
  }

  .hero--video-auto .hero__container,
  .hero--image-auto .hero__container {
    min-height: auto !important;
    display: block !important;
  }

  .hero--video-auto .hero__media-wrapper,
  .hero--image-auto .hero__media-wrapper {
    position: relative !important;
    inset: auto !important;
    width: 100% !important;
    height: auto !important;
  }

  .hero--video-auto .hero__video-wrapper--desktop,
  .hero--video-auto .hero__video-wrapper--mobile {
    position: relative !important;
    width: 100% !important;
    height: auto !important;
  }

  .hero--video-auto .hero__image,
  .hero--video-auto .hero__video,
  .hero--image-auto .hero__image {
    width: 100% !important;
    height: auto !important;
    position: relative !important;
    object-fit: cover !important;
  }

  /* Content wrapper MUST overlay on top of media */
  .hero--video-auto .hero__content-wrapper,
  .hero--image-auto .hero__content-wrapper {
    position: absolute !important;
    inset: 0 !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    z-index: var(--layer-flat) !important;
  }

  /* ============================================= */
  /* CUSTOM AUDIO TOGGLE FOR HERO VIDEO            */
  /* ============================================= */

  .hero__video-wrapper--mobile {
    position: relative;
  }

  .hero__audio-toggle {
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.45);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease, background 0.2s ease;
    pointer-events: auto;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0;
  }

  .hero__video-wrapper--desktop:hover .hero__audio-toggle,
  .hero__video-wrapper--mobile:hover .hero__audio-toggle {
    opacity: 1;
  }

  .hero__audio-toggle:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .hero__audio-toggle[data-muted="true"] .hero__audio-icon--unmuted,
  .hero__audio-toggle[data-muted="false"] .hero__audio-icon--muted {
    display: none;
  }

  .hero__audio-toggle[data-muted="true"] .hero__audio-icon--muted,
  .hero__audio-toggle[data-muted="false"] .hero__audio-icon--unmuted {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .hero__audio-toggle {
      opacity: 0.7;
      width: 40px;
      height: 40px;
      bottom: 12px;
      right: 12px;
    }

    .hero__audio-toggle:active {
      opacity: 1;
    }
  }

  @media (hover: none) {
    .hero__audio-toggle {
      opacity: 0.7;
    }
  }

  /* ============================================= */
  /* HOME PAGE LOGO OVERLAY                        */
  /* ============================================= */
  
  .hero__logo-overlay {
    position: absolute;
    top: 0;
    left: 0;
    z-index: var(--layer-overlay);
    padding: var(--page-margin);
    pointer-events: none;
    display: flex;
    align-items: center;
    height: var(--header-height, 80px);
  }

  .hero__logo-overlay--link {
    pointer-events: auto;
    text-decoration: none;
  }

  .hero__logo-image {
    display: block;
    max-width: 280px;
    max-height: calc(var(--header-height, 80px) - 20px);
    height: auto;
    width: auto;
    object-fit: contain;
    /* Base shadow for visibility on all backgrounds */
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3)) drop-shadow(0 1px 2px rgba(0, 0, 0, 0.4));
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .hero__logo-overlay {
      padding: calc(var(--page-margin) * 0.75);
      height: var(--header-height-mobile, 60px);
    }

    .hero__logo-image {
      max-width: 160px;
      max-height: calc(var(--header-height-mobile, 60px) - 16px);
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.hero__audio-toggle').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var wrapper = btn.parentElement;
      var video = wrapper ? wrapper.querySelector('video') : null;
      if (video) {
        video.muted = !video.muted;
        btn.setAttribute('data-muted', String(video.muted));
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "text"
    },
    {
      "type": "button"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "spacer"
    },
    {
      "type": "group"
    },
    {
      "type": "_marquee"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.media"
    },
    {
      "type": "select",
      "id": "media_type_1",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_1 == 'image' }}"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "t:settings.video",
      "visible_if": "{{ section.settings.media_type_1 == 'video' }}"
    },
    {
      "type": "header",
      "content": "t:content.media_2"
    },
    {
      "type": "select",
      "id": "media_type_2",
      "label": "t:settings.type",
      "options": [
        {
          "value": "image",
          "label": "t:options.image"
        },
        {
          "value": "video",
          "label": "t:options.video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:settings.image",
      "visible_if": "{{ section.settings.media_type_2 == 'image' }}"
    },
    {
      "type": "video",
