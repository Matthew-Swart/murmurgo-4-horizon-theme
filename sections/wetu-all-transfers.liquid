{% comment %}
  ============================================================================
  WETU ALL TRANSFERS SECTION
  ============================================================================
  
  Displays ALL transfers/routes from the itinerary in a timeline layout.
  Shows flights, drives, boats, trains, etc. with detailed information.
  
  TEMPLATE: product.wetu-itinerary3.json
  
  ============================================================================
  DATA ACCESS
  ============================================================================
  
  Uses wetu-itinerary-data snippet for centralized data loading.
  Accesses routes from itinerary metaobject.
  Can optionally group by transport type (flights, drives, etc.).
  
  ============================================================================
{% endcomment %}

{% comment %} Load itinerary data {% endcomment %}
{% render 'wetu-itinerary-data', product: product %}

{% assign itinerary = product.metafields.wetu.itinerary_metaobject.value %}
{% assign routes = itinerary.routes.value | sort: 'sequence.value' %}

{% comment %} Count transport types {% endcomment %}
{% assign flight_count = 0 %}
{% assign drive_count = 0 %}
{% assign other_count = 0 %}

{% for route in routes %}
  {% assign mode = route.mode.value %}
  {% if mode contains 'Flight' or mode == 'Helicopter' %}
    {% assign flight_count = flight_count | plus: 1 %}
  {% elsif mode == 'Selfdrive' or mode == 'Transfer' or mode == 'Shuttle' %}
    {% assign drive_count = drive_count | plus: 1 %}
  {% else %}
    {% assign other_count = other_count | plus: 1 %}
  {% endif %}
{% endfor %}

<section 
  id="transfers"
  class="wetu-transfers color-{{ section.settings.color_scheme }}"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {% comment %} Section Header {% endcomment %}
    <header class="wetu-transfers__header">
      {% if section.settings.subheading != blank %}
        <span class="wetu-transfers__subheading">{{ section.settings.subheading }}</span>
      {% endif %}
      <h2 class="wetu-transfers__heading h2">{{ section.settings.heading }}</h2>
      
      {% comment %} Transport Type Counts {% endcomment %}
      <div class="wetu-transfers__stats">
        {% if flight_count > 0 %}
          <span class="stat-badge stat-badge--flight">
            {% render 'icon-transport', icon: 'plane', size: 16 %}
            {{ flight_count }} {{ flight_count | pluralize: 'Flight', 'Flights' }}
          </span>
        {% endif %}
        {% if drive_count > 0 %}
          <span class="stat-badge stat-badge--drive">
            {% render 'icon-transport', icon: 'car', size: 16 %}
            {{ drive_count }} {{ drive_count | pluralize: 'Drive', 'Drives' }}
          </span>
        {% endif %}
        {% if other_count > 0 %}
          <span class="stat-badge stat-badge--other">
            {% render 'icon-transport', icon: 'transfer', size: 16 %}
            {{ other_count }} Other
          </span>
        {% endif %}
      </div>
    </header>

    {% if routes.size > 0 %}
      {% if section.settings.group_by_type %}
        {% comment %} Grouped Layout {% endcomment %}
        
        {% comment %} Flights Group {% endcomment %}
        {% if flight_count > 0 %}
          <div class="wetu-transfers__group">
            <h3 class="transfers-group__title">
              {% render 'icon-transport', icon: 'plane', size: 20 %}
              Flights
            </h3>
            <div class="wetu-transfers__timeline">
              {% for route in routes %}
                {% assign mode = route.mode.value %}
                {% if mode contains 'Flight' or mode == 'Helicopter' %}
                  {% render 'wetu-transfer-list-item', 
                    route: route, 
                    index: forloop.index,
                    show_map_link: section.settings.show_map_link
                  %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% comment %} Ground Transport Group {% endcomment %}
        {% if drive_count > 0 %}
          <div class="wetu-transfers__group">
            <h3 class="transfers-group__title">
              {% render 'icon-transport', icon: 'car', size: 20 %}
              Ground Transport
            </h3>
            <div class="wetu-transfers__timeline">
              {% for route in routes %}
                {% assign mode = route.mode.value %}
                {% if mode == 'Selfdrive' or mode == 'Transfer' or mode == 'Shuttle' %}
                  {% render 'wetu-transfer-list-item', 
                    route: route, 
                    index: forloop.index,
                    show_map_link: section.settings.show_map_link,
                    show_directions: section.settings.show_driving_directions
                  %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% comment %} Other Transport Group {% endcomment %}
        {% if other_count > 0 %}
          <div class="wetu-transfers__group">
            <h3 class="transfers-group__title">
              {% render 'icon-transport', icon: 'transfer', size: 20 %}
              Other Transport
            </h3>
            <div class="wetu-transfers__timeline">
              {% for route in routes %}
                {% assign mode = route.mode.value %}
                {% unless mode contains 'Flight' or mode == 'Helicopter' or mode == 'Selfdrive' or mode == 'Transfer' or mode == 'Shuttle' %}
                  {% render 'wetu-transfer-list-item', 
                    route: route, 
                    index: forloop.index,
                    show_map_link: section.settings.show_map_link
                  %}
                {% endunless %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
        
      {% else %}
        {% comment %} Sequential Timeline Layout {% endcomment %}
        <div class="wetu-transfers__timeline">
          {% for route in routes %}
            {% render 'wetu-transfer-list-item', 
              route: route, 
              index: forloop.index,
              show_map_link: section.settings.show_map_link,
              show_directions: section.settings.show_driving_directions
            %}
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <p class="wetu-transfers__empty">No transfers found for this itinerary.</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .wetu-transfers {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background: var(--color-background);
    color: var(--color-foreground);
  }

  /* Header */
  .wetu-transfers__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .wetu-transfers__subheading {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .wetu-transfers__heading {
    margin: 0 0 20px;
    color: var(--color-foreground);
  }

  /* Stats */
  .wetu-transfers__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 24px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .stat-badge--flight {
    background: color-mix(in srgb, #3b82f6 15%, transparent);
    color: #3b82f6;
  }

  .stat-badge--drive {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
  }

  .stat-badge--other {
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    color: #f59e0b;
  }

  /* Groups */
  .wetu-transfers__group {
    margin-bottom: 48px;
  }

  .wetu-transfers__group:last-child {
    margin-bottom: 0;
  }

  .transfers-group__title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-foreground);
  }

  .transfers-group__title svg {
    color: var(--color-primary);
  }

  /* Timeline */
  .wetu-transfers__timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Timeline Line */
  .wetu-transfers__timeline::before {
    content: '';
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  @media screen and (min-width: 750px) {
    .wetu-transfers__timeline::before {
      left: 28px;
    }
  }

  .wetu-transfers__empty {
    text-align: center;
    padding: 60px 20px;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
    font-style: italic;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    // Handle "View on Map" clicks
    document.querySelectorAll('[data-map-route]').forEach(btn => {
      btn.addEventListener('click', () => {
        const routeIndex = btn.dataset.mapRoute;
        // Scroll to map section and highlight route
        const mapSection = document.getElementById('itinerary-map-section');
        if (mapSection) {
          mapSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Dispatch event to highlight route
          document.dispatchEvent(new CustomEvent('wetu:highlight-route', {
            detail: { routeIndex: parseInt(routeIndex) }
          }));
        }
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "All Transfers & Flights",
  "tag": "section",
  "class": "section-wetu-all-transfers",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your Journey"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Getting Around"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "group_by_type",
      "label": "Group by transport type",
      "default": false,
      "info": "Group flights, drives, and other transport separately"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_map_link",
      "label": "Show 'View on Map' button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_driving_directions",
      "label": "Show driving directions (self-drive)",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "All Transfers & Flights"
    }
  ]
}
{% endschema %}
