{% comment %}
  Product/Collection Videos Section

  Product pages:
  - Renders product.metafields.wetu.videos cards.

  Collection pages (fallback mode):
  - Only renders when the current collection has zero products.
  - Videos: collection.metafields.wetu_property.videos -> parent property wetu.videos -> parent property videos_collection_ref -> shop.metaobjects.travel_video (all-property pages).
  - Documents: collection.metafields.wetu_property.documents -> parent property wetu.documents -> parent property documents_collection_ref -> shop.metaobjects.travel_document (all-property pages).
{% endcomment %}

{% liquid
  assign view_context = 'product'
  if collection
    assign view_context = 'collection'
  endif

  assign fallback_asset = section.settings.fallback_asset | default: 'auto'
  if fallback_asset == 'auto'
    if collection
      if collection.handle contains 'document' or collection.handle == 'all-property-documents'
        assign fallback_asset = 'documents'
      else
        assign fallback_asset = 'videos'
      endif
    else
      assign fallback_asset = 'videos'
    endif
  endif

  assign should_render = false

  assign video_metaobjects = blank
  assign video_count = 0
  assign is_odd_count = false
  assign show_logo_card = false

  assign fallback_metaobjects = blank
  assign fallback_metaobject_count = 0
  assign fallback_products_collection = blank
  assign fallback_products_count = 0

  if view_context == 'product'
    assign property_product = section.settings.product | default: product

    if property_product == blank
      assign properties_collection = collections['properties']
      if properties_collection.products_count == 1
        assign property_product = properties_collection.products.first
      endif
    endif

    assign video_metaobjects = property_product.metafields.wetu.videos.value

    if video_metaobjects
      for video in video_metaobjects
        assign video_count = video_count | plus: 1
      endfor
    endif

    if video_count > 0
      assign should_render = true
      assign video_mod = video_count | modulo: 2
      if video_mod == 1
        assign is_odd_count = true
        assign show_logo_card = true
      endif
    endif

  elsif view_context == 'collection'
    if collection.products_count == 0
      assign is_all_property_videos = false
      assign is_all_property_documents = false
      if collection.handle == 'all-property-videos'
        assign is_all_property_videos = true
      elsif collection.handle == 'all-property-documents'
        assign is_all_property_documents = true
      endif

      assign parent_property = collection.metafields.wetu.property_product.value
      unless parent_property
        assign parent_property = collection.metafields.wetu_collection.property_product.value
      endunless

      if fallback_asset == 'videos'
        assign fallback_metaobjects = collection.metafields.wetu_property.videos.value

        if fallback_metaobjects == blank and parent_property
          assign fallback_metaobjects = parent_property.metafields.wetu.videos.value
          if fallback_metaobjects == blank
            assign fallback_products_collection = parent_property.metafields.wetu.videos_collection_ref.value
            assign fallback_products_collection = fallback_products_collection | default: parent_property.metafields.wetu.videos_collection.value
          endif
        endif

        if fallback_metaobjects == blank and is_all_property_videos
          assign fallback_metaobjects = shop.metaobjects.travel_video.values
        endif

      elsif fallback_asset == 'documents'
        assign fallback_metaobjects = collection.metafields.wetu_property.documents.value

        if fallback_metaobjects == blank and parent_property
          assign fallback_metaobjects = parent_property.metafields.wetu.documents.value
          if fallback_metaobjects == blank
            assign fallback_products_collection = parent_property.metafields.wetu.documents_collection_ref.value
            assign fallback_products_collection = fallback_products_collection | default: parent_property.metafields.wetu.documents_collection.value
          endif
        endif

        if fallback_metaobjects == blank and is_all_property_documents
          assign fallback_metaobjects = shop.metaobjects.travel_document.values
        endif
      endif

      if fallback_metaobjects != blank
        for fallback_item in fallback_metaobjects
          assign fallback_metaobject_count = fallback_metaobject_count | plus: 1
        endfor
      endif

      if fallback_products_collection != blank
        assign fallback_products_count = fallback_products_collection.products_count | default: 0
      endif

      if fallback_metaobject_count > 0 or fallback_products_count > 0
        assign should_render = true
      endif
    endif
  endif
-%}

{% if should_render %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="product-videos{% if fallback_asset == 'documents' and view_context == 'collection' %} product-videos--documents{% endif %}">
      {% if view_context == 'product' or fallback_asset == 'videos' %}
        <div class="product-videos__grid" data-columns="2" data-odd-count="{{ is_odd_count }}">
          {% if view_context == 'product' %}
            {% for video_metaobject in video_metaobjects %}
              {% liquid
                assign video_embed_url = video_metaobject.embed_url.value
                assign video_canonical_url = video_metaobject.url.value | default: video_metaobject.url
                assign video_title = video_metaobject.title.value | default: video_metaobject.label.value | default: video_metaobject.title | default: 'Video'
                assign video_thumbnail = video_metaobject.thumbnail_url.value | default: video_metaobject.thumbnail_url
                assign video_url = video_canonical_url | default: video_embed_url

                assign youtube_id = ''
                if video_embed_url contains 'youtube.com/embed/'
                  assign youtube_parts = video_embed_url | split: 'youtube.com/embed/'
                  assign youtube_id = youtube_parts[1] | split: '?' | first
                elsif video_embed_url contains 'youtu.be/'
                  assign youtube_parts = video_embed_url | split: 'youtu.be/'
                  assign youtube_id = youtube_parts[1] | split: '?' | first
                endif

                if video_thumbnail == blank and youtube_id != ''
                  assign video_thumbnail = 'https://img.youtube.com/vi/' | append: youtube_id | append: '/maxresdefault.jpg'
                endif
              %}

              {% if video_url != blank %}
                <div class="product-videos__item">
                  <div class="video-card">
                    <a href="{{ video_url }}" class="video-card__link" target="_blank" rel="noopener">
                      <div class="video-card__media">
                        {% if video_thumbnail != blank %}
                          <img
                            src="{{ video_thumbnail }}"
                            alt="{{ video_title | escape }}"
                            class="video-card__image"
                            loading="lazy"
                          >
                        {% else %}
                          <div class="video-card__placeholder"></div>
                        {% endif %}

                        <div class="video-card__play-button">
                          <span class="video-card__play-icon">
                            <span class="visually-hidden">{{ 'accessibility.play_video' | t }}</span>
                            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M8 6.5L22 14L8 21.5V6.5Z" fill="currentColor"/>
                            </svg>
                          </span>
                        </div>

                        <div class="video-card__title-overlay">
                          <h3 class="video-card__title">{{ video_title }}</h3>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
              {% endif %}
            {% endfor %}

            {% if show_logo_card %}
              {% liquid
                assign logo_to_use = settings.logo
                if section.settings.color_scheme == 'scheme-5' and settings.logo_inverse != blank
                  assign logo_to_use = settings.logo_inverse
                endif
              %}
              <div class="product-videos__item product-videos__item--logo">
                <div class="video-card video-card--logo">
                  <div class="video-card__media video-card__media--logo">
                    {% if logo_to_use != blank %}
                      <img
                        src="{{ logo_to_use | image_url: width: 500 }}"
                        alt="{{ shop.name | escape }}"
                        class="video-card__logo"
                        loading="lazy"
                      >
                    {% elsif shop.brand.logo != blank %}
                      <img
                        src="{{ shop.brand.logo | image_url: width: 500 }}"
                        alt="{{ shop.name | escape }}"
                        class="video-card__logo"
                        loading="lazy"
                      >
                    {% else %}
                      <p class="video-card__logo-text">{{ shop.name }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}

          {% elsif fallback_metaobject_count > 0 %}
            {% for video_metaobject in fallback_metaobjects %}
              {% liquid
                assign video_embed_url = video_metaobject.embed_url.value | default: video_metaobject.embed_url
                assign video_canonical_url = video_metaobject.url.value | default: video_metaobject.url
                assign video_title = video_metaobject.title.value | default: video_metaobject.label.value | default: video_metaobject.title | default: 'Video'
                assign video_thumbnail = video_metaobject.thumbnail_url.value | default: video_metaobject.thumbnail_url
                assign video_url = video_canonical_url | default: video_embed_url

                assign youtube_id = ''
                if video_embed_url contains 'youtube.com/embed/'
                  assign youtube_parts = video_embed_url | split: 'youtube.com/embed/'
                  assign youtube_id = youtube_parts[1] | split: '?' | first
                elsif video_embed_url contains 'youtu.be/'
                  assign youtube_parts = video_embed_url | split: 'youtu.be/'
                  assign youtube_id = youtube_parts[1] | split: '?' | first
                endif

                if video_thumbnail == blank and youtube_id != ''
                  assign video_thumbnail = 'https://img.youtube.com/vi/' | append: youtube_id | append: '/maxresdefault.jpg'
                endif
              %}

              {% if video_url != blank %}
                <div class="product-videos__item">
                  <div class="video-card">
                    <a href="{{ video_url }}" class="video-card__link" target="_blank" rel="noopener">
                      <div class="video-card__media">
                        {% if video_thumbnail != blank %}
                          <img
                            src="{{ video_thumbnail }}"
                            alt="{{ video_title | escape }}"
                            class="video-card__image"
                            loading="lazy"
                          >
                        {% else %}
                          <div class="video-card__placeholder"></div>
                        {% endif %}

                        <div class="video-card__play-button">
                          <span class="video-card__play-icon">
                            <span class="visually-hidden">{{ 'accessibility.play_video' | t }}</span>
                            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M8 6.5L22 14L8 21.5V6.5Z" fill="currentColor"/>
                            </svg>
                          </span>
                        </div>

                        <div class="video-card__title-overlay">
                          <h3 class="video-card__title">{{ video_title }}</h3>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
              {% endif %}
            {% endfor %}

          {% else %}
            {% for video_product in fallback_products_collection.products %}
              <div class="product-videos__item">
                <div class="video-card">
                  <a href="{{ video_product.url }}" class="video-card__link">
                    <div class="video-card__media">
                      {% if video_product.featured_image %}
                        <img
                          src="{{ video_product.featured_image | image_url: width: 1200 }}"
                          alt="{{ video_product.title | escape }}"
                          class="video-card__image"
                          loading="lazy"
                        >
                      {% else %}
                        <div class="video-card__placeholder"></div>
                      {% endif %}

                      <div class="video-card__play-button">
                        <span class="video-card__play-icon">
                          <span class="visually-hidden">{{ 'accessibility.play_video' | t }}</span>
                          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 6.5L22 14L8 21.5V6.5Z" fill="currentColor"/>
                          </svg>
                        </span>
                      </div>

                      <div class="video-card__title-overlay">
                        <h3 class="video-card__title">{{ video_product.title }}</h3>
                      </div>
                    </div>
                  </a>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>

      {% else %}
        <div class="product-videos__documents-grid">
          {% if fallback_metaobject_count > 0 %}
            {% for document_metaobject in fallback_metaobjects %}
              {% liquid
                assign document_url = document_metaobject.file_url.value | default: document_metaobject.url.value | default: document_metaobject.file_url | default: document_metaobject.url
                assign document_title = document_metaobject.label.value | default: document_metaobject.title.value | default: document_metaobject.label | default: document_metaobject.title | default: 'Document'
                assign document_section = document_metaobject.section.value | default: document_metaobject.section
              %}
              {% if document_url != blank %}
                <a href="{{ document_url }}" class="product-videos__document-card" target="_blank" rel="noopener">
                  <span class="product-videos__document-icon">PDF</span>
                  <span class="product-videos__document-title">{{ document_title }}</span>
                  {% if document_section != blank %}
                    <span class="product-videos__document-meta">{{ document_section }}</span>
                  {% endif %}
                </a>
              {% endif %}
            {% endfor %}
          {% else %}
            {% for document_product in fallback_products_collection.products %}
              <a href="{{ document_product.url }}" class="product-videos__document-card">
                <span class="product-videos__document-icon">DOC</span>
                <span class="product-videos__document-title">{{ document_product.title }}</span>
              </a>
            {% endfor %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .product-videos-section {
    background-color: var(--color-background);
  }

  .product-videos {
    width: 100%;
    background-color: var(--color-background);
  }

  .product-videos__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    width: 100%;
  }

  .product-videos__item {
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  .product-videos__item--logo {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .product-videos__item--logo {
      display: flex;
    }
  }

  .video-card {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .video-card__link {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    width: 100%;
  }

  .video-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: rgba(var(--color-foreground-rgb), 0.05);
  }

  .video-card__media--logo {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .video-card__logo {
    max-width: 60%;
    max-height: 60%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .video-card__logo-text {
    color: rgba(var(--color-foreground-rgb), 0.5);
    font-size: 14px;
    padding: 20px;
    text-align: center;
  }

  .video-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .video-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: rgba(var(--color-foreground-rgb), 0.1);
  }

  .video-card__link:hover .video-card__image {
    transform: scale(1.05);
  }

  .video-card__play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    pointer-events: none;
  }

  .video-card__play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    transition: all 0.3s ease;
  }

  .video-card__play-icon svg {
    width: 28px;
    height: 28px;
    fill: #000;
    margin-left: 4px;
  }

  .video-card__link:hover .video-card__play-icon {
    background-color: rgba(255, 255, 255, 1);
    transform: scale(1.1);
  }

  .video-card__title-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .video-card__title {
    color: white;
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .product-videos__documents-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .product-videos__document-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    text-decoration: none;
    color: rgb(var(--color-foreground-rgb));
    border: 1px solid rgba(var(--color-foreground-rgb), 0.18);
    background: rgba(var(--color-foreground-rgb), 0.04);
  }

  .product-videos__document-card:hover {
    background: rgba(var(--color-foreground-rgb), 0.08);
  }

  .product-videos__document-icon {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .product-videos__document-title {
    font-size: 1rem;
    line-height: 1.3;
    font-weight: 600;
  }

  .product-videos__document-meta {
    font-size: 0.875rem;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .product-videos__grid {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .video-card__title-overlay {
      padding: 16px;
    }

    .video-card__title {
      font-size: 1rem;
    }

    .video-card__play-icon {
      width: 48px;
      height: 48px;
    }

    .video-card__play-icon svg {
      width: 20px;
      height: 20px;
      margin-left: 3px;
    }

    .product-videos__documents-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product videos",
  "tag": "section",
  "class": "product-videos-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Defaults to current product if not set"
    },
    {
      "type": "select",
      "id": "fallback_asset",
      "label": "Collection fallback asset",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "videos",
          "label": "Videos"
        },
        {
          "value": "documents",
          "label": "Documents"
        }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product videos"
    }
  ],
  "enabled_on": {
    "templates": ["product", "index", "collection"]
  }
}
{% endschema %}
