{% stylesheet %}
  .resource-list__item--logo-fill {
    display: grid;
    place-items: center;
    padding: clamp(12px, 4cqw, 28px);
    overflow: hidden;
    height: 100%;
    min-height: 100%;
    position: relative;
  }

  .resource-list__item--logo-fill .product-grid__card {
    width: 100%;
    height: 100%;
  }

  .resource-list__item--logo-fill .logo-fill-wrapper {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }
  /* Fallback to padding-top trick removed to allow natural filling */

  .resource-list__item--logo-fill .logo-fill-image,
  .resource-list__item--logo-fill .logo-fill-placeholder {
    position: absolute;
    inset: 0;
    margin: auto;
    max-width: clamp(120px, 90%, 450px);
    max-height: 90%;
    width: auto;
    height: auto;
    object-fit: contain;
    z-index: 1;
  }

  .resource-list__item--logo-fill .logo-fill-placeholder {
    opacity: 0.3;
    color: var(--color-foreground, currentColor);
  }

  /* Show logo fill on mobile as well */
  @media screen and (max-width: 749px) {
    .resource-list__item--logo-fill {
      padding: clamp(12px, 6cqw, 24px);
    }
  }
{% endstylesheet %}
