

{% liquid
  assign max_items = section.settings.max_products
  
  # Check if this is the activities section and handle odd count logic
  assign activities_collection = null
  assign spa_collection = null
  assign spa_count = 0
  assign should_add_spa = false
  assign should_show_three_columns_last_row = false
  assign should_add_logo = false
  
  if section.settings.collection != blank and product != blank
    # Check if this is the activities collection
    assign activities_collection_ref = product.metafields.wetu.activities_collection_ref.value
    if activities_collection_ref and activities_collection_ref.id == section.settings.collection.id
      assign activities_collection = section.settings.collection
      
      # Get spa collection
      assign spa_collection = product.metafields.wetu.spa_collection.value
      
      if spa_collection != blank
        assign spa_count = spa_collection.products_count
      endif
      
      # Count actual activities (limited by max_items)
      assign activities_count = activities_collection.products_count
      if activities_count > max_items
        assign activities_count = max_items
      endif
      
      # Only apply logic on desktop (2 columns) when there's an odd number of activities
      if section.settings.columns == 2 and section.settings.layout_type == 'grid'
        assign activities_mod = activities_count | modulo: 2
        
        if activities_mod == 1
          # Odd number of activities
          if spa_count == 1
            # Add the single spa product to fill the empty space
            assign should_add_spa = true
          elsif spa_count > 1
            # Show 3 activities in the last row instead
            assign should_show_three_columns_last_row = true
            # Calculate the threshold for last 3 items (for CSS class application)
            assign last_row_threshold = activities_count | minus: 2
          endif
        endif
      endif
    endif
  endif
  
  # General logic for all collections: Check if we have an odd number of products and should add logo
  if section.settings.collection != blank and section.settings.layout_type == 'grid'
    # Count the products that will be displayed (limited by max_items)
    assign product_count = section.settings.collection.products_count
    if product_count > max_items
      assign product_count = max_items
    endif
    
    # Check if we have an odd number and if we should add logo (not spa product already)
    if product_count > 0
      assign product_mod = product_count | modulo: 2
      if product_mod == 1 and should_add_spa == false and should_show_three_columns_last_row == false
        # Show logo for any collection with odd number of products
        assign should_add_logo = true
      endif
    endif
  endif
%}

{% liquid
  # Only render the section if the collection has products
  assign should_render_section = false
  if section.settings.collection != blank and section.settings.collection.products_count > 0
    assign should_render_section = true
  endif
%}

{% if should_render_section %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
    {% if should_show_three_columns_last_row %}section-resource-list--three-column-last-row{% endif %}
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div
            class="resource-list__item{% if should_show_three_columns_last_row and forloop.index >= last_row_threshold %} resource-list__item--last-row{% endif %}"
          >
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>

          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
        
        {% comment %} Add spa product if conditions are met {% endcomment %}
        {% if should_add_spa and spa_collection != blank %}
          <!--@list/split-->
          {% assign spa_product = spa_collection.products.first %}
          <div
            class="resource-list__item resource-list__item--spa-fill"
          >
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: spa_product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>
        {% endif %}
        
        {% comment %} Add logo if we have an odd number of products {% endcomment %}
        {% if should_add_logo %}
          {% liquid
            # Use inverse logo for dark color schemes (scheme-5)
            assign logo_to_use = settings.logo
            if section.settings.color_scheme == 'scheme-5' and settings.logo_inverse != blank
              assign logo_to_use = settings.logo_inverse
            endif
          %}
          <!--@list/split-->
          <div
            class="resource-list__item resource-list__item--logo-fill"
          >
            <div class="product-grid__card">
              <div class="card-gallery logo-fill-wrapper" style="--gallery-aspect-ratio: 16 / 9;">
                {% if logo_to_use %}
                  <img
                    src="{{ logo_to_use | image_url: width: 640 }}"
                    alt="{{ shop.name }}"
                    class="logo-fill-image"
                    loading="lazy"
                    width="320"
                    height="{{ 320 | divided_by: logo_to_use.aspect_ratio | round }}"
                  >
                {% else %}
                  <svg class="logo-fill-placeholder" width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="2" fill="none"/>
                  </svg>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item"
        >
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>
{% endif %}

