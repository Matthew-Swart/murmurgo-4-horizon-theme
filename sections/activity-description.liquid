{% comment %} activity-description.liquid {% endcomment %}
<section class="m-activity-desc" data-section-id="{{ section.id }}">
  <div class="page-width">
    <h2 class="m-activity-desc__headline">About this</h2>
    <div class="m-activity-desc__body">
      {% if metaobject.description.value != blank %}
        <p>{{ metaobject.description.value | strip_html | truncate: 500 }}</p>
      {% elsif metaobject.short_description.value != blank %}
        <p>{{ metaobject.short_description.value | strip_html | truncate: 500 }}</p>
      {% else %}
        <p>{{ metaobject.name.value | escape }}. Placeholder description.</p>
      {% endif %}
    </div>
  </div>
</section>
{% schema %}{ "name": "Activity Description", "class": "section-activity-description", "settings": [], "presets": [{ "name": "Activity Description" }] }{% endschema %}
