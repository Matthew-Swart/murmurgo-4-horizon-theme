{% style %}
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&family=IBM+Plex+Mono:wght@300;400&display=swap');
{% endstyle %}

<div class="plekify-v8-fw">

<!-- ═══ SECTION 7: BRIDGE STATEMENT ════════════════════════ -->
<section class="v8-band v8-band--bridge">
  <div class="v8-contain" style="text-align:center">
    <p class="v8-bridge__text">Whether you're selling a fourteen-day journey or a single night, the commercial infrastructure is identical — on your domain, under your brand, with guest data that belongs to you, not to a booking engine.</p>
    <p class="v8-bridge__sub">Both capabilities — itinerary commerce and accommodation booking — run on the same Shopify infrastructure, on the operator's own domain, with guest data owned by the operator.</p>
  </div>
</section>

</div>

{% stylesheet %}

.plekify-v8-fw {
  font-family: 'Inter', sans-serif;
  font-weight: 300;
  color: #1a1a1a;
  background: #fff;
}

.plekify-v8-fw .v8-contain {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 2rem;
}

.plekify-v8-fw .v8-band {
  padding: 3rem 0;
  border-bottom: 1px solid #eee;
}

.plekify-v8-fw .v8-band--bridge {
  background: #f2f2f2;
  border-top: 1px solid #e0e0e0;
  border-bottom: 1px solid #e0e0e0;
  padding: 2.5rem 0;
}

.plekify-v8-fw .v8-bridge__text {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(18px, 2.4vw, 24px);
  font-weight: 300;
  font-style: italic;
  color: #333;
  line-height: 1.55;
  max-width: 720px;
  margin: 0 auto;
}

.plekify-v8-fw .v8-bridge__sub {
  font-size: 12px;
  color: #777;
  font-weight: 300;
  margin-top: 1rem;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.7;
}

@media (max-width: 720px) {
  .plekify-v8-fw .v8-contain {
    padding: 0 1.25rem;
  }
  .plekify-v8-fw .v8-band--bridge {
    padding: 2rem 0;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Plekify V8 Bridge",
  "tag": "section",
  "class": "plekify-v8-bridge-section",
  "limit": 1,
  "settings": [],
  "presets": [
    {
      "name": "Plekify V8 Bridge",
      "category": "Plekify"
    }
  ]
}
{% endschema %}
