{% comment %}
  ai-hero.liquid
  Light-mode, full-viewport landing for Murmurgo AI itinerary builder.
  Inspired by Plekify travel-brief aesthetic - minimal, clean, light.
  All interaction handled by murmurgo-ai.js.
{% endcomment %}

{% assign hero_image = section.settings.hero_image %}
{% assign hero_video = section.settings.hero_video %}
{% if hero_video != blank %}
  {% capture video_fallback_attrs %}style="display:none;" data-hero-fallback{% endcapture %}
{% endif %}

<section class="m-ai-hero" data-ai-hero data-section-id="{{ section.id }}">
  {% comment %} Background media (video or solid color) {% endcomment %}
  <div class="m-ai-hero__media">
    {% if hero_video != blank %}
      <video
        class="m-ai-hero__video"
        data-hero-video
        autoplay
        muted
        loop
        playsinline
        {% if hero_image != blank %}poster="{{ hero_image | image_url: width: 1200 }}"{% endif %}
      >
        <source src="{{ hero_video }}" type="video/mp4">
      </video>
    {% endif %}

    {% if hero_image != blank %}
      <img
        class="m-ai-hero__fallback-img"
        src="{{ hero_image | image_url: width: 1200 }}"
        srcset="{{ hero_image | image_url: width: 600 }} 600w, {{ hero_image | image_url: width: 1200 }} 1200w, {{ hero_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.hero_alt | default: 'African landscape' }}"
        loading="eager"
        width="1920"
        height="1080"
        {{ video_fallback_attrs }}
      >
    {% endif %}

    {% comment %} Subtle gradient overlay for text legibility {% endcomment %}
    <div class="m-ai-hero__overlay"></div>
  </div>

  {% comment %} Content {% endcomment %}
  <div class="m-ai-hero__content">
    <div class="m-ai-hero__brand">
      {% if section.settings.show_logo %}
        <svg class="m-ai-hero__logo" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/>
          <path d="M16 24c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="24" cy="28" r="4" fill="currentColor"/>
          <path d="M24 32v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      {% endif %}
    </div>

    <h1 class="m-ai-hero__headline">{{ section.settings.headline | default: 'Build your trip.' }}</h1>
    <p class="m-ai-hero__subtitle">{{ section.settings.subtitle | default: 'Describe what you are dreaming of.' }}</p>

    {% comment %} Input Area {% endcomment %}
    <div class="m-ai-hero__input-wrap">
      <textarea
        class="m-ai-hero__input"
        data-ai-input
        placeholder="{{ section.settings.input_placeholder | default: 'I want to be in the bush by Thursday...' }}"
        rows="2"
        aria-label="Describe your trip"
      ></textarea>

      <div class="m-ai-hero__input-actions">
        <button
          class="m-ai-hero__mic"
          data-ai-mic
          aria-label="Voice input"
          title="Tap to speak"
        >
          <svg class="m-ai-hero__mic-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 12a2 2 0 002-2V5a2 2 0 00-4 0v5a2 2 0 002 2z"/>
            <path d="M6 9a1 1 0 011 1v1a3 3 0 006 0v-1a1 1 0 112 0v1a5 5 0 01-10 0v-1a1 1 0 011-1zM10 15v3"/>
            <path d="M7 18h6"/>
          </svg>
          <span class="m-ai-hero__mic-pulse" data-mic-pulse></span>
        </button>

        <button
          class="m-ai-hero__send"
          data-ai-send
          aria-label="Send message"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22,2 15,22 11,13 2,9"/>
          </svg>
        </button>
      </div>
    </div>

    {% comment %} Sample Prompt Chips {% endcomment %}
    <div class="m-ai-hero__chips" data-ai-chips>
      <span class="m-ai-hero__chips-label">Popular journeys:</span>
      <div class="m-ai-hero__chips-list">
        {% assign chips = section.settings.quick_tags | default: '7 nights, Cape Town + bush,Honeymoon, no crowds,Family safari, kids under 10,Long weekend from Joburg,Winelands by bicycle,Best light for photography,Beach after safari,Under R5000 per night,Small lodge, Big Five,Road trip Garden Route' | split: ',' %}
        {% for chip in chips %}
          <button class="m-ai-hero__chip" data-chip="{{ chip | strip }}">{{ chip | strip }}</button>
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Sticky input bar (hidden until transition) {% endcomment %}
  <div class="m-ai-hero__sticky" data-ai-sticky>
    <div class="m-ai-hero__sticky-inner">
      <input
        type="text"
        class="m-ai-hero__sticky-input"
        data-ai-sticky-input
        placeholder="{{ section.settings.input_placeholder | default: 'I want to be in the bush by Thursday...' }}"
        autocomplete="off"
        aria-label="Describe your trip"
      >
      <button class="m-ai-hero__sticky-mic" data-ai-sticky-mic aria-label="Voice input">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10 12a2 2 0 002-2V5a2 2 0 00-4 0v5a2 2 0 002 2z"/>
          <path d="M6 9a1 1 0 011 1v1a3 3 0 006 0v-1a1 1 0 112 0v1a5 5 0 01-10 0v-1a1 1 0 011-1zM10 15v3"/>
          <path d="M7 18h6"/>
        </svg>
      </button>
      <button class="m-ai-hero__sticky-send" data-ai-sticky-send aria-label="Send message">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22,2 15,22 11,13 2,9"/>
        </svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "AI Hero",
  "class": "section-ai-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image",
      "info": "Fallback when video fails or on mobile data saver."
    },
    {
      "type": "text",
      "id": "hero_video",
      "label": "Hero background video URL",
      "info": "Direct URL to an MP4 video. Leave blank for image-only."
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Hero image alt text",
      "default": "African landscape"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Build your trip."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Describe what you are dreaming of."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "I want to be in the bush by Thursday..."
    },
    {
      "type": "text",
      "id": "quick_tags",
      "label": "Quick start prompts",
      "default": "7 nights, Cape Town + bush, Honeymoon, no crowds, Family safari, kids under 10, Long weekend from Joburg, Winelands by bicycle, Best light for photography, Beach after safari, Under R5000 per night, Small lodge, Big Five, Road trip Garden Route",
      "info": "Comma-separated list of sample prompts. Each becomes a clickable chip."
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show logo icon",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "AI Hero"
    }
  ]
}
{% endschema %}
