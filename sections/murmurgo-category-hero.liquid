{% comment %}
  Murmurgo Category Hero
  Maps page.handle to a category slug, display name, and accent color.
{% endcomment %}

{%- assign handle_to_category = 'places-to-stay:lodging,restaurant:restaurant,nature:nature,attraction:attraction,spa:spa,park:park,shopping:shopping,nightlife:nightlife' | split: ',' -%}
{%- assign category_slug = '' -%}

{%- for pair in handle_to_category -%}
  {%- assign parts = pair | split: ':' -%}
  {%- if parts[0] == page.handle -%}
    {%- assign category_slug = parts[1] -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if category_slug == '' -%}
  {%- assign category_slug = page.handle -%}
{%- endif -%}

{%- case category_slug -%}
  {%- when 'lodging' -%}
    {%- assign display_name = 'Places to Stay' -%}
    {%- assign accent_color = '#D4A373' -%}
  {%- when 'restaurant' -%}
    {%- assign display_name = 'Restaurants & Bars' -%}
    {%- assign accent_color = '#E76F51' -%}
  {%- when 'nature' -%}
    {%- assign display_name = 'Wildlife & Nature' -%}
    {%- assign accent_color = '#52796F' -%}
  {%- when 'attraction' -%}
    {%- assign display_name = 'Attractions & Activities' -%}
    {%- assign accent_color = '#2A9D8F' -%}
  {%- when 'spa' -%}
    {%- assign display_name = 'Spa & Wellness' -%}
    {%- assign accent_color = '#2A9D8F' -%}
  {%- when 'park' -%}
    {%- assign display_name = 'Parks & Reserves' -%}
    {%- assign accent_color = '#52796F' -%}
  {%- when 'shopping' -%}
    {%- assign display_name = 'Shopping' -%}
    {%- assign accent_color = '#E9C46A' -%}
  {%- when 'nightlife' -%}
    {%- assign display_name = 'Nightlife' -%}
    {%- assign accent_color = '#6D597A' -%}
  {%- else -%}
    {%- assign display_name = page.title | default: category_slug | capitalize -%}
    {%- assign accent_color = '#D4A373' -%}
{%- endcase -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ display_name | json }},
  "description": {{ 'Discover curated ' | append: display_name | downcase | append: ' across Africa. Browse the best ' | append: display_name | downcase | append: ' on Murmurgo.' | json }},
  "itemListElement": [],
  "url": {{ request.origin | append: page.url | json }}
}
</script>

{{ 'murmurgo-browse.css' | asset_url | stylesheet_tag }}

<section
  class="mg-category-hero"
  data-section-id="{{ section.id }}"
  data-category-slug="{{ category_slug }}"
  style="{%- unless section.settings.hero_image -%}background: linear-gradient(135deg, {{ accent_color }} 0%, {{ accent_color | color_darken: 20 }} 100%);{%- endunless -%}"
>
  {%- if section.settings.hero_image -%}
    <div
      class="mg-category-hero__bg"
      style="background-image: url('{{ section.settings.hero_image | image_url: width: 1920 }}');"
      role="img"
      aria-label="{{ display_name }} hero background"
    ></div>
  {%- endif -%}

  <div class="mg-category-hero__overlay"></div>

  <nav class="mg-category-hero__breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}" style="color: inherit; text-decoration: none;">Home</a>
    <span aria-hidden="true"> &gt; </span>
    <a href="/pages/browse" style="color: inherit; text-decoration: none;">Browse</a>
    <span aria-hidden="true"> &gt; </span>
    <span>{{ display_name }}</span>
  </nav>

  <div class="mg-category-hero__content">
    <h1 class="mg-category-hero__heading">{{ display_name }}</h1>
    <p class="mg-category-hero__subtitle">
      {%- if section.settings.subtitle != blank -%}
        {{ section.settings.subtitle }}
      {%- else -%}
        Explore curated {{ display_name | downcase }} across Africa
      {%- endif -%}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Murmurgo Category Hero",
  "settings": [
    {
      "type": "text",
      "id": "category_handle",
      "label": "Category Handle (for mapping)",
      "info": "Leave blank to auto-detect from page.handle"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use the default category display name"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Leave blank to use the default subtitle"
    }
  ],
  "presets": [
    {
      "name": "Murmurgo Category Hero"
    }
  ]
}
{% endschema %}
