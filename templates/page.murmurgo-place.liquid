{% comment %}
  page.murmurgo-place.liquid
  World-class place page for Tier 1/2 places.
  Reads from page.metafields.plekify.*
{% endcomment %}

{% assign plekify_place_id = page.metafields.plekify.place_id.value %}
{% assign plekify_copy_short = page.metafields.plekify.copy_short.value %}
{% assign plekify_copy_medium = page.metafields.plekify.copy_medium.value %}
{% assign plekify_copy_long = page.metafields.plekify.copy_long.value %}
{% assign plekify_copy_tips = page.metafields.plekify.copy_tips.value %}
{% assign plekify_photos_json = page.metafields.plekify.photos.value %}
{% assign plekify_google_rating = page.metafields.plekify.google_rating.value %}
{% assign plekify_google_review_count = page.metafields.plekify.google_review_count.value %}
{% assign plekify_latitude = page.metafields.plekify.latitude.value %}
{% assign plekify_longitude = page.metafields.plekify.longitude.value %}
{% assign plekify_formatted_address = page.metafields.plekify.formatted_address.value %}
{% assign plekify_website = page.metafields.plekify.website.value %}
{% assign plekify_phone = page.metafields.plekify.phone.value %}
{% assign plekify_email = page.metafields.plekify.email.value %}
{% assign plekify_opening_hours = page.metafields.plekify.opening_hours.value %}
{% assign plekify_primary_type = page.metafields.plekify.primary_type.value %}
{% assign plekify_city = page.metafields.plekify.city.value %}
{% assign plekify_region = page.metafields.plekify.region.value %}
{% assign plekify_country = page.metafields.plekify.country.value %}
{% assign plekify_price_level = page.metafields.plekify.price_level.value %}

{% assign plekify_copy_body = plekify_copy_long | default: plekify_copy_medium %}

{% assign photos = "" %}
{% if plekify_photos_json != blank %}
  {% assign photos = plekify_photos_json | json %}
{% endif %}

{% comment %} Accent colour by type {% endcomment %}
{% assign accent_color = "#2A9D8F" %}
{% if plekify_primary_type contains "lodging" or plekify_primary_type contains "hotel" %}
  {% assign accent_color = "#D4A373" %}
{% elsif plekify_primary_type contains "restaurant" or plekify_primary_type contains "food" or plekify_primary_type contains "bar" or plekify_primary_type contains "cafe" %}
  {% assign accent_color = "#E76F51" %}
{% elsif plekify_primary_type contains "park" or plekify_primary_type contains "nature" or plekify_primary_type contains "reserve" or plekify_primary_type contains "trail" %}
  {% assign accent_color = "#52796F" %}
{% elsif plekify_primary_type contains "spa" or plekify_primary_type contains "wellness" or plekify_primary_type contains "attraction" or plekify_primary_type contains "tourist" %}
  {% assign accent_color = "#2A9D8F" %}
{% endif %}

{% assign schema_type = "TouristAttraction" %}
{% if plekify_primary_type contains "lodging" or plekify_primary_type contains "hotel" %}
  {% assign schema_type = "LodgingBusiness" %}
{% elsif plekify_primary_type contains "restaurant" or plekify_primary_type contains "food" %}
  {% assign schema_type = "Restaurant" %}
{% endif %}

{% assign has_photos = false %}
{% assign first_photo = "" %}
{% if plekify_photos_json != blank and plekify_photos_json != "null" %}
  {% assign first_photo = plekify_photos_json | split: '"url"' | slice: 1 | first | split: '"' | slice: 1 | first | replace: '\\/', '/' %}
  {% if first_photo == blank %}
    {% comment %} Fallback: if json metafield is already parsed as array {% endcomment %}
    {% for p in plekify_photos_json limit: 1 %}
      {% assign first_photo = p.url %}
    {% endfor %}
  {% endif %}
  {% if first_photo != blank %}
    {% assign has_photos = true %}
  {% endif %}
{% endif %}

{% assign has_tips = false %}
{% if plekify_copy_tips != blank %}
  {% assign has_tips = true %}
{% endif %}

{% assign has_map = false %}
{% if plekify_latitude != blank and plekify_longitude != blank %}
  {% assign has_map = true %}
{% endif %}

{% assign has_nearby = has_map %}

{% assign meta_description = plekify_copy_short | default: page.description | default: page.title %}

<!-- 1. JSON-LD Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schema_type }}",
  "name": {{ page.title | json }},
  "description": {{ plekify_copy_short | json }},
  "url": {{ canonical_url | json }},
  {% if plekify_latitude != blank and plekify_longitude != blank %}
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ plekify_latitude | json }},
    "longitude": {{ plekify_longitude | json }}
  },
  {% endif %}
  "address": {
    "@type": "PostalAddress",
    "addressLocality": {{ plekify_city | json }},
    "addressRegion": {{ plekify_region | json }},
    "addressCountry": {{ plekify_country | json }}
  }{% if plekify_google_rating != blank %},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ plekify_google_rating | json }},
    "reviewCount": {{ plekify_google_review_count | default: 0 | json }}
  }{% endif %}{% if first_photo != blank %},
  "image": {{ first_photo | json }}{% endif %}
}
</script>

<!-- 2. Open Graph & Twitter Meta Tags -->
{% if first_photo != blank %}
<meta property="og:image" content="{{ first_photo }}">
<meta name="twitter:image" content="{{ first_photo }}">
{% endif %}
<meta property="og:title" content="{{ page.title | escape }}">
<meta property="og:description" content="{{ meta_description | strip_html | truncate: 160 | escape }}">
<meta property="og:type" content="place">
<meta property="og:url" content="{{ canonical_url }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page.title | escape }}">
<meta name="twitter:description" content="{{ meta_description | strip_html | truncate: 160 | escape }}">
<meta name="description" content="{{ meta_description | strip_html | truncate: 160 | escape }}">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --mg-bg: #FAFAF8;
    --mg-text: #1A1A1A;
    --mg-text-secondary: #6B6B6B;
    --mg-accent: {{ accent_color }};
    --mg-star-gold: #D4AF37;
    --mg-border: rgba(0,0,0,0.08);
    --mg-white: #ffffff;
  }

  .murmurgo-place-page {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--mg-text);
    background: var(--mg-bg);
    line-height: 1.6;
  }

  .murmurgo-place-page h1,
  .murmurgo-place-page h2,
  .murmurgo-place-page h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
  }

  /* 3. Hero Section */
  .mg-hero {
    position: relative;
    width: 100%;
    min-height: 600px;
    height: 100vh;
    max-height: 900px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background-color: #1a1a1a;
  }

  .mg-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  .mg-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.05) 100%);
    z-index: 2;
  }

  .mg-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    color: var(--mg-white);
  }

  .mg-hero__breadcrumb {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
    margin-bottom: 16px;
  }

  .mg-hero__breadcrumb a {
    color: var(--mg-white);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .mg-hero__breadcrumb a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .mg-hero__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin: 0 0 16px;
    color: var(--mg-white);
  }

  .mg-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    font-size: 0.95rem;
  }

  .mg-hero__badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    background: var(--mg-accent);
    color: var(--mg-white);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .mg-hero__rating {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mg-hero__stars {
    color: var(--mg-star-gold);
    letter-spacing: 2px;
  }

  .mg-hero__scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: var(--mg-white);
    opacity: 0.6;
    animation: mg-bounce 2s infinite;
    cursor: pointer;
  }

  @keyframes mg-bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-8px); }
    60% { transform: translateX(-50%) translateY(-4px); }
  }

  /* 4. Tab Navigation */
  .mg-tabs {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--mg-bg);
    border-bottom: 1px solid var(--mg-border);
  }

  .mg-tabs__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .mg-tabs__inner::-webkit-scrollbar {
    display: none;
  }

  .mg-tabs__link {
    display: block;
    padding: 16px 20px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--mg-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .mg-tabs__link:hover {
    color: var(--mg-text);
  }

  .mg-tabs__link--active {
    color: var(--mg-text);
    border-bottom-color: var(--mg-accent);
  }

  /* 5. Overview Section */
  .mg-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 24px;
  }

  .mg-overview {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 48px;
  }

  .mg-overview__main h2 {
    font-size: 2rem;
    margin: 0 0 24px;
  }

  .mg-overview__body {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--mg-text-secondary);
  }

  .mg-overview__body p + p {
    margin-top: 1.2em;
  }

  .mg-facts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
  }

  .mg-fact {
    padding: 16px;
    background: rgba(0,0,0,0.02);
    border-radius: 8px;
    border: 1px solid var(--mg-border);
  }

  .mg-fact__label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mg-text-secondary);
    margin-bottom: 6px;
  }

  .mg-fact__value {
    font-size: 0.95rem;
    color: var(--mg-text);
    word-break: break-word;
  }

  .mg-fact__value a {
    color: var(--mg-accent);
    text-decoration: none;
  }

  .mg-fact__value a:hover {
    text-decoration: underline;
  }

  .mg-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mg-card {
    background: var(--mg-white);
    border: 1px solid var(--mg-border);
    border-radius: 12px;
    padding: 24px;
  }

  .mg-card__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.25rem;
    margin: 0 0 16px;
  }

  .mg-card__row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    margin-bottom: 10px;
    color: var(--mg-text-secondary);
  }

  .mg-card__row:last-child {
    margin-bottom: 0;
  }

  .mg-card__row a {
    color: var(--mg-text);
    text-decoration: none;
    word-break: break-all;
  }

  .mg-card__row a:hover {
    color: var(--mg-accent);
    text-decoration: underline;
  }

  .mg-card__stars {
    color: var(--mg-star-gold);
    letter-spacing: 1px;
  }

  .mg-share {
    display: flex;
    gap: 10px;
    margin-top: 12px;
  }

  .mg-share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--mg-bg);
    border: 1px solid var(--mg-border);
    color: var(--mg-text-secondary);
    text-decoration: none;
    transition: all 0.2s;
    font-size: 0.8rem;
  }

  .mg-share__btn:hover {
    background: var(--mg-accent);
    color: var(--mg-white);
    border-color: var(--mg-accent);
  }

  /* 6. Tips Section */
  .mg-tips {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  .mg-tips__inner {
    position: relative;
    padding: 32px 36px;
    background: color-mix(in srgb, var(--mg-accent) 6%, transparent);
    border-left: 4px solid var(--mg-accent);
    border-radius: 0 8px 8px 0;
  }

  .mg-tips__label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--mg-accent);
    margin-bottom: 12px;
  }

  .mg-tips__body {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--mg-text);
  }

  .mg-tips__toggle {
    display: inline-block;
    margin-top: 16px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--mg-accent);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    text-decoration: underline;
  }

  .mg-tips__body--truncated {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 7. Photos Section */
  .mg-photos {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  .mg-photos__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .mg-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    background: #e5e5e5;
  }

  .mg-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .mg-photo:hover img {
    transform: scale(1.04);
  }

  /* 8. Map Section */
  .mg-map {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 64px;
  }

  .mg-map__container {
    width: 100%;
    height: 400px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--mg-border);
  }

  .mg-map__actions {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .mg-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid var(--mg-border);
    background: var(--mg-white);
    color: var(--mg-text);
  }

  .mg-btn:hover {
    background: var(--mg-accent);
    color: var(--mg-white);
    border-color: var(--mg-accent);
  }

  /* 9. Nearby Section */
  .mg-nearby {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .mg-nearby__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .mg-nearby__loading,
  .mg-nearby__empty {
    color: var(--mg-text-secondary);
    font-size: 0.95rem;
  }

  /* 10. Footer */
  .mg-footer {
    text-align: center;
    padding: 40px 24px;
    border-top: 1px solid var(--mg-border);
    color: var(--mg-text-secondary);
    font-size: 0.85rem;
  }

  /* Lightbox */
  .mg-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.92);
    display: none;
    align-items: center;
    justify-content: center;
  }

  .mg-lightbox--open {
    display: flex;
  }

  .mg-lightbox__img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
  }

  .mg-lightbox__close,
  .mg-lightbox__prev,
  .mg-lightbox__next {
    position: absolute;
    background: rgba(255,255,255,0.1);
    border: none;
    color: var(--mg-white);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .mg-lightbox__close:hover,
  .mg-lightbox__prev:hover,
  .mg-lightbox__next:hover {
    background: rgba(255,255,255,0.25);
  }

  .mg-lightbox__close {
    top: 20px;
    right: 20px;
  }

  .mg-lightbox__prev {
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .mg-lightbox__next {
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .mg-photos__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .mg-nearby__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .mg-photos__grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .mg-nearby__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 767px) {
    .mg-overview {
      grid-template-columns: 1fr;
    }
    .mg-facts {
      grid-template-columns: 1fr;
    }
    .mg-hero__content {
      padding-bottom: 60px;
    }
    .mg-section {
      padding-top: 40px;
      padding-bottom: 40px;
    }
  }
</style>

<div class="murmurgo-place-page">

  <!-- 3. Hero Section -->
  <section class="mg-hero">
    {% if has_photos %}
      <div class="mg-hero__bg" style="background-image: url('{{ first_photo | escape }}');"></div>
    {% else %}
      <div class="mg-hero__bg" style="background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);"></div>
    {% endif %}
    <div class="mg-hero__overlay"></div>
    <div class="mg-hero__content">
      <nav class="mg-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        {% if plekify_country != blank %}<span> / </span><a href="/pages/{{ plekify_country | handleize }}">{{ plekify_country }}</a>{% endif %}
        {% if plekify_region != blank %}<span> / </span><a href="/pages/{{ plekify_region | handleize }}">{{ plekify_region }}</a>{% endif %}
        {% if plekify_city != blank %}<span> / </span><a href="/pages/{{ plekify_city | handleize }}">{{ plekify_city }}</a>{% endif %}
        <span> / {{ page.title | escape }}</span>
      </nav>
      <h1 class="mg-hero__title">{{ page.title | escape }}</h1>
      <div class="mg-hero__meta">
        {% if plekify_primary_type != blank %}
          <span class="mg-hero__badge">{{ plekify_primary_type | replace: '_', ' ' | capitalize }}</span>
        {% endif %}
        {% if plekify_city != blank %}
          <span>{{ plekify_city }}{% if plekify_country != blank %}, {{ plekify_country }}{% endif %}</span>
        {% endif %}
        {% if plekify_google_rating != blank %}
          <div class="mg-hero__rating">
            <span class="mg-hero__stars">{% for i in (1..5) %}{% if i <= plekify_google_rating %}★{% else %}☆{% endif %}{% endfor %}</span>
            <span>{{ plekify_google_rating }} <small>({{ plekify_google_review_count | default: 0 }} reviews)</small></span>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="mg-hero__scroll" onclick="document.getElementById('overview').scrollIntoView({behavior:'smooth'})">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>
  </section>

  <!-- 4. Tab Navigation -->
  <nav class="mg-tabs">
    <div class="mg-tabs__inner">
      <a href="#overview" class="mg-tabs__link mg-tabs__link--active" data-tab="overview">Overview</a>
      {% if has_tips %}<a href="#tips" class="mg-tabs__link" data-tab="tips">Tips</a>{% endif %}
      {% if has_photos %}<a href="#photos" class="mg-tabs__link" data-tab="photos">Photos</a>{% endif %}
      {% if has_map %}<a href="#map" class="mg-tabs__link" data-tab="map">Map</a>{% endif %}
      {% if has_nearby %}<a href="#nearby" class="mg-tabs__link" data-tab="nearby">Nearby</a>{% endif %}
    </div>
  </nav>

  <!-- 5. Overview Section -->
  <section id="overview" class="mg-section">
    <div class="mg-overview">
      <div class="mg-overview__main">
        <h2>About</h2>
        {% if plekify_copy_body != blank %}
          <div class="mg-overview__body">
            {{ plekify_copy_body | newline_to_br }}
          </div>
        {% elsif plekify_copy_short != blank %}
          <div class="mg-overview__body">
            {{ plekify_copy_short | newline_to_br }}
          </div>
        {% endif %}

        <div class="mg-facts">
          {% if plekify_formatted_address != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Address</div>
              <div class="mg-fact__value">{{ plekify_formatted_address | escape }}</div>
            </div>
          {% endif %}
          {% if plekify_phone != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Phone</div>
              <div class="mg-fact__value"><a href="tel:{{ plekify_phone | escape }}">{{ plekify_phone | escape }}</a></div>
            </div>
          {% endif %}
          {% if plekify_website != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Website</div>
              <div class="mg-fact__value"><a href="{{ plekify_website | escape }}" target="_blank" rel="noopener">{{ plekify_website | truncate: 40 | escape }}</a></div>
            </div>
          {% endif %}
          {% if plekify_opening_hours != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Hours</div>
              <div class="mg-fact__value">{{ plekify_opening_hours | newline_to_br }}</div>
            </div>
          {% endif %}
          {% if plekify_price_level != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Price</div>
              <div class="mg-fact__value">{{ plekify_price_level | escape }}</div>
            </div>
          {% endif %}
          {% if plekify_primary_type != blank %}
            <div class="mg-fact">
              <div class="mg-fact__label">Type</div>
              <div class="mg-fact__value">{{ plekify_primary_type | replace: '_', ' ' | capitalize | escape }}</div>
            </div>
          {% endif %}
        </div>
      </div>

      <aside class="mg-sidebar">
        <div class="mg-card">
          <h3 class="mg-card__title">At a Glance</h3>
          {% if plekify_primary_type != blank %}
            <div class="mg-card__row">
              <span>Type:</span>
              <span>{{ plekify_primary_type | replace: '_', ' ' | capitalize | escape }}</span>
            </div>
          {% endif %}
          {% if plekify_google_rating != blank %}
            <div class="mg-card__row">
              <span>Rating:</span>
              <span class="mg-card__stars">
                {% for i in (1..5) %}{% if i <= plekify_google_rating %}★{% else %}☆{% endif %}{% endfor %}
                {{ plekify_google_rating }}
              </span>
            </div>
          {% endif %}
          {% if plekify_city != blank %}
            <div class="mg-card__row">
              <span>Location:</span>
              <span>{{ plekify_city | escape }}{% if plekify_region != blank %}, {{ plekify_region | escape }}{% endif %}</span>
            </div>
          {% endif %}
          {% if has_map %}
            <div class="mg-card__row" style="margin-top:8px;">
              <a href="https://www.google.com/maps/search/?api=1&query={{ plekify_latitude }},{{ plekify_longitude }}" target="_blank" rel="noopener">
                <img src="https://api.mapbox.com/styles/v1/mapbox/light-v11/static/pin-s+{{ accent_color | remove: '#' }}({{ plekify_longitude }},{{ plekify_latitude }})/{{ plekify_longitude }},{{ plekify_latitude }},13,0/400x200@2x?access_token=pk.placeholder" alt="Map" style="width:100%;border-radius:6px;border:1px solid var(--mg-border);" loading="lazy">
              </a>
            </div>
          {% endif %}
        </div>

        <div class="mg-card">
          <h3 class="mg-card__title">Contact</h3>
          {% if plekify_phone != blank %}
            <div class="mg-card__row">
              <a href="tel:{{ plekify_phone | escape }}">{{ plekify_phone | escape }}</a>
            </div>
          {% endif %}
          {% if plekify_email != blank %}
            <div class="mg-card__row">
              <a href="mailto:{{ plekify_email | escape }}">{{ plekify_email | escape }}</a>
            </div>
          {% endif %}
          {% if plekify_website != blank %}
            <div class="mg-card__row">
              <a href="{{ plekify_website | escape }}" target="_blank" rel="noopener">Visit website</a>
            </div>
          {% endif %}
        </div>

        <div class="mg-card">
          <h3 class="mg-card__title">Share</h3>
          <div class="mg-share">
            <a class="mg-share__btn" href="https://www.facebook.com/sharer/sharer.php?u={{ canonical_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Facebook">f</a>
            <a class="mg-share__btn" href="https://twitter.com/intent/tweet?url={{ canonical_url | url_encode }}&text={{ page.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on X">X</a>
            <a class="mg-share__btn" href="https://wa.me/?text={{ page.title | url_encode }}%20{{ canonical_url | url_encode }}" target="_blank" rel="noopener" aria-label="Share on WhatsApp">W</a>
            <a class="mg-share__btn" href="mailto:?subject={{ page.title | url_encode }}&body={{ canonical_url | url_encode }}" aria-label="Share by email">@</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- 6. Tips Section -->
  {% if has_tips %}
  <section id="tips" class="mg-tips">
    <div class="mg-tips__inner">
      <div class="mg-tips__label">Insider Tips</div>
      <div class="mg-tips__body" id="tips-body">
        {{ plekify_copy_tips | newline_to_br }}
      </div>
      <button class="mg-tips__toggle" id="tips-toggle" style="display:none;">Read more</button>
    </div>
  </section>
  {% endif %}

  <!-- 7. Photos Section -->
  {% if has_photos %}
  <section id="photos" class="mg-photos">
    <div class="mg-photos__grid" id="photos-grid">
      {% for photo in plekify_photos_json limit: 20 %}
        {% assign photo_url = photo.url %}
        {% if photo_url == blank %}
          {% assign photo_url = photo | split: '"url"' | last | split: '"' | slice: 1 | first | replace: '\\/', '/' %}
        {% endif %}
        {% if photo_url != blank %}
          <div class="mg-photo" data-index="{{ forloop.index0 }}" data-src="{{ photo_url | escape }}">
            <img src="{{ photo_url | escape }}" alt="{{ page.title | escape }} - photo {{ forloop.index }}" loading="lazy" width="{{ photo.width | default: 600 }}" height="{{ photo.height | default: 450 }}">
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- 8. Map Section -->
  {% if has_map %}
  <section id="map" class="mg-map">
    <div class="mg-map__container" id="map-container" data-lat="{{ plekify_latitude }}" data-lng="{{ plekify_longitude }}"></div>
    <div class="mg-map__actions">
      <a class="mg-btn" href="https://www.google.com/maps/dir/?api=1&destination={{ plekify_latitude }},{{ plekify_longitude }}" target="_blank" rel="noopener">Get Directions</a>
      <a class="mg-btn" href="https://www.google.com/maps/search/?api=1&query={{ plekify_latitude }},{{ plekify_longitude }}" target="_blank" rel="noopener">Open in Google Maps</a>
    </div>
  </section>
  {% endif %}

  <!-- 9. Nearby Section -->
  {% if has_nearby %}
  <section id="nearby" class="mg-nearby">
    <h2 style="font-size:2rem;margin:0 0 24px;font-family:'Cormorant Garamond',Georgia,serif;">Nearby Places</h2>
    <div class="mg-nearby__grid" id="nearby-grid">
      <div class="mg-nearby__loading">Loading nearby places...</div>
    </div>
  </section>
  {% endif %}

  <!-- 10. Footer -->
  <footer class="mg-footer">
    <p>&copy; 2026 Murmurgo. Crafted for African travel.</p>
  </footer>

</div>

<!-- Lightbox -->
<div class="mg-lightbox" id="lightbox">
  <button class="mg-lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
  <button class="mg-lightbox__prev" id="lightbox-prev" aria-label="Previous">&#10094;</button>
  <img class="mg-lightbox__img" id="lightbox-img" src="" alt="">
  <button class="mg-lightbox__next" id="lightbox-next" aria-label="Next">&#10095;</button>
</div>

<script>
(function() {
  'use strict';

  // ---- Tabs ----
  const tabLinks = document.querySelectorAll('.mg-tabs__link');
  function onScroll() {
    const sections = ['overview', 'tips', 'photos', 'map', 'nearby']
      .map(id => document.getElementById(id))
      .filter(Boolean);
    let current = 'overview';
    const scrollPos = window.scrollY + 120;
    for (const sec of sections) {
      if (sec.offsetTop <= scrollPos) current = sec.id;
    }
    tabLinks.forEach(link => {
      link.classList.toggle('mg-tabs__link--active', link.dataset.tab === current);
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ---- Tips toggle ----
  const tipsBody = document.getElementById('tips-body');
  const tipsToggle = document.getElementById('tips-toggle');
  if (tipsBody && tipsToggle) {
    if (tipsBody.textContent.length > 500) {
      tipsToggle.style.display = 'inline-block';
      tipsBody.classList.add('mg-tips__body--truncated');
      tipsToggle.addEventListener('click', () => {
        const isTruncated = tipsBody.classList.toggle('mg-tips__body--truncated');
        tipsToggle.textContent = isTruncated ? 'Read more' : 'Show less';
      });
    }
  }

  // ---- Lightbox ----
  const photos = [];
  document.querySelectorAll('.mg-photo').forEach(el => {
    photos.push(el.dataset.src);
  });
  let currentPhoto = 0;
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');

  function openLightbox(index) {
    currentPhoto = index;
    lightboxImg.src = photos[index];
    lightbox.classList.add('mg-lightbox--open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lightbox.classList.remove('mg-lightbox--open');
    document.body.style.overflow = '';
  }
  function prevPhoto() {
    currentPhoto = (currentPhoto - 1 + photos.length) % photos.length;
    lightboxImg.src = photos[currentPhoto];
  }
  function nextPhoto() {
    currentPhoto = (currentPhoto + 1) % photos.length;
    lightboxImg.src = photos[currentPhoto];
  }

  document.querySelectorAll('.mg-photo').forEach(el => {
    el.addEventListener('click', () => openLightbox(parseInt(el.dataset.index, 10)));
  });
  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev').addEventListener('click', prevPhoto);
  document.getElementById('lightbox-next').addEventListener('click', nextPhoto);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (!lightbox.classList.contains('mg-lightbox--open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevPhoto();
    if (e.key === 'ArrowRight') nextPhoto();
  });

  // ---- MapLibre ----
  const mapContainer = document.getElementById('map-container');
  if (mapContainer && typeof maplibregl !== 'undefined') {
    const lat = parseFloat(mapContainer.dataset.lat);
    const lng = parseFloat(mapContainer.dataset.lng);
    const map = new maplibregl.Map({
      container: 'map-container',
      style: 'https://demotiles.maplibre.org/style.json',
      center: [lng, lat],
      zoom: 13
    });
    new maplibregl.Marker({ color: getComputedStyle(document.documentElement).getPropertyValue('--mg-accent').trim() || '#2A9D8F' })
      .setLngLat([lng, lat])
      .addTo(map);
  }

  // ---- Nearby ----
  const nearbyGrid = document.getElementById('nearby-grid');
  if (nearbyGrid && mapContainer) {
    const lat = mapContainer.dataset.lat;
    const lng = mapContainer.dataset.lng;
    fetch(`/api/places/nearby?lat=${lat}&lng=${lng}&limit=8`)
      .then(r => r.ok ? r.json() : Promise.reject(r.status))
      .then(data => {
        if (!Array.isArray(data) || data.length === 0) {
          nearbyGrid.innerHTML = '<div class="mg-nearby__empty">No nearby places found.</div>';
          return;
        }
        nearbyGrid.innerHTML = data.map(p => `
          <a href="${p.slug ? '/pages/' + p.slug : '/a/murmurgo/place/' + p.id}" class="mg-card" style="text-decoration:none;color:inherit;">
            <div style="aspect-ratio:4/3;border-radius:8px;overflow:hidden;margin-bottom:12px;background:#e5e5e5;">
              <img src="${p.thumbnail || p.hero_image || ''}" alt="${p.name}" loading="lazy" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'">
            </div>
            <div style="font-weight:600;font-size:0.95rem;color:var(--mg-text);margin-bottom:4px;">${p.name}</div>
            <div style="font-size:0.8rem;color:var(--mg-text-secondary);">
              ${p.primary_type ? p.primary_type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) : 'Place'}
              ${p.distance ? ' · ' + (p.distance < 1 ? (p.distance * 1000).toFixed(0) + 'm' : p.distance.toFixed(1) + 'km') : ''}
            </div>
          </a>
        `).join('');
      })
      .catch(() => {
        nearbyGrid.innerHTML = '<div class="mg-nearby__empty">Unable to load nearby places.</div>';
      });
  }
})();
</script>
