            "text_RbMLWp": {
              "type": "text",
              "name": "t:names.description",
              "settings": {
                "text": "<h4>Who its for</h4><ul><li><strong>Single Properties</strong>: Safari lodges, boutique hotels, and guest houses</li><li><strong>Property Groups</strong>: Multi-property collections (like hotel groups or safari camps)</li><li><strong>Tour Operators</strong>: Companies selling safaris, tours, and travel packages</li></ul><h4>How It Works</h4><ol><li><strong>Sync Your Content</strong>: Plekify pulls all your data from Wetu—descriptions, photos, videos, 360° tours, room types, activities, and GPS coordinates</li><li><strong>Auto-Generate Your Site</strong>: Every property, room, and activity becomes its own page with interactive maps, image galleries, and rich media</li><li><strong>Accept Bookings</strong>: Customers book and pay directly on your domain using Shopify's checkout</li></ol><p></p><p></p><p></p>",
