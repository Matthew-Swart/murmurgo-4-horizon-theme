{% comment %}
  page.place-country.liquid
  Country destination hub — provinces as sub-regions + map
  Reads from page.metafields.plekify_region.*
{% endcomment %}

{% assign country_id = page.metafields.plekify_region.hierarchy_id.value %}
{% assign country_name = page.metafields.plekify_region.name.value | default: page.title %}
{% assign country_level = page.metafields.plekify_region.level.value %}
{% assign country_code = page.metafields.plekify_region.country_code.value %}
{% assign country_lat = page.metafields.plekify_region.center_lat.value %}
{% assign country_lng = page.metafields.plekify_region.center_lng.value %}
{% assign country_place_count = page.metafields.plekify_region.place_count.value %}
{% assign country_description = page.metafields.plekify_region.description.value | default: page.content %}
{% assign country_photos_json = page.metafields.plekify_region.photos.value %}
{% assign country_children_json = page.metafields.plekify_region.children.value %}

{% assign has_photos = false %}
{% assign first_photo = "" %}
{% if country_photos_json != blank and country_photos_json != "[]" and country_photos_json != "null" %}
  {% assign photos_array = country_photos_json | json %}
  {% assign first_photo = photos_array | split: '"' | slice: 1 | first | replace: '\\/', '/' %}
  {% if first_photo != blank %}
    {% assign has_photos = true %}
  {% endif %}
{% endif %}

{% assign has_children = false %}
{% if country_children_json != blank and country_children_json != "[]" and country_children_json != "null" %}
  {% assign has_children = true %}
{% endif %}

{% assign has_map = false %}
{% if country_lat != blank and country_lng != blank %}
  {% assign has_map = true %}
{% endif %}

<!-- JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Country",
  "name": {{ country_name | json }},
  "description": {{ country_description | strip_html | truncate: 300 | json }},
  "url": {{ canonical_url | json }}{% if has_map %},
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ country_lat | json }},
    "longitude": {{ country_lng | json }}
  }{% endif %}{% if first_photo != blank %},
  "image": {{ first_photo | json }}{% endif %}
}
</script>

<!-- MapLibre -->
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>

<!-- Shared styles -->
{{ 'place-hub.css' | asset_url | stylesheet_tag }}

<div class="place-hub-page">

  <!-- Hero -->
  <section class="ph-hero ph-hero--country">
    {% if has_photos %}
      <div class="ph-hero__bg" style="background-image: url('{{ first_photo | escape }}');"></div>
    {% endif %}
    <div class="ph-hero__overlay"></div>
    <div class="ph-hero__content">
      <nav class="ph-hero__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span> / {{ country_name | escape }}</span>
      </nav>
      <h1 class="ph-hero__title">{{ country_name | escape }}</h1>
      <div class="ph-hero__meta">
        <span class="ph-hero__badge">Country</span>
        {% if country_place_count != blank %}
          <span>{{ country_place_count | append: ' places' }}</span>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- Overview -->
  {% if country_description != blank %}
  <section class="ph-overview">
    <h2>About {{ country_name | escape }}</h2>
    <div class="ph-description">
      {{ country_description | newline_to_br }}
    </div>
    {% if country_place_count != blank %}
    <div class="ph-stats">
      <div class="ph-stat">
        <div class="ph-stat__value">{{ country_place_count }}</div>
        <div class="ph-stat__label">Places</div>
      </div>
      {% if has_children %}
      <div class="ph-stat">
        <div class="ph-stat__value" id="stat-provinces">—</div>
        <div class="ph-stat__label">Provinces</div>
      </div>
      {% endif %}
    </div>
    {% endif %}
  </section>
  {% endif %}

  <!-- Provinces -->
  <section class="ph-subregions" id="subregions-section" style="display:none;" data-children-json='{{ page.metafields.plekify_region.children.value | json }}'>
    <div class="ph-subregions__header">
      <h2>Explore {{ country_name | escape }}</h2>
    </div>
    <div class="ph-subregions__scroll" id="subregions-scroll"></div>
  </section>

  <!-- Map -->
  {% if has_map %}
  <section class="ph-map-section">
    <h2>Map of {{ country_name | escape }}</h2>
    <div class="ph-map-container" id="country-map"
         data-lat="{{ country_lat }}"
         data-lng="{{ country_lng }}"
         data-name="{{ country_name | escape }}"
         data-level="country">
    </div>
  </section>
  {% endif %}

  <!-- Photos -->
  {% if has_photos %}
  <section class="ph-photos-section">
    <h2>Photos</h2>
    <div class="ph-photos-grid" id="photos-grid">
      {% assign photo_list = country_photos_json | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ',' %}
      {% for photo_url in photo_list limit: 20 %}
        {% assign photo_url = photo_url | strip %}
        {% if photo_url != blank %}
          <div class="ph-photo" data-index="{{ forloop.index0 }}" data-src="{{ photo_url | escape }}">
            <img src="{{ photo_url | escape }}" alt="{{ country_name | escape }} - photo {{ forloop.index }}" loading="lazy">
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>

<!-- Fullscreen Gallery -->
<div class="ph-gallery-overlay" id="gallery-overlay">
  <div class="ph-gallery-counter" id="gallery-counter">1 / 1</div>
  <button class="ph-gallery-close" id="gallery-close" aria-label="Close">&times;</button>
  <div class="ph-gallery-main" id="gallery-main">
    <div class="ph-gallery-stack" id="gallery-stack"></div>
  </div>
  <div class="ph-gallery-sidebar" id="gallery-sidebar"></div>
</div>

<!-- Shared JS -->
<script src="{{ 'place-hub.js' | asset_url }}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  window.renderSubRegions('subregions-section', 'subregions-scroll', 'stat-provinces');
  window.initGallery('.ph-photo', 'gallery-overlay', 'gallery-stack', 'gallery-sidebar', 'gallery-counter', 'gallery-close');
  window.initMap('country-map');
});
</script>
