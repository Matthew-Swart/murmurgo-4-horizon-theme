{% comment %}
  ============================================================================
  WETU TRANSFER CARD SNIPPET
  ============================================================================

  Displays transfer/transport information between destinations.

  PARAMETERS:
  - route: The route metaobject
  - compact: Boolean for compact display (arrival transfers)
  - use_boarding_pass: Boolean for enhanced boarding pass style for flights (default: false)
  - itinerary_date: Date of travel (optional, for calendar export)

  ROUTE MODES:
  - Transfer, Shuttle: Ground vehicle
  - ScheduledFlight, CharterFlight: Air travel (optionally enhanced boarding pass)
  - Selfdrive: Self-drive route
  - Train: Rail travel
  - Boat: Water transport
  - Helicopter: Helicopter transfer

  ============================================================================
{% endcomment %}

{% comment %} Check if we should render as boarding pass {% endcomment %}
{% assign route_mode = route.mode.value %}
{% if use_boarding_pass and route_mode == 'ScheduledFlight' or use_boarding_pass and route_mode == 'CharterFlight' %}
  {% render 'wetu-flight-boarding-pass',
    route: route,
    day_number: day_number,
    itinerary_date: itinerary_date
  %}
{% else %}

{% assign route_mode = route.mode.value %}
{% assign route_type = route.type.value %}
{% assign route_label = route.label.value | default: route_mode %}
{% assign start_location = route.start_location.value %}
{% assign end_location = route.end_location.value %}
{% assign start_time = route.start_time.value %}
{% assign end_time = route.end_time.value %}
{% assign duration = route.duration.value %}
{% assign distance = route.distance.value %}
{% assign agency = route.agency.value %}
{% assign vehicle = route.vehicle.value %}
{% assign ticket_class = route.ticket_class.value %}
{% assign start_terminal = route.start_terminal.value %}
{% assign end_terminal = route.end_terminal.value %}
{% assign directions = route.directions.value %}
{% assign reference_codes = route.reference_codes.value %}
{% assign via_points = route.via_points.value %}

{% comment %} Determine if this is a flight {% endcomment %}
{% assign is_flight = false %}
{% if route_mode == 'ScheduledFlight' or route_mode == 'CharterFlight' or route_mode == 'Helicopter' %}
  {% assign is_flight = true %}
{% endif %}

{% assign is_self_drive = false %}
{% if route_mode == 'Selfdrive' %}
  {% assign is_self_drive = true %}
{% endif %}

<div class="wetu-transfer-card{% if compact %} wetu-transfer-card--compact{% endif %} wetu-transfer-card--{{ route_mode | handleize }}">
  {% comment %} Transport Icon {% endcomment %}
  <div class="transfer-card__icon">
    {% case route_mode %}
      {% when 'ScheduledFlight', 'CharterFlight' %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
        </svg>
      {% when 'Helicopter' %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v2M5 6h14M12 8v8M6 16h12"/>
          <ellipse cx="12" cy="18" rx="5" ry="3"/>
        </svg>
      {% when 'Selfdrive' %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/>
          <circle cx="6.5" cy="16.5" r="2.5"/>
          <circle cx="16.5" cy="16.5" r="2.5"/>
        </svg>
      {% when 'Train' %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="4" y="3" width="16" height="16" rx="2"/>
          <path d="M4 11h16"/>
          <path d="M12 3v8"/>
          <path d="M8 19l-2 3"/>
          <path d="M16 19l2 3"/>
          <circle cx="8" cy="15" r="1"/>
          <circle cx="16" cy="15" r="1"/>
        </svg>
      {% when 'Boat' %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
          <path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/>
          <path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/>
          <path d="M12 10v4"/>
          <path d="M12 2v3"/>
        </svg>
      {% else %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="1" y="3" width="15" height="13"/>
          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
    {% endcase %}
  </div>

  {% comment %} Transfer Content {% endcomment %}
  <div class="transfer-card__content">
    {% comment %} Mode & Label {% endcomment %}
    <div class="transfer-card__header">
      <span class="transfer-card__mode">
        {% case route_mode %}
          {% when 'ScheduledFlight' %}Flight
          {% when 'CharterFlight' %}Charter Flight
          {% when 'Selfdrive' %}Self-Drive
          {% when 'Transfer' %}Transfer
          {% when 'Shuttle' %}Shuttle
          {% when 'Train' %}Train
          {% when 'Boat' %}Boat
          {% when 'Helicopter' %}Helicopter
          {% else %}{{ route_mode }}
        {% endcase %}
        {% if route_label != route_mode and route_label != blank %}
          <span class="transfer-card__label-badge">{{ route_label }}</span>
        {% endif %}
      </span>
      
      {% if reference_codes != blank %}
        <span class="transfer-card__label-badge" style="background: color-mix(in srgb, var(--color-foreground) 8%, transparent); color: color-mix(in srgb, var(--color-foreground) 70%, transparent);">Ref: {{ reference_codes }}</span>
      {% endif %}
      
      {% comment %} Duration Badge {% endcomment %}
      {% if duration != blank %}
        <span class="transfer-card__duration">{{ duration }}</span>
      {% endif %}
    </div>

    {% comment %} Route Points {% endcomment %}
    <div class="transfer-card__route">
      {% comment %} Start Point {% endcomment %}
      <div class="route-point route-point--start">
        <span class="route-point__dot"></span>
        <div class="route-point__info">
          <span class="route-point__location">{{ start_location | default: 'Origin' }}</span>
          {% if start_time != blank %}
            <span class="route-point__time">{{ start_time }}</span>
          {% endif %}
          {% if is_flight and start_terminal != blank %}
            <span class="route-point__terminal">Terminal {{ start_terminal }}</span>
          {% endif %}
        </div>
      </div>

      {% comment %} Route Line {% endcomment %}
      <div class="route-line">
        {% if distance != blank %}
          {% assign distance_km = distance | divided_by: 1000.0 | round %}
          <span class="route-line__distance">{{ distance_km }} km</span>
        {% endif %}
      </div>

      {% comment %} End Point {% endcomment %}
      <div class="route-point route-point--end">
        <span class="route-point__dot"></span>
        <div class="route-point__info">
          <span class="route-point__location">{{ end_location | default: 'Destination' }}</span>
          {% if end_time != blank %}
            <span class="route-point__time">{{ end_time }}</span>
          {% endif %}
          {% if is_flight and end_terminal != blank %}
            <span class="route-point__terminal">Terminal {{ end_terminal }}</span>
          {% endif %}
        </div>
      </div>
    </div>

    {% comment %} Additional Details (not shown in compact mode) {% endcomment %}
    {% unless compact %}
      {% if via_points != blank %}
        <div class="transfer-card__via-points" style="margin-bottom: 12px; font-size: 0.85rem; color: color-mix(in srgb, var(--color-foreground) 70%, transparent);">
          <strong>Via:</strong> {{ via_points }}
        </div>
      {% endif %}
      
      {% if agency != blank or vehicle != blank or ticket_class != blank %}
        <div class="transfer-card__details">
          {% if agency != blank %}
            <span class="detail-item">
              <span class="detail-label">{% if is_flight %}Airline{% else %}Provider{% endif %}:</span>
              <span class="detail-value">{{ agency }}</span>
            </span>
          {% endif %}
          {% if vehicle != blank %}
            <span class="detail-item">
              <span class="detail-label">{% if is_flight %}Flight{% else %}Vehicle{% endif %}:</span>
              <span class="detail-value">{{ vehicle }}</span>
            </span>
          {% endif %}
          {% if ticket_class != blank %}
            <span class="detail-item">
              <span class="detail-label">Class:</span>
              <span class="detail-value">{{ ticket_class }}</span>
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% comment %} Driving Directions (for self-drive) {% endcomment %}
      {% if is_self_drive and directions != blank %}
        <details class="transfer-card__directions">
          <summary class="directions__toggle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
            View Driving Directions
          </summary>
          <div class="directions__content">
            {% assign direction_steps = directions | split: '|' %}
            <ol class="directions__list">
              {% for step in direction_steps %}
                {% assign step_clean = step | strip %}
                {% if step_clean != blank %}
                  <li>{{ step_clean }}</li>
                {% endif %}
              {% endfor %}
            </ol>
          </div>
        </details>
      {% endif %}
    {% endunless %}
  </div>
</div>

<style>
  .wetu-transfer-card {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .wetu-transfer-card--compact {
    padding: 16px;
    background: transparent;
    border: none;
    border-radius: 0;
  }

  /* Icon */
  .transfer-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .wetu-transfer-card--scheduledFlight .transfer-card__icon,
  .wetu-transfer-card--charterflight .transfer-card__icon {
    background: color-mix(in srgb, #3b82f6 15%, transparent);
    color: #3b82f6;
  }

  .wetu-transfer-card--helicopter .transfer-card__icon {
    background: color-mix(in srgb, #8b5cf6 15%, transparent);
    color: #8b5cf6;
  }

  .wetu-transfer-card--selfdrive .transfer-card__icon {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
  }

  .wetu-transfer-card--train .transfer-card__icon {
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    color: #f59e0b;
  }

  .wetu-transfer-card--boat .transfer-card__icon {
    background: color-mix(in srgb, #06b6d4 15%, transparent);
    color: #06b6d4;
  }

  .wetu-transfer-card--transfer .transfer-card__icon,
  .wetu-transfer-card--shuttle .transfer-card__icon {
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    color: var(--color-primary);
  }

  .wetu-transfer-card--compact .transfer-card__icon {
    width: 40px;
    height: 40px;
  }

  /* Content */
  .transfer-card__content {
    flex: 1;
    min-width: 0;
  }

  /* Header */
  .transfer-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .transfer-card__mode {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .transfer-card__label-badge {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 8px;
    background: color-mix(in srgb, var(--color-foreground) 10%, transparent);
    border-radius: 4px;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
  }

  .transfer-card__duration {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    padding: 4px 10px;
    border-radius: 12px;
  }

  /* Route Display */
  .transfer-card__route {
    display: flex;
    align-items: stretch;
    gap: 12px;
    margin-bottom: 12px;
  }

  .route-point {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    flex: 1;
  }

  .route-point__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .route-point--start .route-point__dot {
    background: var(--color-primary);
  }

  .route-point--end .route-point__dot {
    background: transparent;
    border: 2px solid var(--color-foreground);
  }

  .route-point__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .route-point__location {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .route-point__time {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .route-point__terminal {
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .route-line {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 80px;
    position: relative;
  }

  .route-line::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-border) 0px,
      var(--color-border) 6px,
      transparent 6px,
      transparent 10px
    );
  }

  .route-line__distance {
    position: relative;
    z-index: 1;
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    padding: 2px 8px;
    border-radius: 4px;
  }

  /* Details */
  .transfer-card__details {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding: 12px 16px;
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .detail-item {
    display: flex;
    gap: 6px;
    font-size: 0.85rem;
  }

  .detail-label {
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  .detail-value {
    font-weight: 500;
    color: var(--color-foreground);
  }

  /* Directions */
  .transfer-card__directions {
    margin-top: 12px;
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
  }

  .directions__toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    list-style: none;
  }

  .directions__toggle::-webkit-details-marker {
    display: none;
  }

  .directions__toggle svg {
    transition: transform 0.2s ease;
  }

  .transfer-card__directions[open] .directions__toggle svg {
    transform: rotate(90deg);
  }

  .directions__content {
    padding-top: 12px;
  }

  .directions__list {
    margin: 0;
    padding-left: 24px;
    font-size: 0.9rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
  }

  .directions__list li {
    padding: 4px 0;
  }

  /* Compact Adjustments */
  .wetu-transfer-card--compact .transfer-card__header {
    margin-bottom: 8px;
  }

  .wetu-transfer-card--compact .transfer-card__route {
    margin-bottom: 0;
  }

  /* Mobile */
  @media screen and (max-width: 600px) {
    .transfer-card__route {
      flex-direction: column;
      gap: 16px;
    }

    .route-line {
      flex: 0 0 auto;
      height: 40px;
      width: 100%;
      padding-left: 20px;
    }

    .route-line::before {
      top: 0;
      bottom: 0;
      left: 5px;
      right: auto;
      width: 2px;
      height: 100%;
      background: repeating-linear-gradient(
        180deg,
        var(--color-border) 0px,
        var(--color-border) 6px,
        transparent 6px,
        transparent 10px
      );
    }

    .route-line__distance {
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%);
    }
  }
</style>

{% endif %}

