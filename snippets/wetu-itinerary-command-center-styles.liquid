{% style %}
  .itin-command-center[data-section-id="{{ section.id }}"] {
    --itin-command-center-surface-primary: #f2f2f2;
    --itin-command-center-surface-depth: #e8e8e8;
    --itin-command-center-surface-center: #ffffff;
    --itin-command-center-card: #ffffff;
    --itin-command-center-card-hover: #f4f4f4;
    --itin-command-center-border: #bcbcbc;
    --itin-command-center-border-soft: rgba(17, 17, 17, 0.14);
    --itin-command-center-text-primary: #111111;
    --itin-command-center-text-muted: rgba(17, 17, 17, 0.76);
    --itin-command-center-text-faint: rgba(17, 17, 17, 0.5);
    --itin-command-center-accent-rgb: 17, 17, 17;
    --itin-command-center-inverse-rgb: 255, 255, 255;
    --itin-command-center-pane-header-bg: rgba(242, 242, 242, 0.94);
    --itin-command-center-pane-center-header-bg: rgba(246, 246, 246, 0.94);
    --itin-command-center-hero-gradient: linear-gradient(135deg, #696969 0%, #7a7a7a 44%, #8a8a8a 100%);
    --itin-command-center-pane-inline-padding: 1rem;
    --itin-command-center-workspace-columns: 206px minmax(0, 1fr) minmax(0, 1fr);
    --itin-command-center-workspace-columns-left-center: 206px minmax(0, 1fr);
    --itin-command-center-workspace-columns-center-right: minmax(0, 1fr) minmax(0, 1fr);
    --itin-command-center-workspace-columns-center-only: minmax(0, 1fr);
    --itin-command-center-map-panel-bg: rgba(255, 255, 255, 0.9);
    --itin-command-center-map-panel-text: #1a1a1a;
    --itin-command-center-map-shadow: 0 18px 44px rgba(0, 0, 0, 0.25);
    --itin-command-center-map-marker-bg: #ffffff;
    --itin-command-center-map-marker-text: #161616;
    --itin-command-center-map-marker-border: rgba(0, 0, 0, 0.12);
    --itin-command-center-sticky-top: 0px;
    --itin-command-center-control-bar-height: 0px;
    --itin-command-center-font-serif: 'Palatino Linotype', 'Book Antiqua', Palatino, Georgia, serif;
    --itin-command-center-font-sans: 'Avenir Next', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;

    position: relative;
    display: block;
    height: auto;
    max-height: none;
    overflow: visible;
    background: var(--itin-command-center-surface-primary);
    color: var(--itin-command-center-text-primary);
    font-family: var(--itin-command-center-font-sans);
    isolation: isolate;
  }

  .itin-command-center[data-section-id="{{ section.id }}"].color-scheme-5,
  .itin-command-center[data-section-id="{{ section.id }}"].is-theme-light {
    --itin-command-center-surface-primary: #f2f2f2;
    --itin-command-center-surface-depth: #e8e8e8;
    --itin-command-center-surface-center: #ffffff;
    --itin-command-center-card: #ffffff;
    --itin-command-center-card-hover: #f4f4f4;
    --itin-command-center-border: #bcbcbc;
    --itin-command-center-border-soft: rgba(17, 17, 17, 0.14);
    --itin-command-center-text-primary: #111111;
    --itin-command-center-text-muted: rgba(17, 17, 17, 0.76);
    --itin-command-center-text-faint: rgba(17, 17, 17, 0.5);
    --itin-command-center-accent-rgb: 17, 17, 17;
    --itin-command-center-inverse-rgb: 255, 255, 255;
    --itin-command-center-pane-header-bg: rgba(242, 242, 242, 0.94);
    --itin-command-center-pane-center-header-bg: rgba(246, 246, 246, 0.94);
    --itin-command-center-hero-gradient: linear-gradient(135deg, #696969 0%, #7a7a7a 44%, #8a8a8a 100%);
  }

  .itin-command-center[data-section-id="{{ section.id }}"].is-theme-dark {
    --itin-command-center-surface-primary: #333333;
    --itin-command-center-surface-depth: #2e2e2e;
    --itin-command-center-surface-center: #2a2a2a;
    --itin-command-center-card: #3d3d3d;
    --itin-command-center-card-hover: #444444;
    --itin-command-center-border: #505050;
    --itin-command-center-border-soft: rgba(255, 255, 255, 0.14);
    --itin-command-center-text-primary: #ffffff;
    --itin-command-center-text-muted: rgba(255, 255, 255, 0.72);
    --itin-command-center-text-faint: rgba(255, 255, 255, 0.48);
    --itin-command-center-accent-rgb: 255, 255, 255;
    --itin-command-center-inverse-rgb: 17, 17, 17;
    --itin-command-center-pane-header-bg: rgba(46, 46, 46, 0.94);
    --itin-command-center-pane-center-header-bg: rgba(51, 51, 51, 0.94);
    --itin-command-center-hero-gradient: linear-gradient(135deg, #1d1d1d 0%, #252525 45%, #2e2e2e 100%);
    --itin-command-center-map-panel-bg: rgba(22, 22, 30, 0.78);
    --itin-command-center-map-panel-text: #f2f2f4;
    --itin-command-center-map-shadow: 0 18px 44px rgba(0, 0, 0, 0.42);
    --itin-command-center-map-marker-bg: #ffffff;
    --itin-command-center-map-marker-text: #0f0f12;
    --itin-command-center-map-marker-border: rgba(255, 255, 255, 0.24);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__mode-flash {
    position: absolute;
    inset: 0;
    z-index: 26;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.68);
    opacity: 0;
    transition: opacity 0.18s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__mode-flash.is-active {
    opacity: 0.12;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__visually-hidden {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle {
    margin: 0.82rem 0 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.34rem;
    inline-size: auto;
    min-block-size: auto;
    padding: 0.12rem 0;
    border: 0;
    background: transparent;
    color: #ffffff;
    cursor: pointer;
    backdrop-filter: none;
    transition: opacity 0.2s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle:hover,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle:focus-visible {
    opacity: 0.9;
    outline: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle-icon {
    display: grid;
    place-items: center;
    inline-size: 1.52rem;
    block-size: 1.52rem;
    border-radius: 999px;
    opacity: 0.42;
    transform: scale(0.9);
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle-icon svg {
    inline-size: 1.12rem;
    block-size: 1.12rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__theme-toggle-icon--moon svg {
    inline-size: 1.2rem;
    block-size: 1.2rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"].is-theme-light .itin-command-center__theme-toggle-icon--sun,
  .itin-command-center[data-section-id="{{ section.id }}"][data-theme='light'] .itin-command-center__theme-toggle-icon--sun,
  .itin-command-center[data-section-id="{{ section.id }}"].is-theme-dark .itin-command-center__theme-toggle-icon--moon,
  .itin-command-center[data-section-id="{{ section.id }}"][data-theme='dark'] .itin-command-center__theme-toggle-icon--moon {
    opacity: 1;
    transform: scale(1);
    background: transparent;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__desktop-scroll-wrapper {
    block-size: 100dvh;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior-y: contain;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__desktop-scroll-wrapper::-webkit-scrollbar {
    width: 0.35rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__desktop-scroll-wrapper::-webkit-scrollbar-thumb {
    background: var(--itin-command-center-border);
    border-radius: 999px;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] *,
  .itin-command-center[data-section-id="{{ section.id }}"] *::before,
  .itin-command-center[data-section-id="{{ section.id }}"] *::after {
    border-radius: 0 !important;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero {
    position: relative;
    inline-size: 100%;
    min-block-size: clamp(16rem, 36vw, 30rem);
    aspect-ratio: 2.4 / 1;
    overflow: clip;
    background:
      radial-gradient(circle at 20% 20%, rgba(var(--itin-command-center-accent-rgb), 0.12), transparent 50%),
      var(--itin-command-center-hero-gradient);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    display: block;
    filter: none;
    transform: scale(1.04);
    transform-origin: center;
    transition: transform 0.65s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-video {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    display: block;
    filter: none;
    transform: scale(1.03);
    transform-origin: center;
    transition: transform 0.65s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-inner {
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.2rem, 3vw, 3rem) clamp(1.5rem, 3vw, 2.7rem);
    max-inline-size: 68ch;
    transition: transform 0.45s ease, opacity 0.35s ease;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-title {
    margin: 0;
    font-family: var(--itin-command-center-font-serif);
    font-size: clamp(2rem, 5.1vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    color: #ffffff;
    text-wrap: balance;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.28), 0 0 14px rgba(0, 0, 0, 0.14);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-locations {
    margin: 0.6rem 0 0;
    font-size: 0.7rem;
    font-family: var(--itin-command-center-font-sans);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.26), 0 0 8px rgba(0, 0, 0, 0.16);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__hero-days {
    margin: 0.32rem 0 0;
    font-size: 0.82rem;
    font-family: var(--itin-command-center-font-serif);
    font-weight: 500;
    line-height: 1.2;
    color: #ffffff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.26), 0 0 8px rgba(0, 0, 0, 0.16);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary {
    position: sticky;
    inset-block-start: var(--itin-command-center-sticky-top);
    z-index: 20;
    padding: 0;
    border-block-end: 1px solid var(--itin-command-center-border-soft);
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--itin-command-center-surface-primary) 94%, transparent);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell {
    display: grid;
    grid-template-columns: var(--itin-command-center-workspace-columns);
    align-items: center;
    min-block-size: 4.65rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-left-center {
    grid-template-columns: var(--itin-command-center-workspace-columns-left-center);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-right {
    grid-template-columns: var(--itin-command-center-workspace-columns-center-right);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-only {
    grid-template-columns: var(--itin-command-center-workspace-columns-center-only);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-left-center .itin-command-center__tour-summary-rail {
    grid-column: 1 / span 1;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-left-center .itin-command-center__tour-summary-main {
    grid-column: 2 / span 1;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-left-center .itin-command-center__tour-summary-side {
    display: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-right .itin-command-center__tour-summary-rail {
    display: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-right .itin-command-center__tour-summary-main {
    grid-column: 1 / span 1;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-right .itin-command-center__tour-summary-side {
    grid-column: 2 / span 1;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-only .itin-command-center__tour-summary-main {
    grid-column: 1 / -1;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-only .itin-command-center__tour-summary-rail,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-shell--layout-center-only .itin-command-center__tour-summary-side {
    display: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-rail {
    grid-column: 1 / span 1;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.68rem 0.9rem;
    border-inline-end: 1px solid var(--itin-command-center-border-soft);
    background: color-mix(in srgb, var(--itin-command-center-surface-depth) 95%, transparent);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-rail-label {
    margin: 0;
    font-size: 0.56rem;
    font-family: var(--itin-command-center-font-sans);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--itin-command-center-text-faint);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-facts {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.3rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-fact {
    display: grid;
    gap: 0.05rem;
    margin: 0;
    padding: 0.34rem 0.42rem;
    border: 1px solid var(--itin-command-center-border-soft);
    background: color-mix(in srgb, var(--itin-command-center-card) 76%, transparent);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-fact dt {
    margin: 0;
    font-size: 0.5rem;
    font-family: var(--itin-command-center-font-sans);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--itin-command-center-text-faint);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-fact dd {
    margin: 0;
    font-size: 0.8rem;
    font-family: var(--itin-command-center-font-serif);
    line-height: 1.22;
    color: var(--itin-command-center-text-primary);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-main {
    grid-column: 2 / span 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.68rem 0.95rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-side {
    grid-column: 3 / span 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.62rem 0.95rem;
    border-inline-start: 1px solid var(--itin-command-center-border-soft);
    background: color-mix(in srgb, var(--itin-command-center-surface-depth) 92%, transparent);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-prose {
    margin: 0;
    font-family: var(--itin-command-center-font-serif);
    font-size: clamp(0.78rem, 0.92vw, 0.92rem);
    line-height: 1.36;
    color: var(--itin-command-center-text-primary);
    max-inline-size: 72ch;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-prose p {
    margin: 0;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-prose p + p {
    margin-block-start: 0.2rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-overview-line {
    margin: 0;
    font-size: 0.54rem;
    font-family: var(--itin-command-center-font-sans);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.42;
    color: var(--itin-command-center-text-muted);
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-rail {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.28rem;
    overflow-x: auto;
    padding-block: 0.08rem 0;
    scrollbar-width: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-rail::-webkit-scrollbar {
    display: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-context-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.28rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-context-link {
    border: 1px solid var(--itin-command-center-border-soft);
    background: rgba(var(--itin-command-center-accent-rgb), 0.04);
    color: var(--itin-command-center-text-muted);
    font-size: 0.52rem;
    font-family: var(--itin-command-center-font-sans);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0.26rem 0.48rem;
    cursor: pointer;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-context-link:hover,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-context-link:focus-visible {
    color: var(--itin-command-center-text-primary);
    border-color: rgba(var(--itin-command-center-accent-rgb), 0.36);
    background: rgba(var(--itin-command-center-accent-rgb), 0.12);
    outline: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-chip {
    border: 1px solid var(--itin-command-center-border-soft);
    background: rgba(var(--itin-command-center-accent-rgb), 0.04);
    color: var(--itin-command-center-text-muted);
    font-size: 0.52rem;
    font-family: var(--itin-command-center-font-sans);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0.26rem 0.48rem;
    cursor: pointer;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-chip.is-active,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-chip:hover,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-leg-chip:focus-visible {
    color: var(--itin-command-center-text-primary);
    border-color: rgba(var(--itin-command-center-accent-rgb), 0.36);
    background: rgba(var(--itin-command-center-accent-rgb), 0.12);
    outline: none;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-booking {
    padding: 0;
    border: 0;
    background: transparent;
    gap: 0.34rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-consultant {
    margin: 0;
    padding: 0.42rem 0.5rem;
    border: 1px solid var(--itin-command-center-border-soft);
    background: rgba(var(--itin-command-center-accent-rgb), 0.04);
    grid-template-columns: 1.95rem minmax(0, 1fr);
    row-gap: 0.1rem;
    column-gap: 0.5rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-consultant .itin-command-center__inspector-consultant-avatar {
    inline-size: 1.95rem;
    block-size: 1.95rem;
    font-size: 0.52rem;
    grid-row: 1 / span 4;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-consultant .itin-command-center__inspector-consultant-name {
    font-size: 0.67rem;
  }

  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-consultant .itin-command-center__inspector-consultant-role,
  .itin-command-center[data-section-id="{{ section.id }}"] .itin-command-center__tour-summary-consultant .itin-command-center__inspector-consultant-link {
    font-size: 0.57rem;
    line-height: 1.25;
  }

