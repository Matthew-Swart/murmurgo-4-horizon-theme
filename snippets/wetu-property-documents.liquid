{% comment %}
  Snippet: wetu-property-documents
  Display travel documents for Wetu properties in a clean, minimalist style
  
  Usage: {% render 'wetu-property-documents', product: product %}
{% endcomment %}

{% assign document_refs = product.metafields.wetu.documents.value %}

{% if document_refs and document_refs.size > 0 %}
  <div class="wetu-documents">
    <h3 class="wetu-documents__title">Travel Documents & Resources</h3>
    
    <div class="wetu-documents__list">
      {% for document_ref in document_refs %}
        {% assign document = document_ref %}
        {% if document and document.is_public.value != false %}
          
          {% comment %} Get document URL (prefer file reference over direct URL) {% endcomment %}
          {% assign doc_url = nil %}
          {% if document.file and document.file.value %}
            {% assign doc_url = document.file.value.url %}
          {% elsif document.url and document.url.value %}
            {% assign doc_url = document.url.value %}
          {% endif %}
          
          {% if doc_url %}
            <div class="wetu-documents__item">
              {% comment %} Document Icon based on type {% endcomment %}
              <div class="wetu-documents__icon">
                {% if document.document_type and document.document_type.value contains 'pdf' or doc_url contains '.pdf' %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                {% else %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                    <polyline points="13 2 13 9 20 9"></polyline>
                  </svg>
                {% endif %}
              </div>
              
              {% comment %} Document Title and Link {% endcomment %}
              <div class="wetu-documents__content">
                <a href="{{ doc_url }}" 
                   target="_blank" 
                   rel="noopener noreferrer" 
                   class="wetu-documents__link">
                  {{ document.title.value }}
                  <svg class="wetu-documents__external" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
                
                {% comment %} Optional: Show section/category {% endcomment %}
                {% if document.section and document.section.value != blank %}
                  <span class="wetu-documents__section">{{ document.section.value }}</span>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <style>
    .wetu-documents {
      margin: 2rem 0;
      padding: 2rem;
      background: #fafafa;
      border-radius: 8px;
    }

    .wetu-documents__title {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0 0 1.5rem 0;
      color: #1a1a1a;
      letter-spacing: -0.01em;
    }

    .wetu-documents__list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .wetu-documents__item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem;
      background: #ffffff;
      border-radius: 6px;
      transition: box-shadow 0.2s ease;
    }

    .wetu-documents__item:hover {
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .wetu-documents__icon {
      flex-shrink: 0;
      color: #666;
      margin-top: 2px;
    }

    .wetu-documents__content {
      flex: 1;
      min-width: 0;
    }

    .wetu-documents__link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      color: #1a1a1a;
      text-decoration: none;
      font-size: 0.9375rem;
      font-weight: 500;
      transition: color 0.2s ease;
      word-break: break-word;
    }

    .wetu-documents__link:hover {
      color: #0066cc;
    }

    .wetu-documents__external {
      flex-shrink: 0;
      opacity: 0.5;
      transition: opacity 0.2s ease;
    }

    .wetu-documents__link:hover .wetu-documents__external {
      opacity: 1;
    }

    .wetu-documents__section {
      display: inline-block;
      margin-top: 0.25rem;
      font-size: 0.75rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    @media (max-width: 768px) {
      .wetu-documents {
        padding: 1.5rem;
        margin: 1.5rem 0;
      }

      .wetu-documents__title {
        font-size: 1.125rem;
      }
    }
  </style>
{% endif %}
