  .wetu-flight-pass__barcode-lines {
    width: 200px;
    height: 40px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-foreground) 0px,
      var(--color-foreground) 2px,
      transparent 2px,
      transparent 4px,
      var(--color-foreground) 4px,
      var(--color-foreground) 5px,
      transparent 5px,
      transparent 8px,
      var(--color-foreground) 8px,
      var(--color-foreground) 10px,
      transparent 10px,
      transparent 11px,
      var(--color-foreground) 11px,
      var(--color-foreground) 14px,
      transparent 14px,
      transparent 16px
    );
    opacity: 0.15;
    border-radius: 4px;
  }

  /* ============================================
     MOBILE STYLES - Boarding Pass Optimized
     ============================================ */

  @media screen and (max-width: 600px) {
    .wetu-flight-pass {
      margin: 16px 0;
      border-radius: 12px;
    }

    .wetu-flight-pass__header {
      padding: 16px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .wetu-flight-pass__airline-icon {
      width: 36px;
      height: 36px;
    }

    .wetu-flight-pass__airline-icon svg {
      width: 20px;
      height: 20px;
    }

    .wetu-flight-pass__airline-name {
      font-size: 0.95rem;
    }

    .wetu-flight-pass__class {
      padding: 6px 12px;
      font-size: 0.7rem;
    }

    .wetu-flight-pass__route {
      flex-direction: column;
      padding: 24px 16px;
      gap: 24px;
    }

    .wetu-flight-pass__endpoint {
      max-width: 100%;
      width: 100%;
      flex-direction: row;
