  .wetu-flight-pass__perforation::before,
  .wetu-flight-pass__perforation::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    background: var(--color-background, #f8f8f8);
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
  }

  .wetu-flight-pass__perforation::before {
    left: -10px;
    box-shadow: inset -2px 0 4px rgba(0,0,0,0.05);
  }

  .wetu-flight-pass__perforation::after {
    right: -10px;
    box-shadow: inset 2px 0 4px rgba(0,0,0,0.05);
