      box-shadow: none;
      border: 2px solid #000;
    }

    .wetu-flight-pass__header {
      background: #333;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .wetu-flight-pass__actions {
      display: none;
    }
  }
</style>

<script>
  (function() {
    const flightPass = document.getElementById('{{ unique_id }}');
    if (!flightPass) return;

    // Copy to clipboard functionality
    const copyBtns = flightPass.querySelectorAll('.wetu-flight-pass__copy-btn');
    copyBtns.forEach(btn => {
      btn.addEventListener('click', async function() {
        const textToCopy = this.dataset.copy;
        try {
          await navigator.clipboard.writeText(textToCopy);
          this.classList.add('copied');
          setTimeout(() => {
            this.classList.remove('copied');
          }, 2000);
        } catch (err) {
          // Fallback for older browsers
          const textarea = document.createElement('textarea');
          textarea.value = textToCopy;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          this.classList.add('copied');
          setTimeout(() => {
            this.classList.remove('copied');
          }, 2000);
        }
      });
    });

    // Add to Calendar functionality
    const calendarBtn = flightPass.querySelector('.wetu-flight-pass__calendar-btn');
    if (calendarBtn) {
      calendarBtn.addEventListener('click', function() {
        const fromLocation = this.dataset.from || 'Departure';
        const toLocation = this.dataset.to || 'Arrival';
        const startTime = this.dataset.startTime || '';
        const endTime = this.dataset.endTime || '';
        const airline = this.dataset.airline || '';
        const flightNum = this.dataset.flight || '';
        const ref = this.dataset.ref || '';
        const dateStr = this.dataset.date || '';

        // Build event title
        let title = 'Flight';
        if (airline) title = airline + ' Flight';
        if (flightNum) title += ' ' + flightNum;
        title += ': ' + fromLocation.split('(')[0].trim() + ' → ' + toLocation.split('(')[0].trim();

        // Build description
        let description = 'Flight Details:\\n';
        description += 'From: ' + fromLocation + '\\n';
        description += 'To: ' + toLocation + '\\n';
        if (startTime) description += 'Departure: ' + startTime + '\\n';
        if (endTime) description += 'Arrival: ' + endTime + '\\n';
        if (ref) description += 'Booking Reference: ' + ref + '\\n';

        // Create ICS content (simplified - works without specific date)
        const now = new Date();
        const startDate = dateStr ? new Date(dateStr) : now;

        // Parse time if available
        if (startTime) {
          const timeParts = startTime.match(/(\d{1,2}):(\d{2})/);
          if (timeParts) {
            startDate.setHours(parseInt(timeParts[1]), parseInt(timeParts[2]));
          }
        }

        // Assume 2 hour flight if no end time
        const endDate = new Date(startDate);
        if (endTime) {
          const endParts = endTime.match(/(\d{1,2}):(\d{2})/);
          if (endParts) {
            endDate.setHours(parseInt(endParts[1]), parseInt(endParts[2]));
          }
        } else {
          endDate.setHours(endDate.getHours() + 2);
        }

        // Format dates for ICS
        const formatDate = (date) => {
          return date.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
        };

        const icsContent = [
          'BEGIN:VCALENDAR',
          'VERSION:2.0',
          'PRODID:-//WETU Itinerary//Flight//EN',
          'BEGIN:VEVENT',
          'UID:' + '{{ unique_id }}' + '@wetu',
          'DTSTAMP:' + formatDate(now),
          'DTSTART:' + formatDate(startDate),
          'DTEND:' + formatDate(endDate),
          'SUMMARY:' + title,
          'DESCRIPTION:' + description.replace(/\n/g, '\\n'),
          'LOCATION:' + fromLocation,
          'END:VEVENT',
          'END:VCALENDAR'
        ].join('\r\n');

        // Download ICS file
        const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'flight-' + (flightNum || 'booking') + '.ics';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(link.href);
      });
    }
  })();
</script>
