      flex-direction: row-reverse;
    }

    .wetu-flight-pass__endpoint--arrival .wetu-flight-pass__location {
      margin-left: 0;
      margin-right: auto;
    }

    .wetu-flight-pass__code {
      font-size: 2rem;
      min-width: 80px;
    }

    .wetu-flight-pass__location {
      max-width: none;
      flex: 1;
    }

    .wetu-flight-pass__time {
      font-size: 1.25rem;
      margin-top: 0;
    }

    .wetu-flight-pass__path {
      width: 100%;
      flex-direction: row;
      padding: 0;
      min-width: auto;
    }

    .wetu-flight-pass__path-line {
      flex: 1;
    }

    .wetu-flight-pass__details {
      grid-template-columns: 1fr;
    }

    .wetu-flight-pass__detail--reference {
      grid-column: span 1;
    }

    .wetu-flight-pass__detail {
      padding: 14px 16px;
    }

    .wetu-flight-pass__ref-code {
      flex-wrap: wrap;
    }

    .wetu-flight-pass__ref-code code {
      font-size: 1rem;
    }

    .wetu-flight-pass__actions {
      padding: 12px 16px;
      flex-wrap: wrap;
