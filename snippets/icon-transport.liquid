{% comment %}
  ============================================================================
  TRANSPORT ICONS SNIPPET
  ============================================================================
  
  SVG icons for various transport modes.
  
  PARAMETERS:
  - icon: Icon name (plane, car, train, boat, helicopter, transfer, walking)
  - size: Icon size in pixels (default: 24)
  - class: Additional CSS classes
  
  USAGE:
  {% render 'icon-transport', icon: 'plane', size: 24 %}
  
  ============================================================================
{% endcomment %}

{% assign icon_size = size | default: 24 %}
{% assign icon_class = class | default: '' %}

{% case icon %}
  {% when 'plane' %}
    <svg 
      class="icon-transport icon-transport--plane {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
    </svg>

  {% when 'car' %}
    <svg 
      class="icon-transport icon-transport--car {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/>
      <circle cx="6.5" cy="16.5" r="2.5"/>
      <circle cx="16.5" cy="16.5" r="2.5"/>
    </svg>

  {% when 'train' %}
    <svg 
      class="icon-transport icon-transport--train {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="4" y="3" width="16" height="16" rx="2"/>
      <path d="M4 11h16"/>
      <path d="M12 3v8"/>
      <path d="M8 19l-2 3"/>
      <path d="M16 19l2 3"/>
      <circle cx="8" cy="15" r="1"/>
      <circle cx="16" cy="15" r="1"/>
    </svg>

  {% when 'boat' %}
    <svg 
      class="icon-transport icon-transport--boat {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
      <path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/>
      <path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/>
      <path d="M12 10v4"/>
      <path d="M12 2v3"/>
    </svg>

  {% when 'helicopter' %}
    <svg 
      class="icon-transport icon-transport--helicopter {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 2v4"/>
      <path d="M4 4h16"/>
      <ellipse cx="12" cy="14" rx="6" ry="4"/>
      <path d="M18 14h4"/>
      <path d="M8 18l-2 4"/>
      <path d="M16 18l2 4"/>
    </svg>

  {% when 'transfer' %}
    <svg 
      class="icon-transport icon-transport--transfer {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="1" y="3" width="15" height="13"/>
      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
      <circle cx="5.5" cy="18.5" r="2.5"/>
      <circle cx="18.5" cy="18.5" r="2.5"/>
    </svg>

  {% when 'walking' %}
    <svg 
      class="icon-transport icon-transport--walking {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="4" r="2"/>
      <path d="M15 22v-4l-3-3-1 4-4-4"/>
      <path d="M10 14l-1.5 2.5"/>
      <path d="M18 10l-4-1-2 3"/>
    </svg>

  {% when 'bus' %}
    <svg 
      class="icon-transport icon-transport--bus {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M8 6v6"/>
      <path d="M16 6v6"/>
      <path d="M2 12h19.6"/>
      <path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/>
      <circle cx="7" cy="18" r="2"/>
      <path d="M9 18h5"/>
      <circle cx="16" cy="18" r="2"/>
    </svg>

  {% when 'motorcycle' %}
    <svg 
      class="icon-transport icon-transport--motorcycle {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="5.5" cy="17.5" r="3.5"/>
      <circle cx="18.5" cy="17.5" r="3.5"/>
      <path d="M15 6a1 1 0 0 1 0 2h-4.5l-4 8"/>
      <path d="M5.5 14l4-7h7l3.5 7"/>
    </svg>

  {% else %}
    {% comment %} Default fallback icon {% endcomment %}
    <svg 
      class="icon-transport icon-transport--default {{ icon_class }}" 
      width="{{ icon_size }}" 
      height="{{ icon_size }}" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 6v6l4 2"/>
    </svg>
{% endcase %}

<style>
  .icon-transport {
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>

