{% doc %}
  ResRequest Accommodation Headline

  Displays headline information for ResRequest accommodation products including capacity,
  rate information, and parent property reference.

  @param {product} product - The accommodation product (required)

  @example
  {% render 'resrequest-accommodation-headline', product: product %}
{% enddoc %}

{% liquid
  assign max_capacity = product.metafields.resrequest.max_capacity_product
  assign max_adults = product.metafields.resrequest.max_adults_product
  assign parent_property = product.metafields.resrequest.parent_property.value
  assign rate_groups_json = product.metafields.resrequest.rate_json.value
  
  assign property_name = ''
  assign property_url = ''
  if parent_property
    assign property_name = parent_property.title
    assign property_url = parent_property.url
  endif
  
  assign rate_groups = null
  if rate_groups_json and rate_groups_json.capacity
    assign rate_groups = rate_groups_json.rateGroups
  endif
%}

<div class="resrequest-accommodation-headline">
  {% if property_name != blank %}
    <div class="resrequest-accommodation-headline__property">
      <span class="resrequest-accommodation-headline__property-label">Property</span>
      <a href="{{ property_url }}" class="resrequest-accommodation-headline__property-link">{{ property_name }}</a>
    </div>
  {% endif %}
  
  <div class="resrequest-accommodation-headline__details">
    {% if max_capacity or max_adults %}
      <div class="resrequest-accommodation-headline__detail">
        <span class="resrequest-accommodation-headline__label">Capacity</span>
        <span class="resrequest-accommodation-headline__value">
          {% if max_capacity %}
            Up to {{ max_capacity }} {{ max_capacity | pluralize: 'guest', 'guests' }}
          {% elsif max_adults %}
            Up to {{ max_adults }} {{ max_adults | pluralize: 'adult', 'adults' }}
          {% endif %}
        </span>
      </div>
    {% endif %}
    
    {% if rate_groups and rate_groups.size > 0 %}
      <div class="resrequest-accommodation-headline__detail">
        <span class="resrequest-accommodation-headline__label">Rate groups</span>
        <span class="resrequest-accommodation-headline__value">
          {% assign rate_group_names = '' | split: '' %}
          {% for rate_group in rate_groups %}
            {% if rate_group.isDefault %}
              {% assign rate_group_names = rate_group_names | push: rate_group.description %}
            {% endif %}
          {% endfor %}
          {{ rate_group_names | join: ', ' }}
        </span>
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .resrequest-accommodation-headline {
    margin-block-end: var(--spacing-xl, 40px);
  }
  
  .resrequest-accommodation-headline__property {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs, 8px);
    margin-block-end: var(--spacing-sm, 12px);
    flex-wrap: wrap;
  }
  
  .resrequest-accommodation-headline__property-label {
    font-size: var(--font-size-sm, 0.875rem);
    color: #999;
  }
  
  .resrequest-accommodation-headline__property-link {
    font-size: var(--font-size-base, 0.9375rem);
    color: #333;
    text-decoration: underline;
    font-weight: 400;
  }
  
  .resrequest-accommodation-headline__property-link:hover {
    color: #000;
  }
  
  .resrequest-accommodation-headline__details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 12px);
  }
  
  .resrequest-accommodation-headline__detail {
    display: flex;
    gap: var(--spacing-xs, 8px);
    font-size: var(--font-size-sm, 0.875rem);
    line-height: 1.6;
  }
  
  .resrequest-accommodation-headline__label {
    color: #999;
    min-width: 80px;
  }
  
  .resrequest-accommodation-headline__value {
    color: #333;
  }
{% endstylesheet %}
