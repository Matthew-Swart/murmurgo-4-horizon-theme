      normalizeText(payload?.displayUrl) || normalizeText(payload?.url);
    if (!baseUrl) return "";
    try {
      const url = new URL(baseUrl, window.location.origin);
      url.searchParams.set("view", PANEL_VIEW);
      return withPreviewParams(url.toString());
    } catch (_error) {
      return "";
    }
  };

  const ensureCache = (root) => {
    const existing = cacheByRoot.get(root);
    if (existing instanceof Map) return existing;
    const next = new Map();
    cacheByRoot.set(root, next);
    return next;
  };

  const applyPanelMarkup = (root, inspectorBody, html, payload) => {
    inspectorBody.classList.remove("is-overview-active");
    inspectorBody.removeAttribute("data-command-center-route-placeholder");
    inspectorBody.classList.add("is-product-embed");
    inspectorBody.setAttribute(
      "aria-label",
      normalizeText(payload?.title) || "Selected journey stop",
    );
    inspectorBody.setAttribute("aria-busy", "false");
    inspectorBody.innerHTML = `
      <section class="itin-command-center__inspector-product-surface" data-inspector-product-surface>
        <div class="itin-command-center__inspector-product-content" data-inspector-product-content aria-live="polite">
          ${html}
        </div>
      </section>
    `;
    root.classList.remove("is-initial-inspector-hydrating");
  };

  const renderActiveProductInspector = async (root) => {
    if (!(root instanceof HTMLElement)) return false;

    const inspectorBody = root.querySelector(INSPECTOR_BODY_SELECTOR);
    if (!(inspectorBody instanceof HTMLElement)) return false;

    if (isMapOwnedView(root)) {
      const inflight = inflightByRoot.get(root);
      if (inflight?.controller instanceof AbortController)
        inflight.controller.abort();
      inflightByRoot.delete(root);
      payloadKeyByRoot.delete(root);
      inspectorBody.setAttribute("aria-busy", "false");
      return false;
    }

    const payload = getPayload(root);
    if (!payload) {
      const inflight = inflightByRoot.get(root);
      if (inflight?.controller instanceof AbortController)
        inflight.controller.abort();
      inflightByRoot.delete(root);
      payloadKeyByRoot.delete(root);
      return false;
    }

    const payloadKey = getPayloadKey(payload);
    if (!payloadKey) return false;

    const activePanel = inspectorBody.querySelector(`.${PANEL_CLASS}`);
    if (activePanel && payloadKeyByRoot.get(root) === payloadKey) return true;

    const cache = ensureCache(root);
    if (cache.has(payloadKey)) {
      applyPanelMarkup(
        root,
        inspectorBody,
        String(cache.get(payloadKey) || ""),
        payload,
      );
      payloadKeyByRoot.set(root, payloadKey);
      return true;
    }

    const inflight = inflightByRoot.get(root);
    if (
      inflight?.payloadKey === payloadKey &&
      inflight.promise instanceof Promise
    ) {
      return inflight.promise;
    }
    if (inflight?.controller instanceof AbortController) {
      inflight.controller.abort();
      inflightByRoot.delete(root);
    }

    const inspectorUrl = buildInspectorUrl(payload);
    if (!inspectorUrl) return false;

    const requestToken =
      Number(root.dataset.commandCenterPanelRequestToken || "0") + 1;
    root.dataset.commandCenterPanelRequestToken = String(requestToken);

    const controller = new AbortController();
    inspectorBody.setAttribute("aria-busy", "true");

    const requestPromise = fetch(inspectorUrl, {
      credentials: "same-origin",
      signal: controller.signal,
    })
      .then((response) => {
        if (!response.ok)
          throw new Error(`Product panel request failed (${response.status})`);
        return response.text();
      })
      .then((html) => {
        if (
          normalizeText(root.dataset.commandCenterPanelRequestToken) !==
          String(requestToken)
        )
          return false;
        if (isMapOwnedView(root)) return false;
        const activePayload = getPayload(root);
        if (!activePayload || getPayloadKey(activePayload) !== payloadKey)
          return false;
        cache.set(payloadKey, html);
        applyPanelMarkup(root, inspectorBody, html, payload);
        payloadKeyByRoot.set(root, payloadKey);
        return true;
      })
      .catch((_error) => {
        if (controller.signal.aborted) return false;
        if (
          normalizeText(root.dataset.commandCenterPanelRequestToken) !==
          String(requestToken)
        )
          return false;
        inspectorBody.setAttribute("aria-busy", "false");
        return false;
      })
      .finally(() => {
        const current = inflightByRoot.get(root);
        if (current && current.requestToken === requestToken) {
          inflightByRoot.delete(root);
        }
      });

    inflightByRoot.set(root, {
      requestToken,
      payloadKey,
      controller,
      promise: requestPromise,
    });

    return requestPromise;
  };

  const scheduleHydration = (root) => {
    if (!(root instanceof HTMLElement)) return;

    const existingFrame = frameByRoot.get(root);
    if (typeof existingFrame === "number") {
      window.cancelAnimationFrame(existingFrame);
    }

    const frame = window.requestAnimationFrame(() => {
      frameByRoot.delete(root);
      renderActiveProductInspector(root).catch(() => {});
    });

    frameByRoot.set(root, frame);
  };

  const setJourneyTabSelection = (root, activeView) => {
    const nextView = normalizeText(activeView).toLowerCase();
    if (!nextView) return;

    const tabs = root.querySelectorAll("[data-command-center-journey-tab]");
    for (const tab of tabs) {
      if (!(tab instanceof HTMLElement)) continue;
      const tabView = normalizeText(
        tab.getAttribute("data-command-center-journey-tab"),
      ).toLowerCase();
      const isActive = tabView === nextView;
      tab.classList.toggle("is-active", isActive);
      tab.setAttribute("aria-selected", isActive ? "true" : "false");
      tab.setAttribute("tabindex", isActive ? "0" : "-1");
    }
  };

  const triggerOverviewProxyDetail = (root, detailKey) => {
    const key = normalizeText(detailKey).toLowerCase();
    if (!key) return false;
    const proxyTrigger = root.querySelector(
      `[data-command-center-overview-proxy-controls] [data-command-center-overview-detail="${key}"]`,
    );
    if (!(proxyTrigger instanceof HTMLButtonElement)) return false;
    proxyTrigger.click();
    return true;
  };

  const initializeRoot = (root) => {
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.commandCenterProductHydratorReady === "true") return;
    root.dataset.commandCenterProductHydratorReady = "true";

    const inspectorBody = root.querySelector(INSPECTOR_BODY_SELECTOR);
    if (inspectorBody instanceof HTMLElement) {
      const observer = new MutationObserver(() => {
        scheduleHydration(root);
      });
      observer.observe(inspectorBody, {
        childList: true,
        subtree: false,
        attributes: true,
        attributeFilter: ["class", "data-command-center-route-placeholder"],
      });
      observerByRoot.set(root, observer);
    }

    root.addEventListener(
      "click",
      (event) => {
        const journeyTab =
          event.target instanceof Element
            ? event.target.closest("[data-command-center-journey-tab]")
            : null;
        if (journeyTab instanceof HTMLElement) {
          const view = normalizeText(
            journeyTab.getAttribute("data-command-center-journey-tab"),
          ).toLowerCase();
          if (view === "guests") {
            triggerOverviewProxyDetail(root, "participants");
            setJourneyTabSelection(root, "guests");
          } else if (view === "pricing") {
            triggerOverviewProxyDetail(root, "pricing");
            setJourneyTabSelection(root, "pricing");
          } else if (view === "overview" || view === "route") {
            setJourneyTabSelection(root, view);
          }
        }

        scheduleHydration(root);
      },
      true,
    );

    root.addEventListener(
      "keydown",
      (event) => {
        const key = normalizeText(event?.key).toLowerCase();
        if (key === "enter" || key === " " || key === "spacebar") {
          scheduleHydration(root);
        }
      },
      true,
    );

    const intervalId = window.setInterval(() => {
      if (!document.contains(root)) {
        const observer = observerByRoot.get(root);
        if (observer) observer.disconnect();

        const inflight = inflightByRoot.get(root);
        if (inflight?.controller instanceof AbortController)
          inflight.controller.abort();

        const frame = frameByRoot.get(root);
        if (typeof frame === "number") window.cancelAnimationFrame(frame);

        window.clearInterval(intervalId);
        pollerByRoot.delete(root);
        return;
      }

      const payload = getPayload(root);
      const nextSignature = payload ? getPayloadKey(payload) : "";
      const previousSignature = signatureByRoot.get(root) || "";
      if (nextSignature !== previousSignature) {
        signatureByRoot.set(root, nextSignature);
        scheduleHydration(root);
      }
    }, 260);

    pollerByRoot.set(root, intervalId);
    scheduleHydration(root);
  };

  const initializeFromScope = (scope) => {
    if (!(scope instanceof Element) && scope !== document) return;

    const roots = [];
    if (scope instanceof Element && scope.matches(ROOT_SELECTOR))
      roots.push(scope);
    const nested = scope.querySelectorAll
      ? scope.querySelectorAll(ROOT_SELECTOR)
      : [];
    for (const root of nested) roots.push(root);

    for (const root of roots) initializeRoot(root);
  };

  ensurePanelFetchDedupe();

  const onReady = () => initializeFromScope(document);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", onReady, { once: true });
  } else {
    onReady();
  }

  document.addEventListener("shopify:section:load", (event) => {
    const scope = event.target instanceof Element ? event.target : document;
    initializeFromScope(scope);
  });
})();
