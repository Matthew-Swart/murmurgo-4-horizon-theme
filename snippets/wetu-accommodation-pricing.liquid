  <script>
    // Rate type tab switching functionality - runs immediately to prevent flash
    (function() {
      function initRateTabs() {
        const tabContainers = document.querySelectorAll('.wetu-rate-tabs');
        
        tabContainers.forEach(tabContainer => {
          const tabs = tabContainer.querySelectorAll('.wetu-rate-tab');
          const seasonalRatesSection = tabContainer.closest('.wetu-seasonal-rates');
          if (!seasonalRatesSection) return;
          
          const rateCards = seasonalRatesSection.querySelectorAll('.wetu-rate-card');
          
          // Initialize - show only the first tab's rate type (runs immediately)
          if (tabs.length > 0) {
            const firstTab = tabs[0];
            const selectedType = firstTab.getAttribute('data-rate-type');
            
            rateCards.forEach(card => {
              const cardType = card.getAttribute('data-rate-type');
              if (cardType === selectedType) {
                card.style.display = '';
              } else {
                card.style.display = 'none';
              }
            });
          }
          
          // Add click handlers
          tabs.forEach(tab => {
            tab.addEventListener('click', function() {
              const selectedType = this.getAttribute('data-rate-type');
              
              // Update tab states
              tabs.forEach(t => {
                t.classList.remove('wetu-rate-tab--active');
                t.setAttribute('aria-selected', 'false');
              });
              this.classList.add('wetu-rate-tab--active');
              this.setAttribute('aria-selected', 'true');
              
              // Show/hide rate cards based on type
              rateCards.forEach(card => {
                const cardType = card.getAttribute('data-rate-type');
                if (cardType === selectedType) {
                  card.style.display = '';
                  card.removeAttribute('open'); // Close all expanded cards when switching
                } else {
                  card.style.display = 'none';
                }
              });
            });
          });
        });
      }
      
      // Run immediately if DOM is already loaded, otherwise wait
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRateTabs);
      } else {
        initRateTabs();
      }
    })();
  </script>
