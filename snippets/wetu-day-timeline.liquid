{% comment %}
  ============================================================================
  WETU DAY TIMELINE
  ============================================================================

  Renders a visual timeline for a day showing transfers, flights, and stays.

  PARAMETERS:
  - routes: All itinerary routes (wetu_routes)
  - start_day: Day number to start checking
  - end_day: Day number to end checking
  - from_location: Starting location name
  - to_location: Ending location name (accommodation)
  - flight_info: (optional) Flight details extracted from notes

  ============================================================================
{% endcomment %}

{% liquid
  assign routes = routes | default: blank
  assign start_day = start_day | default: 1
  assign end_day = end_day | default: 1
  assign from_location = from_location | default: ''
  assign to_location = to_location | default: ''
  assign flight_info = flight_info | default: blank

  assign day_routes = '' | split: ''
%}

{% comment %} Find routes that match this day range {% endcomment %}
{% if routes %}
  {% for route in routes %}
    {% assign route_start = route.start_day.value | default: 0 %}
    {% assign route_end = route.end_day.value | default: 0 %}

    {% if route_start >= start_day and route_start <= end_day %}
      {% assign day_routes = day_routes | push: route %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if day_routes.size > 0 or flight_info != blank %}
  <div class="wetu-day-timeline">
    <div class="wetu-day-timeline__items">

      {% comment %} Show flight info if provided {% endcomment %}
      {% if flight_info != blank %}
        {% for flight in flight_info %}
          <div class="wetu-day-timeline__item wetu-day-timeline__item--flight">
            <div class="wetu-day-timeline__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
              </svg>
            </div>
            <div class="wetu-day-timeline__content">
              <span class="wetu-day-timeline__label">Charter Flight</span>
              <span class="wetu-day-timeline__description">{{ flight }}</span>
            </div>
          </div>
        {% endfor %}
      {% endif %}

      {% comment %} Show routes {% endcomment %}
      {% for route in day_routes %}
        {% assign route_type = route.route_type.value | default: 'Road' %}
        {% assign transport_type = route.transport_type.value | default: '' %}
        {% assign from_name = route.from_name.value | default: '' %}
        {% assign to_name = route.to_name.value | default: '' %}
        {% assign duration_minutes = route.duration_minutes.value | default: 0 %}

        {% comment %} Determine icon based on route type {% endcomment %}
        {% case route_type %}
          {% when 'Flight', 'Air' %}
            <div class="wetu-day-timeline__item wetu-day-timeline__item--flight">
              <div class="wetu-day-timeline__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
                </svg>
              </div>
              <div class="wetu-day-timeline__content">
                <span class="wetu-day-timeline__label">Flight</span>
                <span class="wetu-day-timeline__description">
                  {{ from_name }} → {{ to_name }}
                  {% if duration_minutes > 0 %}
                    {% assign hours = duration_minutes | divided_by: 60 %}
                    {% assign minutes = duration_minutes | modulo: 60 %}
                    {% if hours > 0 %}({{ hours }}h {% if minutes > 0 %}{{ minutes }}m{% endif %}){% elsif minutes > 0 %}({{ minutes }}m){% endif %}
                  {% endif %}
                </span>
              </div>
            </div>

          {% when 'Road', 'Transfer' %}
            <div class="wetu-day-timeline__item wetu-day-timeline__item--road">
              <div class="wetu-day-timeline__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="5" y="11" width="14" height="10" rx="2"/>
                  <circle cx="9" cy="18" r="2"/>
                  <circle cx="15" cy="18" r="2"/>
                  <path d="M5 11V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v5"/>
                  <line x1="5" y1="14" x2="19" y2="14"/>
                </svg>
              </div>
              <div class="wetu-day-timeline__content">
                <span class="wetu-day-timeline__label">{{ transport_type | default: 'Road Transfer' }}</span>
                <span class="wetu-day-timeline__description">
                  {{ from_name }} → {{ to_name }}
                  {% if duration_minutes > 0 %}
                    {% assign hours = duration_minutes | divided_by: 60 %}
                    {% assign minutes = duration_minutes | modulo: 60 %}
                    {% if hours > 0 %}({{ hours }}h {% if minutes > 0 %}{{ minutes }}m{% endif %}){% elsif minutes > 0 %}({{ minutes }}m){% endif %}
                  {% endif %}
                </span>
              </div>
            </div>

          {% when 'Boat', 'Water' %}
            <div class="wetu-day-timeline__item wetu-day-timeline__item--boat">
              <div class="wetu-day-timeline__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 20a2.4 2.4 0 0 0 2 1 2.4 2.4 0 0 0 2-1 2.4 2.4 0 0 1 4 0 2.4 2.4 0 0 0 4 0 2.4 2.4 0 0 1 4 0 2.4 2.4 0 0 0 2 1 2.4 2.4 0 0 0 2-1"/>
                  <path d="M4 18 3 9 7 6l3 3 4-6 3 3 3-2 1 9"/>
                </svg>
              </div>
              <div class="wetu-day-timeline__content">
                <span class="wetu-day-timeline__label">Boat Transfer</span>
                <span class="wetu-day-timeline__description">
                  {{ from_name }} → {{ to_name }}
                  {% if duration_minutes > 0 %}
                    {% assign hours = duration_minutes | divided_by: 60 %}
                    {% assign minutes = duration_minutes | modulo: 60 %}
                    {% if hours > 0 %}({{ hours }}h {% if minutes > 0 %}{{ minutes }}m{% endif %}){% elsif minutes > 0 %}({{ minutes }}m){% endif %}
                  {% endif %}
                </span>
              </div>
            </div>
        {% endcase %}
      {% endfor %}

      {% comment %} Show accommodation stay {% endcomment %}
      {% if to_location != blank %}
        <div class="wetu-day-timeline__item wetu-day-timeline__item--stay">
          <div class="wetu-day-timeline__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="wetu-day-timeline__content">
            <span class="wetu-day-timeline__label">Stay</span>
            <span class="wetu-day-timeline__description">{{ to_location }}</span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}

<style>
.wetu-day-timeline {
  margin: 20px 0;
  padding: 20px;
  background: color-mix(in srgb, var(--color-primary) 4%, transparent);
  border: 1px solid color-mix(in srgb, var(--color-primary) 10%, transparent);
  border-radius: 12px;
}

.wetu-day-timeline__items {
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
}

.wetu-day-timeline__items::before {
  content: '';
  position: absolute;
  left: 10px;
  top: 28px;
  bottom: 28px;
  width: 2px;
  background: color-mix(in srgb, var(--color-primary) 15%, transparent);
}

.wetu-day-timeline__item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  position: relative;
}

.wetu-day-timeline__icon {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-background);
  border: 2px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
  color: var(--color-primary);
  position: relative;
  z-index: 1;
}

.wetu-day-timeline__item--flight .wetu-day-timeline__icon {
  background: color-mix(in srgb, var(--color-primary) 10%, transparent);
}

.wetu-day-timeline__item--stay .wetu-day-timeline__icon {
  background: var(--color-primary);
  color: var(--color-background);
  border-color: var(--color-primary);
}

.wetu-day-timeline__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-top: 6px;
}

.wetu-day-timeline__label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-primary);
}

.wetu-day-timeline__description {
  font-size: 0.9375rem;
  line-height: 1.5;
  color: var(--color-foreground);
}

@media (max-width: 640px) {
  .wetu-day-timeline {
    padding: 16px;
  }

  .wetu-day-timeline__icon {
    width: 36px;
    height: 36px;
  }

  .wetu-day-timeline__items::before {
    left: 9px;
  }
}
</style>
