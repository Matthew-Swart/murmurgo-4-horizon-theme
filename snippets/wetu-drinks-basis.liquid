{% comment %}
  ============================================================================
  WETU DRINKS BASIS DISPLAY SNIPPET
  ============================================================================

  Converts WETU drinks_basis codes to human-readable labels.

  USAGE:
    {% render 'wetu-drinks-basis', basis: period.drinks_basis.value %}
    {% render 'wetu-drinks-basis', basis: period.drinks_basis.value, format: 'full' %}
    {% render 'wetu-drinks-basis', basis: period.drinks_basis.value, format: 'badge', show_tooltip: true %}

  PARAMETERS:
    - basis: (required) The WETU drinks_basis value
    - format: (optional) 'abbr' (default), 'full', or 'badge' for styled display
    - show_tooltip: (optional) Show info icon with description tooltip

  SUPPORTED BASIS CODES:
    AllDrinks / AI           -> All Drinks Included
    LocalBrands / Local      -> Local Brands Included
    HouseBrands / House      -> House Brands Included
    SoftDrinksOnly / Soft    -> Soft Drinks Only
    NonAlcoholic             -> Non-Alcoholic Drinks
    ExcludesDrinks / Excluded / None -> Drinks Not Included
    PremiumDrinks            -> Premium Drinks Included
    DrinksExclPremium        -> Drinks (Excl. Premium)

  ============================================================================
{% endcomment %}

{%- liquid
  assign format = format | default: 'abbr'
  assign show_tooltip = show_tooltip | default: false
  assign basis_code = basis | default: ''

  if basis_code == blank or basis_code == 'None' or basis_code == 'ExcludesDrinks' or basis_code == 'Excluded'
    assign display_abbr = ''
    assign display_full = ''
    assign display_desc = ''
    assign display_icon = 'none'
  else
    case basis_code
      when 'AllDrinks' or 'AI'
        assign display_abbr = 'All'
        assign display_full = 'wetu.itinerary.drinks_all' | t | default: 'All Drinks Included'
        assign display_desc = 'wetu.itinerary.drinks_desc_all' | t | default: 'All alcoholic and non-alcoholic beverages included'
        assign display_icon = 'wine'
      when 'LocalBrands' or 'Local' or 'LocalDrinks'
        assign display_abbr = 'Local'
        assign display_full = 'wetu.itinerary.drinks_local' | t | default: 'Local Brands Included'
        assign display_desc = 'wetu.itinerary.drinks_desc_local' | t | default: 'Local wines, beers, and spirits included'
        assign display_icon = 'wine'
      when 'HouseBrands' or 'House'
        assign display_abbr = 'House'
        assign display_full = 'wetu.itinerary.drinks_house' | t | default: 'House Brands Included'
        assign display_desc = 'wetu.itinerary.drinks_desc_house' | t | default: 'House wines, beers, and selected spirits included'
        assign display_icon = 'wine'
      when 'SoftDrinksOnly' or 'Soft'
        assign display_abbr = 'Soft'
        assign display_full = 'wetu.itinerary.drinks_soft' | t | default: 'Soft Drinks Only'
        assign display_desc = 'wetu.itinerary.drinks_desc_soft' | t | default: 'Non-alcoholic beverages included only'
        assign display_icon = 'cup'
      when 'NonAlcoholic'
        assign display_abbr = 'N/A'
        assign display_full = 'wetu.itinerary.drinks_non_alcoholic' | t | default: 'Non-Alcoholic Drinks'
        assign display_desc = 'wetu.itinerary.drinks_desc_non_alcoholic' | t | default: 'Soft drinks, juices, tea, and coffee included'
        assign display_icon = 'cup'
      when 'PremiumDrinks' or 'Premium'
        assign display_abbr = 'Prem'
        assign display_full = 'wetu.itinerary.drinks_premium' | t | default: 'Premium Drinks Included'
        assign display_desc = 'wetu.itinerary.drinks_desc_premium' | t | default: 'Premium wines, champagne, and top-shelf spirits included'
        assign display_icon = 'sparkle'
      when 'DrinksExclPremium'
        assign display_abbr = 'Excl P'
        assign display_full = 'wetu.itinerary.drinks_excl_premium' | t | default: 'Drinks (Excl. Premium)'
        assign display_desc = 'wetu.itinerary.drinks_desc_excl_premium' | t | default: 'Standard drinks included, premium brands extra'
        assign display_icon = 'wine'
      else
        assign display_abbr = basis_code | truncate: 5, '' | capitalize
        assign display_full = basis_code | replace: '_', ' ' | replace: 'Excl', 'Excluding' | capitalize
        assign display_desc = ''
        assign display_icon = 'wine'
    endcase
  endif
-%}

{%- if display_abbr != blank -%}
  {%- if format == 'full' -%}
    {{- display_full -}}
  {%- elsif format == 'badge' -%}
    <span class="wetu-drinks-basis wetu-drinks-basis--badge wetu-drinks-basis--{{ display_icon }}" title="{{ display_full }}{% if display_desc != blank %}: {{ display_desc }}{% endif %}">
      {%- case display_icon -%}
        {%- when 'wine' -%}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 2h8l-1 9H9L8 2z"/><path d="M12 11v9"/><path d="M6 22h12"/>
          </svg>
        {%- when 'cup' -%}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
          </svg>
        {%- when 'sparkle' -%}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
          </svg>
        {%- else -%}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 2h8l-1 9H9L8 2z"/><path d="M12 11v9"/><path d="M6 22h12"/>
          </svg>
        {%- endcase -%}
      {{ display_abbr }}
      {%- if show_tooltip and display_desc != blank -%}
        <span class="wetu-drinks-basis__tooltip">
          <svg class="wetu-drinks-basis__info-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
          </svg>
          <span class="wetu-drinks-basis__tooltip-text">{{ display_desc }}</span>
        </span>
      {%- endif -%}
    </span>
  {%- else -%}
    <span class="wetu-drinks-basis" title="{{ display_full }}">{{ display_abbr }}</span>
  {%- endif -%}
{%- endif -%}

<style>
  .wetu-drinks-basis {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  
  .wetu-drinks-basis--badge {
    padding: 3px 8px;
    background: rgba(var(--color-foreground), 0.05);
    border-radius: 4px;
    color: rgba(var(--color-foreground), 0.7);
  }
  
  .wetu-drinks-basis--badge svg {
    opacity: 0.6;
  }
  
  .wetu-drinks-basis--sparkle {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(245, 158, 11, 0.15));
    color: #b45309;
  }
  
  .wetu-drinks-basis__tooltip {
    position: relative;
    display: inline-flex;
    cursor: help;
  }
  
  .wetu-drinks-basis__info-icon {
    opacity: 0.5;
    transition: opacity 0.2s;
  }
  
  .wetu-drinks-basis__tooltip:hover .wetu-drinks-basis__info-icon {
    opacity: 1;
  }
  
  .wetu-drinks-basis__tooltip-text {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.9);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 400;
    white-space: nowrap;
    border-radius: 4px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
    z-index: 100;
    margin-bottom: 6px;
  }
  
  .wetu-drinks-basis__tooltip:hover .wetu-drinks-basis__tooltip-text {
    opacity: 1;
    visibility: visible;
  }
</style>
