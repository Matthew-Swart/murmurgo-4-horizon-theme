</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const allOccupancySelectors = document.querySelectorAll('[data-occupancy-selector]');
    const todayStr = document.querySelector('.horizon-rates')?.dataset.todayDate || new Date().toISOString().split('T')[0];
    const today = new Date(todayStr);
    today.setHours(0, 0, 0, 0);
    
    // Sync all occupancy dropdowns when any one changes
    function syncAllOccupancyDropdowns(newValue) {
      allOccupancySelectors.forEach(sel => {
        if (sel.value !== newValue) {
          sel.value = newValue;
        }
      });
    }
    
    // Add change listener to all occupancy selectors
    allOccupancySelectors.forEach(selector => {
      selector.addEventListener('change', (e) => {
        const newValue = e.target.value;
        syncAllOccupancyDropdowns(newValue);
        filterAndUpdateRates();
        initRoomGraphs();
      });
    });

    function filterAndUpdateRates() {
      // Get current occupancy from any selector (they're all synced)
      const firstSelector = document.querySelector('[data-occupancy-selector]');
      const selectedOcc = firstSelector ? firstSelector.value : 'per_person_sharing';

      // Update header price range based on selected occupancy
      const rangeContainer = document.querySelector('.horizon-rates__range');
      if (rangeContainer) {
        const currency = rangeContainer.dataset.currency || 'USD';
        let minVal, maxVal;
        
        if (selectedOcc === 'single') {
          minVal = parseFloat(rangeContainer.dataset.singleMin) || 0;
          maxVal = parseFloat(rangeContainer.dataset.singleMax) || 0;
        } else {
          minVal = parseFloat(rangeContainer.dataset.ppsMin) || 0;
          maxVal = parseFloat(rangeContainer.dataset.ppsMax) || 0;
        }
        
        const minEl = rangeContainer.querySelector('.horizon-rates__amount--min');
        const maxEl = rangeContainer.querySelector('.horizon-rates__amount--max');
        const sepEl = rangeContainer.querySelector('.horizon-rates__sep');
        const toLabel = rangeContainer.querySelectorAll('.horizon-rates__label')[1];
        
        if (minEl && minVal > 0) {
          minEl.textContent = `${currency} ${Math.round(minVal)}`;
        }
        
        if (maxEl && maxVal > 0 && maxVal !== minVal) {
          maxEl.textContent = `${currency} ${Math.round(maxVal)}`;
          maxEl.style.display = '';
          if (sepEl) sepEl.style.display = '';
          if (toLabel) toLabel.style.display = '';
        } else if (maxEl) {
          maxEl.style.display = 'none';
          if (sepEl) sepEl.style.display = 'none';
          if (toLabel) toLabel.style.display = 'none';
        }
      }

      document.querySelectorAll('.room-accordion').forEach(acc => {
        const tiers = acc.querySelectorAll('.tier');
        let foundMatch = false;
        let lowestPrice = Infinity;
        let currency = 'USD';

        const minPps = parseFloat(acc.dataset.minPps) || 0;
        const minSingle = parseFloat(acc.dataset.minSingle) || 0;

        tiers.forEach(tier => {
          const tEnd = new Date(tier.dataset.end);
          tEnd.setHours(23, 59, 59, 999);
          const tType = tier.dataset.type;
          const tPriceText = tier.querySelector('.tier__price')?.innerText || '';
          const priceMatch = tPriceText.match(/([A-Z]{3}|[A-Z$€£]+)\s*([\d,.]+)/i);
          let tPrice = 0;

          if (priceMatch) {
            currency = priceMatch[1];
            tPrice = Math.round(parseFloat(priceMatch[2].replace(/,/g, '')));
          }

          const isFuture = tEnd >= today;
          const isOccMatch = (tType === selectedOcc);

          if (isFuture && isOccMatch) {
            tier.hidden = false;
            tier.classList.remove('past-rate');
            foundMatch = true;
            if (tPrice < lowestPrice && tPrice > 0) lowestPrice = tPrice;
          } else {
            tier.hidden = true;
            if (!isFuture) tier.classList.add('past-rate');
          }
        });

        // Update Summary Card Price
        const pricePreviewContainer = acc.querySelector('.room-accordion__price-preview');
        const pricePreview = acc.querySelector('.room-accordion__price-preview .amount');

        if (pricePreview) {
          let displayPrice = 0;
          const baseRate = parseFloat(pricePreview.dataset.lowestRate) || 0;
          
          if (selectedOcc === 'per_person_sharing' && minPps > 0) {
            displayPrice = minPps;
          } else if (selectedOcc === 'single' && minSingle > 0) {
            displayPrice = minSingle;
          } else if (lowestPrice !== Infinity && lowestPrice > 0) {
            displayPrice = lowestPrice;
          } else if (baseRate > 0) {
            // Fallback to base rate when no tier matches
            displayPrice = baseRate;
          }

          const currencyCode = pricePreview.dataset.currency || 'USD';
          if (displayPrice > 0) {
            pricePreview.innerHTML = `${currencyCode} ${Math.round(displayPrice)}`;
            if (pricePreviewContainer) pricePreviewContainer.style.display = '';
          } else {
            // Hide the entire price preview when there's no valid price
            if (pricePreviewContainer) pricePreviewContainer.style.display = 'none';
          }
        }
        
        // Update occupancy label text
        const occLabel = acc.querySelector('.room-accordion__price-preview .occupancy-label');
        if (occLabel) {
          occLabel.textContent = selectedOcc === 'single' 
            ? occLabel.dataset.singleLabel 
            : occLabel.dataset.ppsLabel;
        }

        // Show/hide empty message
        const emptyMsg = acc.querySelector('.tier-empty-message');
        if (emptyMsg) {
          emptyMsg.style.display = foundMatch ? 'none' : 'block';
        }
      });
    }

    filterAndUpdateRates();
    initAggregateGraph();
    initRoomGraphs();
  });

  function initAggregateGraph() {
    const graphContainer = document.getElementById('aggregate-graph');
    if (!graphContainer) return;

    const rateDataRaw = graphContainer.dataset.rates;
    if (!rateDataRaw) return;

    const currency = graphContainer.dataset.currency || 'USD';
    const entries = rateDataRaw.split('||').filter(e => e).map(e => {
      const parts = e.split('|');
      return {
        start: new Date(parts[0]),
        end: new Date(parts[1]),
        amount: parseFloat(parts[2])
      };
    });

    const today = new Date();
    today.setDate(1);
    const months = [];

    for (let i = 0; i < 18; i++) {
      const m = new Date(today);
      m.setMonth(today.getMonth() + i);
      months.push(m);
    }

    const monthlyStats = months.map(month => {
      const monthStart = new Date(month.getFullYear(), month.getMonth(), 1);
      const monthEnd = new Date(month.getFullYear(), month.getMonth() + 1, 0);

      const activeRates = entries.filter(r => {
        return (r.start <= monthEnd && r.end >= monthStart);
      });

      if (activeRates.length === 0) return null;

      const amounts = activeRates.map(r => r.amount);
      return {
        date: month,
        min: Math.min(...amounts),
        max: Math.max(...amounts)
      };
    }).filter(s => s !== null);

    if (monthlyStats.length < 2) return;

    const allPrices = monthlyStats.flatMap(s => [s.min, s.max]);
    const minPrice = Math.min(...allPrices);
    const maxPrice = Math.max(...allPrices);
    const yMin = Math.floor(minPrice * 0.9);
    const yMax = Math.ceil(maxPrice * 1.1);
    const yRange = yMax - yMin;

    const yAxisEl = document.getElementById('agg-y-axis');
    yAxisEl.innerHTML = '';
    [1, 0.66, 0.33, 0].forEach(pct => {
      const val = Math.round(yMin + (yRange * pct));
      const div = document.createElement('div');
      div.innerText = `${currency} ${val.toLocaleString()}`;
      yAxisEl.appendChild(div);
    });

    const xAxisEl = document.getElementById('agg-x-axis');
    xAxisEl.innerHTML = '';
    monthlyStats.forEach((stat, idx) => {
      const span = document.createElement('span');
      const monthName = stat.date.toLocaleDateString('en-US', { month: 'short' });
      const year = stat.date.getFullYear();
      const month = stat.date.getMonth();

      if (month === 0) {
        span.innerHTML = `<span class="month-label">${monthName}</span><span class="year-label">${year}</span>`;
      } else {
        span.innerText = monthName;
      }
      xAxisEl.appendChild(span);
    });

    const width = 1600;
    const height = 225;

    const getX = (index) => {
      return (index / (monthlyStats.length - 1)) * width;
    };

    const getY = (val) => {
      const pct = (val - yMin) / yRange;
      return height - (pct * height);
    };

    const maxPoints = monthlyStats.map((s, i) => `${getX(i)},${getY(s.max)}`).join(' ');
    const minPoints = monthlyStats.map((s, i) => `${getX(i)},${getY(s.min)}`).join(' ');

    const shadePoints = [
      ...monthlyStats.map((s, i) => `${getX(i)},${getY(s.max)}`),
      ...monthlyStats.slice().reverse().map((s, i) => {
        const realIndex = monthlyStats.length - 1 - i;
        return `${getX(realIndex)},${getY(s.min)}`;
      })
    ].join(' ');

    document.getElementById('agg-max-line').setAttribute('points', maxPoints);
    document.getElementById('agg-min-line').setAttribute('points', minPoints);
    document.getElementById('agg-shaded-area').setAttribute('points', shadePoints);
  }

  function initRoomGraphs() {
    document.querySelectorAll('.room-graph-container').forEach(container => {
      const rateDataRaw = container.dataset.roomRates;
      if (!rateDataRaw) return;

      const currency = container.dataset.currency || 'USD';
      const firstSelector = document.querySelector('[data-occupancy-selector]');
      const selectedOcc = firstSelector ? firstSelector.value : 'per_person_sharing';

      const entries = rateDataRaw.split('||').filter(e => e).map(e => {
        const parts = e.split('|');
        return {
          start: new Date(parts[0]),
          end: new Date(parts[1]),
          amount: parseFloat(parts[2]),
          type: parts[3] || 'per_person_sharing'
        };
      }).filter(e => e.type === selectedOcc);

      if (entries.length === 0) {
        container.style.display = 'none';
        return;
      }
      container.style.display = 'block';

      const today = new Date();
      today.setDate(1);
      const months = [];

      for (let i = 0; i < 18; i++) {
        const m = new Date(today);
        m.setMonth(today.getMonth() + i);
        months.push(m);
      }

      const monthlyPrices = months.map(month => {
        const monthStart = new Date(month.getFullYear(), month.getMonth(), 1);
        const monthEnd = new Date(month.getFullYear(), month.getMonth() + 1, 0);

        const activeRates = entries.filter(r => {
          return (r.start <= monthEnd && r.end >= monthStart);
        });

        if (activeRates.length === 0) return null;

        const amounts = activeRates.map(r => r.amount);
        return {
          date: month,
          price: amounts[0]
        };
      }).filter(s => s !== null);

      if (monthlyPrices.length < 2) {
        container.style.display = 'none';
        return;
      }

      const allPrices = monthlyPrices.map(s => s.price);
      const minPrice = Math.min(...allPrices);
      const maxPrice = Math.max(...allPrices);
      const yMin = Math.floor(minPrice * 0.9);
      const yMax = Math.ceil(maxPrice * 1.1);
      const yRange = yMax - yMin || 1;

      const yAxisEl = container.querySelector('.room-graph__y-axis');
      if (yAxisEl) {
        yAxisEl.innerHTML = '';
        [1, 0.5, 0].forEach(pct => {
          const val = Math.round(yMin + (yRange * pct));
          const div = document.createElement('div');
          div.innerText = `${currency} ${val.toLocaleString()}`;
          yAxisEl.appendChild(div);
        });
      }

      const xAxisEl = container.querySelector('.room-graph__x-axis');
      if (xAxisEl) {
        xAxisEl.innerHTML = '';
        monthlyPrices.forEach((stat) => {
          const span = document.createElement('span');
          const monthName = stat.date.toLocaleDateString('en-US', { month: 'short' });
          const year = stat.date.getFullYear();
          const month = stat.date.getMonth();

          if (month === 0) {
            span.innerHTML = `<span class="month-label">${monthName}</span><span class="year-label">${year}</span>`;
          } else {
            span.innerText = monthName;
          }
          xAxisEl.appendChild(span);
        });
      }

      const width = 1600;
      const height = 225;

      const getX = (index) => {
        return (index / (monthlyPrices.length - 1)) * width;
      };

      const getY = (val) => {
        const pct = (val - yMin) / yRange;
        return height - (pct * height);
      };

      const linePoints = monthlyPrices.map((s, i) => `${getX(i)},${getY(s.price)}`).join(' ');

      const lineEl = container.querySelector('.room-line');
      if (lineEl) {
        lineEl.setAttribute('points', linePoints);
      }
    });
  }

</script>
