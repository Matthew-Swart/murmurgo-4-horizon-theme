{% comment %}
  ============================================================================
  WETU ITINERARY VIEW TOGGLE
  ============================================================================
  
  Toggle between Story View and Map View for itinerary templates.
  
  USAGE:
    {% render 'wetu-itinerary-view-toggle', 
      current_view: 'story' | 'map',
      product: product,
      style: 'floating' | 'inline'
    %}
  
  ============================================================================
{% endcomment %}

{% assign active_view = current_view | default: 'story' %}
{% assign toggle_style = style | default: 'floating' %}

{% comment %} Build URLs for each view {% endcomment %}
{% assign story_url = product.url %}
{% assign map_url = product.url | append: '?view=wetu-itinerary-map' %}

{% comment %} Detect current view from URL or template {% endcomment %}
{% if request.path contains 'view=map' or template.suffix == 'wetu-itinerary-map' %}
  {% assign active_view = 'map' %}
{% endif %}

<div class="view-toggle view-toggle--{{ toggle_style }}" role="tablist" aria-label="Itinerary view options">
  <a 
    href="{{ story_url }}"
    class="view-toggle__option view-toggle__option--story {% if active_view == 'story' %}view-toggle__option--active{% endif %}"
    role="tab"
    aria-selected="{% if active_view == 'story' %}true{% else %}false{% endif %}"
    aria-label="Story View - Visual storytelling layout"
  >
    <svg class="view-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <path d="M3 9h18"/>
      <path d="M9 21V9"/>
    </svg>
    <span class="view-toggle__label">Story</span>
  </a>
  
  <a 
    href="{{ map_url }}"
    class="view-toggle__option view-toggle__option--map {% if active_view == 'map' %}view-toggle__option--active{% endif %}"
    role="tab"
    aria-selected="{% if active_view == 'map' %}true{% else %}false{% endif %}"
    aria-label="Map View - Interactive map with timeline"
  >
    <svg class="view-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
      <path d="M8 2v16"/>
      <path d="M16 6v16"/>
    </svg>
    <span class="view-toggle__label">Map</span>
  </a>
</div>

<style>
/* ====================================
   View Toggle - Base Styles
   ==================================== */

.view-toggle {
  display: inline-flex;
  align-items: center;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(8px);
  border-radius: 28px;
  padding: 4px;
  gap: 4px;
}

.view-toggle__option {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  font-size: 0.875rem;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  border-radius: 24px;
  transition: all 0.25s ease;
  cursor: pointer;
}

.view-toggle__option:hover:not(.view-toggle__option--active) {
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.1);
}

.view-toggle__option--active {
  color: var(--color-button-text, #1a1a2e);
  background: var(--color-button, #fff);
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.view-toggle__icon {
  flex-shrink: 0;
  opacity: 0.9;
}

.view-toggle__label {
  white-space: nowrap;
}

/* ====================================
   Style: Floating (fixed position)
   ==================================== */

.view-toggle--floating {
  position: fixed;
  top: calc(var(--header-height, 60px) + 16px);
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

/* Hide floating toggle when scrolled far down */
.view-toggle--floating.is-hidden {
  opacity: 0;
  pointer-events: none;
  transform: translateX(-50%) translateY(-20px);
}

/* ====================================
   Style: Inline (within content)
   ==================================== */

.view-toggle--inline {
  background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
  backdrop-filter: none;
}

.view-toggle--inline .view-toggle__option {
  color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
}

.view-toggle--inline .view-toggle__option:hover:not(.view-toggle__option--active) {
  color: var(--color-foreground);
  background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
}

.view-toggle--inline .view-toggle__option--active {
  color: var(--color-background);
  background: var(--color-primary);
}

/* ====================================
   Responsive
   ==================================== */

@media (max-width: 480px) {
  .view-toggle__label {
    display: none;
  }
  
  .view-toggle__option {
    padding: 10px 14px;
  }
  
  .view-toggle--floating {
    top: auto;
    bottom: calc(var(--sticky-bar-height, 70px) + 16px);
  }
}
</style>

<script>
(function() {
  const floatingToggle = document.querySelector('.view-toggle--floating');
  if (!floatingToggle) return;
  
  let lastScrollY = 0;
  let ticking = false;
  
  function updateToggleVisibility() {
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    const docHeight = document.documentElement.scrollHeight;
    
    // Hide when near bottom of page (80% scrolled)
    const scrollPercent = scrollY / (docHeight - windowHeight);
    
    if (scrollPercent > 0.8) {
      floatingToggle.classList.add('is-hidden');
    } else {
      floatingToggle.classList.remove('is-hidden');
    }
    
    lastScrollY = scrollY;
    ticking = false;
  }
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateToggleVisibility);
      ticking = true;
    }
  }, { passive: true });
})();
</script>
