{% doc %}
  ResRequest Accommodation Key Details

  Displays detailed information for ResRequest accommodation products including
  bed configuration, amenities, and capacity details.

  @param {product} product - The accommodation product (required)

  @example
  {% render 'resrequest-accommodation-key-details', product: product %}
{% enddoc %}

{% liquid
  assign max_capacity = product.metafields.resrequest.max_capacity_product
  assign max_adults = product.metafields.resrequest.max_adults_product
  assign bed_configuration = product.metafields.resrequest.bed_configuration.value
  assign accommodation_amenities = product.metafields.resrequest.accommodation_amenities.value
  
  assign has_capacity_info = false
  if max_capacity or max_adults
    assign has_capacity_info = true
  endif
  
  assign has_bed_config = false
  if bed_configuration and bed_configuration.size > 0
    assign has_bed_config = true
  endif
  
  assign has_amenities = false
  if accommodation_amenities and accommodation_amenities.size > 0
    assign has_amenities = true
  endif
%}

{% if has_capacity_info or has_bed_config or has_amenities %}
<div class="resrequest-accommodation-key-details">
  <h3 class="resrequest-accommodation-key-details__title">Accommodation details</h3>
  
  <div class="resrequest-accommodation-key-details__grid">
    {% if has_capacity_info or has_bed_config %}
      <div class="resrequest-accommodation-key-details__section">
        <h4 class="resrequest-accommodation-key-details__subtitle">Room information</h4>
        <div class="resrequest-accommodation-key-details__content">
          {% if max_capacity %}
            <div class="resrequest-accommodation-key-details__info-row">
              <span class="resrequest-accommodation-key-details__info-label">Max capacity</span>
              <span class="resrequest-accommodation-key-details__info-value">{{ max_capacity }} {{ max_capacity | pluralize: 'guest', 'guests' }}</span>
            </div>
          {% endif %}
          {% if max_adults %}
            <div class="resrequest-accommodation-key-details__info-row">
              <span class="resrequest-accommodation-key-details__info-label">Max adults</span>
              <span class="resrequest-accommodation-key-details__info-value">{{ max_adults }}</span>
            </div>
          {% endif %}
          {% if has_bed_config %}
            <div class="resrequest-accommodation-key-details__info-row">
              <span class="resrequest-accommodation-key-details__info-label">Beds</span>
              <span class="resrequest-accommodation-key-details__info-value">
                {% assign bed_descriptions = '' | split: '' %}
                {% for bed in bed_configuration %}
                  {% if bed.type and bed.quantity %}
                    {% assign bed_text = bed.quantity | append: ' ' | append: bed.type %}
                    {% assign bed_descriptions = bed_descriptions | push: bed_text %}
                  {% endif %}
                {% endfor %}
                {{ bed_descriptions | join: ', ' }}
              </span>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
    
    {% if has_amenities %}
      <div class="resrequest-accommodation-key-details__section resrequest-accommodation-key-details__section--wide">
        <h4 class="resrequest-accommodation-key-details__subtitle">Amenities</h4>
        <ul class="resrequest-accommodation-key-details__list">
          {% for amenity in accommodation_amenities %}
            {% if amenity.name %}
              <li class="resrequest-accommodation-key-details__list-item">{{ amenity.name }}</li>
            {% elsif amenity %}
              <li class="resrequest-accommodation-key-details__list-item">{{ amenity }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>
</div>
{% endif %}

{% stylesheet %}
  .resrequest-accommodation-key-details {
    margin-block: var(--spacing-xl, 40px);
  }
  
  .resrequest-accommodation-key-details__title {
    font-size: var(--font-size-h5, 1.25rem);
    font-weight: 600;
    margin-block-end: var(--spacing-lg, 32px);
    color: #000;
    letter-spacing: -0.01em;
  }
  
  .resrequest-accommodation-key-details__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl, 40px) var(--spacing-lg, 32px);
  }
  
  @media screen and (max-width: 749px) {
    .resrequest-accommodation-key-details__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg, 32px);
    }
  }
  
  .resrequest-accommodation-key-details__section--wide {
    grid-column: 1 / -1;
  }
  
  .resrequest-accommodation-key-details__section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 12px);
  }
  
  .resrequest-accommodation-key-details__subtitle {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 600;
    margin: 0;
    color: #000;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .resrequest-accommodation-key-details__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs, 8px);
  }
  
  .resrequest-accommodation-key-details__info-row {
    display: flex;
    gap: var(--spacing-sm, 12px);
    font-size: var(--font-size-sm, 0.875rem);
    line-height: 1.6;
  }
  
  .resrequest-accommodation-key-details__info-label {
    color: #999;
    min-width: 100px;
  }
  
  .resrequest-accommodation-key-details__info-value {
    color: #333;
  }
  
  .resrequest-accommodation-key-details__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-xs, 8px) var(--spacing-sm, 12px);
  }
  
  @media screen and (max-width: 749px) {
    .resrequest-accommodation-key-details__list {
      grid-template-columns: 1fr;
    }
  }
  
  .resrequest-accommodation-key-details__list-item {
    font-size: var(--font-size-sm, 0.875rem);
    line-height: 1.6;
    color: #666;
    position: relative;
    padding-inline-start: 12px;
  }
  
  .resrequest-accommodation-key-details__list-item::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #ccc;
  }
{% endstylesheet %}
