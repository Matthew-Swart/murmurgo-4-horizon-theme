{% liquid
  assign property_product = property_product | default: closest.product

  assign accommodation_collection = property_product.metafields.wetu.accommodation_collection.value
  assign accommodation_collection = accommodation_collection | default: property_product.metafields.wetu.accommodation_collection_ref.value

  assign activities_collection = property_product.metafields.wetu.activities_collection_ref.value
  assign activities_collection = activities_collection | default: property_product.metafields.wetu.activities_collection.value

  assign dining_collection = property_product.metafields.wetu.restaurants_collection_ref.value
  assign dining_collection = dining_collection | default: property_product.metafields.wetu.restaurants_collection.value

  assign spa_collection = property_product.metafields.wetu.spa_collection_ref.value
  assign spa_collection = spa_collection | default: property_product.metafields.wetu.spa_collection.value

  assign videos_collection = property_product.metafields.wetu.videos_collection_ref.value
  assign videos_collection = videos_collection | default: property_product.metafields.wetu.videos_collection.value

  assign tours_collection = property_product.metafields.wetu.three_d_views_collection_ref.value
  assign tours_collection = tours_collection | default: property_product.metafields.wetu.panoramas_collection_ref.value

  assign documents_collection = property_product.metafields.wetu.documents_collection_ref.value
  assign documents_collection = documents_collection | default: property_product.metafields.wetu.documents_collection.value
  assign video_refs = property_product.metafields.wetu.videos.value
  assign document_refs = property_product.metafields.wetu.documents.value
  assign layout_mode = layout_mode | default: 'default'
  assign is_stream_layout = false
  if layout_mode == 'stream'
    assign is_stream_layout = true
  endif

  assign videos_collection_has_products = false
  if videos_collection != blank and videos_collection.products_count > 0
    assign videos_collection_has_products = true
  endif

  assign documents_collection_has_products = false
  if documents_collection != blank and documents_collection.products_count > 0
    assign documents_collection_has_products = true
  endif

  assign video_refs_count = 0
  if video_refs != blank
    for video_ref in video_refs
      assign video_refs_count = video_refs_count | plus: 1
    endfor
  endif

  assign document_refs_count = 0
  if document_refs != blank
    for document_ref in document_refs
      assign document_refs_count = document_refs_count | plus: 1
    endfor
  endif

  assign show_paired_dining_spa = false
  if dining_collection != blank and spa_collection != blank and dining_collection.products_count == 1 and spa_collection.products_count == 1
    assign show_paired_dining_spa = true
  endif
%}

<div class="wetu-sidebar-child-lists{% if is_stream_layout %} wetu-sidebar-child-lists--stream{% endif %}">
  {% render 'wetu-sidebar-child-list-group', collection: accommodation_collection, fallback_heading: 'Accommodation', use_fallback_heading: true, content_type: 'standard' %}

  {% if show_paired_dining_spa and is_stream_layout == false %}
    <div class="wetu-sidebar-child-lists__paired-groups">
      {% render 'wetu-sidebar-child-list-group', collection: dining_collection, fallback_heading: 'Dining', use_fallback_heading: true, content_type: 'standard', max_items: 1, grid_columns: 1 %}
      {% render 'wetu-sidebar-child-list-group', collection: spa_collection, fallback_heading: 'Spa', use_fallback_heading: true, content_type: 'standard', max_items: 1, grid_columns: 1 %}
    </div>
  {% else %}
    {% render 'wetu-sidebar-child-list-group', collection: dining_collection, fallback_heading: 'Dining', use_fallback_heading: true, content_type: 'standard' %}
    {% render 'wetu-sidebar-child-list-group', collection: spa_collection, fallback_heading: 'Spa', use_fallback_heading: true, content_type: 'standard' %}
  {% endif %}

  {% render 'wetu-sidebar-child-list-group', collection: activities_collection, fallback_heading: 'Activities', use_fallback_heading: true, content_type: 'standard' %}
  {% if videos_collection_has_products %}
    {% render 'wetu-sidebar-child-list-group', collection: videos_collection, fallback_heading: 'Videos', content_type: 'video' %}
  {% elsif video_refs_count > 0 %}
    <section class="wetu-sidebar-child-lists__group">
      <h3 class="wetu-sidebar-child-lists__heading">Videos</h3>
      <div class="wetu-sidebar-child-lists__grid">
        {% for video_ref in video_refs %}
          {% liquid
            assign video_link = video_ref.url.value | default: video_ref.embed_url.value | default: video_ref.url | default: video_ref.embed_url
            assign video_title = video_ref.title.value | default: video_ref.label.value | default: video_ref.title | default: 'Video'
            assign video_thumbnail = video_ref.thumbnail_url.value | default: video_ref.thumbnail_url
            assign video_embed = video_ref.embed_url.value | default: video_ref.embed_url

            assign youtube_id = ''
            if video_embed contains 'youtube.com/embed/'
              assign youtube_parts = video_embed | split: 'youtube.com/embed/'
              assign youtube_id = youtube_parts[1] | split: '?' | first
            elsif video_embed contains 'youtu.be/'
              assign youtube_parts = video_embed | split: 'youtu.be/'
              assign youtube_id = youtube_parts[1] | split: '?' | first
            endif

            if video_thumbnail == blank and youtube_id != ''
              assign video_thumbnail = 'https://img.youtube.com/vi/' | append: youtube_id | append: '/maxresdefault.jpg'
            endif
          %}
          {% if video_link != blank %}
            <a class="wetu-sidebar-child-lists__card" href="{{ video_link }}" target="_blank" rel="noopener">
              <div class="wetu-sidebar-child-lists__media">
                {% if video_thumbnail != blank %}
                  <img src="{{ video_thumbnail }}" alt="{{ video_title | escape }}" class="wetu-sidebar-child-lists__image" loading="lazy">
                {% endif %}
                <span class="wetu-sidebar-child-lists__media-badge">Video</span>
                <h4 class="wetu-sidebar-child-lists__title">{{ video_title }}</h4>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
  {% render 'wetu-sidebar-child-list-group', collection: tours_collection, fallback_heading: '360° Views', content_type: 'panorama' %}
  {% if documents_collection_has_products %}
    {% render 'wetu-sidebar-child-list-group', collection: documents_collection, fallback_heading: 'Documents', content_type: 'document' %}
  {% elsif document_refs_count > 0 %}
    <section class="wetu-sidebar-child-lists__group">
      <h3 class="wetu-sidebar-child-lists__heading">Documents</h3>
      <div class="wetu-sidebar-child-lists__grid">
        {% for document_ref in document_refs %}
          {% liquid
            assign document_link = document_ref.file_url.value | default: document_ref.url.value | default: document_ref.file_url | default: document_ref.url
            assign document_title_source = document_ref.label.value | default: document_ref.title.value | default: document_ref.label | default: document_ref.title | default: 'Document'
            assign document_section = document_ref.section.value | default: document_ref.section
          %}
          {% if document_link != blank %}
            {%- capture document_title -%}
              {% render 'wetu-normalize-document-title', raw_title: document_title_source %}
            {%- endcapture -%}
            <a class="wetu-sidebar-child-lists__card wetu-sidebar-child-lists__card--document" href="{{ document_link }}" target="_blank" rel="noopener">
              <div class="wetu-sidebar-child-lists__media wetu-sidebar-child-lists__media--document">
                <span class="wetu-sidebar-child-lists__document-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5A3.375 3.375 0 0 0 10.125 2.25H8.25m2.25 0H5.625A1.125 1.125 0 0 0 4.5 3.375v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" />
                  </svg>
                </span>
                <div class="wetu-sidebar-child-lists__document-content">
                  <span class="wetu-sidebar-child-lists__media-badge">Document</span>
                  {% if document_section != blank %}
                    <p class="wetu-sidebar-child-lists__media-subtitle">{{ document_section }}</p>
                  {% endif %}
                  <h4 class="wetu-sidebar-child-lists__title">{{ document_title | strip }}</h4>
                </div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
</div>

{% stylesheet %}
  .wetu-sidebar-child-lists {
    --wetu-sidebar-inline-padding: 24px;
    --wetu-sidebar-thumbnail-gap: 2px;
    --wetu-sidebar-title-inset: 6px;
    --wetu-sidebar-default-columns: 2;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }

  .wetu-sidebar-child-lists--stream {
    --wetu-sidebar-default-columns: 1;
    --wetu-sidebar-inline-padding: 0;
    --wetu-sidebar-thumbnail-gap: 8px;
    gap: 24px;
  }

  .wetu-sidebar-child-lists__paired-groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--wetu-sidebar-thumbnail-gap);
    margin: 0;
    padding: 0;
  }

  .wetu-sidebar-child-lists__paired-groups .wetu-sidebar-child-lists__heading {
    padding-inline-start: 0;
  }

  .wetu-sidebar-child-lists__paired-groups .wetu-sidebar-child-lists__grid {
    padding: 0;
  }

  .wetu-sidebar-child-lists__group {
    margin: 0;
    padding: 0;
  }

  .wetu-sidebar-child-lists__heading {
    margin: 0 0 8px;
    padding-inline-start: var(--wetu-sidebar-inline-padding);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.72);
  }

  .wetu-sidebar-child-lists__grid {
    display: grid;
    grid-template-columns: repeat(var(--wetu-sidebar-group-columns, var(--wetu-sidebar-default-columns)), minmax(0, 1fr));
    gap: var(--wetu-sidebar-thumbnail-gap);
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .wetu-sidebar-child-lists__card {
    display: block;
    text-decoration: none;
    color: inherit;
    margin: 0;
    padding: 0;
  }

  .wetu-sidebar-child-lists__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111111;
  }

  .wetu-sidebar-child-lists__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wetu-sidebar-child-lists__title {
    position: absolute;
    inset-block-end: var(--wetu-sidebar-title-inset);
    inset-inline-start: var(--wetu-sidebar-title-inset);
    inset-inline-end: var(--wetu-sidebar-title-inset);
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.2;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #ffffff;
    text-shadow:
      0 0 2px #333333,
      0 1px 3px #333333;
    pointer-events: none;
    z-index: 1;
  }

  .wetu-sidebar-child-lists__media-badge {
    position: absolute;
    inset-block-start: var(--wetu-sidebar-title-inset);
    inset-inline-start: var(--wetu-sidebar-title-inset);
    z-index: 1;
    display: inline-flex;
    align-items: center;
    margin: 0;
    padding: 3px 6px;
    font-size: 0.65rem;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgb(0 0 0 / 55%);
  }

  .wetu-sidebar-child-lists__media-subtitle {
    position: absolute;
    inset-block-end: calc(var(--wetu-sidebar-title-inset) + 18px);
    inset-inline-start: var(--wetu-sidebar-title-inset);
    inset-inline-end: var(--wetu-sidebar-title-inset);
    z-index: 1;
    margin: 0;
    font-size: 0.6875rem;
    line-height: 1.2;
    color: rgb(255 255 255 / 88%);
    pointer-events: none;
  }

  .wetu-sidebar-child-lists__media--panorama-fallback {
    background: #333333;
  }

  .wetu-sidebar-child-lists__media--document {
    aspect-ratio: auto;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    min-height: 0;
    padding: 14px;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
  }

  .wetu-sidebar-child-lists__document-icon {
    flex: 0 0 36px;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground-rgb) / 0.68);
    background: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .wetu-sidebar-child-lists__document-content {
    min-width: 0;
    display: grid;
    gap: 4px;
  }

  .wetu-sidebar-child-lists__card--document .wetu-sidebar-child-lists__media-badge {
    position: static;
    margin: 0;
    width: fit-content;
    color: rgb(var(--color-foreground-rgb) / 0.72);
    background: rgb(var(--color-foreground-rgb) / 0.1);
  }

  .wetu-sidebar-child-lists__card--document .wetu-sidebar-child-lists__media-subtitle {
    position: static;
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.62);
  }

  .wetu-sidebar-child-lists__card--document .wetu-sidebar-child-lists__title {
    position: static;
    margin: 0;
    white-space: normal;
    overflow: visible;
    text-overflow: initial;
    line-height: 1.35;
    color: rgb(var(--color-foreground-rgb) / 0.92);
    text-shadow: none;
    pointer-events: auto;
  }

  .wetu-sidebar-child-lists__media--panorama-fallback::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(145deg, rgb(255 255 255 / 9%), rgb(255 255 255 / 0%) 42%),
      linear-gradient(40deg, #222222 0%, #333333 58%, #444444 100%);
  }

  @media screen and (min-width: 750px) {
    .wetu-sidebar-child-lists {
      --wetu-sidebar-default-columns: 3;
      gap: var(--wetu-sidebar-inline-padding);
      padding-block-start: var(--wetu-sidebar-inline-padding);
    }

    .product-information__grid .wetu-sidebar-child-lists__grid {
      padding-inline-start: var(--wetu-sidebar-inline-padding);
      padding-inline-end: 0;
    }

    .product-information__grid .wetu-sidebar-child-lists__paired-groups {
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding-inline-start: var(--wetu-sidebar-inline-padding);
      padding-inline-end: 0;
    }

    .product-information__grid .wetu-sidebar-child-lists__paired-groups .wetu-sidebar-child-lists__grid {
      width: 100%;
      margin: 0;
      padding: 0;
    }

    .wetu-sidebar-child-lists--stream {
      --wetu-sidebar-default-columns: 1;
      --wetu-sidebar-inline-padding: 0;
      padding-block-start: 0;
      gap: 24px;
    }

    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__paired-groups {
      grid-template-columns: 1fr;
      padding-inline: 0;
    }

    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__grid,
    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__heading {
      padding-inline: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .wetu-sidebar-child-lists__grid {
      padding-inline-start: var(--wetu-sidebar-inline-padding);
      padding-inline-end: 0;
    }

    .wetu-sidebar-child-lists__paired-groups {
      padding-inline-start: var(--wetu-sidebar-inline-padding);
      padding-inline-end: 0;
    }

    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__grid,
    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__paired-groups,
    .wetu-sidebar-child-lists--stream .wetu-sidebar-child-lists__heading {
      padding-inline: 0;
    }
  }
{% endstylesheet %}
