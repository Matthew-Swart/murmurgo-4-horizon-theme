{% comment %}
  ============================================================================
  WETU SCROLL INDICATOR SNIPPET
  ============================================================================
  
  Animated scroll-down indicator for hero sections.
  Features:
  - Animated bouncing chevron
  - Smooth scroll to next section on click
  - Accessible button with proper ARIA
  - Fades out on scroll
  
  USAGE:
    {% render 'wetu-scroll-indicator' %}
    {% render 'wetu-scroll-indicator', label: 'Explore', target: '#trip-overview' %}
  
  ============================================================================
{% endcomment %}

{% assign scroll_label = label | default: 'Scroll to explore' %}
{% assign scroll_target = target | default: '' %}

<div class="wetu-scroll-indicator">
  <button 
    type="button" 
    class="wetu-scroll-indicator__button"
    aria-label="{{ scroll_label }}"
    {% if scroll_target != blank %}data-scroll-target="{{ scroll_target }}"{% endif %}
  >
    <span class="wetu-scroll-indicator__text">{{ scroll_label }}</span>
    <span class="wetu-scroll-indicator__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"/>
        <path d="m19 12-7 7-7-7"/>
      </svg>
    </span>
    <span class="wetu-scroll-indicator__pulse" aria-hidden="true"></span>
  </button>
</div>

<style>
  .wetu-scroll-indicator {
    display: flex;
    justify-content: center;
    padding-top: 32px;
    animation: fadeInUp 1s ease-out 0.5s both;
  }

  .wetu-scroll-indicator__button {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: transparent;
    border: none;
    color: var(--color-foreground, white);
    cursor: pointer;
    position: relative;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .wetu-scroll-indicator__button:hover {
    transform: translateY(4px);
  }

  .wetu-scroll-indicator__button:focus-visible {
    outline: 2px solid var(--color-foreground, white);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .wetu-scroll-indicator__text {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .wetu-scroll-indicator__button:hover .wetu-scroll-indicator__text {
    opacity: 1;
  }

  .wetu-scroll-indicator__icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  .wetu-scroll-indicator__icon svg {
    width: 100%;
    height: 100%;
  }

  .wetu-scroll-indicator__pulse {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid currentColor;
    opacity: 0;
    animation: scrollPulse 2s ease-out infinite;
    animation-delay: 0.5s;
  }

  /* Bouncing animation for the chevron */
  @keyframes scrollBounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  /* Pulse ring animation */
  @keyframes scrollPulse {
    0% {
      opacity: 0.6;
      transform: translateX(-50%) scale(0.8);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) scale(1.5);
    }
  }

  /* Fade in animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hide on scroll (controlled by JS) */
  .wetu-scroll-indicator--hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .wetu-scroll-indicator {
      padding-top: 24px;
    }

    .wetu-scroll-indicator__text {
      font-size: 0.7rem;
    }

    .wetu-scroll-indicator__icon {
      width: 20px;
      height: 20px;
    }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .wetu-scroll-indicator__icon {
      animation: none;
    }

    .wetu-scroll-indicator__pulse {
      animation: none;
      display: none;
    }

    .wetu-scroll-indicator {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  (function() {
    const indicator = document.querySelector('.wetu-scroll-indicator');
    const button = document.querySelector('.wetu-scroll-indicator__button');
    
    if (!indicator || !button) return;

    // Smooth scroll to next section or specified target
    button.addEventListener('click', function() {
      const target = this.dataset.scrollTarget;
      let targetElement;
      
      if (target) {
        targetElement = document.querySelector(target);
      } else {
        // Find the hero section and scroll to the next sibling
        const heroSection = indicator.closest('section, .shopify-section');
        if (heroSection) {
          targetElement = heroSection.nextElementSibling;
        }
      }

      if (targetElement) {
        targetElement.scrollIntoView({ 
          behavior: 'smooth',
          block: 'start'
        });
      } else {
        // Fallback: scroll down by viewport height
        window.scrollBy({
          top: window.innerHeight * 0.9,
          behavior: 'smooth'
        });
      }
    });

    // Hide indicator on scroll
    let scrollTimeout;
    let lastScrollY = 0;

    function handleScroll() {
      const currentScrollY = window.scrollY;
      const threshold = 100;

      if (currentScrollY > threshold) {
        indicator.classList.add('wetu-scroll-indicator--hidden');
      } else {
        indicator.classList.remove('wetu-scroll-indicator--hidden');
      }

      lastScrollY = currentScrollY;
    }

    // Throttled scroll handler
    window.addEventListener('scroll', function() {
      if (scrollTimeout) return;
      
      scrollTimeout = requestAnimationFrame(function() {
        handleScroll();
        scrollTimeout = null;
      });
    }, { passive: true });

    // Initial check
    handleScroll();
  })();
</script>

